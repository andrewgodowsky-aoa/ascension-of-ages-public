	file.0000000000000001.title: "&6Ascension of Ages&r"
	quest.0089B6C20C45DDCA.quest_desc: [
		"Push the &bSmeltery&r to level five. At its top tier it processes ore quickly and returns the most bonus metal, giving your ingot supply a serious boost."
		"Worth the haul of materials the upgrade demands."
	]
	quest.0089B6C20C45DDCA.quest_subtitle: "Top-tier ore returns."
	quest.0089B6C20C45DDCA.title: "Smeltery, Level 5"
	quest.00A3AD4BD4EE0FC7.quest_desc: [
		"Place a &bGuard Tower&r. Each one posts a guard to watch and defend a stretch of your border, your first answer to night mobs and early raids."
		"Place them to cover the approaches an enemy would actually take."
	]
	quest.00A3AD4BD4EE0FC7.quest_subtitle: "Your first real defense."
	quest.00A3AD4BD4EE0FC7.title: "Guard Tower"
	quest.051AB096CA0848B4.quest_desc: [
		"Craft &bPrismarine Alloy&r from Create Aquatic Ambitions. This alloy is the base material for the mod's ocean machines, and it takes prismarine you already gather from the reef."
		"Feed prismarine shards and a base metal through your Create processing line to produce the alloy. Keep a stock of it. The rod, the Conduit Cage, and every part beyond this point are built from it."
	]
	quest.051AB096CA0848B4.quest_subtitle: "Optional flavor. Create Aquatic Ambitions."
	quest.051AB096CA0848B4.title: "Alloy From the Reef"
	quest.07C26C046CDE2507.quest_desc: [
		"Raise the &bCrusher's Hut&r. The Crusher grinds cobblestone into gravel, gravel into sand, and ore into extra dust, feeding both the sifter and your building supply."
		"Keep it fed with cheap bulk material and it pays back steadily."
	]
	quest.07C26C046CDE2507.quest_subtitle: "Grind bulk materials down."
	quest.07C26C046CDE2507.title: "Crusher's Hut"
	quest.082F612406308078.quest_desc: [
		"Craft the portable crafting table. It opens a 3x3 grid from your hotbar. A mining trip or build run no longer stalls every time you need to make something."
		"The first of the portable stations that keep you out of the workshop and in the field."
	]
	quest.082F612406308078.quest_subtitle: "A full grid you carry with you."
	quest.082F612406308078.title: "Pocket Crafting Table"
	quest.084EF9CB7FD7C395.quest_desc: ["Cook the mushrooms on a stick, from raw through cooked to golden. They are food first, but the golden skewer carries a real effect worth saving for the work ahead."]
	quest.084EF9CB7FD7C395.quest_subtitle: "Skewered, three ways."
	quest.084EF9CB7FD7C395.title: "Mushrooms on a Stick"
	quest.085F473094778DCD.quest_desc: [
		"Craft a &bResource Scroll&r and bind it to a builder. From anywhere it shows exactly what materials that build still needs."
		"Carry one on supply runs so you never come back a few blocks short."
	]
	quest.085F473094778DCD.quest_subtitle: "Know what a build needs, anywhere."
	quest.085F473094778DCD.title: "Resource Scroll"
	quest.097AED7C91033D5E.quest_desc: [
		"Have a drafted Overgeared smithing blueprint of any quality in your inventory."
		"Completing this grants &dMedieval Times&r and opens the colony, the mill, and deeper metalworking."
		"If your stage ever desyncs, this grant quest can be repeated to reapply &dMedieval Times&r."
	]
	quest.097AED7C91033D5E.quest_subtitle: "Cross into the Medieval age."
	quest.097AED7C91033D5E.title: "Entering the Iron Era"
	quest.09B42DE5A859BA0D.quest_desc: ["Claim the &bPowered King's Shovel&r from the &c&lGnome King&r. It digs faster than an ordinary shovel and carries the king's edge into your toolkit."]
	quest.09B42DE5A859BA0D.quest_subtitle: "The crown's own tool."
	quest.09B42DE5A859BA0D.title: "King's Shovel"
	quest.0A05779A920E548B.quest_desc: ["Produce &bHigh Quality Mulch&r. Worked into your beds, it speeds the magical crops along as the garden's own &bfertilizer&r."]
	quest.0A05779A920E548B.quest_subtitle: "Push the crops faster."
	quest.0A05779A920E548B.title: "High Quality Mulch"
	quest.0ABD97C61DE42DCF.quest_desc: ["Take the &bQueen's Fang&r dagger from the &c&lSpider Queen&r. It is a quick blade with a venomous bite, good for hit-and-run against tougher foes."]
	quest.0ABD97C61DE42DCF.quest_subtitle: "A fast, venomous blade."
	quest.0ABD97C61DE42DCF.title: "Queen's Fang"
	quest.0B009391E3F76D6E.quest_desc: [
		"Set up a &bFisherman's Hut&r beside water. The Fisherman reels in food and the occasional treasure, a low-effort supply for a colony near a pond or coast."
		"Place it right on the shoreline so the worker can reach open water."
	]
	quest.0B009391E3F76D6E.quest_subtitle: "Easy food from the water."
	quest.0B009391E3F76D6E.title: "Fisherman's Hut"
	quest.0B03101000000001.quest_desc: [
		"&bMagic Foundations&r enrolls you in Renaissance magic. Three schools are required depth here: &6Malum&r spirit alchemy, &6Theurgy&r machine alchemy, and &6Occultism&r summoning. Run each lane to its spine end."
		"&6Neo Vitae&r is the chapter close. Build its blood altar path through the &bAthanor&r. The three school spines feed that close. You do not pick one school and skip the rest."
	]
	quest.0B03101000000001.quest_subtitle: "Three schools feed the Athanor close."
	quest.0B03101000000001.title: "Magic Foundations"
	quest.0B03101000000002.quest_desc: ["Infuse clay at the &bSpirit Altar&r to produce &bAlchemical Calx&r, the plain powder the whole of &6Malum&r is built from. Nearly every spirit-alchemy recipe wants it. Set up a steady supply early."]
	quest.0B03101000000002.quest_subtitle: "Malum's base reagent."
	quest.0B03101000000002.title: "Alchemical Calx"
	quest.0B03101000000003.quest_desc: ["Dig up &bRaw Soulstone&r. It is the ore that holds the spirits &6Malum&r's craft runs on. Refine it before the altar will accept it."]
	quest.0B03101000000003.quest_subtitle: "Mine the spirit-bearing ore."
	quest.0B03101000000003.title: "Raw Soulstone"
	quest.0B03101000000004.quest_desc: ["Refine your raw stone into &bRefined Soulstone&r. This is the worked form the altar build calls for: the Spirit Altar itself is crafted around it, and recipes like the crude scythe ask for it too. Spirits you capture live in a Spirit Jar, not in the stone."]
	quest.0B03101000000004.quest_subtitle: "Process the ore into building material."
	quest.0B03101000000004.title: "Refined Soulstone"
	quest.0B03101000000005.quest_desc: ["Produce an &bArcane Charcoal Fragment&r. Eight fragments press back together into a full piece of arcane charcoal, the burned-runewood reagent that later soul-binding and infusion recipes ask for."]
	quest.0B03101000000005.quest_subtitle: "A sliver of reagent."
	quest.0B03101000000005.title: "Arcane Charcoal Fragment"
	quest.0B03101000000006.quest_desc: [
		"Build the &bSpirit Altar&r. It runs &6Malum&r's spagyric crafting: ring it with pedestals holding the recipe's ingredients, drop the core item in, and feed it the spirits it asks for."
		"Everything else in this lane orbits the altar."
	]
	quest.0B03101000000006.quest_subtitle: "Malum's central crafter."
	quest.0B03101000000006.title: "Spirit Altar"
	quest.0B03101000000007.quest_desc: ["Mine &bBrilliant Stone&r with Silk Touch. It is &6Malum&r's brilliance ore hiding in plain stone; without silk hands it crumbles to raw brilliance, the enchanting-flavored resource instead."]
	quest.0B03101000000007.quest_subtitle: "Ore worth a silk touch."
	quest.0B03101000000007.title: "Brilliant Stone"
	quest.0B03101000000008.quest_desc: ["Press fragments into &bArcane Charcoal&r. The altar does not burn it; charcoal is a crafting reagent that &6Malum&r's soul-binding and spirit infusion recipes consume. The Pact of the Warlock is among them. Keep a stack on hand before you start binding."]
	quest.0B03101000000008.quest_subtitle: "Stock the binding reagent."
	quest.0B03101000000008.title: "Arcane Charcoal"
	quest.0B03101000000009.quest_desc: ["Build the &bRunic Workbench&r. It shapes blocks of rock and concentrated spirits into runes, each one carrying a single effect. The Encyclopedia Arcana's Runeworking chapter lists every rune &6Malum&r offers and what it does."]
	quest.0B03101000000009.quest_subtitle: "Shape runes from rock and spirit."
	quest.0B03101000000009.title: "Runic Workbench"
	quest.0B0310100000000A.quest_desc: ["Craft a &bSpirit Jar&r. It holds the spirits you harvest from slain mobs, letting you stockpile them between altar runs instead of gathering fresh every time."]
	quest.0B0310100000000A.quest_subtitle: "Bottle captured spirits."
	quest.0B0310100000000A.title: "Spirit Jar"
	quest.0B0310100000000B.quest_desc: [
		"Craft the Crude Scythe. This is the harvest tool that actually fills the spirit jars you set up earlier in the Malum lane."
		"You built the spirit altar, soulstone, arcane charcoal, and the runic workbench to prepare for this moment. The scythe is what reaps souls from the creatures you slay, turning kills into aspected spirits you can collect."
		"Keep the scythe in hand when you fight. Every mob you cut down with it drops spirits instead of vanishing, and those spirits are the raw material for everything Malum builds next."
	]
	quest.0B0310100000000B.quest_subtitle: "Craft the crude scythe to harvest spirits"
	quest.0B0310100000000B.title: "Reaper's Scythe"
	quest.0B0310100000000C.quest_desc: [
		"Collect aspected spirits with your scythe. This quest accepts any of the nine spirit types, so bring back whichever ones your hunting produces."
		"Different creatures yield different spirits: sacred, wicked, arcane, eldritch, aerial, aqueous, earthen, infernal, and umbral. Each aspect feeds different recipes, so it pays to hunt a range of mobs rather than farm just one."
		"Store your spirits in jars near the altar. With a supply on hand you can move on to infusing gear, starting with the soul-stained upgrade to your scythe."
	]
	quest.0B0310100000000C.quest_subtitle: "Reap your first aspected spirits"
	quest.0B0310100000000C.title: "Harvest of Souls"
	quest.0B0310100000000D.quest_desc: [
		"Optional. Upgrade the Crude Scythe into the Soul-Stained Steel Scythe through spirit infusion on the spirit altar."
		"The recipe combines your crude scythe with a soul-stained steel ingot, refined soulstone, hex ash, and a handful of earthen, wicked, and arcane spirits. Everything it needs is available here in the Renaissance, so it is a natural next step once you have a steady spirit supply."
		"The soul-stained scythe reaps more spirits per kill and cuts harder. It is the payoff for setting up the harvest loop, and it makes every later Malum project faster to feed."
	]
	quest.0B0310100000000D.quest_subtitle: "Infuse the scythe into its soul-stained form"
	quest.0B0310100000000D.title: "Soul-Stained Reaper"
	quest.0B03101000000010.quest_desc: [
		"Build a &bPyromantic Brazier&r. It is the open flame several &6Theurgy&r machines sit over for heat, the first piece of that mod's alchemy line."
		"&6Theurgy&r is about extracting and recombining the essence of materials, and it all needs warming first."
	]
	quest.0B03101000000010.quest_subtitle: "Theurgy's heat source."
	quest.0B03101000000010.title: "Pyromantic Brazier"
	quest.0B03101000000011.quest_desc: ["Set up a &bLiquefaction Cauldron&r over the brazier. Filled with a &bSal Ammoniac&r solvent, it dissolves ores and items into &bAlchemical Sulfur&r, the principle &6Theurgy&r uses for replication and transmutation."]
	quest.0B03101000000011.quest_subtitle: "Dissolve items into Alchemical Sulfur."
	quest.0B03101000000011.title: "Liquefaction Cauldron"
	quest.0B03101000000012.quest_desc: ["Produce &bAlchemical Sulfur&r for iron. A sulfur captures one material exactly, and iron is the natural first target since you already smelt it by the stack."]
	quest.0B03101000000012.quest_subtitle: "Extract a metal's essence."
	quest.0B03101000000012.title: "Iron Sulfur"
	quest.0B03101000000013.quest_desc: ["Distill an &bAlchemical Salt&r from the mineral class. Salts are the broad reagents that pair with sulfurs to drive the more involved recipes."]
	quest.0B03101000000013.quest_subtitle: "The reagent salt class."
	quest.0B03101000000013.title: "Mineral Salt"
	quest.0B03101000000014.quest_desc: ["Build the &bIncubator&r. Fed sulfur, salt, and mercury, it recombines the essence into the real item the sulfur represents. This is the final step of &6Theurgy&r's replication loop."]
	quest.0B03101000000014.quest_subtitle: "Turn sulfur into items."
	quest.0B03101000000014.title: "Incubator"
	quest.0B03101000000015.quest_desc: [
		"Craft the &bGlass Divination Rod&r, &6Theurgy&r's entry-tier finder. Held and used, it points toward nearby blocks of the type it is keyed to. That is already an advantage over mining blind."
		"Better rods and attunements wait in the Observation chapter."
	]
	quest.0B03101000000015.quest_subtitle: "Find ore by feel."
	quest.0B03101000000015.title: "Glass Divination Rod"
	quest.0B03101000000016.quest_desc: ["Build the &bCalcination Oven&r. It is where raw materials are reduced to their &bAlchemical Salt&r, the body or physical matter every later transmutation needs."]
	quest.0B03101000000016.quest_subtitle: "Burn items down to salt."
	quest.0B03101000000016.title: "Calcination Oven"
	quest.0B03101000000017.quest_desc: ["Set up the &bMercury Distiller&r. It extracts &bAlchemical Mercury&r directly from items you feed it, the energy and catalyst your transmutations run on."]
	quest.0B03101000000017.quest_subtitle: "Distill Alchemical Mercury."
	quest.0B03101000000017.title: "Mercury Distiller"
	quest.0B03101000000018.quest_desc: ["Build the &bFermentation Vat&r. It ferments &bAlchemical Sulfur&r into &bAlchemical Niter&r, the step that unlocks &6Theurgy&r's transmutation between metals and gems."]
	quest.0B03101000000018.quest_subtitle: "Ferment sulfur into niter."
	quest.0B03101000000018.title: "Fermentation Vat"
	quest.0B03101000000019.quest_desc: ["Place a &bSal Ammoniac Tank&r. Set a &bSal Ammoniac Accumulator&r on top and feed it water; the tank fills with &bSal Ammoniac&r below, the solvent the Liquefaction Cauldron needs."]
	quest.0B03101000000019.quest_subtitle: "Store the flux."
	quest.0B03101000000019.title: "Sal Ammoniac Tank"
	quest.0B03101000000020.quest_desc: [
		"Craft the &bDictionary of Spirits&r. Every pentacle, ritual, and spirit in &6Occultism&r is documented inside it. Keep it in hand as your reference for the entire school."
		"Read it before you draw a single chalk line."
	]
	quest.0B03101000000020.quest_subtitle: "Occultism's whole manual."
	quest.0B03101000000020.title: "Dictionary of Spirits"
	quest.0B03101000000021.quest_desc: ["Make &bImpure White Chalk&r. It cannot draw a single glyph yet; throw it into Spirit Fire and it purifies into the white chalk your first pentacle needs."]
	quest.0B03101000000021.quest_subtitle: "Chalk, before the purifying."
	quest.0B03101000000021.title: "Impure White Chalk"
	quest.0B03101000000022.quest_desc: [
		"Craft the &bGolden Ritual Bowl&r. It sits at the heart of a drawn pentacle, and right-clicking it with the activation item is what starts a summoning."
		"Sacrifice items land in or beside it as the ritual demands."
	]
	quest.0B03101000000022.quest_subtitle: "Where rituals start."
	quest.0B03101000000022.title: "Golden Ritual Bowl"
	quest.0B03101000000023.quest_desc: ["Assemble a &bBook of Binding&r for a Foliot. It is the vessel a summoned Foliot spirit gets sealed into, the lowest and most willing class of spirit &6Occultism&r works with."]
	quest.0B03101000000023.quest_subtitle: "An empty binding for a Foliot."
	quest.0B03101000000023.title: "Book of Binding: Foliot"
	quest.0B03101000000024.quest_desc: [
		"Perform the ritual to bind a Foliot into its book. Draw the pentacle the Dictionary specifies, place the &bGolden Ritual Bowl&r, supply the offerings, and let the summoning complete."
		"A bound Foliot is the spirit you put to work in the steps that follow."
	]
	quest.0B03101000000024.quest_subtitle: "Run your first summoning."
	quest.0B03101000000024.title: "Bind a Foliot"
	quest.0B03101000000025.quest_desc: ["Forge an &bEmpty Magic Lamp&r. Summon a miner spirit into it, then slot the lamp into a Dimensional Mineshaft and it digs ore for you passively, &6Occultism&r's route to hands-off mining."]
	quest.0B03101000000025.quest_subtitle: "A home for a Djinni."
	quest.0B03101000000025.title: "Empty Magic Lamp"
	quest.0B03101000000026.quest_desc: ["Obtain an &bOtherworld Sapling&r from the Sapling Trader spirit. The stable variant grows trees you can see and harvest without the Third Eye effect, a permanent otherworld wood supply at home."]
	quest.0B03101000000026.quest_subtitle: "Grow otherworld wood at home."
	quest.0B03101000000026.title: "Otherworld Sapling"
	quest.0B03101000000027.quest_desc: ["Craft an empty &bBook of Binding&r. It is the unwritten base you key to a specific spirit class before a summoning, the reusable shell behind the bound books."]
	quest.0B03101000000027.quest_subtitle: "A blank binding book."
	quest.0B03101000000027.title: "Book of Binding: Empty"
	quest.0B03101000000028.quest_desc: ["Make &bWhite Chalk&r by purifying the impure stuff in Spirit Fire. Every first pentacle is drawn with it; the rituals beyond demand the colored chalks layered on top."]
	quest.0B03101000000028.quest_subtitle: "Purified ritual chalk."
	quest.0B03101000000028.title: "White Chalk"
	quest.0B03101000000029.quest_desc: [
		"Write a &bBook of Calling&r that orders a bound Foliot to move items between inventories. It is the cleanest early automation &6Occultism&r offers: a spirit-powered item pipe."
		"Point it at a source and a destination and the Foliot does the carrying."
	]
	quest.0B03101000000029.quest_subtitle: "Put a Foliot to work hauling."
	quest.0B03101000000029.title: "Book of Calling: Transporter"
	quest.0B03101000000030.quest_desc: ["Gather a &bWeak Blood Shard&r from the &6Neo Vitae&r altar. Blood Shards are the mod's core currency, traded into the altar to fuel rituals and upgrades."]
	quest.0B03101000000030.quest_subtitle: "The blood currency of Neo Vitae."
	quest.0B03101000000030.title: "Blood Shard"
	quest.0B03101000000031.quest_desc: ["Craft the &bWeak Blood Orb&r. It stores &bLife Essence&r drawn from your own blood and is the entry point to &6Neo Vitae's&r self-sacrifice engine."]
	quest.0B03101000000031.quest_subtitle: "First vessel for Life Essence."
	quest.0B03101000000031.title: "Weak Blood Orb"
	quest.0B03101000000032.quest_desc: ["Place and interact with the &bAra Vitae&r, &6Neo Vitae's&r blood altar. Every ritual and upgrade in the mod flows through this block, fuelled by your Life Essence."]
	quest.0B03101000000032.quest_subtitle: "Activate the Blood Altar."
	quest.0B03101000000032.title: "Ara Vitae"
	quest.0B03101000000033.quest_desc: ["Carve a &bBlank Rune&r. Slotted around the &bAra Vitae&r, each rune upgrades a stat: capacity, self-sacrifice speed, orb potency. The altar scales by how many you place."]
	quest.0B03101000000033.quest_subtitle: "Foundation of altar upgrades."
	quest.0B03101000000033.title: "Blank Rune"
	quest.0B03101000000034.quest_desc: ["Upgrade to the &bApprentice Blood Orb&r. It holds more &bLife Essence&r than the weak orb, reducing how often the altar starves mid-ritual."]
	quest.0B03101000000034.quest_subtitle: "Greater Life Essence capacity."
	quest.0B03101000000034.title: "Apprentice Blood Orb"
	quest.0B03101000000035.quest_desc: ["Craft the &bSigil of Divination&r. It displays your current &bLife Essence&r level and the network owner so you always know how full the altar is before you cut."]
	quest.0B03101000000035.quest_subtitle: "Read your Life Essence at a glance."
	quest.0B03101000000035.title: "Sigil of Divination"
	quest.0B03101000000036.quest_desc: ["Build a stockpile of &bWeak Blood Shards&r. Later ritual recipes consume shards as standing reagents, so a reserve on hand keeps the altar from halting mid-sequence."]
	quest.0B03101000000036.quest_subtitle: "Stock the altar's reagent reserve."
	quest.0B03101000000036.title: "Blood Shard Supply"
	quest.0B03101000000037.quest_desc: ["Place and interact with the &bHellfire Forge&r. It smelts ore and alloys using &bLife Essence&r as fuel in place of coal, the multiblock heart of &6Neo Vitae's&r metalworking line."]
	quest.0B03101000000037.quest_subtitle: "Smelt with blood-fired heat."
	quest.0B03101000000037.title: "Hellfire Forge"
	quest.0B03101000000039.quest_desc: [
		"Build the &bAthanor&r, &6Neo Vitae's&r Life Essence furnace. It distils and transmutes materials once your blood altar path is ready."
		"This closes &bMagic Foundations&r enrollment. Finish the &6Malum&r, &6Theurgy&r, and &6Occultism&r spines first, then craft the Athanor. Deeper magic mastery continues in later chapters and ages."
	]
	quest.0B03101000000039.quest_subtitle: "Foundations close. School spines required."
	quest.0B03101000000039.title: "Athanor"
	quest.0B0310100000003A.quest_desc: ["Set Runewood Item Pedestals around the &bSpirit Altar&r. Each one presents an ingredient to the altar during a craft. A full ring lets you run the larger recipes without juggling items by hand."]
	quest.0B0310100000003A.quest_subtitle: "Optional: surround the altar."
	quest.0B0310100000003A.title: "Runewood Item Pedestal"
	quest.0B0310100000003B.quest_desc: ["Craft a &bFermentation Starter&r. This one belongs to &6Theurgy&r, not &6Malum&r: one piece stands in for the raw sugar and crops a Fermentation Vat recipe would otherwise eat. Brew a batch once your niter runs get regular."]
	quest.0B0310100000003B.quest_subtitle: "Optional: seed the vat."
	quest.0B0310100000003B.title: "Fermentation Starter"
	quest.0B0310100000003C.quest_desc: ["Bind a Foliot to a Janitor's &bBook of Calling&r. It collects dropped items in an area and stows them, which keeps a busy work floor from littering itself."]
	quest.0B0310100000003C.quest_subtitle: "Optional: a Foliot that tidies."
	quest.0B0310100000003C.title: "Book of Calling: Janitor"
	quest.0B0310100000003D.quest_desc: ["Place an &bIncense Altar&r near the &bAra Vitae&r. It burns &bIncense Sticks&r to slowly fill the blood altar with &bLife Essence&r without any self-sacrifice. A passive supply for when you are away."]
	quest.0B0310100000003D.quest_subtitle: "Burn incense to passively fill the altar."
	quest.0B0310100000003D.title: "Incense Altar"
	quest.0B03101000000051.quest_desc: ["Upgrade to the &bIron Divination Rod&r. It reaches further and lasts longer than the glass starter, and is the natural second step in &6Theurgy&r's ore-finding line."]
	quest.0B03101000000051.quest_subtitle: "A longer-reaching finder."
	quest.0B03101000000051.title: "Iron Divination Rod"
	quest.0B03101000000052.quest_desc: ["Craft the &bDiamond Divination Rod&r. Its range and durability make it the right tool for hunting scarcer ores once the easy veins are gone."]
	quest.0B03101000000052.quest_subtitle: "Optional: the deep-search rod."
	quest.0B03101000000052.title: "Diamond Divination Rod"
	quest.0B03101000000053.quest_desc: ["Make the &bAmethyst Divination Rod&r. It is a specialist rod keyed to amethyst, handy given how many pack recipes pull on the crystal."]
	quest.0B03101000000053.quest_subtitle: "Optional: tuned to amethyst."
	quest.0B03101000000053.title: "Amethyst Divination Rod"
	quest.0B03101000000054.quest_desc: ["Crystallize &bSal Ammoniac&r. The solid form stores and stacks more conveniently than the liquid, useful when you are carrying flux between setups."]
	quest.0B03101000000054.quest_subtitle: "Optional: solid flux."
	quest.0B03101000000054.title: "Sal Ammoniac Crystal"
	quest.0B03101000000055.quest_desc: ["Produce a &bMercury Shard&r. It is mercury pinned into a handling-safe solid, a component the reformation gear ahead will ask for."]
	quest.0B03101000000055.quest_subtitle: "Optional: solidified mercury."
	quest.0B03101000000055.title: "Mercury Shard"
	quest.0B03101000000056.quest_desc: ["Attach an &bIncubator Salt Vessel&r. The incubator needs a vessel for each of its three ingredients, salt, mercury, and sulfur, and this one holds the salt."]
	quest.0B03101000000056.quest_subtitle: "Optional: feed the incubator salt."
	quest.0B03101000000056.title: "Incubator Salt Vessel"
	quest.0B03101000000057.quest_desc: ["Attach an &bIncubator Mercury Vessel&r. Two of three: with salt and mercury vessels in place, only the sulfur vessel stands between you and a running incubator."]
	quest.0B03101000000057.quest_subtitle: "Optional: feed it mercury."
	quest.0B03101000000057.title: "Incubator Mercury Vessel"
	quest.0B03101000000058.quest_desc: [
		"Place a &bReformation Source Pedestal&r. It holds the source &bAlchemical Sulfur&r the array converts into your chosen target sulfur, the first piece of &6Theurgy&r's essence-conversion setup."
		"Reformation turns one captured essence into another; the incubator then turns essence into items."
	]
	quest.0B03101000000058.quest_subtitle: "Optional: store an essence."
	quest.0B03101000000058.title: "Reformation Source Pedestal"
	quest.0B03101000000059.quest_desc: ["Craft the &bMercurial Wand&r. It is &6Theurgy&r's configuration wrench: point it at apparatuses and mercurial logistics to link and adjust them. The reformation array itself is wired and driven by the Sulfuric Flux Emitter."]
	quest.0B03101000000059.quest_subtitle: "Optional: the alchemist's wrench."
	quest.0B03101000000059.title: "Mercurial Wand"
	quest.0B03101000000060.quest_desc: ["Distill an &bAlchemical Salt&r from plants. It is the reagent for the recipes that touch living, growing things, distinct from the mineral salt."]
	quest.0B03101000000060.quest_subtitle: "The growing class."
	quest.0B03101000000060.title: "Plant Salt"
	quest.0B03101000000061.quest_desc: ["Render an &bAlchemical Salt&r from creatures. It rounds out the salt classes, drawn from the drops of the things you hunt and herd."]
	quest.0B03101000000061.quest_subtitle: "Optional: the animal class."
	quest.0B03101000000061.title: "Creature Salt"
	quest.0B03101000000062.quest_desc: ["Grow a &bMercury Crystal&r. It is the most concentrated mercury form &6Theurgy&r makes: a digestion ingredient and a catalyst fuel worth four times the flux of a shard."]
	quest.0B03101000000062.quest_subtitle: "Optional: the purest mercury."
	quest.0B03101000000062.title: "Mercury Crystal"
	quest.0B03101000000070.quest_desc: ["Cut a &bLesser Spiritus Gem&r from raw &bSpiritus&r. It carries more soul charge than the petty grade and feeds the stronger sigil upgrades ahead."]
	quest.0B03101000000070.quest_subtitle: "Upgraded soul crystal."
	quest.0B03101000000070.title: "Lesser Spiritus Gem"
	quest.0B03101000000071.quest_desc: ["Collect &bRaw Spiritus&r. This unrefined soul material is harvested from mob drops and the world, and it is the base feedstock for every gem grade in the Spiritus line."]
	quest.0B03101000000071.quest_subtitle: "Unrefined soul material."
	quest.0B03101000000071.title: "Raw Spiritus"
	quest.0B03101000000072.quest_desc: ["Obtain &bCorrupted Dust&r. It is a tainted byproduct of soul manipulation, and &6Neo Vitae&r requires it in the darker ritual recipes where ordinary reagents refuse to work."]
	quest.0B03101000000072.quest_subtitle: "A tainted alchemical reagent."
	quest.0B03101000000072.title: "Corrupted Dust"
	quest.0B03101000000073.quest_desc: ["Gather a &bBase Spiritus Soul (Raw)&r. It is a raw soul pulled directly from the world and is the first step in the soul-refinement chain that leads to bound tools and higher gems."]
	quest.0B03101000000073.quest_subtitle: "The raw soul form."
	quest.0B03101000000073.title: "Base Spiritus Soul"
	quest.0B03101000000074.quest_desc: ["Obtain a &bSpiritus Ruina Shard&r. It carries the destructive facet of soul energy and is needed in the rites that call on ruination, the violent end of the Spiritus spectrum."]
	quest.0B03101000000074.quest_subtitle: "A shard of destructive soul energy."
	quest.0B03101000000074.title: "Spiritus Ruina Shard"
	quest.0B03101000000075.quest_desc: ["Polish a &bCommon Spiritus Gem&r from raw &bSpiritus&r. Mid-tier in the gem ladder, it powers mid-range sigil boosts and is the grade most bound tools of this era will call for."]
	quest.0B03101000000075.quest_subtitle: "Mid-tier soul crystal."
	quest.0B03101000000075.title: "Common Spiritus Gem"
	quest.0B03101000000076.quest_desc: ["Craft a &bBlood Pearl&r. It is &bLife Essence&r pressed into a portable solid form, a reagent and component for higher-tier &6Neo Vitae&r rituals and bound-tool recipes."]
	quest.0B03101000000076.quest_subtitle: "Life Essence crystallised into a pearl."
	quest.0B03101000000076.title: "Blood Pearl"
	quest.0B03101000000077.quest_desc: ["Interact with an &bIncense Altar&r loaded with sticks. Burning incense is &6Neo Vitae's&r gentle way to channel soul energy without direct sacrifice, completing the mod's passive-supply loop."]
	quest.0B03101000000077.quest_subtitle: "Burn incense to channel soul energy."
	quest.0B03101000000077.title: "Incense Rites"
	quest.0B03102000000001.quest_desc: [
		"The &dRenaissance&r is when the Nether stops being a quick errand and becomes a place you work in. Waiting below are the &bHephaestus Forge&r and its divine metal, blaze-powered heat for &6Create&r, and a clutch of mods that rebuild the dimension entirely."
		"Pack fire resistance before you go. Almost everything down here burns."
	]
	quest.0B03102000000001.quest_subtitle: "The lower world opens."
	quest.0B03102000000001.title: "Nether Threshold"
	quest.0B03102000000011.quest_desc: [
		"Open a portal and enter the Nether. Bring a fire resistance source, a bow for ghasts, and gold on your body to keep the piglins calm."
		"Pick your landing carefully, since the far side can drop you straight into a lava sea."
	]
	quest.0B03102000000011.quest_subtitle: "Light the portal and step through."
	quest.0B03102000000011.title: "Into the Nether"
	quest.0B03102000000021.quest_desc: [
		"Track down a &bNether Fortress&r. The pack's fortresses are larger and meaner than vanilla's, packed with blazes and wither skeletons but also the loot and spawners you came for."
		"Blazes here are your only early source of rods. You will need this trip soon."
	]
	quest.0B03102000000021.quest_subtitle: "Find the blaze-haunted halls."
	quest.0B03102000000021.title: "A Nether Fortress"
	quest.0B03102000000040.quest_desc: [
		"Place a &bSpeed Rune&r. &6Neo Vitae&r's runes are attuned blocks that upgrade the Blood Altar; this one hastens its transmutations."
		"Later, hellforged parts reinforce runes like this one into stronger tiers."
	]
	quest.0B03102000000040.quest_subtitle: "Entry rune for the Neo Vitae lane."
	quest.0B03102000000040.title: "Speed Rune"
	quest.0B03102000000041.quest_desc: [
		"Craft &bHellforged Dust&r. It is ground from demonite dug out of &6Neo Vitae&r's dungeon mines, and it serves as a reagent for the mod's advanced work, not as an ingot precursor."
		"Keep a stock; you will spend it before this lane is done."
	]
	quest.0B03102000000041.quest_subtitle: "Demonite ground to reagent dust."
	quest.0B03102000000041.title: "Hellforged Dust"
	quest.0B03102000000042.quest_desc: ["Smelt a &bHellforged Ingot&r from raw demonite or its ore. It is the core metal of &6Neo Vitae&r's demon tier, the material the parts and block downstream are built from."]
	quest.0B03102000000042.quest_subtitle: "Neo Vitae's demon-forged metal."
	quest.0B03102000000042.title: "Hellforged Ingot"
	quest.0B03102000000046.quest_desc: ["Craft &bHellforged Parts&r from the ingot. The smaller component form is what the finer &6Neo Vitae&r recipes call for, so keep a few in reserve."]
	quest.0B03102000000046.quest_subtitle: "Ingot broken into components."
	quest.0B03102000000046.title: "Hellforged Parts"
	quest.0B03102000000050.quest_desc: ["Mine &bCincinnasite&r. It is the workhorse material of &6Better Nether&r, the mod that fills the dimension with new biomes and stone, and most of its recipes trace back to this ore."]
	quest.0B03102000000050.quest_subtitle: "Optional: Better Nether's base ore."
	quest.0B03102000000050.title: "Cincinnasite"
	quest.0B03102000000051.quest_desc: ["Find a &bNether Ruby&r. It is &6Better Nether&r's signature gemstone, the stone its better tools and the flaming-ruby upgrade are cut from."]
	quest.0B03102000000051.quest_subtitle: "Optional: a fiery gem."
	quest.0B03102000000051.title: "Nether Ruby"
	quest.0B03102000000052.quest_desc: ["Smelt a &bCincinnasite Ingot&r. It is the usable metal form of the ore, the rung between raw Cincinnasite and the gear &6Better Nether&r builds from it."]
	quest.0B03102000000052.quest_subtitle: "Optional: smelt the ore."
	quest.0B03102000000052.title: "Cincinnasite Ingot"
	quest.0B03102000000053.quest_desc: ["Grind &bWithered Bone Meal&r. &6Eternal Nether&r adds its own corner of the dimension, and this is one of its base materials, ground from the bones the wither leaves behind."]
	quest.0B03102000000053.quest_subtitle: "Optional: Eternal Nether grit."
	quest.0B03102000000053.title: "Withered Bone Meal"
	quest.0B03102000000054.quest_desc: ["Collect a &bWithered Bone&r. It is the intact source the bone meal is ground from, and a crafting component in &6Eternal Nether&r's recipes in its own right."]
	quest.0B03102000000054.quest_subtitle: "Optional: the whole bone."
	quest.0B03102000000054.title: "Withered Bone"
	quest.0B03102000000055.quest_desc: ["Obtain a &bWarped Ender Pearl&r. &6Eternal Nether&r's twist on the pearl behaves differently from the vanilla throw, a curiosity worth picking up while you are exploring."]
	quest.0B03102000000055.quest_subtitle: "Optional: a stabilized pearl."
	quest.0B03102000000055.title: "Warped Ender Pearl"
	quest.0B03102000000061.quest_desc: [
		"Craft an &bEmpty Blaze Burner&r. On its own it does nothing, but catch a blaze in it and it becomes one of &6Create&r's most useful heat sources."
		"Bring it to a fortress where the blazes are."
	]
	quest.0B03102000000061.quest_subtitle: "A burner waiting for fire."
	quest.0B03102000000061.title: "Empty Blaze Burner"
	quest.0B03102000000062.quest_desc: [
		"Catch a blaze in the empty burner to make a working &bBlaze Burner&r. Fed the right fuel it heats &6Create&r's mixing and cooking recipes, the heart of the mod's mid-game processing."
		"Turning one in completes &bThe Nether Threshold&r and marks that Renaissance chapter gate done."
	]
	quest.0B03102000000062.quest_subtitle: "Capture a blaze for heat."
	quest.0B03102000000062.title: "Blaze Burner"
	quest.0B03102000000063.quest_desc: ["Bake a &bBlaze Cake&r. Burned in a &bBlaze Burner&r it reaches the highest heat tier &6Create&r offers, which a handful of its recipes specifically demand."]
	quest.0B03102000000063.quest_subtitle: "Optional: the hottest fuel."
	quest.0B03102000000063.title: "Blaze Cake"
	quest.0B03102000000070.quest_desc: ["Distill an &bAlchemical Salt&r from the local strata. The Nether's stone reads as its own source, the base for a whole branch of nether-flavored sulfurs."]
	quest.0B03102000000070.quest_subtitle: "Theurgy comes to the Nether."
	quest.0B03102000000070.title: "Strata Salt"
	quest.0B03102000000071.quest_desc: ["Extract an &bAlchemical Sulfur&r from glowstone. It opens the nether sulfur set, each one keyed to a block you can only gather down here."]
	quest.0B03102000000071.quest_subtitle: "Optional: distill the light."
	quest.0B03102000000071.title: "Sulfur: Glowstone"
	quest.0B03102000000072.quest_desc: ["Render a netherrack sulfur. The dimension's bedrock-to-ceiling filler is endless, which makes this the cheapest of the nether sulfurs to keep stocked."]
	quest.0B03102000000072.quest_subtitle: "Optional: the common stone."
	quest.0B03102000000072.title: "Sulfur: Netherrack"
	quest.0B03102000000073.quest_desc: ["Distill a soul sand sulfur. It captures the strange essence of the soul-bound blocks, a reagent for the recipes that lean on that side of the Nether."]
	quest.0B03102000000073.quest_subtitle: "Optional: the clinging sand."
	quest.0B03102000000073.title: "Sulfur: Soul Sand"
	quest.0B03102000000074.quest_desc: ["Extract a quartz sulfur. Nether quartz is plentiful in the ceiling and walls. This one stocks up quickly as you mine."]
	quest.0B03102000000074.quest_subtitle: "Optional: nether quartz."
	quest.0B03102000000074.title: "Sulfur: Quartz"
	quest.0B03102000000075.quest_desc: ["Render an obsidian sulfur. It demands the slow mining obsidian always does, but the reagent feeds the sturdier end of the alchemy recipes."]
	quest.0B03102000000075.quest_subtitle: "Optional: the hard black stone."
	quest.0B03102000000075.title: "Sulfur: Obsidian"
	quest.0B03102000000076.quest_desc: ["Distill a soul soil sulfur. Gathered from the soul valleys, it is the soil counterpart to the soul sand reagent."]
	quest.0B03102000000076.quest_subtitle: "Soul soil sulfur reagent."
	quest.0B03102000000076.title: "Sulfur: Soul Soil"
	quest.0B03102000000077.quest_desc: ["Extract a crying obsidian sulfur. The rarer weeping stone gives a scarcer reagent, one the more demanding recipes ask for by name."]
	quest.0B03102000000077.quest_subtitle: "Crying obsidian sulfur reagent."
	quest.0B03102000000077.title: "Sulfur: Crying Obsidian"
	quest.0B03102000000078.quest_desc: ["Render a magma cream sulfur. Its source comes off magma cubes rather than the ground, tying this reagent to the fighting you do down here."]
	quest.0B03102000000078.quest_subtitle: "Magma cream sulfur reagent."
	quest.0B03102000000078.title: "Sulfur: Magma Cream"
	quest.0B03102000000079.quest_desc: ["Distill a basalt sulfur. The basalt deltas supply it in bulk, an easy gather once you find that biome."]
	quest.0B03102000000079.quest_subtitle: "Basalt sulfur reagent."
	quest.0B03102000000079.title: "Sulfur: Basalt"
	quest.0B0310200000007A.quest_desc: ["Extract a blackstone sulfur. It rounds out the nether sulfur set, drawn from the dark stone that fills the dimension's lower reaches."]
	quest.0B0310200000007A.quest_subtitle: "Blackstone sulfur reagent."
	quest.0B0310200000007A.title: "Sulfur: Blackstone"
	quest.0B03102000000081.quest_desc: ["Obtain a &bPetty Spiritus Gem&r. &6Neo Vitae&r's spiritus gems are condensed spirit essence. Even the smallest grade is a rare find and a component in the mod's highest crafts."]
	quest.0B03102000000081.quest_subtitle: "Petty-grade Neo Vitae spirit gem."
	quest.0B03102000000081.title: "Spiritus Gem (Petty)"
	quest.0B03102000000082.quest_desc: ["Forge a &bNether Ruby Pickaxe&r. Cut from &6Better Nether&r's signature gem, it is a strong mining tool and the base the flaming-ruby upgrade improves on."]
	quest.0B03102000000082.quest_subtitle: "Nether Ruby tool."
	quest.0B03102000000082.title: "Nether Ruby Pickaxe"
	quest.0B03102000000083.quest_desc: ["Find the &bFlaming Ruby&r smithing template. Applied at a smithing table it upgrades gear with the gem's fiery properties, &6Better Nether&r's answer to the netherite step."]
	quest.0B03102000000083.quest_subtitle: "Flaming Ruby smithing template."
	quest.0B03102000000083.title: "Flaming Ruby Template"
	quest.0B03102000000084.quest_desc: ["Brew &bAgave Medicine&r from &6Better Nether&r's plants. It is a healing item grown from the dimension's flora, useful when potions run short far from home."]
	quest.0B03102000000084.quest_subtitle: "Better Nether healing item."
	quest.0B03102000000084.title: "Agave Medicine"
	quest.0B03102000000085.quest_desc: ["Prepare &bHerbal Medicine&r. It is the upgraded healing item in &6Better Nether&r's line, worth the extra plants when the fighting gets serious."]
	quest.0B03102000000085.quest_subtitle: "Upgraded nether medicine."
	quest.0B03102000000085.title: "Herbal Medicine"
	quest.0B03102000000086.quest_desc: ["Gather &bBone Mushroom Spores&r. Planted, they grow one of &6Better Nether&r's fungi, a renewable source of its mushroom materials back at base."]
	quest.0B03102000000086.quest_subtitle: "Better Nether fungus spores."
	quest.0B03102000000086.title: "Bone Mushroom Spores"
	quest.0B03102000000087.quest_desc: ["Collect &bMungal Spores&r. The Mungus of the Mushroom Fields sheds them every few days, &6Alex's Mobs&r' odd fungal courier, and the creature can carry crimson and warped fungus in turn."]
	quest.0B03102000000087.quest_subtitle: "Mungus fungal drop."
	quest.0B03102000000087.title: "Mungal Spores"
	quest.0B03102000000088.quest_desc: ["Obtain &bWarped Muscle&r. It drops from the Warped Mosco, the mutation born when a Crimson Mosquito bites a warped-fungus Mungus, a crafting reagent for &6Alex's Mobs&r' nether recipes."]
	quest.0B03102000000088.quest_subtitle: "Warped Mosco reagent."
	quest.0B03102000000088.title: "Warped Muscle"
	quest.0B031020000000B0.quest_desc: ["Find the &bFungi Forest&r. &6NetherEx&r layers its own biomes over the dimension, and this towering fungal woodland holds that mod's materials and mobs."]
	quest.0B031020000000B0.quest_subtitle: "NetherEx fungal biome."
	quest.0B031020000000B0.title: "Fungi Forest"
	quest.0B031020000000B1.quest_desc: ["Pick &bShroomfruit&r from the &bFungi Forest&r. It is an edible &6NetherEx&r crop, a rare bit of food that actually grows in the Nether."]
	quest.0B031020000000B1.quest_subtitle: "NetherEx forage item."
	quest.0B031020000000B1.title: "Shroomfruit"
	quest.0B031020000000B2.quest_desc: ["Take a &bHoglin Tusk&r. &6NetherEx&r uses the tusk as a brewing ingredient for its Potion of Knocking. The hoglins you fight for food give up something useful besides meat."]
	quest.0B031020000000B2.quest_subtitle: "Hoglin brewing drop."
	quest.0B031020000000B2.title: "Hoglin Tusk"
	quest.0B031020000000B3.quest_desc: ["Collect &bRibs&r. &6NetherEx&r adds them to the drops of the hoglins you already hunt. On their own they are poor eating, the before to the cooked version."]
	quest.0B031020000000B3.quest_subtitle: "Raw NetherEx food."
	quest.0B031020000000B3.title: "Ribs"
	quest.0B031020000000B4.quest_desc: ["Cook your &bribs&r into &bCooked Ribs&r. Properly fired they become a solid meal, a reliable food source for long stints in the dimension."]
	quest.0B031020000000B4.quest_subtitle: "Cooked NetherEx food."
	quest.0B031020000000B4.title: "Cooked Ribs"
	quest.0B031020000000B5.quest_desc: ["Build the &6NetherEx&r &bKiln&r. It smelts like a plain &bfurnace&r but is built from nether bricks. You can raise one down here without hauling surface cobblestone."]
	quest.0B031020000000B5.quest_subtitle: "NetherEx furnace block."
	quest.0B031020000000B5.title: "Kiln"
	quest.0B03102000000100.quest_desc: [
		"&c&lIgnis&r is a Nether boss that spawns inside Nether Fortresses. He is the first real test of the Renaissance-tier gear you carried down here, so bring fire resistance and a strong melee weapon before you pick a fight in the corridors."
		"Kill Ignis and keep the &bIgnitium Ingot&r he leaves behind. The drop is guaranteed on a real player kill, so one clean fight is enough. Turn the ingot in here."
		"Ignis anchors the Nether boss line for this chapter. His ingot is also the entry to the Ignitium gear tier, so the kill pays off twice."
	]
	quest.0B03102000000100.quest_subtitle: "Defeat the Nether forge boss."
	quest.0B03102000000100.title: "Ignis"
	quest.0B03102000000101.quest_desc: [
		"&c&lThe Harbinger&r haunts the ruined factory structures scattered through the Nether. It is a wither-touched horror that hits harder than Ignis, so clear the fight only after you have his gear behind you."
		"Defeat the Harbinger and recover the &bWitherite Block&r it drops. The drop is guaranteed on a player kill. Bring it back here to record the fight."
		"This step depends on the Ignis kill and pushes the Nether line one boss deeper toward its terminal Gauntlet fight."
	]
	quest.0B03102000000101.quest_subtitle: "Defeat the wither-touched Nether boss."
	quest.0B03102000000101.title: "The Harbinger"
	quest.0B03102000000102.quest_desc: [
		"The final Nether boss waits inside a &bGauntlet Arena&r, a structure that generates naturally in the Nether. This step is simple: find one."
		"Explore the Nether wastes and soul sand valleys until you locate the arena. Standing inside it completes the objective and opens the fight in the next step."
		"Scout it before you commit. Knowing the layout and your exits makes the Gauntlet itself far more survivable."
	]
	quest.0B03102000000102.quest_subtitle: "Find a Nether Gauntlet arena."
	quest.0B03102000000102.title: "Locate the Gauntlet Arena"
	quest.0B03102000000103.quest_desc: [
		"The &c&lGauntlet&r is the terminal Nether boss, a massive fist that guards its arena. This is the hardest fight of the Nether line, so arrive with your best Renaissance gear and healing."
		"Keep the Blazing Eye proof."
		"Finishing this closes the Nether required-boss line and feeds the Nether chapter completion."
	]
	quest.0B03102000000103.quest_subtitle: "Defeat the Nether Gauntlet."
	quest.0B03102000000103.title: "Nether Gauntlet"
	quest.0B03103000000001.quest_desc: [
		"Most of the &dRenaissance&r digs deeper. The &6Aether&r goes the other way, a bright dimension of floating islands reached through a glowstone frame filled with water."
		"There is no lava and no cold here. The danger is the long fall off the edge, so keep blocks in hand and watch your footing."
	]
	quest.0B03103000000001.quest_subtitle: "Up, for once, instead of down."
	quest.0B03103000000001.title: "Aether Literacy"
	quest.0B03103000000012.quest_desc: [
		"Build a glowstone portal, fill it with a water bucket, and step into the &6Aether&r. The islands drift over open void. Do not walk off an edge you cannot bridge back from."
		"Arriving is the chapter's opening milestone."
	]
	quest.0B03103000000012.quest_subtitle: "Cross to the floating isles."
	quest.0B03103000000012.title: "Into the Aether"
	quest.0B03103000000020.quest_desc: [
		"Cut skyroot and craft a &bSkyroot Pickaxe&r. The &6Aether&r has its own tool ladder and starts you at the bottom, wood tier."
		"It mines &bholystone&r, which is all you need to climb the next step."
	]
	quest.0B03103000000020.quest_subtitle: "The Aether's wooden tier."
	quest.0B03103000000020.title: "Skyroot Pickaxe"
	quest.0B03103000000021.quest_desc: [
		"Forge a &bHolystone Pickaxe&r. Holystone is the &6Aether&r's bedrock-grade stone, and a pickaxe of it is sturdy enough to mine the dimension's zanite gems."
		"This is the tool that unlocks the metal-equivalent tier here."
	]
	quest.0B03103000000021.quest_subtitle: "The stone tier of the sky."
	quest.0B03103000000021.title: "Holystone Pickaxe"
	quest.0B03103000000022.quest_desc: [
		"Mine a &bZanite Gemstone&r with your &bholystone pickaxe&r. Zanite is the &6Aether&r's signature material, the base for its mid-tier tools and armor."
		"Its gear has a quirk worth knowing: it mines faster as it wears down."
	]
	quest.0B03103000000022.quest_subtitle: "Mine the sky's gem."
	quest.0B03103000000022.title: "Zanite Gemstone"
	quest.0B03103000000023.quest_desc: ["Collect &bGolden Amber&r from the golden oak trees. The amber comes from breaking or stripping the logs with a &bzanite&r axe or better, a crafting material for some of the dimension's finer items."]
	quest.0B03103000000023.quest_subtitle: "Harvest the golden oaks."
	quest.0B03103000000023.title: "Golden Amber"
	quest.0B03103000000030.quest_desc: [
		"Locate a &bBronze Dungeon&r, a sealed stone structure floating among the islands. It holds the &6Aether&r's first boss and the loot behind it. This is the destination the chapter builds toward."
		"Scout the outside before you break in. What waits inside does not negotiate."
	]
	quest.0B03103000000030.quest_subtitle: "Find the locked vault."
	quest.0B03103000000030.title: "Bronze Dungeon"
	quest.0B03103000000031.quest_desc: [
		"Wake and defeat the &c&lSlider&r inside the &bBronze Dungeon&r. The stone boss hurls itself in straight lines to crush you against the walls. Put the room's pillars between you and it and strike its face when it stops."
		"Good armor and a strong blade matter far more than a bow here. Beating it completes &bAether Literacy&r and marks the chapter gate done."
	]
	quest.0B03103000000031.quest_subtitle: "Crack open the bronze vault."
	quest.0B03103000000031.title: "The Slider"
	quest.0B03103000000032.quest_desc: ["Claim a &bBronze Key&r from the dungeon. It opens the locked chests and doors of the bronze vaults. A spare in your pack saves a trip when you find the next one."]
	quest.0B03103000000032.quest_subtitle: "Optional: a spare key."
	quest.0B03103000000032.title: "Bronze Key"
	quest.0B03103000000040.quest_desc: [
		"Locate a &bSilver Dungeon&r in the &6Aether&r. It is the labyrinth the &c&lValkyrie Queen&r rules, a puzzle-and-combat structure that guards the dimension's best gear."
		"Scout it before you provoke a fight you cannot leave."
	]
	quest.0B03103000000040.quest_subtitle: "Find the queen's hall."
	quest.0B03103000000040.title: "Silver Dungeon"
	quest.0B03103000000071.quest_desc: ["Gather Ambrosium Shards from &bholystone&r. They serve the &6Aether&r as both fuel and a light reagent, the common resource its healing stones and lamps draw on."]
	quest.0B03103000000071.quest_subtitle: "Optional: the sky's coal."
	quest.0B03103000000071.title: "Ambrosium Shard"
	quest.0B03103000000072.quest_desc: ["Collect a &bSwet Ball&r from the &6Aether&r's swets. The gelatinous drop is a crafting reagent for leads and a serviceable crop fertilizer."]
	quest.0B03103000000072.quest_subtitle: "Optional: a slime of the sky."
	quest.0B03103000000072.title: "Swet Ball"
	quest.0B03103000000073.quest_desc: ["Pick Blue Berries from the &6Aether&r's bushes. They make a light, plentiful food, the easiest thing to graze on while you explore the islands."]
	quest.0B03103000000073.quest_subtitle: "Optional: forage the bushes."
	quest.0B03103000000073.title: "Blue Berry"
	quest.0B03103000000074.quest_desc: ["Loot a &bCloud Staff&r from the Bronze Dungeon's reward chest. It calls up small cloud allies that swarm whatever you point them at, a handy bit of summoned help in a fight."]
	quest.0B03103000000074.quest_subtitle: "Optional: summon cloud minions."
	quest.0B03103000000074.title: "Cloud Staff"
	quest.0B03103000000080.quest_desc: ["Forge a &bZanite Sword&r. Cut from the dimension's gem, it hits noticeably harder than &bholystone&r and is worth carrying into the dungeon."]
	quest.0B03103000000080.quest_subtitle: "Optional: the gem blade."
	quest.0B03103000000080.title: "Zanite Sword"
	quest.0B03103000000081.quest_desc: ["Craft a &bZanite Pickaxe&r. Like all zanite gear it speeds up as it wears, so a worn pick mines fast before it gives out."]
	quest.0B03103000000081.quest_subtitle: "Optional: the gem pick."
	quest.0B03103000000081.title: "Zanite Pickaxe"
	quest.0B03103000000084.quest_desc: [
		"Collect a &bVictory Medal&r. The Valkyries drop them, and gathering enough is part of earning the right to challenge their queen."
		"A token of every winged duel you win."
	]
	quest.0B03103000000084.quest_subtitle: "Aether duel medal."
	quest.0B03103000000084.title: "Victory Medal"
	quest.0B03103000000085.quest_desc: ["Make a &bHealing Stone&r from ambrosium and &bholystone&r. Eat it for a stretch of regeneration, a quiet way to top up between fights."]
	quest.0B03103000000085.quest_subtitle: "Optional: edible regeneration."
	quest.0B03103000000085.title: "Healing Stone"
	quest.0B03103000000086.quest_desc: ["Build the &6Aether&r's &bIncubator&r. Fueled with ambrosium torches it hatches a &bMoa&r egg into a Moa, the rideable bird that lets you glide between islands instead of bridging. Having a mount changes how much of the sky you can reach."]
	quest.0B03103000000086.quest_subtitle: "Optional: hatch a Moa."
	quest.0B03103000000086.title: "Incubator"
	quest.0B03103000000087.quest_desc: ["Find a &bBlue Gummy Swet&r in Bronze and Silver dungeon chests. It is a small food item with a bit of bounce to it that fills the whole hunger bar."]
	quest.0B03103000000087.quest_subtitle: "Optional: dungeon candy."
	quest.0B03103000000087.title: "Blue Gummy Swet"
	quest.0B03103000000088.quest_desc: ["Take an &bAechor Petal&r from an aechor plant. The petals are the reagent behind the &6Aether&r's darts and poison skyroot tools, gathered from a plant that fights back."]
	quest.0B03103000000088.quest_subtitle: "Optional: a thorny harvest."
	quest.0B03103000000088.title: "Aechor Petal"
	quest.0B03103000000089.quest_desc: ["Distill an &bAlchemical Sulfur&r from skyroot. &6Theurgy&r reaches even here, and the &6Aether&r's wood reads as its own source for a sky-flavored reagent."]
	quest.0B03103000000089.quest_subtitle: "Optional: Theurgy in the sky."
	quest.0B03103000000089.title: "Sulfur: Skyroot"
	quest.0B0310300000008A.quest_desc: ["Render an &bAlchemical Sulfur&r from blue berries. It rounds out the &6Aether&r's small contribution to the sulfur collection, drawn from the dimension's fruit."]
	quest.0B0310300000008A.quest_subtitle: "Optional: distill the berry."
	quest.0B0310300000008A.title: "Sulfur: Blueberry"
	quest.0B03103000000100.quest_desc: [
		"The &bSilver Dungeon&r is a vault built into one of the Aether's floating islands. Reaching it is the objective here."
		"Fly or bridge across the Aether and search the larger islands for the dungeon's entrance. Standing inside completes this step and sets up the boss fight that follows."
		"The Silver Dungeon holds the Valkyrie Queen, so treat this as your staging point. Rest, stock arrows and food, then go in ready."
	]
	quest.0B03103000000100.quest_subtitle: "Find the Aether Silver Dungeon."
	quest.0B03103000000100.title: "Silver Dungeon"
	quest.0B03103000000101.quest_desc: [
		"The &c&lValkyrie Queen&r rules the Silver Dungeon and is the required Aether boss for this chapter. She fights with speed and reach, so keep moving and punish the openings between her lunges."
		"Keep the Silver Dungeon Key she drops."
		"This kill is the Aether chapter climax and carries its completion proof, so the Renaissance age progress now waits on the Queen falling. The dungeon does not open its full rewards until she is beaten."
	]
	quest.0B03103000000101.quest_subtitle: "Defeat the Valkyrie Queen."
	quest.0B03103000000101.title: "Valkyrie Queen"
	quest.0B03104000000001.quest_desc: [
		"&6Eternal Starlight&r is a world held in perpetual moonlit dark, cold and quiet and full of strange materials. This chapter charts the way in, the metals and crystals worth hauling out, and the bosses that guard them."
		"Dress warm before you cross. The cold bites at least as hard as anything the &dDark Age&r threw at you."
	]
	quest.0B03104000000001.quest_subtitle: "A dimension of endless night."
	quest.0B03104000000001.title: "Starlight Observation"
	quest.0B03104000000010.quest_desc: [
		"Locate a set of &bCommon Portal Ruins&r. The portal to &6Eternal Starlight&r is not built but found, half-collapsed in the overworld, and repairing one is how you open the crossing."
		"Scout the structure before you commit to the trip."
	]
	quest.0B03104000000010.quest_subtitle: "Find the way across."
	quest.0B03104000000010.title: "Common Portal Ruins"
	quest.0B03104000000011.quest_desc: ["Find the &bForest Portal Ruins&r variant. It is an alternate flavor of the same gateway, worth logging for the explorer who wants to map every entrance."]
	quest.0B03104000000011.quest_subtitle: "Find the forest portal ruin variant."
	quest.0B03104000000011.title: "Forest Portal Ruins"
	quest.0B03104000000012.quest_desc: [
		"Cross into &6Eternal Starlight&r. The moon never sets here, so light is steady but the chill is constant. Bring warm gear before you step through."
		"Setting foot in the dimension is the chapter's first real milestone."
	]
	quest.0B03104000000012.quest_subtitle: "Step through the repaired portal."
	quest.0B03104000000012.title: "Into Eternal Starlight"
	quest.0B03104000000020.quest_desc: ["Pick &bLunar Berries&r. They grow across the dimension and make a reliable trail food, the easiest thing to gather while you find your feet here."]
	quest.0B03104000000020.quest_subtitle: "First food of the moon world."
	quest.0B03104000000020.title: "Lunar Berries"
	quest.0B03104000000030.quest_desc: ["Harvest &bLunaris Cactus Fruit&r. It is both food and the raw material for the cactus gel further along. A stand of the plants is worth marking."]
	quest.0B03104000000030.quest_subtitle: "Forage the pale cacti."
	quest.0B03104000000030.title: "Lunaris Cactus Fruit"
	quest.0B03104000000031.quest_desc: ["Gather &bSaltpeter Powder&r. &6Eternal Starlight&r uses it as a base crafting reagent, the kind of bulk material the dimension's recipes quietly assume you have."]
	quest.0B03104000000031.quest_subtitle: "A common reagent."
	quest.0B03104000000031.title: "Saltpeter Powder"
	quest.0B03104000000032.quest_desc: [
		"Smelt a &bDeepsilver Ingot&r. Deepsilver is &6Eternal Starlight&r's entry metal, the one its early tools and the next tier of materials are built from."
		"Most of the crafting branches here trace back through it."
	]
	quest.0B03104000000032.quest_subtitle: "The dimension's first metal."
	quest.0B03104000000032.title: "Deepsilver Ingot"
	quest.0B03104000000033.quest_desc: ["Forge a &bStarcore&r. It is a dense crafting component the higher &6Eternal Starlight&r recipes call for, drawn from the dimension's springstone work."]
	quest.0B03104000000033.quest_subtitle: "Dense Eternal Starlight component."
	quest.0B03104000000033.title: "Starcore"
	quest.0B03104000000034.quest_desc: ["Harvest a &bLunar Crystal&r. It is &6Eternal Starlight&r's defining material, glowing faintly with the dimension's light, and a key ingredient across its mid-tier crafts."]
	quest.0B03104000000034.quest_subtitle: "The signature crystal."
	quest.0B03104000000034.title: "Lunar Crystal"
	quest.0B03104000000035.quest_desc: ["Collect a &bRed Starlight Crystal Shard&r. The starlight crystals come in colors, and the red shard pairs with the cactus gel into the dimension's amber alloy."]
	quest.0B03104000000035.quest_subtitle: "Crystal in red."
	quest.0B03104000000035.title: "Red Starlight Crystal Shard"
	quest.0B03104000000036.quest_desc: ["Process &bLunaris Cactus Fruit&r into &bLunaris Cactus Gel&r. The gel is the worked reagent the recipes want, a binder for the metalwork ahead."]
	quest.0B03104000000036.quest_subtitle: "Render the fruit into gel."
	quest.0B03104000000036.title: "Lunaris Cactus Gel"
	quest.0B03104000000037.quest_desc: ["Alloy an &bAmaramber Ingot&r from the red shard and the cactus gel. It is one of &6Eternal Starlight&r's stronger metals, the base for its better gear and the prophecy orb."]
	quest.0B03104000000037.quest_subtitle: "An amber alloy."
	quest.0B03104000000037.title: "Amaramber Ingot"
	quest.0B03104000000040.quest_desc: ["Mine a &bGlacite Shard&r. The frozen crystal feeds the cold-themed gear, the raw piece behind the &bcoldsnap&r line."]
	quest.0B03104000000040.quest_subtitle: "Frozen crystal material."
	quest.0B03104000000040.title: "Glacite Shard"
	quest.0B03104000000041.quest_desc: ["Smelt a &bThermal Springstone Ingot&r. The warm stone runs counter to the dimension's chill, and it feeds the golem &bsteel&r and &bstarcore&r branches both."]
	quest.0B03104000000041.quest_subtitle: "Warmth in metal."
	quest.0B03104000000041.title: "Thermal Springstone Ingot"
	quest.0B03104000000043.quest_desc: ["Craft a &bWand of Teleportation&r. It throws you a short distance in a blink, a real help for crossing the dimension's broken terrain and dodging in a fight."]
	quest.0B03104000000043.quest_subtitle: "Short-range teleport tool."
	quest.0B03104000000043.title: "Wand of Teleportation"
	quest.0B03104000000044.quest_desc: ["Find an &bAbyssal Fruit&r in &6Eternal Starlight&r. It is a food with its own quirks and a gateway to the dimension's fishing chains."]
	quest.0B03104000000044.quest_subtitle: "Eternal Starlight food item."
	quest.0B03104000000044.title: "Abyssal Fruit"
	quest.0B03104000000045.quest_desc: ["Grow a &bMana Crystal&r. It stores magical energy for &6Eternal Starlight&r's enchanted gear, the source the &bsoul dew&r and crystal shards branch from."]
	quest.0B03104000000045.quest_subtitle: "Grow the magic crystal."
	quest.0B03104000000045.title: "Mana Crystal"
	quest.0B03104000000050.quest_desc: [
		"Defeat &c&lThe Gatekeeper&r, &6Eternal Starlight&r's central boss. Keep warm gear on, stay mobile across its arena, and watch for the ranged attacks that punish standing still."
		"Beating it completes &bStarlight Observation&r and marks that Renaissance chapter gate done."
	]
	quest.0B03104000000050.quest_subtitle: "Defeat the dimension's guardian."
	quest.0B03104000000050.title: "The Gatekeeper"
	quest.0B03104000000060.quest_desc: ["Collect a &bBlue Starlight Crystal Shard&r. It is the cooler-toned partner to the red shard, used where a recipe wants the blue variant."]
	quest.0B03104000000060.quest_subtitle: "Blue starlight crystal variant."
	quest.0B03104000000060.title: "Blue Starlight Crystal Shard"
	quest.0B03104000000061.quest_desc: ["Forge a &bGolem Steel Ingot&r. It is the metal the dimension's golems are built from, a tough alloy for armor and the heavier tools."]
	quest.0B03104000000061.quest_subtitle: "Golem steel material."
	quest.0B03104000000061.title: "Golem Steel Ingot"
	quest.0B03104000000062.quest_desc: ["Make &bOxidized Golem Steel&r. The aged form has its own uses in the golem-themed recipes, a variant rather than a straight upgrade."]
	quest.0B03104000000062.quest_subtitle: "Oxidized golem steel variant."
	quest.0B03104000000062.title: "Oxidized Golem Steel"
	quest.0B03104000000063.quest_desc: ["Craft &bColdsnap&r from glacite. It carries the dimension's bite into a usable form, the basis of its frost gear and the &bshivering gel&r ahead."]
	quest.0B03104000000063.quest_subtitle: "Craft the cold reagent."
	quest.0B03104000000063.title: "Coldsnap"
	quest.0B03104000000064.quest_desc: ["Gather &bSoul Dew&r. Drawn from the mana crystals, it is a potent reagent for the enchanted end of &6Eternal Starlight&r's crafting."]
	quest.0B03104000000064.quest_subtitle: "Mana crystal reagent."
	quest.0B03104000000064.title: "Soul Dew"
	quest.0B03104000000065.quest_desc: ["Catch a &bLuminofish&r. The glowing swimmer is both food and a light-giving curiosity, the start of one of the dimension's two fishing lines."]
	quest.0B03104000000065.quest_subtitle: "Catch the glowing fish."
	quest.0B03104000000065.title: "Luminofish"
	quest.0B03104000000066.quest_desc: ["Scoop a &bLuminofish&r into a bucket. Kept live it makes a glowing ornament for a tank back home, or a fish to release where you like."]
	quest.0B03104000000066.quest_subtitle: "Bucket a live luminofish."
	quest.0B03104000000066.title: "Luminofish Bucket"
	quest.0B03104000000067.quest_desc: ["Cook a &bLuminofish&r. Fired up it is a decent meal, the practical end of catching the glowing fish."]
	quest.0B03104000000067.quest_subtitle: "Cook the glowing Starlight catch."
	quest.0B03104000000067.title: "Cooked Luminofish"
	quest.0B03104000000068.quest_desc: ["Catch a &bRookfish&r. It is the other fish of &6Eternal Starlight&r's waters, with its own drops and a swim bladder worth keeping."]
	quest.0B03104000000068.quest_subtitle: "Catch a rookfish."
	quest.0B03104000000068.title: "Rookfish"
	quest.0B03104000000069.quest_desc: ["Bucket a live &bRookfish&r. Like the &bluminofish&r it travels and displays well, a catch you can move rather than eat."]
	quest.0B03104000000069.quest_subtitle: "Bucket a live rookfish."
	quest.0B03104000000069.title: "Rookfish Bucket"
	quest.0B0310400000006A.quest_desc: ["Cook a &bRookfish&r into a meal. It rounds out the dimension's home-grown food, useful on a long expedition far from your farm."]
	quest.0B0310400000006A.quest_subtitle: "Cook the rookfish."
	quest.0B0310400000006A.title: "Cooked Rookfish"
	quest.0B0310400000006B.quest_desc: ["Recover a &bRookfish Air Sac&r. The swim bladder is a crafting reagent in &6Eternal Starlight&r's recipes, the reason to gut your catch rather than just cook it."]
	quest.0B0310400000006B.quest_subtitle: "Recover the air sac."
	quest.0B0310400000006B.title: "Rookfish Air Sac"
	quest.0B0310400000006C.quest_desc: ["Take a &bCreteor Hide&r. It comes off one of the dimension's creatures, a leather-like material for its armor and bound recipes."]
	quest.0B0310400000006C.quest_subtitle: "Collect creature hide."
	quest.0B0310400000006C.title: "Creteor Hide"
	quest.0B0310400000006D.quest_desc: ["Process &bColdsnap&r into &bShivering Gel&r. The gel is the worked form of the dimension's cold, a reagent for its frostier enchanted gear."]
	quest.0B0310400000006D.quest_subtitle: "Process coldsnap into gel."
	quest.0B0310400000006D.title: "Shivering Gel"
	quest.0B0310400000006E.quest_desc: ["Mine a &bThioquartz Shard&r. The dimension's own quartz carries odd properties, a component the springstone-side recipes draw on."]
	quest.0B0310400000006E.quest_subtitle: "Mine the quartz shard."
	quest.0B0310400000006E.title: "Thioquartz Shard"
	quest.0B0310400000006F.quest_desc: ["Split off a &bMana Crystal Shard&r. The smaller fraction is what the lighter enchanted recipes ask for, cheaper than spending a whole crystal."]
	quest.0B0310400000006F.quest_subtitle: "Split off a mana shard."
	quest.0B0310400000006F.title: "Mana Crystal Shard"
	quest.0B03104000000070.quest_desc: ["Forge a &bStarlit Diamond&r. Steeped in the dimension's light, it is a high-grade gem for &6Eternal Starlight&r's best gear, the payoff of the amber-alloy line."]
	quest.0B03104000000070.quest_subtitle: "Forge the starlit gem."
	quest.0B03104000000070.title: "Starlit Diamond"
	quest.0B03104000000071.quest_desc: [
		"Assemble the &bOrb of Prophecy&r. It is the summoning key for the dimension's guardian, built from the amaramber and springstone work you have done."
		"Crafting it is the last step before the boss fight."
	]
	quest.0B03104000000071.quest_subtitle: "Opens the Gatekeeper fight."
	quest.0B03104000000071.title: "Orb of Prophecy"
	quest.0B03104000000072.quest_desc: [
		"Hunt down &c&lPermafrost&r, an optional boss in &6Eternal Starlight&r. Bring warm gear and a fast weapon."
		"Its drops feed the dimension's coldest gear, a reward for the fight rather than a gate."
	]
	quest.0B03104000000072.quest_subtitle: "Defeat the frost boss."
	quest.0B03104000000072.title: "Permafrost"
	quest.0B03104000000073.quest_desc: [
		"Take on the &c&lStarlight Golem&r, a required construct boss of Eternal Starlight. It is slow but heavy-hitting, so circle it and chip away rather than trading blows head-on."
		"This kill is required. The Starlight proof depends on the Golem's defeat, and the observation work cannot complete without it."
	]
	quest.0B03104000000073.quest_subtitle: "Defeat the golem boss."
	quest.0B03104000000073.title: "Starlight Golem"
	quest.0B03104000000100.quest_desc: [
		"Keep an Orb of Prophecy after the Starlight Golem is defeated; its possession marks the guardian work as done."
		"It depends on the &c&lStarlight Golem&r kill, which is now a required fight rather than an optional trophy. You cannot log this proof until the Golem is down."
		"Completing it carries the Starlight chapter proof, so the Renaissance age progress runs through this node. Finish the Golem, bring the orb, and the observation work is closed."
	]
	quest.0B03104000000100.quest_subtitle: "Record the Starlight boss victory."
	quest.0B03104000000100.title: "Starlight Proven"
	quest.0B03105000000001.quest_desc: [
		"The &6Undergarden&r is a vast cavern dimension of glowing fog, strange metals, and meaner-than-they-look locals. This chapter covers the way down, the Cloggrum-and-Utherium metalwork waiting there, and the guardians that keep the best of it."
		"Entry runs through the &bCatalyst&r, crafted from copper, stone, and an ender pearl, then used on a built portal frame."
	]
	quest.0B03105000000001.quest_subtitle: "A foggy world beneath the world."
	quest.0B03105000000001.title: "Undergarden Descent"
	quest.0B03105000000010.quest_desc: [
		"Craft a &bCatalyst&r. The &6Undergarden&r portal is opened not with &bflint&r and steel but by throwing this at a built frame. It is the item that lets you cross."
		"Make it before you go looking for a fight in the deep dark."
	]
	quest.0B03105000000010.quest_subtitle: "Opens the Undergarden."
	quest.0B03105000000010.title: "Catalyst"
	quest.0B03105000000011.quest_desc: [
		"Before the descent opens you must put down a &c&lWarden&r. It is among the deadliest things in the game: blind but deafening, with a melee that flattens armor and a sonic boom that ignores it entirely."
		"Come with totems, strength and regeneration, and an escape plan. Stay off the sculk, strike, and reposition. Winning here earns you the way below."
	]
	quest.0B03105000000011.quest_subtitle: "Best the deep dark's guardian."
	quest.0B03105000000011.title: "The Warden"
	quest.0B03105000000012.quest_desc: [
		"Open your frame with the &bCatalyst&r and step into the &6Undergarden&r. The fog cuts your sight short and the locals do not wait for an introduction. Move carefully until you have a base."
		"Arriving is the milestone the &c&lwarden&r fight bought you."
	]
	quest.0B03105000000012.quest_subtitle: "Throw the Catalyst and drop down."
	quest.0B03105000000012.title: "Into the Undergarden"
	quest.0B03105000000020.quest_desc: ["Pick up a &bDepthrock Pebble&r. Depthrock is the &6Undergarden&r's bedrock-to-ceiling filler, and the pebble is the first crafting material the place hands you."]
	quest.0B03105000000020.quest_subtitle: "The dimension's first stone."
	quest.0B03105000000020.title: "Depthrock Pebble"
	quest.0B03105000000021.quest_desc: ["Harvest &bDroopfruit&r from the droopvines. It is early food and the input for &bditchbulb paste&r, the start of the &6Undergarden&r's small kitchen."]
	quest.0B03105000000021.quest_subtitle: "Forage the hanging vines."
	quest.0B03105000000021.title: "Droopfruit"
	quest.0B03105000000022.quest_desc: ["Grind &bDitchbulb Paste&r. It is a reagent the dimension's recipes and some of its food lean on, worked up from the bulbs that light the caverns."]
	quest.0B03105000000022.quest_subtitle: "Mash the glowing bulbs."
	quest.0B03105000000022.title: "Ditchbulb Paste"
	quest.0B03105000000030.quest_desc: [
		"Smelt a &bCloggrum Ingot&r. Cloggrum is the workhorse metal of the &6Undergarden&r, the one its first tools, weapons, and the shield are forged from."
		"Nearly every crafting branch here starts with a stack of it."
	]
	quest.0B03105000000030.quest_subtitle: "The Undergarden's base metal."
	quest.0B03105000000030.title: "Cloggrum Ingot"
	quest.0B03105000000031.quest_desc: [
		"Mine a &bUtherium Crystal&r. The glowing red gem is the &6Undergarden&r's prize material, the upgrade reagent that lifts Cloggrum gear to something special."
		"It feeds the &binfuser&r and the better pickaxe both."
	]
	quest.0B03105000000031.quest_subtitle: "The signature red crystal."
	quest.0B03105000000031.title: "Utherium Crystal"
	quest.0B03105000000032.quest_desc: ["Smelt a &bFroststeel Ingot&r. It is one of the Undergarden metals used for the dimension's gear line."]
	quest.0B03105000000032.quest_subtitle: "Collect one Froststeel Ingot."
	quest.0B03105000000032.title: "Froststeel Ingot"
	quest.0B03105000000033.quest_desc: ["Find a &bRegalium Crystal&r. It is a gem from the &6Undergarden&r used in the dimension's equipment paths."]
	quest.0B03105000000033.quest_subtitle: "Collect one Regalium Crystal."
	quest.0B03105000000033.title: "Regalium Crystal"
	quest.0B03105000000034.quest_desc: ["Forge a &bUtherium Pickaxe&r. Built with the red crystal it mines faster and lasts longer than Cloggrum, the natural step up for digging deeper here."]
	quest.0B03105000000034.quest_subtitle: "A crystal-cut mining tool."
	quest.0B03105000000034.title: "Utherium Pickaxe"
	quest.0B03105000000035.quest_desc: ["Forge a &bCloggrum Sword&r. This optional objective tracks one of the dimension's early weapon crafts."]
	quest.0B03105000000035.quest_subtitle: "Collect one Cloggrum Sword."
	quest.0B03105000000035.title: "Cloggrum Sword"
	quest.0B03105000000036.quest_desc: [
		"Build the &bInfuser&r. It is the &6Undergarden&r's upgrade station, working Utherium and other crystals into your Cloggrum and Froststeel tools to meaningfully extend their performance."
		"It fills the same role a smithing table does on the surface."
	]
	quest.0B03105000000036.quest_subtitle: "Collect one Infuser."
	quest.0B03105000000036.title: "Infuser"
	quest.0B03105000000037.quest_desc: ["Bake a &bGloomgourd Pie&r. It is one of the &6Undergarden&r food crafts."]
	quest.0B03105000000037.quest_subtitle: "Collect one Gloomgourd Pie."
	quest.0B03105000000037.title: "Gloomgourd Pie"
	quest.0B03105000000038.quest_desc: ["Collect a &bScintling Goo Ball&r. It is an &6Undergarden&r material used by side recipes."]
	quest.0B03105000000038.quest_subtitle: "Collect one Scintling Goo Ball."
	quest.0B03105000000038.title: "Scintling Goo Ball"
	quest.0B03105000000040.quest_desc: [
		"Locate the &bCatacombs&r. The buried structure is where the &6Undergarden&r hides its forgotten gear and the guardian that watches it, the destination for anyone chasing the top tier."
		"Go in prepared, not curious."
	]
	quest.0B03105000000040.quest_subtitle: "Find the Catacombs."
	quest.0B03105000000040.title: "The Catacombs"
	quest.0B03105000000041.quest_desc: [
		"Bring down the &c&lForgotten Guardian&r in the &bCatacombs&r. The stone sentinel hits hard and soaks damage. Circle it, use the pillars for cover, and wear it down rather than rushing."
		"Its defeat opens the forgotten gear, the &6Undergarden&r's highest tier."
	]
	quest.0B03105000000041.quest_subtitle: "Defeat one Forgotten Guardian."
	quest.0B03105000000041.title: "Forgotten Guardian"
	quest.0B03105000000042.quest_desc: ["Recover a &bForgotten Nugget&r. It is a small piece of the forgotten metal used by the Undergarden upgrade line."]
	quest.0B03105000000042.quest_subtitle: "Collect one Forgotten Nugget."
	quest.0B03105000000042.title: "Forgotten Nugget"
	quest.0B03105000000043.quest_desc: ["Assemble a &bForgotten Ingot&r. It is the usable ingot for the Undergarden forgotten upgrade line."]
	quest.0B03105000000043.quest_subtitle: "Collect one Forgotten Ingot."
	quest.0B03105000000043.title: "Forgotten Ingot"
	quest.0B03105000000044.quest_desc: ["Find the &bForgotten Upgrade&r smithing template. Pair it with the &bforgotten ingot&r at a smithing table for the related upgrade recipes."]
	quest.0B03105000000044.quest_subtitle: "Collect one Forgotten Upgrade Smithing Template."
	quest.0B03105000000044.title: "Forgotten Upgrade Template"
	quest.0B03105000000045.quest_desc: ["Find a &bForgotten Vestige&r. These ruins hold more of the forgotten materials and a stiffer challenge, the reward for mapping the dimension thoroughly."]
	quest.0B03105000000045.quest_subtitle: "Find the Undergarden's deeper guardian site."
	quest.0B03105000000045.title: "Forgotten Vestige Ruin"
	quest.0B03105000000050.quest_desc: [
		"Return to the overworld from the &6Undergarden&r. The quest checks that you made the crossing back with your haul."
		"Completing it marks &bUndergarden Descent&r done and counts toward the Renaissance gates."
	]
	quest.0B03105000000050.quest_subtitle: "Return to the overworld."
	quest.0B03105000000050.title: "Back from the Depths"
	quest.0B03105000000070.quest_desc: ["Mine &bRaw Cloggrum&r. It is the raw material for the Cloggrum ingot line."]
	quest.0B03105000000070.quest_subtitle: "Collect one Raw Cloggrum."
	quest.0B03105000000070.title: "Raw Cloggrum"
	quest.0B03105000000071.quest_desc: ["Forge a &bCloggrum Sword&r for the optional catalog branch."]
	quest.0B03105000000071.quest_subtitle: "Collect one Cloggrum Sword."
	quest.0B03105000000071.title: "Cloggrum Sword"
	quest.0B03105000000072.quest_desc: ["Craft a &bCloggrum Pickaxe&r. It is part of the Cloggrum tool set."]
	quest.0B03105000000072.quest_subtitle: "Collect one Cloggrum Pickaxe."
	quest.0B03105000000072.title: "Cloggrum Pickaxe"
	quest.0B03105000000073.quest_desc: ["Mine &bRaw Froststeel&r. It is the raw material for the Froststeel ingot line."]
	quest.0B03105000000073.quest_subtitle: "Collect one Raw Froststeel."
	quest.0B03105000000073.title: "Raw Froststeel"
	quest.0B03105000000074.quest_desc: ["Collect a &bUtheric Shard&r. It is a smaller piece of the red crystal, the cheaper measure for recipes that do not need a whole gem."]
	quest.0B03105000000074.quest_subtitle: "Collect one Utheric Shard."
	quest.0B03105000000074.title: "Utheric Shard"
	quest.0B03105000000075.quest_desc: ["Craft a &bSlingshot&r. It is a side tool in the &6Undergarden&r equipment set."]
	quest.0B03105000000075.quest_subtitle: "Collect one Slingshot."
	quest.0B03105000000075.title: "Slingshot"
	quest.0B03105000000076.quest_desc: ["Make a &bBlisterbomb&r. It belongs to the &6Undergarden&r side-combat item set."]
	quest.0B03105000000076.quest_subtitle: "Collect one Blisterbomb."
	quest.0B03105000000076.title: "Blisterbomb"
	quest.0B03105000000077.quest_desc: ["Gather a &bBlisterberry&r. It is used by the blisterbomb side recipe."]
	quest.0B03105000000077.quest_subtitle: "Collect one Blisterberry."
	quest.0B03105000000077.title: "Blisterberry"
	quest.0B03105000000078.quest_desc: ["Cook a Gwibling into a meal."]
	quest.0B03105000000078.quest_subtitle: "Collect one Cooked Gwibling."
	quest.0B03105000000078.title: "Cooked Gwibling"
	quest.0B03105000000079.quest_desc: ["Bucket a live Gwibling. Like any fish in a bucket it travels and displays well, a catch to move rather than eat."]
	quest.0B03105000000079.quest_subtitle: "Collect one Bucket of Gwibling."
	quest.0B03105000000079.title: "Bucket of Gwibling"
	quest.0B0310500000007A.quest_desc: ["Cook an &bInky Stew&r from the gloomgourd."]
	quest.0B0310500000007A.quest_subtitle: "Collect one Inky Stew."
	quest.0B0310500000007A.title: "Inky Stew"
	quest.0B0310500000007B.quest_desc: ["Prepare an &bIndigo Stew&r."]
	quest.0B0310500000007B.quest_subtitle: "Collect one Indigo Stew."
	quest.0B0310500000007B.title: "Indigo Stew"
	quest.0B0310500000007C.quest_desc: ["Cook a &bBloody Stew&r."]
	quest.0B0310500000007C.quest_subtitle: "Collect one Bloody Stew."
	quest.0B0310500000007C.title: "Bloody Stew"
	quest.0B0310500000007D.quest_desc: ["Collect a &bBrute Tusk&r."]
	quest.0B0310500000007D.quest_subtitle: "Collect one Brute Tusk."
	quest.0B0310500000007D.title: "Brute Tusk"
	quest.0B03105000000100.quest_desc: [
		"Keep a Forgotten Nugget from the Guardian fight; its possession records the fight."
		"The nugget drops from the &c&lForgotten Guardian&r down in the Catacombs, and that fight is now required, not optional. Kill the Guardian first, then bring its nugget here."
		"Logging this carries the Undergarden chapter proof, so the Renaissance descent completes through this node. Nothing shallower in the dimension will stand in for the Guardian."
	]
	quest.0B03105000000100.quest_subtitle: "Claim the Forgotten Nugget."
	quest.0B03105000000100.title: "Forgotten Guardian Proven"
	quest.0B03106000000001.quest_desc: [
		"&6Deeper Darker&r extends the &bdeep dark&r into a whole dimension, the Otherside: a sculk-choked mirror of the world reached from an &bancient city&r. This chapter covers the way in and the resonarium gear on the other side."
		"The road runs through the Warden's home. Quiet and caution matter more than firepower at first."
	]
	quest.0B03106000000001.quest_subtitle: "Through the deep dark, into the dark."
	quest.0B03106000000001.title: "The Otherside"
	quest.0B03106000000010.quest_desc: [
		"Locate an &bAncient City&r in the &bdeep dark&r. The portal to the Otherside is built from one of its frames. The city is your first destination."
		"Move on wool, give the shriekers a wide berth, and do not wake what sleeps here."
	]
	quest.0B03106000000010.quest_subtitle: "Find the sculk cathedral."
	quest.0B03106000000010.title: "Ancient City"
	quest.0B03106000000011.quest_desc: [
		"Spend time in the &bDeep Dark&r biome itself. The sculk reacts to every sound you make. Learn its rules here before you need them under pressure."
		"Crouch, watch the sensors, and keep an escape route at your back."
	]
	quest.0B03106000000011.quest_subtitle: "Stand in the sculk."
	quest.0B03106000000011.title: "The Deep Dark"
	quest.0B03106000000012.quest_desc: [
		"Recover a &bHeart of the Deep&r. It is the activator for the Otherside portal, found in the depths of the &bancient city&r, which is what makes the city run worth the danger."
		"With it in hand the crossing is one step away."
	]
	quest.0B03106000000012.quest_subtitle: "Activates the Otherside portal."
	quest.0B03106000000012.title: "Heart of the Deep"
	quest.0B03106000000013.quest_desc: [
		"Use the &bHeart of the Deep&r on an &bancient city&r frame and step into the Otherside. It is a sculk-grown dimension, dark and hostile. Bring your own light."
		"Setting foot here is the milestone the deep-dark run earns you."
	]
	quest.0B03106000000013.quest_subtitle: "Open the portal and cross."
	quest.0B03106000000013.title: "Into the Otherside"
	quest.0B03106000000020.quest_desc: ["Gather &bGleam Gel&r. The luminous gel is the Otherside's answer to the dark, the base of its light items and a reagent for several of its recipes."]
	quest.0B03106000000020.quest_subtitle: "Bottle the dimension's glow."
	quest.0B03106000000020.title: "Gleam Gel"
	quest.0B03106000000021.quest_desc: ["Pick &bBloom Berries&r. They grow in the Otherside's gloom and make a steady food, the easiest thing to live on while you explore."]
	quest.0B03106000000021.quest_subtitle: "Forage the glowing fruit."
	quest.0B03106000000021.title: "Bloom Berries"
	quest.0B03106000000030.quest_desc: ["Collect &bSoul Dust&r. It is a common Otherside material, ground from the dimension's soul-bound blocks and used throughout &6Deeper Darker&r's crafting."]
	quest.0B03106000000030.quest_subtitle: "The dimension's base reagent."
	quest.0B03106000000030.title: "Soul Dust"
	quest.0B03106000000032.quest_desc: ["Recover a &bSculk Bone&r. It is a &6Deeper Darker&r crafting reagent for the Otherside branch."]
	quest.0B03106000000032.quest_subtitle: "Optional: a sculk-touched bone."
	quest.0B03106000000032.title: "Sculk Bone"
	quest.0B03106000000033.quest_desc: [
		"Craft a &bReinforced Echo Shard&r. It is the worked form of the echo shard, the building block for &bresonarium&r and the dimension's better gear."
		"Gathering the base shards means braving the &bancient city&r again."
	]
	quest.0B03106000000033.quest_subtitle: "Strengthen the deep-dark drop."
	quest.0B03106000000033.title: "Reinforced Echo Shard"
	quest.0B03106000000034.quest_desc: [
		"Forge &bResonarium&r. It is &6Deeper Darker&r's prize material, refined from reinforced echo shards, and the base for the dimension's armor, staff, and upgrades."
		"Most of what is worth making here runs through it."
	]
	quest.0B03106000000034.quest_subtitle: "The Otherside's signature metal."
	quest.0B03106000000034.title: "Resonarium"
	quest.0B03106000000041.quest_desc: ["Recover a &bGloomsherd&r. It starts the Otherside pottery-sherd collection."]
	quest.0B03106000000041.quest_subtitle: "Optional: a plain pottery sherd."
	quest.0B03106000000041.title: "Gloomsherd"
	quest.0B03106000000042.quest_desc: ["Collect a &bGrime Ball&r. It bakes into Grime Bricks."]
	quest.0B03106000000042.quest_subtitle: "Optional: clumped grime."
	quest.0B03106000000042.title: "Grime Ball"
	quest.0B03106000000044.quest_desc: ["Grow a &bSoul Crystal&r. It is a reagent for &6Deeper Darker&r light and staff recipes."]
	quest.0B03106000000044.quest_subtitle: "Optional: crystallized soul."
	quest.0B03106000000044.title: "Soul Crystal"
	quest.0B03106000000045.quest_desc: ["Craft a &bSonorous Staff&r. Built from &bresonarium&r and soul energy, it strikes with sonic force and fits the late Otherside kit."]
	quest.0B03106000000045.quest_subtitle: "Carry the late-Otherside sonic weapon."
	quest.0B03106000000045.title: "Resonarium Sonorous Staff"
	quest.0B03106000000050.quest_desc: [
		"Return to the overworld from the Otherside. The quest checks that you made the crossing back."
		"Completing it marks &bDeeper, Darker, Otherside&r done and counts toward the Renaissance gates."
	]
	quest.0B03106000000050.quest_subtitle: "Return to the overworld."
	quest.0B03106000000050.title: "Back to the Light"
	quest.0B03106000000070.quest_desc: ["Track down &bMimi-Dust&r from &6Reliquified Artifacts&r. This is a collector objective placed beside the Otherside branch."]
	quest.0B03106000000070.quest_subtitle: "Optional: a curious find."
	quest.0B03106000000070.title: "Mimi-Dust"
	quest.0B03106000000080.quest_desc: ["Catch a &bRaw Angler Fish&r."]
	quest.0B03106000000080.quest_subtitle: "Optional: fish the Otherside."
	quest.0B03106000000080.title: "Raw Angler Fish"
	quest.0B03106000000081.quest_desc: ["Cook your Angler Fish. Fired up it becomes a solid meal, the practical end of fishing the dimension's waters."]
	quest.0B03106000000081.quest_subtitle: "Optional: cook the catch."
	quest.0B03106000000081.title: "Cooked Angler Fish"
	quest.0B03106000000082.quest_desc: ["Find a &bBrittle Gloomsherd&r. It is one of the decorated pottery sherds, each carrying a different motif for the pots you assemble from them."]
	quest.0B03106000000082.quest_subtitle: "Optional: a sherd variant."
	quest.0B03106000000082.title: "Brittle Gloomsherd"
	quest.0B03106000000083.quest_desc: ["Recover a &bDark Heart Gloomsherd&r. Another face for the pottery set."]
	quest.0B03106000000083.quest_subtitle: "Optional: another sherd."
	quest.0B03106000000083.title: "Dark Heart Gloomsherd"
	quest.0B03106000000084.quest_desc: ["Collect a &bListener Gloomsherd&r. It is one more sherd for the pottery collection."]
	quest.0B03106000000084.quest_subtitle: "Optional: the listener motif."
	quest.0B03106000000084.title: "Listener Gloomsherd"
	quest.0B03106000000085.quest_desc: ["Find a &bSnapper Gloomsherd&r. It joins the growing set of Otherside pottery, each variant distinct on a finished pot."]
	quest.0B03106000000085.quest_subtitle: "Optional: the snapper motif."
	quest.0B03106000000085.title: "Snapper Gloomsherd"
	quest.0B03106000000086.quest_desc: ["Recover a &bTemple Gloomsherd&r. It is one of the named pottery variants."]
	quest.0B03106000000086.quest_subtitle: "Optional: from the temples."
	quest.0B03106000000086.title: "Temple Gloomsherd"
	quest.0B03106000000087.quest_desc: ["Collect a &bTransmission Gloomsherd&r. It is another piece of the pottery set."]
	quest.0B03106000000087.quest_subtitle: "Optional: the transmission motif."
	quest.0B03106000000087.title: "Transmission Gloomsherd"
	quest.0B03106000000088.quest_desc: ["Find a &bWard Gloomsherd&r. It is one of the named pottery variants."]
	quest.0B03106000000088.quest_subtitle: "Optional: the ward motif."
	quest.0B03106000000088.title: "Ward Gloomsherd"
	quest.0B03106000000089.quest_desc: ["Recover a &bWayfinder Gloomsherd&r. It is one of the named pottery variants."]
	quest.0B03106000000089.quest_subtitle: "Optional: the last sherd."
	quest.0B03106000000089.title: "Wayfinder Gloomsherd"
	quest.0B0310600000008A.quest_desc: ["Fire Grime Balls into Grime Bricks."]
	quest.0B0310600000008A.quest_subtitle: "Optional: bake the grime."
	quest.0B0310600000008A.title: "Grime Brick"
	quest.0B0310600000008B.quest_desc: ["Craft a &bSculk Transmitter&r. Pair it with another transmitter for the mod's wireless redstone setup."]
	quest.0B0310600000008B.quest_subtitle: "Optional: wireless redstone."
	quest.0B0310600000008B.title: "Sculk Transmitter"
	quest.0B0310600000008C.quest_desc: ["Craft a second &bSculk Transmitter&r after the first. Turn one in here once you have built and linked the pair for wireless redstone."]
	quest.0B0310600000008C.quest_subtitle: "Optional: the matching transmitter."
	quest.0B0310600000008C.title: "A Linked Pair"
	quest.0B0310600000008E.quest_desc: ["Obtain a &bWarden Carapace&r. It is used in the later &6Deeper Darker&r upgrade recipes."]
	quest.0B0310600000008E.quest_subtitle: "Optional: plate from the deep."
	quest.0B0310600000008E.title: "Warden Carapace"
	quest.0B03106000000090.quest_desc: ["Craft a &bLite&r. It is a throwable light item."]
	quest.0B03106000000090.quest_subtitle: "Optional: a throwable light."
	quest.0B03106000000090.title: "Lite"
	quest.0B03106000000092.quest_desc: ["Find an &bAncient Temple&r in the Otherside. The structure holds the dimension's better loot and sherds, the destination for anyone exploring past the basics."]
	quest.0B03106000000092.quest_subtitle: "Optional: a deeper ruin."
	quest.0B03106000000092.title: "Ancient Temple"
	quest.0B03107000000001.quest_desc: [
		"A working civilization keeps records. This chapter gathers the tools for it: in-game manuals, real storage, the archaeology to recover the past, and the jewelry trade to catalogue what you find."
		"The Complete Record milestone is one &dRenaissance&r chapter check for the age close."
	]
	quest.0B03107000000001.quest_subtitle: "Write it down, store it, dig up the rest."
	quest.0B03107000000001.title: "Archive and Recordkeeping"
	quest.0B03107000000010.quest_desc: [
		"Craft the &bModonomicon&r. It is a single book that collects the in-game guidebooks many of the pack's mods register, so every mod manual lives in one book."
		"Open it whenever a new system has you guessing."
	]
	quest.0B03107000000010.quest_subtitle: "Your shelf of mod manuals."
	quest.0B03107000000010.title: "Modonomicon"
	quest.0B03107000000030.quest_desc: ["Build a &6Sophisticated Storage&r &bBarrel&r. It works like a vanilla barrel but takes upgrade slots. The whole mod's storage line extends from this base unit."]
	quest.0B03107000000030.quest_subtitle: "Sophisticated Storage, the base unit."
	quest.0B03107000000030.title: "Barrel"
	quest.0B03107000000031.quest_desc: ["Craft an &bIron Chest&r. It holds far more than wood and accepts the same upgrades. Move up to it once a &bbarrel&r fills."]
	quest.0B03107000000031.quest_subtitle: "More slots, sturdier box."
	quest.0B03107000000031.title: "Iron Chest"
	quest.0B03107000000032.quest_desc: ["Make a &bLimited Barrel&r. It displays its contents on the front and caps each slot, which makes it ideal for a tidy wall of single-item stockpiles."]
	quest.0B03107000000032.quest_subtitle: "A barrel that shows its stock."
	quest.0B03107000000032.title: "Limited Barrel I"
	quest.0B03107000000033.quest_desc: ["Craft the &bStorage Tool&r. It tweaks settings on your storage blocks and their upgrades without opening each one. Worth it once you run more than a few."]
	quest.0B03107000000033.quest_subtitle: "Configure storage at a touch."
	quest.0B03107000000033.title: "Storage Tool"
	quest.0B03107000000034.quest_desc: [
		"Make &bPacking Tape&r. Applied to a storage block it seals the contents so you can pick the whole thing up and set it down elsewhere, inventory intact."
		"Moving base is a lot less painful with a roll on hand."
	]
	quest.0B03107000000034.quest_subtitle: "Move a full storage block."
	quest.0B03107000000034.title: "Packing Tape"
	quest.0B03107000000035.quest_desc: ["Craft an &bUpgrade Base&r. It is the common blank that every storage upgrade is built on, from stacking to magnets. Make a stack before you specialize them."]
	quest.0B03107000000035.quest_subtitle: "The blank every upgrade starts as."
	quest.0B03107000000035.title: "Upgrade Base"
	quest.0B03107000000036.quest_desc: ["Build a &bLimited Barrel&r II. It carries more per slot than the first tier while keeping the contents on show. Good for stockpiles that outgrew the starter."]
	quest.0B03107000000036.quest_subtitle: "A larger display barrel."
	quest.0B03107000000036.title: "Limited Barrel II"
	quest.0B03107000000040.quest_desc: [
		"Bring back &bSkyroot Planks&r from the &6Aether&r. Filing a sample of each dimension's basic wood is the archivist habit. It marks your first trip skyward."
		"The &6Aether&r gets its own chapter when you are ready to go properly."
	]
	quest.0B03107000000040.quest_subtitle: "A specimen from the Aether."
	quest.0B03107000000040.title: "Skyroot Planks"
	quest.0B03107000000041.quest_desc: ["Collect &bShiverstone&r from the &6Undergarden&r. It is a signature stone of that frozen underworld. A second sample for the archive and a preview of the descent to come."]
	quest.0B03107000000041.quest_subtitle: "A specimen from the Undergarden."
	quest.0B03107000000041.title: "Shiverstone"
	quest.0B03107000000050.quest_desc: [
		"Keep a Storage Tool once the Modonomicon is shelved, your storage line is built out, and archeology is underway."
		"Completing this marks &bArchive and Recordkeeping&r done and counts toward the Renaissance gates."
	]
	quest.0B03107000000050.quest_subtitle: "Submit the storage tool capstone."
	quest.0B03107000000050.title: "The Complete Record"
	quest.0B03107000000060.quest_desc: [
		"Craft an &bIron Brush&r. &6Better Archeology&r is dug, not mined: you sweep suspicious blocks with a brush to recover what is buried in them."
		"Everything in this lane starts with the brush in hand."
	]
	quest.0B03107000000060.quest_subtitle: "The archeologist's first tool."
	quest.0B03107000000060.title: "Iron Brush"
	quest.0B03107000000061.quest_desc: ["Recover &bArtifact Shards&r by brushing suspicious blocks. They are the fragments that combine into a whole artifact. Every dig produces them."]
	quest.0B03107000000061.quest_subtitle: "Broken pieces, brushed loose."
	quest.0B03107000000061.title: "Artifact Shards"
	quest.0B03107000000062.quest_desc: ["Combine shards into an &bUnidentified Artifact&r. You cannot tell what it is yet, only that it is whole. The table tells you what you found."]
	quest.0B03107000000062.quest_subtitle: "Assemble the pieces."
	quest.0B03107000000062.title: "Unidentified Artifact"
	quest.0B03107000000063.quest_desc: ["Build the &bArcheology Table&r. It identifies your unknown artifacts into the real finds: totems, fossils, vases, and the rest. Every other step in the digging loop feeds back here."]
	quest.0B03107000000063.quest_subtitle: "Identify what you dug up."
	quest.0B03107000000063.title: "Archeology Table"
	quest.0B03107000000064.quest_desc: ["Make an &bAncient Vase&r. It is a decorative piece for the museum corner. A fitting reward for keeping your finds rather than discarding them."]
	quest.0B03107000000064.quest_subtitle: "A crafted display piece."
	quest.0B03107000000064.title: "Ancient Vase"
	quest.0B03107000000065.quest_desc: ["Identify a &bChicken-Fossil Skull&r. It is one of several mountable fossil heads, more curiosity than tool, but the kind of thing a record-keeper hangs on the wall."]
	quest.0B03107000000065.quest_subtitle: "A mounted fossil trophy."
	quest.0B03107000000065.title: "Chicken-Fossil Skull"
	quest.0B03107000000066.quest_desc: ["Gather &bRotten Planks&r from a dig site. They are a weathered building block recovered from ruins, useful for giving a build that lived-in, ancient look."]
	quest.0B03107000000066.quest_subtitle: "Salvaged old timber."
	quest.0B03107000000066.title: "Rotten Planks"
	quest.0B03107000000067.quest_desc: ["Recover &bCracked Mud Bricks&r. Like &bRotten Planks&r, they are a decorative salvage block. Use them for worn, ruined-looking builds."]
	quest.0B03107000000067.quest_subtitle: "Aged masonry."
	quest.0B03107000000067.title: "Cracked Mud Bricks"
	quest.0B03107000000068.quest_desc: ["Identify a &bTotem of Growth&r. Placed, it nudges nearby crops along. One of the more useful finds the &barcheology table&r can turn up."]
	quest.0B03107000000068.quest_subtitle: "An identified totem."
	quest.0B03107000000068.title: "Totem of Growth"
	quest.0B03107000000069.quest_desc: ["Unearth a &bRusty Bomb&r. It is a thrown explosive recovered from a dig, handy for breaking into the next ruin or clearing a stubborn patch of stone."]
	quest.0B03107000000069.quest_subtitle: "An old explosive, still live."
	quest.0B03107000000069.title: "Rusty Bomb"
	quest.0B03107000000070.quest_desc: ["Upgrade to a &bDiamond Brush&r. It sweeps suspicious blocks faster and lasts far longer than iron. Carry this one once you are digging in earnest."]
	quest.0B03107000000070.quest_subtitle: "A faster, tougher brush."
	quest.0B03107000000070.title: "Diamond Brush"
	quest.0B03107000000071.quest_desc: ["Bring together a broad sample of what the dig sites offer: vases, fossils, salvaged blocks, totems, and a &bdiamond brush&r to keep finding more."]
	quest.0B03107000000071.quest_subtitle: "A wide spread of finds."
	quest.0B03107000000071.title: "Curator's Collection"
	quest.0B03107000000072.quest_desc: ["Find &bSuspicious Dirt&r. It is one of the buried-loot blocks &6Better Archeology&r scatters around, the overworld cousin of vanilla's suspicious sand."]
	quest.0B03107000000072.quest_subtitle: "A block worth brushing."
	quest.0B03107000000072.title: "Suspicious Dirt"
	quest.0B03107000000073.quest_desc: ["Locate &bSuspicious Red Sand&r. Brushed carefully it gives up its buried find, a desert-side source of shards for the table."]
	quest.0B03107000000073.quest_subtitle: "Another dig candidate."
	quest.0B03107000000073.title: "Suspicious Red Sand"
	quest.0B03107000000074.quest_desc: ["Dig up &bFossiliferous Dirt&r. As the name promises it tends to hold fossils, the richest of the suspicious blocks for skull and bone finds."]
	quest.0B03107000000074.quest_subtitle: "Dirt that hides bones."
	quest.0B03107000000074.title: "Fossiliferous Dirt"
	quest.0B03107000000075.quest_desc: ["Recover a &bLoot Vase&r from a ruin. Unlike the decorative kind this one spills loot when broken, a small gamble baked into the dig sites."]
	quest.0B03107000000075.quest_subtitle: "A vase worth breaking."
	quest.0B03107000000075.title: "Loot Vase"
	quest.0B03107000000076.quest_desc: ["Identify a &bCreeper-Fossil Skull&r. It joins the fossil-head set, a recognizable trophy for anyone building out a proper collection."]
	quest.0B03107000000076.quest_subtitle: "Another wall trophy."
	quest.0B03107000000076.title: "Creeper-Fossil Skull"
	quest.0B03107000000077.quest_desc: ["Turn up a &bWolf-Fossil Skull&r. With the chicken and creeper heads it rounds out the easy fossil trophies, more bones for the display."]
	quest.0B03107000000077.quest_subtitle: "The third fossil head."
	quest.0B03107000000077.title: "Wolf-Fossil Skull"
	quest.0B03107000000078.quest_desc: ["Identify a &bTotem of Radiance&r. Set down it sheds light over an area, a tidy way to keep a dig site or a room lit without scattering torches."]
	quest.0B03107000000078.quest_subtitle: "An identified light totem."
	quest.0B03107000000078.title: "Totem of Radiance"
	quest.0B03107000000079.quest_desc: ["Recover a &bMusic Disc&r from the ruins. The archive keeps records in every form, so shelve the disc with the rest of the collection."]
	quest.0B03107000000079.quest_subtitle: "A recovered recording."
	quest.0B03107000000079.title: "Music Disc: Swings"
	quest.0B031070000000A8.quest_desc: ["Forge a &bCloggrum Shield&r from &6Undergarden&r metal. It is a sturdy shield in its own right and another logged sample from the underworld below."]
	quest.0B031070000000A8.quest_subtitle: "Optional: an Undergarden specimen."
	quest.0B031070000000A8.title: "Cloggrum Shield"
	quest.0B031070000000A9.quest_desc: ["Craft an &bAncient Compass&r. It orients you toward the structures of the &6Deeper Darker&r, a useful keepsake for when that descent gets its own chapter."]
	quest.0B031070000000A9.quest_subtitle: "Optional: points toward the deep."
	quest.0B031070000000A9.title: "Ancient Compass"
	quest.0B031070000000B1.quest_desc: ["Apply a Basic to Iron Tier Upgrade. It lifts a wooden storage block to iron capacity in place, no need to rebuild and re-sort."]
	quest.0B031070000000B1.quest_subtitle: "Optional: promote a storage block."
	quest.0B031070000000B1.title: "Basic to Iron Upgrade"
	quest.0B031070000000B2.quest_desc: [
		"Craft the &bJeweler's Kit&r. It is the workstation the Jewelry mod builds its rings and necklaces on. From here you begin cataloguing and wearing real gemstones."
		"Worn jewelry grants quiet passive bonuses."
	]
	quest.0B031070000000B2.quest_subtitle: "Open the gem trade."
	quest.0B031070000000B2.title: "Jeweler's Kit"
	quest.0B031070000000B3.quest_desc: ["Mine a &bGem Vein&r. It is the Jewelry mod's ore, the source the rough gemstones are cut from before they ever reach the kit."]
	quest.0B031070000000B3.quest_subtitle: "Optional: the surface gem ore."
	quest.0B031070000000B3.title: "Gem Vein"
	quest.0B031070000000B4.quest_desc: ["Find a &bDeepslate Gem Vein&r. It is the lower-layer version of the gem ore, richer ground for the rarer stones."]
	quest.0B031070000000B4.quest_subtitle: "Optional: the deep gem ore."
	quest.0B031070000000B4.title: "Deepslate Gem Vein"
	quest.0B031070000000B5.quest_desc: ["Cut a &bRuby&r from a &bgem vein&r. It is one of the three stones the rings and necklaces are set with, each lending a different bonus to the wearer."]
	quest.0B031070000000B5.quest_subtitle: "Optional: cut the red stone."
	quest.0B031070000000B5.title: "Ruby"
	quest.0B031070000000B6.quest_desc: ["Cut a &bSapphire&r. Like the &bruby&r it slots into Jewelry's wearables. A mix of stones lets you tune the bonuses you carry."]
	quest.0B031070000000B6.quest_subtitle: "Optional: the blue stone."
	quest.0B031070000000B6.title: "Sapphire"
	quest.0B031070000000B7.quest_desc: ["Cut a &bTanzanite&r. It is the third of the gemstones, rounding out the set the better jewelry recipes draw on."]
	quest.0B031070000000B7.quest_subtitle: "Optional: the violet stone."
	quest.0B031070000000B7.title: "Tanzanite"
	quest.0B031070000000B8.quest_desc: ["Forge a &bGold Ring&r at the kit. Set with one of your cut stones it becomes a wearable that grants a passive effect, the first real piece of jewelry."]
	quest.0B031070000000B8.quest_subtitle: "Optional: set a gem in gold."
	quest.0B031070000000B8.title: "Gold Ring"
	quest.0B031070000000B9.quest_desc: ["Craft a &bDiamond Ring&r. The sturdier band holds its gem's bonus more strongly than gold, a step up for anyone leaning on jewelry effects."]
	quest.0B031070000000B9.quest_subtitle: "Optional: a stronger band."
	quest.0B031070000000B9.title: "Diamond Ring"
	quest.0B031070000000BA.quest_desc: ["Assemble an &bEmerald Necklace&r. It is the high end of the Jewelry line, the kind of piece worth the trip through every gem and ring before it."]
	quest.0B031070000000BA.quest_subtitle: "Optional: the showpiece."
	quest.0B031070000000BA.title: "Emerald Necklace"
	quest.0B031070000000BB.quest_desc: ["Build a &6Farmer's Delight&r &bStove&r. It pan-fries food without a crafting grid and fits the kitchen corner of any well-kept base, a small comfort beside the archive."]
	quest.0B031070000000BB.quest_subtitle: "Optional: cook off the wall."
	quest.0B031070000000BB.title: "Stove"
	quest.0B031070000000BC.quest_desc: ["Add a &bMagnet Upgrade&r to a storage block. It draws nearby items straight into the container, handy under a mob farm or beside a harvest dump."]
	quest.0B031070000000BC.quest_subtitle: "Optional: pull drops into storage."
	quest.0B031070000000BC.title: "Magnet Upgrade"
	quest.0B031070000000BD.quest_desc: ["Install a &bStack Upgrade&r. It multiplies how much each slot in a storage block can hold, the cleanest way to fight clutter without building outward."]
	quest.0B031070000000BD.quest_subtitle: "Optional: pack slots deeper."
	quest.0B031070000000BD.title: "Stack Upgrade I"
	quest.0B031070000000BE.quest_desc: ["Add a second-tier &bStack Upgrade&r. It pushes slot capacity higher again, for the bulk materials you produce by the thousand."]
	quest.0B031070000000BE.quest_subtitle: "Optional: deeper still."
	quest.0B031070000000BE.title: "Stack Upgrade II"
	quest.0B031070000000BF.quest_desc: ["Apply a Basic to Gold Tier Upgrade. It promotes a wooden storage block two tiers in one step, more slots without the iron stop in between."]
	quest.0B031070000000BF.quest_subtitle: "Optional: jump straight to gold."
	quest.0B031070000000BF.title: "Basic to Gold Upgrade"
	quest.0B03108000000001.quest_desc: [
		"The &dRenaissance&r begins with a change of habit: look closely, then test. This chapter is a workbench for the early sciences, from ore divination and alchemy to your first powered machines."
		"Little of it is ordered. Follow the branches that interest you and circle back for the rest."
	]
	quest.0B03108000000001.quest_subtitle: "The Renaissance opens on the bench."
	quest.0B03108000000001.title: "Observation and Experimentation"
	quest.0B03108000000068.quest_desc: [
		"Distill an &bAlchemical Niter&r keyed to the common metals. Each niter carries the signature of the source class it was drawn from, this one standing in for iron, &bcopper&r, and the everyday ores."
		"Niters are how &6Theurgy&r stores what a material is for later work."
	]
	quest.0B03108000000068.quest_subtitle: "Bottle the essence of base ores."
	quest.0B03108000000068.title: "Niter: Common Metals"
	quest.0B03108000000069.quest_desc: ["Draw a niter from the common gems. Lapis, quartz, and their kin all read as the same source class. A single batch covers the lot."]
	quest.0B03108000000069.quest_subtitle: "Distill from the gemstone class."
	quest.0B03108000000069.title: "Niter: Common Gems"
	quest.0B03108000000070.quest_desc: ["Produce a niter for the other minerals, the catch-all class for the stone-bound materials that are neither metal nor gem. Redstone and its neighbors live here."]
	quest.0B03108000000070.quest_subtitle: "The leftover mineral class."
	quest.0B03108000000070.title: "Niter: Other Minerals"
	quest.0B03108000000071.quest_desc: ["Render a niter from the crops. Wheat, carrots, and the rest of the farmed plants all feed this one, and they are abundant enough that the reagent is cheap to keep stocked."]
	quest.0B03108000000071.quest_subtitle: "Distill the harvest."
	quest.0B03108000000071.title: "Niter: Crops"
	quest.0B03108000000072.quest_desc: ["Pull a niter from the logs. Any wood will do, which makes this the easiest of the set to mass-produce when you need reagent in bulk."]
	quest.0B03108000000072.quest_subtitle: "The forest, distilled."
	quest.0B03108000000072.title: "Niter: Logs"
	quest.0B03108000000073.quest_desc: ["Distill a niter from monster drops. The hostile mobs you cut down on a normal night supply the source material. This one rewards the fighting you were doing anyway."]
	quest.0B03108000000073.quest_subtitle: "Essence from the hostile dead."
	quest.0B03108000000073.title: "Niter: Mobs"
	quest.0B03108000000074.quest_desc: ["Render a niter from the passive animals. Leather, feathers, and the rest of the farmyard drops feed it, rounding out the niter classes."]
	quest.0B03108000000074.quest_subtitle: "Essence from the herd."
	quest.0B03108000000074.title: "Niter: Animals"
	quest.0B03108000000075.quest_desc: [
		"Where niters cover a whole class, &bAlchemical Sulfur&r captures one specific material. Start with &bcopper&r sulfur, drawn straight from the ore."
		"Sulfurs are the precise reagents the higher alchemy recipes call for by name."
	]
	quest.0B03108000000075.quest_subtitle: "Distill a single material."
	quest.0B03108000000075.title: "Sulfur: Copper"
	quest.0B03108000000076.quest_desc: ["Distill a gold sulfur. Like every sulfur it answers to exactly one material, which is what makes it useful when a recipe wants gold and nothing else."]
	quest.0B03108000000076.quest_subtitle: "Bottle the gold itself."
	quest.0B03108000000076.title: "Sulfur: Gold"
	quest.0B03108000000077.quest_desc: ["Render a lapis sulfur. It is a common reagent in the enchanting-adjacent recipes, so a small stock pays off later."]
	quest.0B03108000000077.quest_subtitle: "The blue stone, rendered."
	quest.0B03108000000077.title: "Sulfur: Lapis"
	quest.0B03108000000078.quest_desc: ["Pull an amethyst sulfur from raw amethyst. The crystal sees a lot of use across the pack, and the sulfur form lets &6Theurgy&r work it into alchemy."]
	quest.0B03108000000078.quest_subtitle: "Distill the geode crystal."
	quest.0B03108000000078.title: "Sulfur: Amethyst"
	quest.0B0310800000007D.quest_desc: ["Distill an echo sulfur from echo shards. It means a trip to an ancient city to gather the source, but it opens the deep-sourced end of the sulfur list."]
	quest.0B0310800000007D.quest_subtitle: "Distilled from the deep dark."
	quest.0B0310800000007D.title: "Sulfur: Echo"
	quest.0B031080000000B0.quest_desc: [
		"Upgrade your way to the &bNetherite Divination Rod&r. It is the longest-range, most durable rod &6Theurgy&r offers, and it shrugs off the lava you will be wading through to use it."
		"Worth it if you lean on divination to find ore at all."
	]
	quest.0B031080000000B0.quest_subtitle: "Highest-tier divination rod."
	quest.0B031080000000B0.title: "Netherite Divination Rod"
	quest.0B031080000000B1.quest_desc: [
		"Craft a &bDivination Rod&r attuned to abundant materials. A sulfur-attuned rod points at one specific block type instead of a broad category, so it finds exactly what you tuned it for."
		"This tier covers the common, easy-to-reach materials."
	]
	quest.0B031080000000B1.quest_subtitle: "Abundant-material attunement."
	quest.0B031080000000B1.title: "Attuned Rod: Abundant"
	quest.0B031080000000B2.quest_desc: ["Attune a rod to the common materials. It trades a little reach for tighter focus than the abundant tier, useful once the surface ore is mined out."]
	quest.0B031080000000B2.quest_subtitle: "Common-material attunement."
	quest.0B031080000000B2.title: "Attuned Rod: Common"
	quest.0B031080000000B3.quest_desc: ["Attune a rod to the rare materials. This is the one you carry when you are chasing the ores that do not turn up by accident."]
	quest.0B031080000000B3.quest_subtitle: "Rare-material attunement."
	quest.0B031080000000B3.title: "Attuned Rod: Rare"
	quest.0B031080000000B4.quest_desc: ["Attune a rod to the precious materials, the scarcest tier the system tracks. Pair it with the netherite rod for the best odds of finding the hard-to-reach veins."]
	quest.0B031080000000B4.quest_subtitle: "Precious-material attunement."
	quest.0B031080000000B4.title: "Attuned Rod: Precious"
	quest.0B031080000000B5.quest_desc: ["Distill a niter from the rare metals. These are the source ores you do not trip over, so the reagent is worth more per batch than the common version."]
	quest.0B031080000000B5.quest_subtitle: "Rare-metal niter reagent."
	quest.0B031080000000B5.title: "Niter: Rare Metals"
	quest.0B031080000000B6.quest_desc: ["Render a niter from the rare gems. Diamond and emerald lead the class, so the reagent is as expensive as the stones that make it."]
	quest.0B031080000000B6.quest_subtitle: "Rare-gem niter reagent."
	quest.0B031080000000B6.title: "Niter: Rare Gems"
	quest.0B031080000000B7.quest_desc: ["Produce a niter from the rare minerals, the harder-to-find members of the other-minerals class."]
	quest.0B031080000000B7.quest_subtitle: "Rare-mineral niter reagent."
	quest.0B031080000000B7.title: "Niter: Rare Minerals"
	quest.0B031080000000B8.quest_desc: ["Distill a niter from the rarer animal drops. The unusual creatures feed this one, so it takes a wider hunt than the common version."]
	quest.0B031080000000B8.quest_subtitle: "Rare-animal niter reagent."
	quest.0B031080000000B8.title: "Niter: Rare Animals"
	quest.0B031080000000B9.quest_desc: ["Render a niter from the rarer monster drops. The dangerous mobs supply it, which ties the reagent to the fights you pick deliberately."]
	quest.0B031080000000B9.quest_subtitle: "Rare-mob niter reagent."
	quest.0B031080000000B9.title: "Niter: Rare Mobs"
	quest.0B031080000000BB.quest_desc: ["Pull a lunar sulfur. Its source is tied to the night side of the world, an oddity in the sulfur list and a reagent the stranger recipes ask for."]
	quest.0B031080000000BB.quest_subtitle: "Lunar sulfur reagent."
	quest.0B031080000000BB.title: "Sulfur: Lunar"
	quest.0B031080000000BC.quest_desc: ["Distill a deepslate sulfur. It captures the deep stone itself, useful once your alchemy reaches the recipes that want the world's lower layers."]
	quest.0B031080000000BC.quest_subtitle: "Deepslate sulfur reagent."
	quest.0B031080000000BC.title: "Sulfur: Deepslate"
	quest.0B031080000000C0.quest_desc: ["Mine &bBlack Quartz&r. It is the foundation material for &6Actually Additions&r, the early-tech toolbox this chapter samples. Most of its machines trace back to this stone."]
	quest.0B031080000000C0.quest_subtitle: "Actually Additions base material."
	quest.0B031080000000C0.title: "Black Quartz"
	quest.0B031080000000C1.quest_desc: ["Grow a &bLight Blue Crystal Shard&r. &6Actually Additions&r raises its crystals from seeds rather than mining them, and the shards cluster into the larger crystals its machines use."]
	quest.0B031080000000C1.quest_subtitle: "Grown crystal shard."
	quest.0B031080000000C1.title: "Light Blue Crystal Shard"
	quest.0B031080000000D1.quest_desc: [
		"Produce &bSteel Dust&r through &6Modern Industrialization&r. Grinding to dust before smelting is the mod's habit, and steel is the first proper alloy on its ladder."
		"It feeds the bronze and &bsteel&r parts the rest of this chapter leans on."
	]
	quest.0B031080000000D1.quest_subtitle: "Grind toward real alloys."
	quest.0B031080000000D1.title: "Steel Dust"
	quest.0B031080000000D2.quest_desc: [
		"Steam power is taught in full over in &5Onwards To Steam&r. Build the &bSteam Engine&r there and this node clears itself, tying your alchemical studies to the workshop's new boiler."
		"Mounted on a steam-filled &bboiler&r the engine spins a respectable amount of rotation, a quick way to power a workshop without a field of water wheels."
	]
	quest.0B031080000000D2.quest_subtitle: "Steam theory, cross-referenced."
	quest.0B031080000000D2.title: "Steam Engine"
	quest.0B031080000000D3.quest_desc: ["Make a &bNugget of Experience&r. &6Create&r lets you press experience into a solid nugget, which stores and moves far more cleanly than chasing orbs around the floor."]
	quest.0B031080000000D3.quest_subtitle: "Compact experience storage."
	quest.0B031080000000D3.title: "Nugget of Experience"
	quest.0B031080000000D4.quest_desc: [
		"Craft an &bIron Furnace&r. It smelts faster than the vanilla furnace and burns fuel more efficiently. The first step of an upgrade ladder that climbs through better metals."
		"A simple, worthwhile early swap for any smelting you do by hand."
	]
	quest.0B031080000000D4.quest_subtitle: "A faster, hungrier furnace."
	quest.0B031080000000D4.title: "Iron Furnace"
	quest.0B031080000000E1.quest_desc: ["Roll a &bBronze Plate&r through &6Modern Industrialization&r. Plates are pressed from ingots and form the flat stock half its early machines are assembled from."]
	quest.0B031080000000E1.quest_subtitle: "Press your first alloy part."
	quest.0B031080000000E1.title: "Bronze Plate"
	quest.0B031080000000E2.quest_desc: ["Craft a &bBronze Gear&r. Between plates and gears you have the two staple parts &6Modern Industrialization&r's steam-tier machines are built around. Make a stack of each."]
	quest.0B031080000000E2.quest_subtitle: "The other half of every machine."
	quest.0B031080000000E2.title: "Bronze Gear"
	quest.0B031080000000F2.quest_desc: [
		"Fire Blast Bricks for &6Immersive Engineering&r's &bImproved Blast Furnace&r. That multiblock smelts iron and coke into &bsteel&r, the metal the whole industrial spine is going to run on."
		"Having the Blast Bricks completes Observation and Experimentation."
	]
	quest.0B031080000000F2.quest_subtitle: "Cap the lab with blast brick."
	quest.0B031080000000F2.title: "Blast Brick"
	quest.0B031080000000F3.quest_desc: ["Craft an &bIron Casing&r. It is the shared housing nearly every &6Actually Additions&r machine is built inside. A stack of them unlocks most of that mod at once."]
	quest.0B031080000000F3.quest_subtitle: "Actually Additions' machine frame."
	quest.0B031080000000F3.title: "Iron Casing"
	quest.0B031080000000F4.quest_desc: ["Wind a &bBasic Coil&r. It is the wiring component &6Actually Additions&r uses to move and shape power, and several of its mid-tier devices will not assemble without one."]
	quest.0B031080000000F4.quest_subtitle: "Actually Additions coil part."
	quest.0B031080000000F4.title: "Basic Coil"
	quest.0B031080000000F6.quest_desc: ["Make a &bLens&r. Slotted into the &bAtomic Reconstructor&r it changes what the machine's beam does, turning a single device into a whole table of conversions."]
	quest.0B031080000000F6.quest_subtitle: "Atomic Reconstructor focus."
	quest.0B031080000000F6.title: "Lens"
	quest.0B031080000000F7.quest_desc: ["Cluster shards into a &bDiamatine Crystal&r. It is one of &6Actually Additions&r' two high-grade crystals, standing in where a recipe would otherwise want diamond."]
	quest.0B031080000000F7.quest_subtitle: "Diamatine crystal craft."
	quest.0B031080000000F7.title: "Diamatine Crystal"
	quest.0B031080000000F8.quest_desc: ["Grow an &bEmeradic Crystal&r. The emerald-grade counterpart to diamatine, it covers the recipes that lean on the green gem instead."]
	quest.0B031080000000F8.quest_subtitle: "Emeradic crystal craft."
	quest.0B031080000000F8.title: "Emeradic Crystal"
	quest.0B031080000000F9.quest_desc: ["Build a &bCoffee Maker&r. Fed beans and the right extras it brews coffee that hands you timed buffs, a small quality-of-life win from &6Actually Additions&r."]
	quest.0B031080000000F9.quest_subtitle: "Actually Additions brewing."
	quest.0B031080000000F9.title: "Coffee Maker"
	quest.0B031080000000FA.quest_desc: [
		"Build a &bGold Generator&r from &6Generator Galore&r. It burns fuel for a steady trickle of energy, the no-fuss starter for machines that want power rather than rotation."
		"Several swappable generator types share the same pattern."
	]
	quest.0B031080000000FA.quest_subtitle: "Burn gold for power."
	quest.0B031080000000FA.title: "Gold Generator"
	quest.0B031080000000FB.quest_desc: ["Build a &bCopper Generator&r. It is the budget end of the &6Generator Galore&r line, fine for keeping one or two machines fed while you scale up."]
	quest.0B031080000000FB.quest_subtitle: "Copper-tier generator."
	quest.0B031080000000FB.title: "Copper Generator"
	quest.0B031080000000FC.quest_desc: ["Build an &bIron Generator&r. It outputs more than the &bcopper&r unit and accepts an upgrade, the middle rung of the burner ladder."]
	quest.0B031080000000FC.quest_subtitle: "Iron-tier generator."
	quest.0B031080000000FC.title: "Iron Generator"
	quest.0B031080000000FD.quest_desc: ["Craft the &bIron to Gold Upgrade&r. Applied to an &biron generator&r it lifts the unit to gold-tier output without rebuilding from scratch."]
	quest.0B031080000000FD.quest_subtitle: "Generator tier upgrade."
	quest.0B031080000000FD.title: "Iron to Gold Upgrade"
	quest.0B031080000000FE.quest_desc: ["Build a &bCulinary Generator&r. It runs on food instead of fuel, which turns a surplus harvest into electricity and pairs neatly with a busy farm."]
	quest.0B031080000000FE.quest_subtitle: "Food-powered generator."
	quest.0B031080000000FE.title: "Culinary Generator"
	quest.0B031080000000FF.quest_desc: ["Build a &bPotion Generator&r. It draws energy from potions, giving your brewing stand a second purpose once you have more potions than you can drink."]
	quest.0B031080000000FF.quest_subtitle: "Potion-powered generator."
	quest.0B031080000000FF.title: "Potion Generator"
	quest.0B03108000000100.quest_desc: [
		"Craft a &bDiamond Wand&r from &6Construction Wand&r. It extends a row or face of matching blocks in one click, which turns tedious wall-and-floor work into a single motion."
		"The diamond tier reaches furthest of the basic wands."
	]
	quest.0B03108000000100.quest_subtitle: "Bulk block placement tool."
	quest.0B03108000000100.title: "Diamond Wand"
	quest.0B03108000000101.quest_desc: ["Make the &bAngel Wand Core&r. Fitted to a wand it lets you place blocks out into empty space with no anchor to start from, a real help for bridges and platforms."]
	quest.0B03108000000101.quest_subtitle: "Open-air placement core."
	quest.0B03108000000101.title: "Angel Wand Core"
	quest.0B03108000000102.quest_desc: [
		"Add a &bPickup Upgrade&r to a &6Sophisticated Backpack&r. It funnels matching drops straight into the pack as you collect them. Your inventory stops filling with clutter."
		"More &bbackpack&r upgrades follow in this branch."
	]
	quest.0B03108000000102.quest_subtitle: "Backpack pickup automation."
	quest.0B03108000000102.title: "Pickup Upgrade"
	quest.0B03108000000103.quest_desc: ["Install a &bMagnet Upgrade&r. It draws nearby drops and experience toward you, which pairs well with the &bpickup upgrade&r for hands-off gathering."]
	quest.0B03108000000103.quest_subtitle: "Backpack magnet upgrade."
	quest.0B03108000000103.title: "Magnet Upgrade"
	quest.0B03108000000104.quest_desc: ["Add a &bDeposit Upgrade&r. Standing near a chest it offloads matching items from the pack automatically, cutting the busywork of restocking storage."]
	quest.0B03108000000104.quest_subtitle: "Backpack deposit automation."
	quest.0B03108000000104.title: "Deposit Upgrade"
	quest.0B03108000000105.quest_desc: ["Install a &bRefill Upgrade&r. It tops your hotbar stacks back up from the pack as they run low. Torches and blocks never quietly run out mid-task."]
	quest.0B03108000000105.quest_subtitle: "Hotbar refill upgrade."
	quest.0B03108000000105.title: "Refill Upgrade"
	quest.0B03108000000106.quest_desc: ["Add a &bRestock Upgrade&r. It pulls items into the pack from adjacent storage, the inbound counterpart to the &bdeposit upgrade&r."]
	quest.0B03108000000106.quest_subtitle: "Storage restock upgrade."
	quest.0B03108000000106.title: "Restock Upgrade"
	quest.0B03108000000107.quest_desc: ["Install a &bFeeding Upgrade&r. It feeds you from the pack whenever your hunger drops, which keeps you fighting and building without breaking to eat."]
	quest.0B03108000000107.quest_subtitle: "Automatic feeding upgrade."
	quest.0B03108000000107.title: "Feeding Upgrade"
	quest.0B03108000000110.quest_desc: [
		"Press a &bCircuit Plate&r. It is the foundation piece &6ProjectRed&r builds its logic gates and wiring from, the start of a compact redstone toolkit."
		"This branch is for anyone who wants real circuits without the bulk of vanilla redstone."
	]
	quest.0B03108000000110.quest_subtitle: "ProjectRed circuit base."
	quest.0B03108000000110.title: "Circuit Plate"
	quest.0B03108000000111.quest_desc: ["Make &bRed Iron Compound&r. Iron dusted with redstone, it is the intermediate that smelts down into &6ProjectRed&r's signature alloy."]
	quest.0B03108000000111.quest_subtitle: "Red alloy precursor."
	quest.0B03108000000111.title: "Red Iron Compound"
	quest.0B03108000000112.quest_desc: ["Smelt a &bRed Alloy Ingot&r. It carries a redstone charge through itself, which is what lets &6ProjectRed&r run wire and gates far more densely than dust on the ground."]
	quest.0B03108000000112.quest_subtitle: "Conductive alloy ingot."
	quest.0B03108000000112.title: "Red Alloy Ingot"
	quest.0B03108000000113.quest_desc: ["Lay &bRed Alloy Wire&r. It carries a signal like redstone dust but sits flat against walls and ceilings. Your circuits stop sprawling across the floor."]
	quest.0B03108000000113.quest_subtitle: "Compact redstone wire."
	quest.0B03108000000113.title: "Red Alloy Wire"
	quest.0B03108000000114.quest_desc: ["Craft a &bConductive Plate&r. It is a &bcircuit plate&r that carries current, a building block for the gates that come next."]
	quest.0B03108000000114.quest_subtitle: "Conductive circuit component."
	quest.0B03108000000114.title: "Conductive Plate"
	quest.0B03108000000115.quest_desc: ["Make an &bAnode&r. With the &bcathode&r it forms the terminal pair &6ProjectRed&r's powered components draw across. Both are required."]
	quest.0B03108000000115.quest_subtitle: "ProjectRed positive terminal."
	quest.0B03108000000115.title: "Anode"
	quest.0B03108000000116.quest_desc: ["Make a &bCathode&r. Paired with the &banode&r it completes the terminals the logic gates are wired between."]
	quest.0B03108000000116.quest_subtitle: "ProjectRed negative terminal."
	quest.0B03108000000116.title: "Cathode"
	quest.0B03108000000117.quest_desc: ["Assemble a &bNOT Gate&r. It flips a signal on to off and back, the simplest logic tile in your circuit kit."]
	quest.0B03108000000117.quest_subtitle: "Signal-inverting logic gate."
	quest.0B03108000000117.title: "NOT Gate"
	quest.0B03108000000118.quest_desc: ["Build a &bTimer&r gate. It fires a signal on a set interval, the clock that drives any automation you want running on its own schedule."]
	quest.0B03108000000118.quest_subtitle: "Interval signal gate."
	quest.0B03108000000118.title: "Timer"
	quest.0B03108000000119.quest_desc: ["Craft a &bRed Lantern&r. It is a colored light &6ProjectRed&r can wire into a circuit, so a redstone signal turns whole rooms on and off."]
	quest.0B03108000000119.quest_subtitle: "Redstone-controlled light."
	quest.0B03108000000119.title: "Red Lantern"
	quest.0B03108000000120.quest_desc: [
		"Craft the Hellshelf, the first custom enchanting shelf Apotheosis adds beyond vanilla's bookshelves."
		"Vanilla caps an enchanting table at fifteen shelves. Apotheosis shelves push past that by adding Eterna, Quanta, and Arcana, three stats that decide how high your enchant levels go, how random the results are, and how many rare enchants can appear. The Hellshelf is a strong Eterna source built from nether materials."
		"Ring your enchanting table with these shelves to raise its power. This node opens the Apotheosis enchanting line, which climbs through stronger shelves toward bulk enchantment storage."
	]
	quest.0B03108000000120.quest_subtitle: "The first Apotheosis enchanting shelf"
	quest.0B03108000000120.title: "Eterna Bookshelves"
	quest.0B03108000000121.quest_desc: [
		"Craft the Infused Hellshelf, the upgraded form of the Hellshelf that pushes Eterna even higher."
		"Swapping infused shelves in for plain ones raises the ceiling on your enchant levels, letting the table reach enchantments a weaker setup cannot. Balance it against your Quanta and Arcana shelves so results stay controlled."
		"Next you branch into the biome-themed shelf families, each of which tunes the enchanting stats differently."
	]
	quest.0B03108000000121.quest_subtitle: "The eterna upgrade tier"
	quest.0B03108000000121.title: "Infused Hellshelf"
	quest.0B03108000000122.quest_desc: [
		"Craft one of the biome shelf families. This quest accepts the sea shelf, deep shelf, or end shelf, so build whichever materials you have on hand."
		"Each family leans on a different stat balance. Some favor Eterna for raw power, others favor Quanta or Arcana for stronger and rarer rolls. Mixing families around one table lets you shape exactly what the table produces."
		"With a varied shelf wall built, you are ready to store enchantments in bulk at the Enchantment Library."
	]
	quest.0B03108000000122.quest_subtitle: "Sea, deep, and end shelves"
	quest.0B03108000000122.title: "Biome Shelf Families"
	quest.0B03108000000123.quest_desc: [
		"Craft the Enchantment Library. This block stores enchantments as levels and lets you deposit them from books or withdraw them onto new gear."
		"Instead of hoarding shelves of enchanted books, you feed books into the library and it banks their enchantments. Later you pull an exact enchantment back out onto whatever item you want to improve."
		"The library turns enchanting from a gamble into a stockpile. The optional nodes below add extraction tomes and a far larger archive on top of it."
	]
	quest.0B03108000000123.quest_subtitle: "Bulk enchantment storage"
	quest.0B03108000000123.title: "The Enchantment Library"
	quest.0B03108000000124.quest_desc: [
		"Optional. Craft one of the Apotheosis enchantment tomes. This quest accepts the full family, from the per-slot weapon and armor tomes to the extraction and scrap tomes."
		"Tomes let you pull an enchantment off a piece of gear and hold it, or scrap unwanted enchants for materials. This is how you move a good enchantment from an old tool onto a new one without losing it."
		"Combined with the library, tomes give you full control over where your enchantments live. Take the tomes that match the gear you actually use."
	]
	quest.0B03108000000124.quest_subtitle: "Extract and re-apply enchantments"
	quest.0B03108000000124.title: "Enchantment Tomes"
	quest.0B03108000000125.quest_desc: [
		"Optional. Craft the Ender Library, the high-capacity archive that stores far more enchantment levels than the basic library."
		"Where the basic library holds a working stock, the Ender Library is built to bank everything. If you enchant heavily and want one central vault for every enchantment you have collected, this is the block for it."
		"This is the capstone of the Apotheosis enchanting line. It is optional depth for players who lean hard on enchanting, so skip it if the basic library already covers your needs."
	]
	quest.0B03108000000125.quest_subtitle: "The capstone enchantment archive"
	quest.0B03108000000125.title: "Library of Alexandria"
	quest.0B03109000000001.quest_desc: [
		"Reaching the End takes more than one ender pearl run. &6End Remastered&r replaces the twelve-eye portal with twelve distinct eyes, and this pack changes how you get them. Do not go raiding desert temples and fortresses for eyes; every chest and mob drop the mod normally uses has been removed."
		"In this pack, ten of the twelve eyes are &bcrafted&r: two of a theme material stacked in a vertical column around one ender eye. The last two are the &bWitch Eye&r (crafted from a Witch Pupil) and the &bExotic Eye&r (an ocean craft). Each eye quest in this chapter tells you its exact recipe."
		"Gather the eyes, find the &bstronghold&r, and face what guards the End. The Elder Guardian still drops a &bGuardian Eye&r if you need a spare frame filler."
	]
	quest.0B03109000000001.quest_subtitle: "Open the way to the End."
	quest.0B03109000000001.title: "End Threshold"
	quest.0B03109000000010.quest_desc: [
		"Craft the &bMagical Eye&r. In this pack it does not come from Evokers or mansion chests; you make it at a crafting table with two &bAmethyst Shards&r stacked vertically around one &bEye of Ender&r: shard on top, ender eye in the middle, shard on the bottom."
		"Every eye in this chapter follows the same column pattern with a different theme material. The portal wants the full set of twelve."
	]
	quest.0B03109000000010.quest_subtitle: "First End portal eye."
	quest.0B03109000000010.title: "Magical Eye"
	quest.0B03109000000011.quest_desc: [
		"Craft the &bNether Eye&r, &bCorrupted Eye&r, and &bCursed Eye&r. Each uses the same vertical column: two theme items around one &bEye of Ender&r. Nether Eye takes two &bBlaze Powder&r, Corrupted Eye takes two &bSculk&r blocks, and Cursed Eye takes two &bMagma Cream&r."
		"None of these drop from chests or mobs in this pack. If you ever lose one, craft it again the same way."
	]
	quest.0B03109000000011.quest_subtitle: "Nether, Corrupted, and Cursed."
	quest.0B03109000000011.title: "Three More Eyes"
	quest.0B03109000000012.quest_desc: [
		"Craft the remaining six column eyes, each from two theme items around one &bEye of Ender&r: &bCold Eye&r from &bBlue Ice&r, &bLost Eye&r from &bEcho Shards&r, &bUndead Eye&r from &bRotten Flesh&r, &bOld Eye&r from &bBone Blocks&r, &bBlack Eye&r from &bInk Sacs&r, and &bRogue Eye&r from &bEmeralds&r."
		"The Evil and Cryptic Eyes are disabled in this pack, so do not hunt for them. With these six plus the earlier four and the Witch and Exotic Eyes, you hold all twelve keys the portal demands."
	]
	quest.0B03109000000012.quest_subtitle: "Assemble every key."
	quest.0B03109000000012.title: "The Full Set of Eyes"
	quest.0B03109000000020.quest_desc: [
		"Track down a &bStronghold&r and its portal room. The frame is built but dormant, waiting for its eyes. Confirm the location before you commit to the full set."
		"Vanilla eyes cannot be thrown in this pack; throw one of your earned &6End Remastered&r eyes instead and follow where it drifts."
	]
	quest.0B03109000000020.quest_subtitle: "Locate the portal room."
	quest.0B03109000000020.title: "Find a Stronghold"
	quest.0B03109000000022.quest_desc: [
		"Place every eye in the frame and drop into the End. Bring blocks to bridge with, a bow, and something for the fall, because the landing island is ringed by void."
		"Setting foot on the central island is the milestone the whole chapter builds toward."
	]
	quest.0B03109000000022.quest_subtitle: "Seat the eyes and step through."
	quest.0B03109000000022.title: "Into the End"
	quest.0B03109000000023.quest_desc: [
		"Fight the &c&lEnder Dragon&r on its home island. Shoot out the healing crystals on the obsidian pillars first, then work it down with beds detonated at point-blank or a strong melee weapon when it perches."
		"Its fall opens the outer islands, the End cities, and elytra, and unlocks the End mods this chapter is wrapped around. Mind the void the entire fight."
	]
	quest.0B03109000000023.quest_subtitle: "Bring it down."
	quest.0B03109000000023.title: "The Ender Dragon"
	quest.0B03109000000040.quest_desc: ["Recover an &bAncient Shard&r. It is a core material of &6Unusual End&r, the mod that fills the outer islands with new life, and several of its recipes start here."]
	quest.0B03109000000040.quest_subtitle: "Unusual End's keystone."
	quest.0B03109000000040.title: "Ancient Shard"
	quest.0B03109000000042.quest_desc: ["Craft a &bPrismalite Gem&r. It is one of &6Unusual End&r's signature crystals, refined from shards into the form its gear and blocks call for."]
	quest.0B03109000000042.quest_subtitle: "A worked End crystal."
	quest.0B03109000000042.title: "Prismalite Gem"
	quest.0B03109000000050.quest_desc: ["Collect &bEnd Blob Jelly&r. Ender Blobs drop the raw blob, and a furnace renders that into jelly, a soft reagent for &6Unusual End&r's stranger recipes."]
	quest.0B03109000000050.quest_subtitle: "Optional: a slime of the void."
	quest.0B03109000000050.title: "End Blob Jelly"
	quest.0B03109000000051.quest_desc: ["Take a &bBolok Scale&r. It comes off one of the End's new beasts, a crafting material for &6Unusual End&r's armor and tools."]
	quest.0B03109000000051.quest_subtitle: "Optional: a hunted hide."
	quest.0B03109000000051.title: "Bolok Scale"
	quest.0B03109000000052.quest_desc: ["Scoop a &bBucket of Bluk&r. The bluk is a small creature of the Warped Reef, caught live in a bucket the way you would scoop a cod, for the handful of &6Unusual End&r recipes that ask for one."]
	quest.0B03109000000052.quest_subtitle: "Optional: a creature in a bucket."
	quest.0B03109000000052.title: "Bucket of Bluk"
	quest.0B03109000000060.quest_desc: [
		"Return to the overworld from the End. The quest checks that you made the crossing back after the dragon fight and island work."
		"Completing it marks &bThe End Threshold&r done and counts toward the Renaissance gates."
	]
	quest.0B03109000000060.quest_subtitle: "Return to the overworld."
	quest.0B03109000000060.title: "Back to the Overworld"
	quest.0B03109000000074.quest_desc: ["Grind &bEnder Dust&r. &6Better End&r reworks the dimension's flora and stone, and this dust is one of its common reagents, the start of that mod's material chain."]
	quest.0B03109000000074.quest_subtitle: "Optional: Better End's grit."
	quest.0B03109000000074.title: "Ender Dust"
	quest.0B03109000000078.quest_desc: ["Gather &bSpectral Scrap&r from &6Unusual End&r's enderlings. It is a salvage material the mod's recipes draw on, picked off the wispier residents of the islands."]
	quest.0B03109000000078.quest_subtitle: "Optional: a ghostly drop."
	quest.0B03109000000078.title: "Spectral Scrap"
	quest.0B03109000000080.quest_desc: ["Craft the &bExotic Eye&r. This one keeps its normal &6End Remastered&r recipe: one &bEye of Ender&r surrounded by four live corals (bubble, fire, horn, and tube), two &bConduits&r, and two &bGlow Ink Sacs&r. It is one of the twelve eyes this portal set counts, so the ocean trip is not optional."]
	quest.0B03109000000080.quest_subtitle: "The ocean's portal eye."
	quest.0B03109000000080.title: "Exotic Eye"
	quest.0B03109000000081.quest_desc: ["Craft the &bWitch Eye&r, the twelfth key of the set. Witches have a small chance to drop a &bWitch Pupil&r on death; combine that pupil with one &bEye of Ender&r in any crafting grid. Expect to hunt a few witches before the pupil drops, so start this one early."]
	quest.0B03109000000081.quest_subtitle: "A pupil pried from a witch."
	quest.0B03109000000081.title: "Witch Eye"
	quest.0B03109000000090.quest_desc: [
		"Craft a &bPrismatic Mirror&r. It is one of &6Unusual End&r's highest trinkets, built from pearlescent alloy and the End's rarest materials."
		"Getting here means you have worked the pearlescent tier through."
	]
	quest.0B03109000000090.quest_subtitle: "Pearlescent mirror craft."
	quest.0B03109000000090.title: "Prismatic Mirror"
	quest.0B03109000000091.quest_desc: ["Complete and charge your &bPrismatic Mirror&r. It is the capstone of the whole side-equipment chapter."]
	quest.0B03109000000091.quest_subtitle: "Charged prismatic mirror."
	quest.0B03109000000091.title: "The Finished Mirror"
	quest.0B03109000000092.quest_desc: ["Collect a &bPrismalite Shard&r. It is the rough form the gem is cut from, gathered straight off the End's crystal growths."]
	quest.0B03109000000092.quest_subtitle: "Optional: the raw crystal."
	quest.0B03109000000092.title: "Prismalite Shard"
	quest.0B03109000000093.quest_desc: ["Find an &bAmber Gem&r. &6Better End&r grows amber in its forests, a gemstone its tools and decorative blocks are built around."]
	quest.0B03109000000093.quest_subtitle: "Optional: Better End's amber."
	quest.0B03109000000093.title: "Amber Gem"
	quest.0B03109000000094.quest_desc: ["Mine &bAurora Crystal Shards&r. They come from the glowing crystals of &6Better End&r's brighter biomes, a luminous material for its higher crafts."]
	quest.0B03109000000094.quest_subtitle: "Optional: shards of light."
	quest.0B03109000000094.title: "Aurora Crystal Shards"
	quest.0B03109000000095.quest_desc: ["Collect &bCrystalline Sulphur&r. &6Better End&r deposits it around the islands, a reagent distinct from the alchemy sulfurs you distill back home."]
	quest.0B03109000000095.quest_subtitle: "Optional: End-grown sulfur."
	quest.0B03109000000095.title: "Crystalline Sulphur"
	quest.0B03109000000096.quest_desc: ["Mine an &bEnder Shard&r from ender ore. Smashed on &6Better End&r's anvil it breaks down into &bender dust&r, the start of the dimension's alloying chain."]
	quest.0B03109000000096.quest_subtitle: "Optional: refined ender."
	quest.0B03109000000096.title: "Ender Shard"
	quest.0B03109000000097.quest_desc: ["Catch an &bEnd Fish&r. &6Better End&r stocks the islands' pools with their own fish, a fresh food source for long stays in the dimension."]
	quest.0B03109000000097.quest_subtitle: "Optional: fish the void pools."
	quest.0B03109000000097.title: "End Fish"
	quest.0B03109000000098.quest_desc: ["Cook your catch into &bCooked End Fish&r. Fired up it becomes a proper meal, far better eating than the raw fillet."]
	quest.0B03109000000098.quest_subtitle: "Optional: cook the catch."
	quest.0B03109000000098.title: "Cooked End Fish"
	quest.0B03109000000099.quest_desc: ["Pick a &bBlossom Berry&r from &6Better End&r's groves. It is an edible find that grows on the gentler islands, a sweet bite between fights."]
	quest.0B03109000000099.quest_subtitle: "Optional: forage the forests."
	quest.0B03109000000099.title: "Blossom Berry"
	quest.0B0310900000009A.quest_desc: ["Harvest a &bShadow Berry&r. It grows in &6Better End&r's darker biomes and can be planted to spread, the shadowy counterpart to the &bblossom berry&r."]
	quest.0B0310900000009A.quest_subtitle: "Optional: the dark fruit."
	quest.0B0310900000009A.title: "Shadow Berry"
	quest.0B0310900000009B.quest_desc: ["Fletch a &bPhantom Arrow&r. &6Unusual End&r's special ammunition carries an effect ordinary arrows lack, worth crafting before the harder island fights."]
	quest.0B0310900000009B.quest_subtitle: "Optional: ammunition with bite."
	quest.0B0310900000009B.title: "Phantom Arrow"
	quest.0B0310900000009C.quest_desc: ["Assemble a &bCitrine Amulet&r. Keep it in your offhand for a chance at bonus experience orbs, one of &6Unusual End&r's small charms."]
	quest.0B0310900000009C.quest_subtitle: "Optional: an offhand charm."
	quest.0B0310900000009C.title: "Citrine Amulet"
	quest.0B0310900000009D.quest_desc: ["Forge a &bTerminite Sword&r. Terminite is one of &6Better End&r's strong metals, and the blade is a real upgrade for clearing the tougher End mobs."]
	quest.0B0310900000009D.quest_subtitle: "Optional: Better End's blade."
	quest.0B0310900000009D.title: "Terminite Sword"
	quest.0B0310900000009E.quest_desc: ["Craft a &bTerminite Pickaxe&r. The same metal makes a fast, durable mining tool, handy for tearing through the dense End stone."]
	quest.0B0310900000009E.quest_subtitle: "Optional: the matching pick."
	quest.0B0310900000009E.title: "Terminite Pickaxe"
	quest.0B0310900000009F.quest_desc: ["Knock loose an &bEnderman Tooth&r. &6Enderman Overhaul&r gives the dimension's natives more variety and better drops, and the tooth is the entry to its materials."]
	quest.0B0310900000009F.quest_subtitle: "Optional: an Enderman Overhaul drop."
	quest.0B0310900000009F.title: "Enderman Tooth"
	quest.0B031090000000A0.quest_desc: ["Collect a &bSoul Pearl&r from &6Enderman Overhaul&r's variants. Each biome's endermen drop a different pearl, and this is the first of that set."]
	quest.0B031090000000A0.quest_subtitle: "Optional: a varied pearl."
	quest.0B031090000000A0.title: "Soul Pearl"
	quest.0B031090000000A1.quest_desc: ["Gather a &bCrimson Pearl&r. It comes from the crimson-forest endermen, another color in &6Enderman Overhaul&r's pearl collection."]
	quest.0B031090000000A1.quest_subtitle: "Optional: the crimson variant."
	quest.0B031090000000A1.title: "Crimson Pearl"
	quest.0B031090000000A2.quest_desc: ["Take a &bWarped Pearl&r. The warped-forest endermen supply it, a third pearl variant for the set."]
	quest.0B031090000000A2.quest_subtitle: "Optional: the warped variant."
	quest.0B031090000000A2.title: "Warped Pearl"
	quest.0B031090000000A3.quest_desc: ["Obtain a &bCorrupted Pearl&r. The End's own overhauled endermen drop it in place of the plain ender pearl, the last stop on the pearl run."]
	quest.0B031090000000A3.quest_subtitle: "Optional: the End's own pearl."
	quest.0B031090000000A3.title: "Corrupted Pearl"
	quest.0B031090000000B0.quest_desc: ["Explore the Warped Reef. It is one of &6Unusual End&r's new biomes, a coral-strewn stretch of the islands worth mapping for its unique gathers."]
	quest.0B031090000000B0.quest_subtitle: "Optional: an Unusual End biome."
	quest.0B031090000000B0.title: "Warped Reef"
	quest.0B031090000000B1.quest_desc: ["Find the Gloopstone Highlands. This &6Unusual End&r biome has its own stone and growths, home to gloopstone, ender blobs, and the shiny crystal blooms."]
	quest.0B031090000000B1.quest_subtitle: "Optional: another new biome."
	quest.0B031090000000B1.title: "Gloopstone Highlands"
	quest.0B031090000000B2.quest_desc: ["Mine a &bCitrine Chunk&r from the crystal isles of the Warped Reef. It is the raw gem the &bcitrine amulet&r and its kin are cut from."]
	quest.0B031090000000B2.quest_subtitle: "Optional: raw citrine."
	quest.0B031090000000B2.title: "Citrine Chunk"
	quest.0B031090000000B3.quest_desc: ["Collect a &bShiny Crystal&r. It is a decorative and crafting crystal from &6Unusual End&r, scattered across the brighter islands."]
	quest.0B031090000000B3.quest_subtitle: "Optional: a glittering find."
	quest.0B031090000000B3.title: "Shiny Crystal"
	quest.0B031090000000B4.quest_desc: ["Catch a &bWandering Pearl&r. Craft it from chorus fruit packed around an ender pearl, or take one from shulkers and End city loot, a pearl variant with its own use in the mod's recipes."]
	quest.0B031090000000B4.quest_subtitle: "Optional: a roaming drop."
	quest.0B031090000000B4.title: "Wandering Pearl"
	quest.0B0310A000000010.quest_desc: [
		"Track down a &bFrosted Prison&r, one of &6Cataclysm&r's cold vaults. It seals the &c&lMaledictus&r inside, behind a &bDoor of Seal&r that a &bStrange Key&r opens."
		"Work through it for cursed metals and the capstone drop that hands off the &dRenaissance&r."
	]
	quest.0B0310A000000010.quest_subtitle: "Find the sealed prison."
	quest.0B0310A000000010.title: "The Frosted Prison"
	quest.0B0310A000000011.quest_desc: [
		"Smelt a &bBlack Steel Ingot&r. It is &6Cataclysm&r's mid-tier metal, the material its weapons and the gear you will want against the &c&lMaledictus&r are forged from."
		"Make a stack before you wake what sleeps in the prison."
	]
	quest.0B0310A000000011.quest_subtitle: "Forge the cursed metal."
	quest.0B0310A000000011.title: "Black Steel Ingot"
	quest.0B0310A000000013.quest_desc: ["The &c&lMaledictus&r does not appear on its own, it must be summoned. Craft an &bEye of Curse&r from four gold ingots, two phantom membranes, a bone, a piece of rotten flesh, and an Eye of Ender. Use the eye on the &bCursed Tombstone&r at the boss chamber to raise the pharaoh. Keep the eye until you reach the tomb, it is spent on the summon."]
	quest.0B0310A000000013.quest_subtitle: "Craft the summon key."
	quest.0B0310A000000013.title: "Eye of Curse"
	quest.0B0310A000000014.quest_desc: [
		"Use your &bEye of Curse&r on the &bCursed Tombstone&r to raise the cursed pharaoh. It teleports, lays curses that twist your own attacks against you, and calls swarms to wear you down. Keep moving and deal with the adds fast."
		"Felling it records the boss proof, completes &bThe Maledictus Vigil&r, and marks that Renaissance chapter gate done."
	]
	quest.0B0310A000000014.quest_subtitle: "Break the pyramid's curse."
	quest.0B0310A000000014.title: "The Maledictus"
	quest.0B0310A000000031.quest_desc: [
		"Craft &bGoat Fur Pants&r once the main &dRenaissance&r gates are done. They unlock the frozen hunt branch."
		"&c&lFrostmaw&r biomes run cold. Cold Sweat will drain you without warm legs."
	]
	quest.0B0310A000000031.quest_subtitle: "Gear up for the cold hunt."
	quest.0B0310A000000031.title: "Goat Fur Pants"
	quest.0B0310A000000032.quest_desc: [
		"Forge a &bNaga Fang Dagger&r from a Naga's fang. Fast and venomous, it punishes slow, heavy beasts."
		"Bring it to the snow."
	]
	quest.0B0310A000000032.quest_subtitle: "A blade with reach."
	quest.0B0310A000000032.title: "Naga Fang Dagger"
	quest.0B0310A000000033.quest_desc: [
		"Travel to open snowy ground like &bSnowy Plains&r. &c&lFrostmaw&r dens avoid trees, so skip snowy taigas and forests; look across bare snowfields for a mound of ice with the beast asleep inside."
		"Keep your warm gear on the moment you arrive."
	]
	quest.0B0310A000000033.quest_subtitle: "Find Frostmaw's range."
	quest.0B0310A000000033.title: "Snowy Plains"
	quest.0B0310A000000041.quest_desc: [
		"Forge a &bBlack Steel Sword&r after the main &dRenaissance&r gates. It arms the nightmare hunt branch."
		"Bring it against the &6Born in Chaos&r bosses that follow."
	]
	quest.0B0310A000000041.quest_subtitle: "Arm for the nightmare hunt."
	quest.0B0310A000000041.title: "Black Steel Sword"
	quest.0B0310A000000051.quest_desc: ["Recover the &bmusic disc&r from &c&lMaledictus&r. Trophy drop from the pyramid fight."]
	quest.0B0310A000000051.quest_subtitle: "Optional: a boss's record."
	quest.0B0310A000000051.title: "Maledictus Disc"
	quest.0B0310A000000052.quest_desc: ["Claim the &bEye of Curse&r from &c&lMaledictus&r. &6Cataclysm&r relic with its own crafting uses."]
	quest.0B0310A000000052.quest_subtitle: "Optional: a cursed relic."
	quest.0B0310A000000052.title: "Eye of Curse"
	quest.0B0310A000000054.quest_desc: ["Take on the &c&lNight Lich&r, a &6Bosses of Mass Destruction&r fight. It hovers out of reach, teleports, and rains projectiles. Bring cover, a bow, and patience to close the gaps."]
	quest.0B0310A000000054.quest_subtitle: "Optional: the floating necromancer."
	quest.0B0310A000000054.title: "Night Lich"
	quest.0B0310A00000005A.quest_desc: ["Face &c&lLord Pumpkinhead&r, the grander cousin of the pumpkin knights. It hits harder and summons more than its lesser kin."]
	quest.0B0310A00000005A.quest_subtitle: "Optional: the harvest tyrant."
	quest.0B0310A00000005A.title: "Lord Pumpkinhead"
	quest.0B0310A00000005B.quest_desc: [
		"Battle &c&lHelvar, the Underworld Knight&r. The armored boss trades heavy, deliberate blows. Read its wind-ups, block or sidestep, and answer in the openings."
		"One of the sterner optional duels of the vigil."
	]
	quest.0B0310A00000005B.quest_subtitle: "Optional: the armored revenant."
	quest.0B0310A00000005B.title: "Helvar, the Underworld Knight"
	quest.0B0310A0000000F0.quest_desc: [
		"Keep the Cursium Ingot after Maledictus falls and all ten Renaissance chapter gates are done."
		"It unlocks the &6Industrial Revolution&r age and records the Renaissance seal subproof."
	]
	quest.0B0310A0000000F0.quest_subtitle: "Age capstone handoff."
	quest.0B0310A0000000F0.title: "Cursium Ingot"
	quest.0B0310C000000001.quest_desc: [
		"Craft the Pigment Palette. It is a wearable ink store: filled with ink, it supplies your Spectrum tools and trinkets while you work."
		"Spectrum runs on colored pigment and ink. Pigment is refined into ink at the Color Picker, and the palette holds a sizable reserve of that ink in a trinket slot."
		"Keep it topped up as you work through this chapter. The pedestals, the Pastel Network, and the Fusion Shrine all lie ahead."
	]
	quest.0B0310C000000001.quest_subtitle: "A wearable ink reserve"
	quest.0B0310C000000001.title: "Pigment Palette"
	quest.0B0310C000000002.quest_desc: [
		"Craft and place the Color Picker. Feed it pigment and it converts that pigment into ink."
		"Ink is what Spectrum's gear and stations actually spend, so the picker is your refinery. Keep it supplied and move the ink into your Pigment Palette and ink-hungry blocks."
		"Once ink is flowing, the crafting lanes of this chapter are open."
	]
	quest.0B0310C000000002.quest_subtitle: "Pigment in, ink out"
	quest.0B0310C000000002.title: "Color Picker"
	quest.0B0310C000000003.quest_desc: [
		"Build the Titration Barrel, Spectrum's fermentation vessel. It makes food and drink, not ink."
		"Load it with ingredients and a liquid, then seal it with a colored plank to start fermenting. Fermentation runs on real time, so set a batch going early and come back to tap it later."
		"From here the chapter branches. One lane builds crafting pedestals, and the other, starting at the Pastel Network nodes, routes items around your workshop automatically."
	]
	quest.0B0310C000000003.quest_subtitle: "Ferment food and drink"
	quest.0B0310C000000003.title: "Titration Barrel"
	quest.0B0310C000000010.quest_desc: [
		"Craft the CMY Pigment Pedestal, the icon of this chapter. The recipe runs inside a basic gem pedestal and takes an amethyst, citrine, and topaz shard."
		"The pedestal is Spectrum's crafting altar, and most of the mod's recipes run through one. Treat it as the heart of your Academy."
		"Upgrading to the CMY tier widens the recipe pool beyond what a single-gem pedestal can run."
	]
	quest.0B0310C000000010.quest_subtitle: "The all-basic crafting altar"
	quest.0B0310C000000010.title: "Pigment Pedestal"
	quest.0B0310C000000011.quest_desc: [
		"Build any one of the basic Pigment Pedestals. This quest accepts the amethyst, citrine, or topaz variant, so pick the gem you have easiest access to."
		"These gem pedestals are Spectrum's starter altars. There is no plainer pedestal below them; the crafting ladder begins here."
		"Once one is running, gather shards of all three gems and craft the CMY upgrade inside it."
	]
	quest.0B0310C000000011.quest_subtitle: "The three starter tiers"
	quest.0B0310C000000011.title: "Basic Pedestals"
	quest.0B0310C000000012.quest_desc: [
		"Craft the Moonstone Pedestal. It is the top of the pedestal ladder, above the Onyx tier."
		"Moonstone runs Spectrum's highest pedestal recipes. The upgrade itself is an advanced-tier recipe: it runs on an Onyx Pedestal and its structure calls for onyx chiseled blocks."
		"With this built, your pedestal lane is complete."
	]
	quest.0B0310C000000012.quest_subtitle: "The top pedestal tier"
	quest.0B0310C000000012.title: "Moonstone Pedestal"
	quest.0B0310C000000013.quest_desc: [
		"Craft the Onyx Pedestal. It sits above the CMY pedestal and unlocks the advanced recipe tier."
		"The upgrade recipe runs on the CMY pedestal, so have that tier working first. Moonstone is the final step above this one."
		"Onyx output feeds the Spirit Instiller convergence at the end of this chapter, so keep it running as you build toward that apparatus."
	]
	quest.0B0310C000000013.quest_subtitle: "The third pedestal rung"
	quest.0B0310C000000013.title: "Onyx Pedestal"
	quest.0B0310C000000020.quest_desc: [
		"Craft any one of the five Pastel Network nodes. This quest accepts the connection, gather, provider, sender, or storage node, so build whichever fits your layout first."
		"The Pastel Network is Spectrum's own item-routing system. Gather nodes pull items in, sender nodes push items out, provider nodes offer stock for the network to request, storage nodes hold it, and connection nodes tie the web together. It moves items between your stations without hoppers or manual hauling."
		"This node roots the automation lane. Next you build the Fusion Shrine, which the network can feed and drain on its own."
	]
	quest.0B0310C000000020.quest_subtitle: "Item routing for Spectrum"
	quest.0B0310C000000020.title: "Pastel Network Nodes"
	quest.0B0310C000000021.quest_desc: [
		"Build the Calcite Fusion Shrine. Note that Spectrum has a basalt variant as well, but that one is locked to a later age, so calcite is the shrine you build now."
		"The Fusion Shrine crafts light-infused outputs by combining items, fluids, and a burst of colored light under the open sky. It handles recipes that neither pedestals nor the barrel can, and it is where much of Spectrum's advanced material comes from."
		"Fed by the Pastel Network, the shrine can run hands-off. Its output, together with the Onyx Pedestal, feeds the Spirit Instiller convergence next."
	]
	quest.0B0310C000000021.quest_subtitle: "The calcite fusion apparatus"
	quest.0B0310C000000021.title: "Fusion Shrine"
	quest.0B0310C000000022.quest_desc: [
		"Assemble the Spirit Instiller multiblock. This quest completes when you finish building the structure, so follow Spectrum's in-game guide for the exact block layout and place the instiller at its center."
		"The Spirit Instiller infuses gems and creatures with stored energy to produce Spectrum's spirit-tier materials. It is the convergence of this chapter, drawing on both the pedestal lane and the Fusion Shrine lane you built above."
		"Completing the structure proves you can run the full Spectrum workflow, from pigment to ink to infused output. The optional flavor nodes below add particle and ink extras on top."
	]
	quest.0B0310C000000022.quest_subtitle: "Build the apparatus"
	quest.0B0310C000000022.title: "Spirit Instiller"
	quest.0B0310C000000023.quest_desc: [
		"Optional. Craft the Particle Spawner if you want a decorative emitter for your builds."
		"The spawner emits colored particle effects you can tune to match a room or a monument. It has no progression role, so pick it up only for the look."
		"This is a flavor node hanging off the Spirit Instiller. Skip it freely if you are not decorating."
	]
	quest.0B0310C000000023.quest_subtitle: "Optional decorative emitter"
	quest.0B0310C000000023.title: "Particle Spawner"
	quest.0B0310C000000024.quest_desc: [
		"Optional. Craft the Ink Assortment to gather a sampler of Spectrum's inks in one bundle."
		"The assortment is a convenient way to see the full color range Spectrum crafting draws on and to keep a stock of each ink on hand. It is a quality-of-life pickup, not a requirement."
		"This node also hangs off the Spirit Instiller. Take it if you want a tidy ink reserve, otherwise move on."
	]
	quest.0B0310C000000024.quest_subtitle: "Optional ink sampler"
	quest.0B0310C000000024.title: "Ink Assortment"
	quest.0B031B1000000001.quest_desc: [
		"You already forged a &bBlaze Burner&r back in the Nether chapter. That burner is the heat source for a steam boiler, so this node clears once you have one."
		"To build a boiler, stack &bFluid Tanks&r, fill them with water, and set lit &bBlaze Burners&r underneath. A taller tank with more burners makes more steam and drives a stronger engine. Press W on any block to Ponder the exact layout."
	]
	quest.0B031B1000000001.quest_subtitle: "Water, heat, and a tall tank."
	quest.0B031B1000000001.title: "Fire the Boiler"
	quest.0B031B1000000002.quest_desc: [
		"Place a &bSteam Engine&r on the side of a heated boiler tank. The engine reads the steam the boiler produces and outputs rotation, far more Stress Units than a water wheel of the same footprint."
		"This frees a large factory from a sprawl of wheels. One good boiler can carry the whole workshop. The rest of this chapter forks from here: trains on the left, factory logistics on the right."
	]
	quest.0B031B1000000002.quest_subtitle: "Trade water wheels for real SU."
	quest.0B031B1000000002.title: "Steam Power"
	quest.0B031B1000000003.quest_desc: ["A &bSteam Whistle&r mounts on a boiler and sounds a note whose pitch you tune with a wrench. Pure flavor for a rail yard, no mechanics attached. Optional."]
	quest.0B031B1000000003.quest_subtitle: "Sound the yard."
	quest.0B031B1000000003.title: "Steam Whistle"
	quest.0B031B1000000010.quest_desc: [
		"Craft &bTrain Track&r and lay it with a track paver. Create trains ride Create track, not vanilla rails, so this is the foundation of every rail line you build."
		"Aim at the ground and hold use to pave straight runs and curves. Track can climb, bank, and turn far more freely than vanilla rail."
	]
	quest.0B031B1000000010.quest_subtitle: "Create trains need Create track."
	quest.0B031B1000000010.title: "Lay the Track"
	quest.0B031B1000000011.quest_desc: [
		"Place a &bTrain Station&r against your track. A station assembles a parked train into a driveable vehicle, disassembles it back into blocks, and hands out schedules."
		"Name the station in its interface. The name is how schedules and the route tools later refer to this stop."
	]
	quest.0B031B1000000011.quest_subtitle: "Assemble, disassemble, dispatch."
	quest.0B031B1000000011.title: "Build a Station"
	quest.0B031B1000000012.quest_desc: [
		"Bogeys are a train's wheels. Place a &bSmall Bogey&r or a &bLarge Bogey&r on the track under the carriage you glued together, then assemble at the station."
		"Small bogeys turn tight and suit short cars. Large bogeys carry longer, heavier carriages. Craft one of each so you know both before you design a train."
	]
	quest.0B031B1000000012.quest_subtitle: "Put the carriage on wheels."
	quest.0B031B1000000012.title: "Wheels on the Rail"
	quest.0B031B1000000013.quest_desc: [
		"Sit in a &bTrain Controls&r seat to drive the train by hand with your movement keys. This is the manual way to run a line."
		"For automation, write a &bTrain Schedule&r item: list the stations to visit and the conditions to depart, then hand it to the train at a station. The train runs the route on its own from then on."
	]
	quest.0B031B1000000013.quest_subtitle: "Drive it, or let a schedule run it."
	quest.0B031B1000000013.title: "Drive and Schedule"
	quest.0B031B1000000014.quest_desc: [
		"A &bTrain Signal&r splits a shared line into blocks and holds a train until the block ahead is clear, which is what keeps two trains from colliding on the same track."
		"A &bTrack Observer&r detects a passing train and emits redstone, handy for triggering doors, crossings, or displays. Optional, since a single-train line never collides with itself."
	]
	quest.0B031B1000000014.quest_subtitle: "Keep two trains off one block."
	quest.0B031B1000000014.title: "Block Signalling"
	quest.0B031B1000000020.quest_desc: [
		"&6Create Railways Navigator&r upgrades Create display boards into rail-aware &bAdvanced Displays&r. Craft a batch from a row of &bDisplay Boards&r framed with andesite alloy and obsidian plates."
		"Placed at a platform and configured with a wrench, it shows live line, destination, delay, and boarding info pulled straight from your scheduled trains. Optional quality-of-life for a busy station."
	]
	quest.0B031B1000000020.quest_subtitle: "A real departure board."
	quest.0B031B1000000020.title: "Read the Departure Board"
	quest.0B031B1000000021.quest_desc: [
		"Craft the &bNavigator&r on a &bMechanical Crafter&r, which needs a &bPrecision Mechanism&r in the pattern, so it sits squarely in the Create tier you are already working in."
		"Right-click it to open a route search: pick a start and a destination station and it plans the connections, departures, transfers, and delays across your network. The nearest-station button seeds the start from where you stand. Optional."
	]
	quest.0B031B1000000021.quest_subtitle: "Plan a route across the network."
	quest.0B031B1000000021.title: "Plan Your Journey"
	quest.0B031B1000000030.quest_desc: ["A &bDisplay Board&r shows text or item data written to it by a &bDisplay Link&r: stock counts, timers, station names. Wire one up as a readout for any Create system, not just rail. Optional signage."]
	quest.0B031B1000000030.quest_subtitle: "Put your data on the wall."
	quest.0B031B1000000030.title: "Display Board"
	quest.0B031B1000000040.quest_desc: [
		"A &bPackager&r wraps a stack of items into a shippable &bPackage&r, the atom of the Create 6 Logistics Network. Feed it items and it seals them into a package entity that the network can move and address."
		"This is the entry point to factory logistics. Everything downstream moves packages, not loose items."
	]
	quest.0B031B1000000040.quest_subtitle: "Seal a stack into a package."
	quest.0B031B1000000040.title: "Package It"
	quest.0B031B1000000041.quest_desc: [
		"Attach a &bStock Link&r to an inventory to enroll it in the Logistics Network. Every linked container becomes part of one shared pool the network can see."
		"Then place a &bStock Ticker&r and open its shopping list. Request items by name and the network gathers them from every linked inventory and ships them to you as packages. This is the order-from-anywhere beat."
	]
	quest.0B031B1000000041.quest_subtitle: "Link the shelves, order from a list."
	quest.0B031B1000000041.title: "Request from the Network"
	quest.0B031B1000000042.quest_desc: [
		"A &bFactory Gauge&r watches a linked inventory and keeps it stocked at a target you set. When the count drops, it dispatches crafting orders through the network to refill it automatically."
		"This is the automation backbone of Create 6. Point gauges at the inputs of your machines and the network keeps every stage fed without you hauling anything."
	]
	quest.0B031B1000000042.quest_subtitle: "Set a target, let it restock."
	quest.0B031B1000000042.title: "Auto-Restock"
	quest.0B031B1000000043.quest_desc: [
		"A &bPackage Frogport&r launches and catches packages between distant nodes on your network, moving goods across gaps that belts and pipes cannot bridge."
		"A &bRedstone Requester&r fires off a network order on a redstone pulse, so a lever, timer, or sensor can trigger a restock. Optional, since the Stock Ticker and Factory Gauge already close the loop."
	]
	quest.0B031B1000000043.quest_subtitle: "Ship packages across the map."
	quest.0B031B1000000043.title: "Deliver by Air"
	quest.0B96EC5055E6B817.quest_desc: [
		"Finish every tower on the &bBarracks&r. A fully towered barracks posts a complete complement of guards. It is the strongest fixed defense a colony fields."
		"Complete it before raids start scaling up against you."
	]
	quest.0B96EC5055E6B817.quest_subtitle: "The barracks at full strength."
	quest.0B96EC5055E6B817.title: "Every Tower Manned"
	quest.0C1D90EE8814578B.quest_desc: ["Spin &bChrysite String&r. It is a strong magical thread the garden's better crafts and gear are bound with."]
	quest.0C1D90EE8814578B.quest_subtitle: "A tough magical fiber."
	quest.0C1D90EE8814578B.title: "Chrysite String"
	quest.0D56E3C121A776DF.quest_desc: [
		"Resurrect a fallen citizen. With the &bGraveyard&r, the Undertaker, and the right preparation, death is not the end of a colonist's service."
		"Bringing back a skilled worker saves hours of training a replacement."
	]
	quest.0D56E3C121A776DF.quest_subtitle: "Recover a lost colonist."
	quest.0D56E3C121A776DF.title: "Bring One Back"
	quest.0D6E099A1A242153.quest_desc: [
		"Set the &bTown Hall&r down with the &bBuild Tool&r to found your colony. The Build Tool previews and positions every structure. Keep it on your hotbar for every build."
		"Founding the colony hands you your first &bBuilder's Hut&r to place."
	]
	quest.0D6E099A1A242153.quest_subtitle: "Place the hall, claim the land."
	quest.0D6E099A1A242153.title: "Found the Colony"
	quest.0EA0543427759BF6.quest_desc: ["The Lantern Maker is the Archive and Recordkeeping station for lantern work."]
	quest.0EA0543427759BF6.quest_subtitle: "Record the archive with a Lantern Maker."
	quest.0EA0543427759BF6.title: "Lantern Maker"
	quest.0EBB4E5195610A82.quest_desc: [
		"Build the &bSawmill&r. Its carpenter crafts planks, sticks, and the more involved wooden parts your buildings keep requesting."
		"Teach it the recipes your builds want most so the couriers can stock them automatically."
	]
	quest.0EBB4E5195610A82.quest_subtitle: "Advanced woodworking."
	quest.0EBB4E5195610A82.title: "Sawmill"
	quest.0F409DACBEB7BBF8.quest_desc: [
		"Drop a &bSupply Ship&r on open water if you would rather start by the coast. Like the camp it bootstraps the colony with the &bBuild Tool&r and starting supplies."
		"It needs a clear stretch of water to deploy, so scout the shoreline first."
	]
	quest.0F409DACBEB7BBF8.quest_subtitle: "The waterside alternative."
	quest.0F409DACBEB7BBF8.title: "Supply Ship"
	quest.11C25203906C0FD4.quest_desc: [
		"Assemble the &bgreenhouse&r from its core container, a &bGrowth Detector&r, a &bWooden Grate Humidifier&r, a &bThermometer&r, and a &bSeasonal Prayer Scroll&r. Together they hold a warm, humid pocket where crops keep growing even when the season outside would stall them."
		"This is how Ecliptic Seasons stops being a hard wall on winter farming. Build one before the cold sets in."
	]
	quest.11C25203906C0FD4.quest_subtitle: "Grow through the off-season."
	quest.11C25203906C0FD4.title: "Greenhouse"
	quest.120152510AD4B59A.quest_desc: [
		"Craft the &bBuilder's Goggles&r. Worn at a build site they show which blocks are still missing and where they go, which takes the guesswork out of supplying a builder."
		"Pull them on whenever a construction stalls on a material you cannot place."
	]
	quest.120152510AD4B59A.quest_subtitle: "See what a build still needs."
	quest.120152510AD4B59A.title: "Builder's Goggles"
	quest.1237BB77A090C2D5.quest_desc: [
		"Build a &bCopper Chest&r. Sophisticated Storage chests hold more than vanilla and take upgrades for sorting and auto-pickup. This starts a storage system that scales with the base."
		"&bCopper&r is the entry tier. Better chests and more upgrade slots follow as you find the metals."
	]
	quest.1237BB77A090C2D5.quest_subtitle: "The first upgradeable chest."
	quest.1237BB77A090C2D5.title: "Copper Chest"
	quest.130E8FC7479E4271.quest_desc: [
		"Raise the &bShepherd's Hut&r. The Shepherd keeps sheep for wool and mutton, and wool feeds your building, banners, and the Dyer."
		"Pair it with the &bDyer's Hut&r and you have colored wool on tap."
	]
	quest.130E8FC7479E4271.quest_subtitle: "Wool and mutton."
	quest.130E8FC7479E4271.title: "Shepherd's Hut"
	quest.14DA3DC7C0009A6A.quest_desc: [
		"Reach fifty citizens. A town this large is a supply chain in itself, demanding constant food, housing, and order to hold together."
		"Lean hard on the &bwarehouse&r and couriers to keep it all moving."
	]
	quest.14DA3DC7C0009A6A.quest_subtitle: "A logistics project of its own."
	quest.14DA3DC7C0009A6A.title: "Fifty Citizens"
	quest.15B51FB56A64C303.quest_desc: [
		"Raise a &bUniversity&r. Its researchers unlock upgrades that touch the whole colony, from faster builders to tougher guards."
		"Staff it and keep the research queue full, since the best bonuses take real time to earn."
	]
	quest.15B51FB56A64C303.quest_subtitle: "Colony-wide upgrades come from here."
	quest.15B51FB56A64C303.title: "University"
	quest.15F03A5E7E14C022.quest_desc: [
		"Build the &bStonemason's Hut&r. The Stonemason crafts bricks, polished stone, and the cut blocks your fancier buildings call for."
		"Teach it the stone recipes your builds keep requesting and the queue takes care of itself."
	]
	quest.15F03A5E7E14C022.quest_subtitle: "Bricks and decorative stone."
	quest.15F03A5E7E14C022.title: "Stonemason's Hut"
	quest.15F65C76BE09F690.quest_desc: [
		"Build a &bSmoker&r. It cooks meat and fish twice as fast as a furnace, which matters when a single furnace is juggling food and ore at the same time."
		"Pair it with the fishing setup so your catch becomes meals as fast as you haul it in."
	]
	quest.15F65C76BE09F690.quest_subtitle: "Cook food at double speed."
	quest.15F65C76BE09F690.title: "Smoker"
	quest.16720DA722F1938F.quest_desc: [
		"Craft a Sophisticated &bBackpack&r. It is portable storage you upgrade with filters, magnets, and feeding slots, which keeps a long mining or foundry run from filling up."
		"Start with the plain pack and add upgrades as you go. It grows with you instead of being replaced."
	]
	quest.16720DA722F1938F.quest_subtitle: "Storage that travels with you."
	quest.16720DA722F1938F.title: "Carry More Things"
	quest.190D88699AB87245.quest_desc: [
		"Craft a &bWaterskin&r and fill it. &6Cold Sweat&r lets you warm or chill the water at a fire or an &bicebox&r, then drink to swing your temperature back toward comfortable while you travel."
		"It is the portable answer to the weather, so keep one filled before any long trip."
	]
	quest.190D88699AB87245.quest_subtitle: "Carry your own climate control."
	quest.190D88699AB87245.title: "Waterskin"
	quest.1998AA8EB20A3D62.quest_desc: [
		"Craft the &6Cold Sweat&r &bBoiler&r and fuel it. It radiates warmth in a small radius, which keeps your body temperature in the safe band while you work through a cold spell."
		"One in the workshop and one by the bed covers most of the night."
	]
	quest.1998AA8EB20A3D62.quest_subtitle: "A heat source you can stand next to."
	quest.1998AA8EB20A3D62.title: "Boiler"
	quest.19D03831EB5EED02.quest_desc: [
		"Raise the &bBlacksmith's Hut&r. The Smith forges the tools and armor your workers and guards burn through, so you stop hand-crafting every pickaxe."
		"Teach it the gear your colony actually uses and let the requests flow."
	]
	quest.19D03831EB5EED02.quest_subtitle: "Tools and armor on demand."
	quest.19D03831EB5EED02.title: "Blacksmith's Hut"
	quest.1BB227EC6C14ACEC.quest_desc: [
		"Craft &bRope and Nail&r. On its own it does nothing, but it is what pins a &bhammock&r to a wall or a pair of posts so you can sleep away from base."
		"Make a couple so a field camp can sleep two."
	]
	quest.1BB227EC6C14ACEC.quest_subtitle: "The mount that holds a hammock up."
	quest.1BB227EC6C14ACEC.title: "Rope and Nail"
	quest.1BB571557F74D3A1.quest_desc: [
		"Craft the &bTown Hall&r block. It is the core of a &6MineColonies&r settlement, setting the borders and giving you the interface that manages every citizen and building."
		"Nothing else in the colony works until this block exists, so make it your first move."
	]
	quest.1BB571557F74D3A1.quest_subtitle: "Colony headquarters."
	quest.1BB571557F74D3A1.title: "Town Hall"
	quest.1C16AEE8E29FB5A0.quest_desc: [
		"Craft the &bRallying Banner&r. Raise it and your guards leave their posts to gather and march where you point, turning scattered defenders into a strike force."
		"Use it to meet a raid head-on instead of letting it pick at your towers."
	]
	quest.1C16AEE8E29FB5A0.quest_subtitle: "Point your guards at the threat."
	quest.1C16AEE8E29FB5A0.title: "Rallying Banner"
	quest.1E1870FAD295DEDE.quest_desc: [
		"Place a &bSupply Camp&r on flat ground. It is the starter structure that hands you the &bBuild Tool&r and the gear to put down your first buildings."
		"Give it open space around it so the camp can unpack cleanly."
	]
	quest.1E1870FAD295DEDE.quest_subtitle: "Bootstrap the colony on land."
	quest.1E1870FAD295DEDE.title: "Supply Camp"
	quest.1E26C1DB07329371.quest_desc: ["Craft the &bBrambler&r. It is a weapon that can lash out with brambleroot thorns, putting the garden's meanest plant to work for you in a fight."]
	quest.1E26C1DB07329371.quest_subtitle: "Turn the thorns on your enemies."
	quest.1E26C1DB07329371.title: "Brambler"
	quest.1E2CC1305BAFB7E2.quest_desc: ["Collect the broken staff pieces, the baby yeti and spiderling fragments. They are the parts you reassemble the garden's summoning staffs from."]
	quest.1E2CC1305BAFB7E2.quest_subtitle: "Fragments to rebuild."
	quest.1E2CC1305BAFB7E2.title: "Broken Staff Pieces"
	quest.1E5A8AEE45E9DDCA.quest_desc: [
		"Forge a &bCinder Sword&r from Cindershell materials. The blade is cut from the same fiery shell the creature carries."
		"Gather the shell shards a Cindershell drops and craft them into the sword. It is a solid early nether weapon and a small reward for working with the creature rather than only fighting the biome."
	]
	quest.1E5A8AEE45E9DDCA.quest_subtitle: "Optional flavor. Forged from a Cindershell's own armor."
	quest.1E5A8AEE45E9DDCA.title: "Cinder Sword"
	quest.1F215CC13B2A1F81.quest_desc: ["Recover an &bAncient Scroll&r. Read it to let loose the spell stored inside, a one-off bit of &6Monster Plus&r magic for a tight spot."]
	quest.1F215CC13B2A1F81.quest_subtitle: "A spell in a single read."
	quest.1F215CC13B2A1F81.title: "Ancient Scroll"
	quest.201CB898A399F1D5.quest_desc: [
		"Set up the &bSwineherder's Hut&r. The Swineherder raises pigs for pork, the quickest meat supply you can hand the kitchen."
		"Keep carrots or similar on hand so the worker can breed them."
	]
	quest.201CB898A399F1D5.quest_subtitle: "Fast, simple meat."
	quest.201CB898A399F1D5.title: "Swineherder's Hut"
	quest.206159A3C7A78447.quest_desc: [
		"Build a &bMystical Site&r. It raises colony happiness in the background, and content citizens work better and complain less."
		"A small decorative investment that pays off across the whole town."
	]
	quest.206159A3C7A78447.quest_subtitle: "Quietly lifts colony mood."
	quest.206159A3C7A78447.title: "Mystical Site"
	quest.2141A51DFA5E7349.quest_desc: [
		"Craft the &bEngineer's Manual&r and open it. &6Immersive Engineering&r multiblocks have exact shapes, and the manual shows each one with a 3D preview you can rotate."
		"Check it first whenever a structure refuses to form. It answers most of the questions this chapter raises."
	]
	quest.2141A51DFA5E7349.quest_subtitle: "Read it before you build."
	quest.2141A51DFA5E7349.title: "Engineer's Manual"
	quest.226176A1C73431B5.quest_desc: [
		"Give the Farmer their full set of fields. A fully-fielded farmer grows the most crops the colony can. More fields means more food for a large population."
		"Mark out and assign every field slot the hut allows."
	]
	quest.226176A1C73431B5.quest_subtitle: "Max out the harvest."
	quest.226176A1C73431B5.title: "Full Fields"
	quest.23012F6C4C522CEB.quest_desc: [
		"Build the &bLumberjack's Hut&r. The Lumberjack fells and replants trees, turning a forest into a steady log supply on its own."
		"Give them a wide wooded area to work and the colony never runs short of wood."
	]
	quest.23012F6C4C522CEB.quest_subtitle: "Logs without swinging an axe."
	quest.23012F6C4C522CEB.title: "Lumberjack's Hut"
	quest.252ADD929CB55CBF.quest_desc: ["Craft an &bEnergy Ball&r. Consumed, it hands you a short burst of energy, a fast pick-me-up worked up from the garden's stranger crops."]
	quest.252ADD929CB55CBF.quest_subtitle: "A quick burst of vigor."
	quest.252ADD929CB55CBF.title: "Energy Ball"
	quest.27631F12D97B7FA8.quest_desc: [
		"Hammer heated &bcopper&r into a full set of tool parts: sword blade, pickaxe head, shovel head, axe head, and hoe head. Forged metal parts hold a better edge than knapped stone and drop straight into the same part-built tools."
		"Make all five. Each one teaches the anvil a little better, and the whole kit carries you until iron."
	]
	quest.27631F12D97B7FA8.quest_subtitle: "Forge the full copper kit."
	quest.27631F12D97B7FA8.title: "Copper Parts"
	quest.280E76D5A93E6B6C.quest_desc: [
		"Hunt the &c&lGnome King&r in its burrow. It fights surrounded by a mob of gnomes, so thin the escort before you focus the king itself."
		"Its loot bag holds the drops worth the trip."
	]
	quest.280E76D5A93E6B6C.quest_subtitle: "Clear the escort, then the crown."
	quest.280E76D5A93E6B6C.title: "Gnome King"
	quest.28FB6A2936D5FEE2.quest_desc: [
		"Craft the &bGoat Fur Parka&r from your collected fur. It comes pre-insulated against cold, so it holds your warmth in snow and on mountaintops without any extra lining."
		"Wear it on expeditions north. It is far less fuss than chasing a &bboiler&r around the map."
	]
	quest.28FB6A2936D5FEE2.quest_subtitle: "Dedicated cold-weather armor."
	quest.28FB6A2936D5FEE2.title: "Goat Fur Parka"
	quest.2902E58DB70F9404.quest_desc: [
		"Mix &bFire Clay&r. It bakes into the heat-resistant bricks the foundry is built from, the first step toward melting metal in bulk."
		"&6Productive Metalworks&r leans on it heavily, so make more than one batch."
	]
	quest.2902E58DB70F9404.quest_subtitle: "Raw material for the foundry shell."
	quest.2902E58DB70F9404.title: "Fire Clay"
	quest.2902E58DB70F9405.quest_desc: ["Smelt &bFire Clay&r into Fire Bricks. They take a foundry's heat without cracking, so they form its inner shell. Stock a stack before you start laying the structure."]
	quest.2902E58DB70F9405.quest_subtitle: "Bricks that hold the heat."
	quest.2902E58DB70F9405.title: "Fire Brick"
	quest.2902E58DB70F9407.quest_desc: ["Craft &bBlack Fire Bricks&r. They are the structural block of the &bBlack Foundry&r, the &6Productive Metalworks&r take on a melting smeltery. A full wall of them encloses the heat that does the work."]
	quest.2902E58DB70F9407.quest_subtitle: "The wall of the foundry."
	quest.2902E58DB70F9407.title: "Black Fire Bricks"
	quest.2902E58DB70F9409.quest_desc: ["Add a &bBlack Foundry Drain&r to the wall. It is the port molten metal leaves through, feeding a &bcasting table&r or &bbasin&r placed against it. Set it at the height you want to pour from."]
	quest.2902E58DB70F9409.quest_subtitle: "How molten metal gets out."
	quest.2902E58DB70F9409.title: "Black Foundry Drain"
	quest.2902E58DB70F940A.quest_desc: ["Build a &bBlack Foundry Tank&r into the structure. It raises how much molten metal and fuel the foundry can hold, so a bigger tank means longer runs between refills. Add more as your batches grow."]
	quest.2902E58DB70F940A.quest_subtitle: "Hold more metal and fuel."
	quest.2902E58DB70F940A.title: "Black Foundry Tank"
	quest.2902E58DB70F940B.quest_desc: ["Set a &bBlack Foundry Window&r into the wall. It lets you watch the molten levels inside, which is the easiest way to tell what is melting and how full the foundry is. One or two covers it."]
	quest.2902E58DB70F940B.quest_subtitle: "See what is melting."
	quest.2902E58DB70F940B.title: "Black Foundry Window"
	quest.2902E58DB70F940C.quest_desc: ["Install a &bFoundry Tap&r. It draws molten metal out on demand and pours it onto whatever sits below. This is the valve that turns a pool of liquid metal into solid parts."]
	quest.2902E58DB70F940C.quest_subtitle: "The spout for liquid metal."
	quest.2902E58DB70F940C.title: "Foundry Tap"
	quest.2902E58DB70F940D.quest_desc: ["Place a &bCasting Table&r under the tap. Pour molten metal over a cast set on it and you get ingots, rods, plates, or tools, depending on the mold. The foundry earns its keep at this table."]
	quest.2902E58DB70F940D.quest_subtitle: "Pour metal into shapes."
	quest.2902E58DB70F940D.title: "Casting Table"
	quest.2902E58DB70F940E.quest_desc: ["Add a &bCasting Basin&r beside the table. Like the table but for blocks and larger castings, it shapes bulk metal and the heavier components. Keep one next to the table for the big jobs."]
	quest.2902E58DB70F940E.quest_subtitle: "For blocks and bigger pours."
	quest.2902E58DB70F940E.title: "Casting Basin"
	quest.2902E58DB70F940F.quest_desc: ["Make an &bIngot Cast&r and set it on the &bcasting table&r. Molten metal poured over it sets into ingots. It is the reusable mold you reach for most, since almost every metal starts as ingots."]
	quest.2902E58DB70F940F.quest_subtitle: "The mold you use most."
	quest.2902E58DB70F940F.title: "Ingot Cast"
	quest.2902E58DB70F9411.quest_desc: ["Craft a &bRod Cast&r. It pours molten metal into rods, the long thin parts that gears, tools, and machine frames ask for. Keep it on the table next to the &bingot cast&r."]
	quest.2902E58DB70F9411.quest_subtitle: "Shape metal into rods."
	quest.2902E58DB70F9411.title: "Rod Cast"
	quest.2902E58DB70F9412.quest_desc: ["Make a &bPlate Cast&r. It pours metal into plates, the flat parts that armor and many machines need. The &bbrass&r plates a few steps from here come straight off this cast."]
	quest.2902E58DB70F9412.quest_subtitle: "Shape metal into plates."
	quest.2902E58DB70F9412.title: "Plate Cast"
	quest.2902E58DB70F9413.quest_desc: ["Build a &bLiquid Heating Coil&r. It supplies the heat that melts metal inside the foundry, so nothing liquefies without it. Treat it as the burner the whole structure depends on."]
	quest.2902E58DB70F9413.quest_subtitle: "The foundry's burner."
	quest.2902E58DB70F9413.title: "Liquid Heating Coil"
	quest.2902E58DB70F9414.quest_desc: [
		"Craft a &bBlack Foundry Capacitor&r and add it to the foundry. It stores heat so the structure can hold temperature between pours."
		"From here, casting is your main way of working metal. Everything downstream assumes a foundry you can pour from."
	]
	quest.2902E58DB70F9414.quest_subtitle: "Heat storage for the foundry."
	quest.2902E58DB70F9414.title: "Foundry Capacitor"
	quest.2902E58DB70F9418.quest_desc: ["Craft a Speed upgrade. Slotted into a &6Productive Metalworks&r machine it processes faster, the first of the upgrade tokens these machines accept. Spend them on the machines you run constantly."]
	quest.2902E58DB70F9418.quest_subtitle: "Run a foundry machine faster."
	quest.2902E58DB70F9418.title: "Upgrade: Speed"
	quest.2902E58DB70F9421.quest_desc: [
		"Bake &bCoke Bricks&r through &6Immersive Engineering&r. They are the blocks the &bCoke Oven&r multiblock is built from."
		"Make enough for the full oven footprint before you move on to forming it."
	]
	quest.2902E58DB70F9421.quest_subtitle: "Line the Coke Oven."
	quest.2902E58DB70F9421.title: "Coke Brick"
	quest.2902E58DB70F9422.quest_desc: [
		"Form a &bCoke Oven&r with the engineer's hammer. The oven cooks coal into &bcoal coke&r and &bcreosote&r, the two materials the rest of this chapter runs on."
		"Build it early and build it once you can afford a second. One oven is slow once demand picks up."
	]
	quest.2902E58DB70F9422.quest_subtitle: "Coal coke and creosote start here."
	quest.2902E58DB70F9422.title: "Coke Oven"
	quest.2902E58DB70F9423.quest_desc: ["Pull &bCoal Coke&r from the &bCoke Oven&r. It burns hotter than coal and is the dense carbon the foundry and later &bsteel&r both want. Let the oven stockpile a supply while you work."]
	quest.2902E58DB70F9423.quest_subtitle: "Hotter fuel, denser carbon."
	quest.2902E58DB70F9423.title: "Coal Coke"
	quest.2902E58DB70F9424.quest_desc: ["Compress &bcoal coke&r into a Coke block. As a solid block it burns a long time, handy for a &bfurnace&r you want running unattended. Keep a few for slow background smelting."]
	quest.2902E58DB70F9424.quest_subtitle: "Long-burning block fuel."
	quest.2902E58DB70F9424.title: "Coke Block"
	quest.2902E58DB70F9425.quest_desc: [
		"Bottle &bCreosote&r from the &bCoke Oven&r. It is the oily byproduct that weatherproofs wood, and it feeds both the treated-wood and &bfertilizer&r lines in this chapter."
		"Bucket or pipe it out as the oven makes it so it does not back the oven up."
	]
	quest.2902E58DB70F9425.quest_subtitle: "The byproduct that treats wood."
	quest.2902E58DB70F9425.title: "Creosote"
	quest.2902E58DB70F9426.quest_desc: [
		"Soak planks in &bcreosote&r to make &bTreated Wood&r. It resists rot and weather and is the material most &6Immersive Engineering&r parts are framed with."
		"Run a steady batch. Almost everything wooden ahead, from wiring to scaffolds, wants treated wood."
	]
	quest.2902E58DB70F9426.quest_subtitle: "The frame for IE parts."
	quest.2902E58DB70F9426.title: "Treated Wood"
	quest.2902E58DB70F9427.quest_desc: ["Craft a &bTreated Wood&r Fence. The treated variants hold up outdoors where plain wood rots, so use them for railings and pen walls around the workshop."]
	quest.2902E58DB70F9427.quest_subtitle: "Railings that survive the weather."
	quest.2902E58DB70F9427.title: "Treated Fence"
	quest.2902E58DB70F9428.quest_desc: ["Make Treated Scaffold. It is climbable scaffolding that shrugs off the weather, useful for raising the tall multiblocks coming up. Keep a stack on hand for vertical work."]
	quest.2902E58DB70F9428.quest_subtitle: "Climbable, weatherproof build scaffold."
	quest.2902E58DB70F9428.title: "Treated Scaffold"
	quest.2902E58DB70F9429.quest_desc: ["Craft a &bTreated Wood&r Trapdoor. A hatch that does not rot, for vents and access points around the base. A small thing that rounds out the treated set."]
	quest.2902E58DB70F9429.quest_subtitle: "A weatherproof hatch."
	quest.2902E58DB70F9429.title: "Treated Trapdoor"
	quest.2902E58DB70F942A.quest_desc: [
		"Forge the &bEngineer's Hammer&r. It is the &6Immersive Engineering&r tool that forms multiblocks and connects wire, and almost nothing in this chapter assembles without it."
		"Keep it on your hotbar. The &bcoke oven&r, the wiring, and the structures ahead all expect you to have one."
	]
	quest.2902E58DB70F942A.quest_subtitle: "The tool that builds the rest."
	quest.2902E58DB70F942A.title: "Engineer's Hammer"
	quest.2902E58DB70F942B.quest_desc: ["Forge a &bWirecutter&r. It cuts and removes &6Immersive Engineering&r wire without dropping a tangle, and you need it to work the &bcopper&r wiring coming up. Keep it with the hammer."]
	quest.2902E58DB70F942B.quest_subtitle: "Handle wire cleanly."
	quest.2902E58DB70F942B.title: "Wirecutter"
	quest.2902E58DB70F942C.quest_desc: [
		"Wind a &bCopper Wire Coil&r. It is the low-voltage line that carries power between connectors, the first wiring tier in &6Immersive Engineering&r. String it where you need to move a little energy."
		"It is enough to light a lamp or feed a small machine well before any heavy power exists."
	]
	quest.2902E58DB70F942C.quest_subtitle: "First power cable."
	quest.2902E58DB70F942C.title: "Copper Wire Coil"
	quest.2902E58DB70F942D.quest_desc: ["Craft a Low-Voltage Connector. It is the terminal a wire coil attaches to, joining a power source to a machine. You need a pair to complete any run, one at each end."]
	quest.2902E58DB70F942D.quest_subtitle: "The terminal at each end of a run."
	quest.2902E58DB70F942D.title: "LV Connector"
	quest.2902E58DB70F942E.quest_desc: ["Make a Low-Voltage Relay. It carries wire across distance without plugging into a machine, so a line can turn corners and span open ground. Use relays for the long stretches between connectors."]
	quest.2902E58DB70F942E.quest_subtitle: "Carry wire across the gaps."
	quest.2902E58DB70F942E.title: "LV Relay"
	quest.2902E58DB70F9430.quest_desc: [
		"Grind iron into &bIron Dust&r. Dust smelts straight back into ingots and is the form most ore-doubling and alloy recipes are written around."
		"A small pile now means the casting and alloy steps ahead do not stall waiting on it."
	]
	quest.2902E58DB70F9430.quest_subtitle: "The form most recipes expect."
	quest.2902E58DB70F9430.title: "Iron Dust"
	quest.2902E58DB70F9431.quest_desc: ["Build a &6Create&r Mechanical &bMixer&r over a &bbasin&r. It blends items and fluids for alloys and building materials, including the concrete steps later in this chapter. Power it from your mill."]
	quest.2902E58DB70F9431.quest_subtitle: "Blend alloys and building mixes."
	quest.2902E58DB70F9431.title: "Mechanical Mixer"
	quest.2902E58DB70F9434.quest_desc: [
		"Melt &bcopper&r and zinc together in the foundry and cast &bBrass&r ingots. Brass is the first real alloy here and the gateway metal for &6Create&r's second tier and a pile of machine parts."
		"Pour a steady supply. The mill chapter is waiting on this brass to build its casings."
	]
	quest.2902E58DB70F9434.quest_subtitle: "Your first cast alloy."
	quest.2902E58DB70F9434.title: "Brass"
	quest.2902E58DB70F9435.quest_desc: ["Make a Stability upgrade. It steadies a Productive machine so it holds up under heavy use, the counterpart to the speed upgrade. Pair the two on your busiest machine for the smoothest run."]
	quest.2902E58DB70F9435.quest_subtitle: "Keep it running under load."
	quest.2902E58DB70F9435.title: "Upgrade: Stability"
	quest.2902E58DB70F9436.quest_desc: ["Craft a second Speed upgrade. Most Productive machines take more than one upgrade, so a stack of these keeps paying off as the foundry line grows. Keep making them as you scale up."]
	quest.2902E58DB70F9436.quest_subtitle: "More slots, more output."
	quest.2902E58DB70F9436.title: "Upgrade: Speed (Stacked)"
	quest.2902E58DB70F9438.quest_desc: ["Make &bTreated Wood&r Sticks. Several &6Immersive Engineering&r recipes call for the treated stick specifically rather than a plain one. Keep a couple stacks, since wiring and tools both eat them."]
	quest.2902E58DB70F9438.quest_subtitle: "The sticks IE recipes ask for."
	quest.2902E58DB70F9438.title: "Treated Sticks"
	quest.2902E58DB70F9439.quest_desc: ["Cut &bCopper Wire&r from a copper plate with the &bWire Cutter&r. It is the raw strand the wire coils are wound from, the smallest piece of a power network. A few are enough to get started."]
	quest.2902E58DB70F9439.quest_subtitle: "The strand coils are wound from."
	quest.2902E58DB70F9439.title: "Copper Wire"
	quest.2902E58DB70F9440.quest_desc: ["Craft &6Immersive Engineering&r Fluid Pipes. They carry &bcreosote&r, water, and other fluids between the oven, tanks, and machines. Plan the run so two fluids never share a line."]
	quest.2902E58DB70F9440.quest_subtitle: "Move creosote and water."
	quest.2902E58DB70F9440.title: "Fluid Pipe"
	quest.2902E58DB70F9441.quest_desc: ["Form a &bFluid Tank&r multiblock from &bsteel sheetmetal&r. It is not a single crafted block; lay the sheetmetal out in the tank shape and it assembles in place. It buffers the &bcreosote&r and water your pipes move so a producer and a consumer never stall each other."]
	quest.2902E58DB70F9441.quest_subtitle: "Buffer the lines."
	quest.2902E58DB70F9441.title: "Fluid Tank"
	quest.2902E58DB70F9442.quest_desc: ["Pour &bBrass&r Plates on the &bplate cast&r. Plates are the flat parts armor and machines need, and brass plates specifically feed several builds ahead. Cast a stack while the foundry is hot."]
	quest.2902E58DB70F9442.quest_subtitle: "Flat brass for machines."
	quest.2902E58DB70F9442.title: "Brass Plate"
	quest.2902E58DB70F9445.quest_desc: ["Craft &bHempcrete&r. It is a light building block that doubles as insulation, made from hemp fiber and the mix you just set up. Use it for walls that should hold their temperature."]
	quest.2902E58DB70F9445.quest_subtitle: "Light block, built-in insulation."
	quest.2902E58DB70F9445.title: "Hempcrete"
	quest.2902E58DB70F9446.quest_desc: ["Mix &bConcrete&r. Poured from the &bmixer&r it sets into a tough, blast-resistant block, the workhorse material for machine rooms and reinforced builds. Keep a stock for the heavier construction ahead."]
	quest.2902E58DB70F9446.quest_subtitle: "Strong, blast-resistant walls."
	quest.2902E58DB70F9446.title: "Concrete"
	quest.2902E58DB70F9449.quest_desc: ["Make &6Immersive Engineering&r &bFertilizer&r. It speeds crop growth and feeds the garden systems later, worked up from &bcreosote&r and farm scraps. A thin application covers a full field."]
	quest.2902E58DB70F9449.quest_subtitle: "Push your crops harder."
	quest.2902E58DB70F9449.title: "Fertilizer"
	quest.2902E58DB70F9450.quest_desc: [
		"Craft the Immersive Engineering Pipe Valve. It is a fluid-pipe control component that regulates flow into and out of your Fluid Pump and tanks."
		"Place the valve on a fluid pipe run to open, close, or throttle a line. This lets you decide which tank fills and when, instead of letting fluid spread wherever the pipes reach."
		"This is a Medieval bootstrap piece for the Immersive Engineering lane. It teaches pipe control now so the full machine fleet later in the Industrial Revolution feels familiar."
	]
	quest.2902E58DB70F9450.quest_subtitle: "Pipe valve on the fluid tank"
	quest.2902E58DB70F9450.title: "Directing the Flow"
	quest.2902E58DB70F9451.quest_desc: [
		"Form the Immersive Engineering Crusher multiblock. This quest completes on the build advancement, so assemble the full structure following IE's Engineer's Manual rather than crafting a single item."
		"The Crusher grinds ores into grit for a doubling gain and processes bulk material far faster than hand work. Building it is your first taste of IE's multiblock style, where machines are structures you assemble in the world."
		"This is the bridge from Medieval metalwork toward the Industrial Revolution machine fleet. Once you can raise one multiblock, the rest of the IE lineup follows the same pattern."
	]
	quest.2902E58DB70F9451.quest_subtitle: "Build your first IE multiblock crusher"
	quest.2902E58DB70F9451.title: "Toward the Machine Fleet"
	quest.29055EFFDCC6576E.quest_desc: [
		"Hunt down the Yeti, a large cold-country beast that hits hard and shrugs off the cold you cannot. Keep warm gear on and do not let it pin you against the ice."
		"Its drops open the garden's staff line."
	]
	quest.29055EFFDCC6576E.quest_subtitle: "Bring warmth and good armor."
	quest.29055EFFDCC6576E.title: "Yeti"
	quest.2940A79987A07E07.quest_desc: [
		"Gather leather from cattle or by tanning hides. You need a steady five before the armor set, and more once you start lining it against the cold."
		"A small cow pen near base keeps leather coming without hunting for it."
	]
	quest.2940A79987A07E07.quest_subtitle: "Hides for insulated armor."
	quest.2940A79987A07E07.title: "Leather"
	quest.2973560A44DEC9A5.quest_desc: [
		"Craft &bFishing Line&r. On its own it is a component, but it is the gate to the &6Aquaculture&r rods and tackle that catch far more than a vanilla rod ever will."
		"Once you can make line, the upgraded fishing gear in later chapters opens up."
	]
	quest.2973560A44DEC9A5.quest_subtitle: "The part that makes better rods."
	quest.2973560A44DEC9A5.title: "Fishing Line"
	quest.29D759EFE44E2422.quest_desc: [
		"Assemble the &bChameleon Scale&r leggings and helmet from molt. Because the lining adapts, this set keeps you comfortable in a desert and a snowfield without swapping gear at the border."
		"It is the survival armor you settle on once you stop fighting the weather one biome at a time."
	]
	quest.29D759EFE44E2422.quest_subtitle: "One set for hot and cold both."
	quest.29D759EFE44E2422.title: "Chameleon Scale Armor"
	quest.29DE51ABF8B5D7FA.quest_desc: [
		"Hunt the &c&lSpider Queen&r, who fights from behind a wall of spiderlings. Clear the brood first, then commit to her once your footing is clear."
		"Her loot bag is the reward."
	]
	quest.29DE51ABF8B5D7FA.quest_subtitle: "Thin the brood, then the queen."
	quest.29DE51ABF8B5D7FA.title: "Spider Queen"
	quest.2BA66AAE2E7B0103.quest_desc: ["Build a &bBrick Fireplace&r. It is a tidy heat source and a bit of decor for the corner of the alchemist's workshop where you do your brewing."]
	quest.2BA66AAE2E7B0103.quest_subtitle: "Warmth for the workshop."
	quest.2BA66AAE2E7B0103.title: "Brick Fireplace"
	quest.2DC5103B4EA6DDEB.quest_desc: ["Use the Cinder Furnace for Nether processing."]
	quest.2DC5103B4EA6DDEB.quest_subtitle: "Build the furnace for Nether processing."
	quest.2DC5103B4EA6DDEB.title: "Cinder Furnace"
	quest.2FD5037D4E720043.quest_desc: [
		"Pull together the full management kit: the &bassistant hammer&r, &bresource scroll&r, &bbuilder's goggles&r, clipboard, rallying banner, ancient tome, postbox, and stash."
		"Together they let you run a colony without micromanaging every builder by hand. This is the toolkit a settled town runs on."
	]
	quest.2FD5037D4E720043.quest_subtitle: "Everything you need to run it."
	quest.2FD5037D4E720043.title: "Colony Manager's Kit"
	quest.305697393DA2FAE8.quest_desc: [
		"Assemble the garden's staffs, from the shroom and spiderling staffs up to the ent, gnome, and yeti staffs. Each one summons an ally to fight for you."
		"The full set turns the garden into a warband you can call up at will."
	]
	quest.305697393DA2FAE8.quest_subtitle: "Call allies to your side."
	quest.305697393DA2FAE8.title: "Summoning Staffs"
	quest.31F70E7481C6CE82.quest_desc: ["Take the &bAncient Broken Sword&r from the fallen hero. Broken as it is, it is the component you reforge its blade from."]
	quest.31F70E7481C6CE82.quest_subtitle: "Reforge what was shattered."
	quest.31F70E7481C6CE82.title: "Ancient Broken Sword"
	quest.329ACE742921BBBB.quest_desc: [
		"Shear or collect &bGoat Fur&r. It is the straightforward cold insulation, and a stack of it lines a full parka against winter and high altitude."
		"Pair a goat pen with the cow pen and your insulation supply takes care of itself."
	]
	quest.329ACE742921BBBB.quest_subtitle: "Warm lining for cold country."
	quest.329ACE742921BBBB.title: "Goat Fur"
	quest.33058894ACD9CB06.quest_desc: [
		"Raise a &bGraveyard&r. It gives fallen citizens a resting place and is where the Undertaker does their work, the first step toward recovering a lost colonist."
		"A morbid build, but a growing colony will eventually need one."
	]
	quest.33058894ACD9CB06.quest_subtitle: "Where the Undertaker works."
	quest.33058894ACD9CB06.title: "Graveyard"
	quest.330BCA56BBF3F15E.quest_desc: ["Build a &bStressometer&r and place it on your kinetic network. It reads total stress against capacity, so you know when the next machine will stall the whole line."]
	quest.330BCA56BBF3F15E.quest_subtitle: "Read stress capacity on a network."
	quest.330BCA56BBF3F15E.title: "&6Stressometer&r"
	quest.34000000000003C1.quest_desc: [
		"Craft a &bStone Hoe&r and till a patch of grass near water. Tilled soil is where every crop in this chapter starts. Pick a flat, lit spot you can fence off later."
		"Seeds drop from breaking tall grass. Get a small plot going before nightfall, because food runs short fast in the &dDark Ages&r."
	]
	quest.34000000000003C1.quest_subtitle: "Break ground and start farming."
	quest.34000000000003C1.title: "Stone Hoe"
	quest.34000000000003C5.quest_desc: [
		"Bring in a real wheat harvest and save part of every cut for reseeding. Wheat feeds bread, animal breeding, and a few early trades. A steady supply pays off."
		"Mature plants give one seed back at minimum, so a field that is replanted as it is cut keeps itself going."
	]
	quest.34000000000003C5.quest_subtitle: "Replant as you reap."
	quest.34000000000003C5.title: "Wheat Harvest"
	quest.34000000000003CD.quest_desc: [
		"Grow and stockpile potatoes. They plant from the potato itself instead of a seed, they yield several per harvest, and baked potatoes are some of the cheapest filling food you can make."
		"A deep potato store is your buffer for the nights when nothing else is ready."
	]
	quest.34000000000003CD.quest_subtitle: "The crop you can eat raw in a pinch."
	quest.34000000000003CD.title: "Potato Stockpile"
	quest.34000000000003D1.quest_desc: [
		"Craft a &bFishing Rod&r and work a pond or river. Fishing costs almost nothing and returns food, bonus loot, and the fish the &bsmoker&r turns into a proper meal."
		"It is the most reliable early food source that does not depend on a field surviving the night."
	]
	quest.34000000000003D1.quest_subtitle: "Pull food straight out of the water."
	quest.34000000000003D1.title: "Fishing Rod"
	quest.3400000000001116.quest_desc: [
		"Craft a &bFurnace&r from cobblestone. It smelts ore and sand, cooks food faster than a &bcampfire&r when you feed it fuel, and doubles as a warm light source indoors."
		"Almost everything ahead routes through a &bfurnace&r at some point, so build it early and keep coal nearby."
	]
	quest.3400000000001116.quest_subtitle: "Smelting, faster cooking, and steady light."
	quest.3400000000001116.title: "Furnace"
	quest.3400000000001119.quest_desc: [
		"Craft a Bed and sleep in it once to lock your spawn point. Any bed works here, so the color does not matter and modded beds like the skyroot or fancy variants count the same. Wool comes from sheep or string, so a few shears save you a long detour."
		"Sleeping also skips the night, which is the cheapest way to avoid the mobs a fresh base cannot fight off yet."
	]
	quest.3400000000001119.quest_subtitle: "Set your spawn before you wander."
	quest.3400000000001119.title: "Bed"
	quest.340000000000111C.quest_desc: [
		"Build a pair of chests. Free inventory space means you carry tools and food instead of dirt, and a sorted base saves real time once production picks up."
		"Put them by the &bfurnace&r and crafting table so the things you use most are one step away."
	]
	quest.340000000000111C.quest_subtitle: "Get your kit out of your pockets."
	quest.340000000000111C.title: "Storage"
	quest.340000000000111F.quest_desc: [
		"Stock a batch of torches and light up your base and the ground around it. Mobs spawn in the dark, so a well-lit perimeter stops most fights before they start."
		"Carry spares underground. A dark tunnel behind you is a free ambush."
	]
	quest.340000000000111F.quest_subtitle: "Light is your cheapest defense."
	quest.340000000000111F.title: "Torches"
	quest.3400000000001414.quest_desc: [
		"Gather wheat seeds from grass and plant them across your tilled soil. Keep water within four blocks of every plant so the whole plot stays hydrated and grows faster."
		"Bone meal will rush a stubborn plant, but a wide field beats forcing one row. Widen the plot now and harvests stop being a worry."
	]
	quest.3400000000001414.quest_subtitle: "Plant your first real crop."
	quest.3400000000001414.title: "Sow the Field"
	quest.340000000000141D.quest_desc: [
		"Stitch a full set of &bleather armor&r. Beyond the small protection, leather is the base layer &6Cold Sweat&r lets you insulate later, so each piece earns its place twice."
		"Wear it from the start. Even a few points of armor change how survivable an early mob hit is."
	]
	quest.340000000000141D.quest_subtitle: "Light cover that also holds heat."
	quest.340000000000141D.title: "Leather Armor"
	quest.3400000000001424.quest_desc: [
		"Bake bread from three wheat at a crafting table. It needs no furnace and no fuel, which makes it the food you fall back on while the rest of your kitchen comes together."
		"Keep a stack on you. Hunger ticks down whether or not you have something better waiting at home."
	]
	quest.3400000000001424.quest_subtitle: "Turn the harvest into a meal."
	quest.3400000000001424.title: "Bread"
	quest.3400000000001427.quest_desc: [
		"Build a &bComposter&r and feed it seeds, leaves, and surplus crops. Fill it seven times and it gives back bone meal, which speeds your next planting without hunting skeletons."
		"Run it next to the field so overflow goes straight in instead of rotting in a chest."
	]
	quest.3400000000001427.quest_subtitle: "Spare crops become bone meal."
	quest.3400000000001427.title: "Composter"
	quest.342A1EF584823D2C.quest_desc: [
		"Add a recipe to a building, starting with torches. Colony crafters produce only what you have taught them, so adding recipes is how a worker learns to make what you need."
		"Open the building's recipe list and feed it a pattern. You will be doing this often."
	]
	quest.342A1EF584823D2C.quest_subtitle: "Crafters only make what you teach them."
	quest.342A1EF584823D2C.title: "Teach a Recipe"
	quest.360E9E02A494217C.quest_desc: [
		"Add a &bBarracks Tower&r. Each tower attached to the Barracks houses and posts another guard, scaling your defense alongside your walls."
		"Ring the &bbarracks&r with them to cover every angle of an assault."
	]
	quest.360E9E02A494217C.quest_subtitle: "One more guard on the wall."
	quest.360E9E02A494217C.title: "Barracks Tower"
	quest.37BE190EE466D697.quest_desc: [
		"Upgrade the &bTown Hall&r to level five. A higher-level hall lifts your citizen cap and unlocks the larger buildings every other system grows under."
		"Gather the materials first, because it is a substantial build."
	]
	quest.37BE190EE466D697.quest_subtitle: "Raise the ceiling on everything."
	quest.37BE190EE466D697.title: "Town Hall, Level 5"
	quest.37E43341FA234E84.quest_desc: [
		"Raise the &bFlorist's Hut&r. The Florist grows flowers in a &bgreenhouse&r using magical compost, supplying the Dyer and brightening the colony."
		"It needs a steady feed of that compost, so keep the &bcomposter&r running."
	]
	quest.37E43341FA234E84.quest_subtitle: "Flowers grown under glass."
	quest.37E43341FA234E84.title: "Florist's Hut"
	quest.3AE1C3290500638F.quest_desc: [
		"Reach ten citizens. A colony of ten can cover its core jobs and start to specialize instead of just surviving."
		"Keep building homes to push the cap higher."
	]
	quest.3AE1C3290500638F.quest_subtitle: "Past scraping by."
	quest.3AE1C3290500638F.title: "Ten Citizens"
	quest.3B177A2622E16785.quest_desc: [
		"Upgrade ring bases into the garden's rings: the &bRing of Shining&r for light, the &bRing of Vampirism&r for life-steal on your hits, and the &bRing of Winds&r for a speed boost."
		"Each one sets a magical stone into the gold base, so make the bases first."
	]
	quest.3B177A2622E16785.quest_subtitle: "Light, life-steal, and speed."
	quest.3B177A2622E16785.title: "Garden Rings"
	quest.3B1DBEF6FB655D29.quest_desc: [
		"Grow the trickier crops: brambleroot, creep orchid, exaustum allium, hungry grass, and sthirn bush. Brambleroot draws blood. Wear the &bAlchemist's Glove&r to pick it."
		"Together with the first set they fill out your reagent shelf."
	]
	quest.3B1DBEF6FB655D29.quest_subtitle: "The plants that bite back."
	quest.3B1DBEF6FB655D29.title: "Harder Herbs"
	quest.3B40A769EDB26EA2.quest_desc: [
		"Place a &bPostbox&r and a &bStash&r. The Postbox lets you request items from the &bwarehouse&r from anywhere, and a Stash is a simple shared drop-off that couriers service."
		"Both cut down on hand-carrying across a growing town."
	]
	quest.3B40A769EDB26EA2.quest_subtitle: "Request and drop off remotely."
	quest.3B40A769EDB26EA2.title: "Postbox and Stash"
	quest.3B91163DE3DA885C.quest_desc: [
		"Build the &bNether Mine&r. Its worker makes timed off-screen Nether trips and returns with resources. This is a MineColonies worker exception, not a portal or personal Nether unlock."
		"Equip the worker well, since the run is dangerous and a poorly geared miner comes back empty."
	]
	quest.3B91163DE3DA885C.quest_subtitle: "A worker-only Nether route."
	quest.3B91163DE3DA885C.title: "Nether Mine"
	quest.3BBA2DF5A9F51CF5.quest_desc: ["Craft the Draconic Energy Transfuser. This convergence node records the final power-transfer component after its listed draconic and boss-route dependencies."]
	quest.3BBA2DF5A9F51CF5.quest_subtitle: "Complete the draconic power network."
	quest.3BBA2DF5A9F51CF5.title: "Energy Transfuser"
	quest.3CA98E14B6A82FF5.quest_desc: [
		"Bring back &bHoglin Hide&r once the Nether opens in the Renaissance; hoglins are its only source. &6Cold Sweat&r treats the hide as heat insulation, the counterpart to &bgoat fur&r for cold places."
		"Stock it before any deep dig or lava-heavy build, where overheating becomes the real threat."
	]
	quest.3CA98E14B6A82FF5.quest_subtitle: "Lining that keeps the heat out."
	quest.3CA98E14B6A82FF5.title: "Hoglin Hide"
	quest.3D0C727EB7D7D9FC.quest_desc: [
		"Make a &bLife Lantern&r on the Lantern Maker. Once placed, it speeds the growth of crops in the area around it."
		"Hang one over a plot and your planting matures faster with no extra work and no special farmland. Fuse it by stacking a lantern on the loaded Lantern Maker with the right catalysts. It is a quiet, hands-off boost for any farm you keep near your base."
	]
	quest.3D0C727EB7D7D9FC.quest_subtitle: "Optional flavor. Faster crops, no farmland required."
	quest.3D0C727EB7D7D9FC.title: "Life Lantern"
	quest.3F33D0F200BD6ED5.quest_desc: [
		"Plant a &6Regions Unexplored&r &bBlackwood Sapling&r and let it grow into a tree. A grove near base saves you from roaming for logs every time you build."
		"Bone meal hurries it along if you want shade and lumber sooner."
	]
	quest.3F33D0F200BD6ED5.quest_subtitle: "Start a renewable wood supply."
	quest.3F33D0F200BD6ED5.title: "Blackwood Sapling"
	quest.3F77375A5E0F0FFA.quest_desc: [
		"Reach seventy-five citizens. A settlement this size runs on deep specialization and constant logistics."
		"Only a well-managed colony sustains a population this large."
	]
	quest.3F77375A5E0F0FFA.quest_subtitle: "Nearly a city."
	quest.3F77375A5E0F0FFA.title: "Seventy-Five Citizens"
	quest.4066BDA88DF29832.quest_desc: ["Claim the &bGnome Shovel&r from a slain gnome. Light and quick, it digs with a mischievous edge."]
	quest.4066BDA88DF29832.quest_subtitle: "A digging tool with mischief in it."
	quest.4066BDA88DF29832.title: "Gnome Shovel"
	quest.4153010000010001.quest_desc: ["Keep the Ultimate Block in your inventory. Completing this quest seals the ascension capstone."]
	quest.4153010000010001.quest_subtitle: "Seal ascension capstone."
	quest.4153010000010001.title: "The Ultimate Block"
	quest.4153010000010002.quest_desc: ["Keep an Infinity Ingot in your inventory. Completing this quest advances the ascension stage."]
	quest.4153010000010002.quest_subtitle: "Advance ascension stage."
	quest.4153010000010002.title: "Infinity Ingot"
	quest.4252010000010009.quest_desc: [
		"Defeat the &c&lInfernal Dragon&r at its encounter site. This is a required fight before the finale, not an optional side route."
		"Its kill is a dependency of the final convergence at the Draconic Guardian, so the Ascension endgame will not open until this dragon is down. Bring your best gear and clear it."
	]
	quest.4252010000010009.quest_subtitle: "Required pre-finale boss."
	quest.4252010000010009.title: "Infernal Dragon"
	quest.425201000001000A.quest_desc: [
		"Defeat the &c&lKraken&r at its encounter site. This is a required pre-finale fight, not an optional boss-route check."
		"Along with Scylla and the Infernal Dragon, the Kraken must fall before the final convergence at the Draconic Guardian unlocks. Do not save it for later."
	]
	quest.425201000001000A.quest_subtitle: "Required pre-finale boss."
	quest.425201000001000A.title: "Kraken"
	quest.425201000001000B.quest_desc: ["Defeat &c&lChaos Guardian&r at the Chaos Island fight; this kill check awards the stage flags."]
	quest.425201000001000B.quest_subtitle: "Boss fight gate."
	quest.425201000001000B.title: "Chaos Guardian"
	quest.4252010000EE0001.quest_desc: [
		"&c&lScylla&r is a required Ascension boss from Cataclysm. She waits at the &bAcropolis&r, a structure that rises over warm oceans, so find the structure to find the fight. She commands water and weather, so fight from stable footing and expect the arena to move under you."
		"Kill Scylla and keep the guaranteed Essence of the Storm in your inventory."
		"Scylla follows the Kraken and is a dependency of the final convergence at the Draconic Guardian. Scylla, the Kraken, and the Infernal Dragon are all required before the finale opens, so none of the three can be skipped."
	]
	quest.4252010000EE0001.quest_subtitle: "Defeat the ocean-storm apex."
	quest.4252010000EE0001.title: "Scylla"
	quest.42560000EE000000.quest_desc: [
		"&c&lSirok&r, the Sandworm, is a Block Factory Bosses arena fight and a required Otherworldly boss. It burrows and surfaces, so read the sand and stay off the spot it is about to erupt from."
		"Keep the guaranteed Sandworm Gauntlet from the kill."
		"Sirok opens the final Otherworldly apex line, the last set of fights before the age hands off to Ascension. Treat these as your exit exam from the Otherworldly age."
	]
	quest.42560000EE000000.quest_subtitle: "Defeat the desert arena worm."
	quest.42560000EE000000.title: "Sirok, the Sandworm"
	quest.42560000EE010000.quest_desc: [
		"The &c&lVoid Worm&r from Alex's Mobs is an End-void apex and the last required Otherworldly boss. It is a long, serpentine horror that phases through the void, so pick an arena with footing and keep it in front of you."
		"Keep the guaranteed Void Worm Eye in your inventory."
		"This is the terminal of the Otherworldly apex line and a dependency of the age capstone that grants Ascension. With the Void Worm dead, the Otherworldly age is complete and the final age opens."
	]
	quest.42560000EE010000.quest_subtitle: "Defeat the End-void apex."
	quest.42560000EE010000.title: "The Void Worm"
	quest.4256010000010001.quest_desc: ["Gather every &bFusion Reactor&r part on the list. Slot them before you fuel the core."]
	quest.4256010000010001.quest_subtitle: "Parts before first fuel."
	quest.4256010000010001.title: "Fusion Reactor"
	quest.4256010000010002.quest_desc: ["Gather every &bQuantum Machine Hull&r part on the list. The hull frames every quantum machine ahead."]
	quest.4256010000010002.quest_subtitle: "Frame for quantum machines."
	quest.4256010000010002.title: "Quantum Machine Hull"
	quest.4256010000010003.quest_desc: ["Gather every &bFusion Reactor Controller&r part on the list. The controller is what lets you start the reactor safely."]
	quest.4256010000010003.quest_subtitle: "Seat the controller first."
	quest.4256010000010003.title: "Fusion Reactor Controller"
	quest.4256010000010004.quest_desc: ["The &c&lLeviathan&r does not wait in its arena. Summon it at the &bAltar of Abyss&r in the Sunken City with an &bAbyssal Sacrifice&r, then win the fight and keep the &bTidal Claws&r for the stage flag."]
	quest.4256010000010004.quest_subtitle: "Summon it, then fight."
	quest.4256010000010004.title: "The Leviathan"
	quest.4256010000010005.quest_desc: ["Keep a Hohlraum in your inventory. Completing this quest advances the fusion stage."]
	quest.4256010000010005.quest_subtitle: "Turn in the capsule."
	quest.4256010000010005.title: "Hohlraum"
	quest.4256010000010006.quest_desc: ["Keep Tidal Claws in your inventory to seal the run and grant Ascension."]
	quest.4256010000010006.quest_subtitle: "Finish every OW lane first."
	quest.4256010000010006.title: "Tidal Claws"
	quest.4256010000010007.quest_desc: ["The &c&lLeviathan&r is summoned, not found waiting. Craft an &bAbyssal Sacrifice&r, a costly ritual item: a nautilus shell, an &6Athame&r, &6Crystallized Coral&r, a heart of the sea, and blocks of diamond, emerald, iron, amethyst, and gold. Use it on the &bAltar of Abyss&r inside the Sunken City to raise the beast. Keep it until you reach the altar, it is consumed on the summon."]
	quest.4256010000010007.quest_subtitle: "Craft the Leviathan's summon."
	quest.4256010000010007.title: "Abyssal Sacrifice"
	quest.4256010000020001.quest_desc: [
		"Occultism's spirit hierarchy ends at the marid. You bound foliots, djinn, and afrits in earlier ages; this tier outclasses them all. Craft an unbound &bBook of Binding: Marid&r, then combine it with your Dictionary of Spirits to name and bind it."
		"The bound book summons a marid on the Summon Marid pentacle, chalked out like your earlier summoning circles but at the marid tier. Draw it carefully and check every rune before you activate."
		"The tier's key reagent comes from a rougher ritual. On the Summon Unbound Marid pentacle, offer a conduit, a prismarine gem, a prismarine shard, and a ghast tear, activate with your bound book, then strike the circle with a trident. The unbound marid that appears is hostile. Kill it and it drops marid essence, which every marid craft ritual ahead demands."
	]
	quest.4256010000020001.quest_subtitle: "The highest tier of spirit."
	quest.4256010000020001.title: "Book of Binding: Marid"
	quest.4256010000020002.quest_desc: [
		"Marid craft rituals begin with a proper surface. Craft the &bIesnium Anvil&r on the Craft Marid pentacle, the ritual circle for marid-tier bindings."
		"Lay out the ingredients: a vanilla anvil, three iesnium storage blocks, and one marid essence from the unbound marid you slew. Activate the ritual with your bound Book of Binding: Marid and the spirit hammers the pieces into the anvil."
		"Iesnium is expensive and three full blocks of it stings, but this anvil anchors the master tier. The crowning ritual of the line, the master miner spirit, comes next."
	]
	quest.4256010000020002.quest_subtitle: "A surface for master rituals."
	quest.4256010000020002.title: "Iesnium Anvil"
	quest.4256010000020003.quest_desc: [
		"The top of Occultism's mining line is the &bMarid Master Miner&r, a spirit that strips dimensional deposits better than any tier below it. It is made on the Craft Marid pentacle, activated with your bound marid book."
		"The ingredient list is a career in itself: a Deep Ores Afrit Miner, an iesnium pickaxe, a spirit attuned crystal, a netherite pickaxe, dragon breath, a totem of undying, a nether star, and marid essence. Lay all eight in the circle and start the ritual."
		"The marid tier pays off elsewhere too. Marid crushers run the tier-four crushing jobs, and marid smelter and crystallizer summons handle processing at the same grade. Bind what your base needs."
		"This miner is one of the proofs the Otherworldly convergence checks, so finish the ritual before you look toward the age capstone."
	]
	quest.4256010000020003.quest_subtitle: "The apex of spirit mining."
	quest.4256010000020003.title: "Master Miner Spirit"
	quest.4256010000020004.quest_desc: [
		"Mahou Tsukai's holy sword is not crafted. &bCaliburn&r is received. You sacrifice an enchanted sword to a lake and the lake gives back something better."
		"The known requirements: the sword must be enchanted, it must be yours, and it must be thrown properly into a lake large enough to accept it. Get any of that wrong and you have donated a sword to the fish."
		"The exact steps are the mod's secret to teach. Consult the Mahou Tsukai guidebook in game for the full procedure before you throw anything you care about."
		"Caliburn is a strong blade in its own right, but hold onto it either way. Its successor, Morgan, is made from it, and that path is darker."
	]
	quest.4256010000020004.quest_subtitle: "The sword from the lake."
	quest.4256010000020004.title: "Caliburn"
	quest.4256010000020005.quest_desc: [
		"A holy sword corrupts when it betrays love. To turn Caliburn into &bMorgan&r, tame a wolf, earn its loyalty, then kill it with Caliburn. In this pack the transform only accepts your own wolf, the companion the mod's book calls your best and most loyal friend."
		"Morgan feeds on the same sin that made it. Villager kills fuel its damage bonus and repair the blade, so the sword gets stronger the further you go."
		"It has two active powers. Right click launches an evil ball, and a keybind grants a brief Rage buff. The two share a cooldown, so spend them deliberately in a fight."
		"Morgan is the Otherworldly apex weapon and one of the proofs the age convergence checks. Whether it was worth the wolf is not a question the questbook answers."
	]
	quest.4256010000020005.quest_subtitle: "The corrupted blade."
	quest.4256010000020005.title: "Morgan"
	quest.4256010000020006.quest_desc: [
		"Unusual End hides its endgame smithing behind loot. Recover the &bPearlescent Upgrade Smithing Template&r and the &bAncient Armor Trim Smithing Template&r from End city additions."
		"These templates only appear in loot once you have reached the Otherworldly age. Chests opened in earlier ages held paper where the templates should be, so any End cities you already stripped are worth revisiting now."
		"Once you hold one pearlescent template, duplicate it at a crafting table with prismalite gems and a pearlescent ingot, so a single find covers a full armor set. The ancient trim is cosmetic pedigree; the pearlescent upgrade is the mechanical prize."
		"Both templates count toward the Otherworldly final convergence. Sweep the End until you have each in hand."
	]
	quest.4256010000020006.quest_subtitle: "Pearlescent and ancient templates."
	quest.4256010000020006.title: "Relics of the End"
	quest.4256010000030001.quest_desc: [
		"Five prophet hearts, one purpose. Set the five hearts and four &6Abhorrent&r crystals into the grid to craft the &4Perturbation&r. This is the summoning of the &4Dead God&r, and using it drags you back into the Pit the instant it takes hold."
		"The Dead God fights with everything its prophets knew, borrowing each of their powers in turn. Watch which prophet it wears, wait for the gap, and put it down. When it falls it leaves a &5Dead God Egg&r where it died. Do not break it."
	]
	quest.4256010000030001.quest_subtitle: "Summon the thing the prophets served."
	quest.4256010000030001.title: "The Dead God"
	quest.4256010000030002.quest_desc: [
		"The egg the Dead God left is a passage, not a prize. Leave it where it lies and let three nights pass. It cracks open on its own. Right click the cracked egg to fall through into &4Limbo&r."
		"Limbo is empty and screaming. &8Shadows&r drift across it, and each one you kill drops &8Black Chalk&r. Gather the chalk. You need it to leave this place, and you need it to call the last thing that lives here."
	]
	quest.4256010000030002.quest_subtitle: "Wait three moons, then step through."
	quest.4256010000030002.title: "Into Limbo"
	quest.4256010000030003.quest_desc: [
		"Four pieces of &8Black Chalk&r press into a &fTabula Rasa&r. It is your ride home from Limbo, and it is also a summons. Use it on a living Shadow and &5Meshuggeneh&r answers the call."
		"This is the true end of the Macabre road, the hidden god that stood behind the false five. Break it and the horror is finished for good. Keep a spare Tabula Rasa on you if you want a clean walk out afterward."
	]
	quest.4256010000030003.quest_subtitle: "The last thing in the dark."
	quest.4256010000030003.title: "Meshuggeneh"
	quest.4256010000050001.quest_desc: [
		"&6Gaze&r grows out of Malum's void tier. Infuse your &bEncyclopedia Esoterica&r with a single &5Umbral Spirit&r at the Spirit Altar and it returns as the &bEncyclopedia Unveiled&r, a spellbook that rides in a curio slot and documents everything that follows."
		"Everything Gaze adds is crafted on stations you already own: the Spirit Altar, the Runic Workbench, and soul binding. Nothing in the mod drops from loot. If you can pay the spirits, you can build it."
		"You will want the Weeping Well work from the Gilded charter behind you. Umbral spirits, malignant pewter, and hallowed gold are this arc's working currency."
	]
	quest.4256010000050001.quest_subtitle: "The book writes back."
	quest.4256010000050001.title: "Encyclopedia Unveiled"
	quest.4256010000050002.quest_desc: [
		"Infuse a soulwood item pedestal with soulwood, hallowed gold, malignant pewter plating, and all nine spirits to raise the &bEnchantment Workbench&r."
		"Place a book in the workbench and enchanted items on nearby pedestals, then empower the working with arcana. It lifts the enchantments off the pedestal items, leaves them inert, and combines everything onto the book. Soulwood pedestals strip matching enchantments instead of donating them, and adding an umbral spirit produces an anomalous result worth experimenting with."
	]
	quest.4256010000050002.quest_subtitle: "Enchantments, lifted whole."
	quest.4256010000050002.title: "Enchantment Workbench"
	quest.4256010000050003.quest_desc: [
		"Infuse a soulwoven pouch with six hallowed gold and a heavy eldritch spirit payment to make the &bSpirit-Channel Pouch&r."
		"Bind the pouch to a location and everything placed inside is disgorged on the other side. Use it as a remote deposit line: feed it drops mid-expedition and they arrive at the bound point back home."
	]
	quest.4256010000050003.quest_subtitle: "A hole in your inventory."
	quest.4256010000050003.title: "Spirit-Channel Pouch"
	quest.4256010000050004.quest_desc: [
		"Gaze adds eight runes for Malum's curio rune slots, all crafted at the &bRunic Workbench&r. Each takes a batch of bulk material plus one &5Umbral Spirit&r: wind charges for Eir, blighted gunk for Fafnir, revealed soulwood logs for Mimir, void salts for Nott, and so on down the list."
		"Their effects range from faster soul-shatter recovery to void damage against armored foes. Craft any one rune to complete this quest, and read the rest in the Encyclopedia before you spend the umbral."
	]
	quest.4256010000050004.quest_subtitle: "Bulk goods, one umbral each."
	quest.4256010000050004.title: "Runes of the Veil"
	quest.4256010000050005.quest_desc: [
		"Raise the &bVeil's Edge&r at the Spirit Altar from twenty-six soulwood logs, a cursed sapball, living flesh, blighted gunk, and a payment across eight spirit types. No umbral spirit is needed, just breadth."
		"The dagger favors the soul-shatter playstyle and has a second form that surfaces in use. The base dagger is the only craft, so this one infusion buys the whole weapon."
	]
	quest.4256010000050005.quest_subtitle: "A dagger with an appetite."
	quest.4256010000050005.title: "Veil's Edge"
	quest.4256010000050006.quest_desc: [
		"The payoff rack. The &bSpirit Saber&r changes its blade effect to match whatever spirit rides in your offhand. The &bSoul Rapier&r is a soulstained steel sword reforged to strike the soul directly. &bSeidhr&r fires bolts of rending void and drains life to recover its arcane charge. &bSplintered World&r is forged around a dragon egg and throws as an astral splinter."
		"Each is a Spirit Altar infusion built on void-tier stock: malignant pewter, fused consciousness, auric embers, hallowed gold. Craft any one of the four to complete the line. The Encyclopedia documents the other three when you are ready to expand the rack."
	]
	quest.4256010000050006.quest_subtitle: "Pick your instrument."
	quest.4256010000050006.title: "The Veil Arsenal"
	quest.4256011000EE0001.quest_desc: ["Forge a Sentient Sword. Place an iron sword in the Hellfire Forge with a Petty Spiritus Gem as the catalyst, and the forge rewrites the blade into a living weapon that scales its damage with your stored spiritus."]
	quest.4256011000EE0001.quest_subtitle: "Optional depth. Neo Vitae Sentient gear line."
	quest.4256011000EE0001.title: "The Sentient Blade"
	quest.4256011000EE0002.quest_desc: ["Keep any one piece in your inventory to complete this quest."]
	quest.4256011000EE0002.quest_subtitle: "Optional depth. Neo Vitae Sentient gear line."
	quest.4256011000EE0002.title: "Armor of Living Metal"
	quest.4256011000EE0003.quest_desc: ["Obtain the Sentient Pickaxe or the Sentient Axe. These are living tools that share the same resonance signature as the Sentient weapon set. Either suffices for this quest. Both scale their harvesting speed with your available LP, making a fully charged altar dramatically faster at harvesting. At high saturation the pickaxe will vein-mine entire ore clusters in a single swing."]
	quest.4256011000EE0003.quest_subtitle: "Optional depth. Neo Vitae Sentient gear line."
	quest.4256011000EE0003.title: "Sentient Toolkit"
	quest.4256011000EE0005.quest_desc: ["Keep any one Spiritus Gem in your inventory."]
	quest.4256011000EE0005.quest_subtitle: "Optional depth. Neo Vitae Spiritus soul economy."
	quest.4256011000EE0005.title: "Ascending Aspects"
	quest.4256011000EE0006.quest_desc: ["Obtain any of the five Spiritus soul types: Raw, Invictus, Nihilum, Ruina, or Vindicta. Each soul type corresponds to a different aspect of will. Raw is neutral, Invictus is strength, Nihilum is void, Ruina is destruction, Vindicta is vengeance. The complete soul palette unlocks every high-tier ritual synthesis in the Neo Vitae system. Each type drops from different mob categories in the Otherworldly biomes."]
	quest.4256011000EE0006.quest_subtitle: "Optional depth. Neo Vitae Spiritus soul economy."
	quest.4256011000EE0006.title: "The Five Souls"
	quest.4256011000EE0007.quest_desc: ["Complete the Transcendent Blood Orb quest after reaching the Otherworldly age. This optional convergence node confirms the Neo Vitae line is finished; it does not consume the orb."]
	quest.4256011000EE0007.quest_subtitle: "Optional depth. Neo Vitae convergence capstone."
	quest.4256011000EE0007.title: "Blood Beyond the Veil"
	quest.4256012000000201.quest_desc: [
		"Bottle the sun. This quest wants a &bLiquid D-T Fuel Bucket&r, the Mekanism fusion feedstock, and it is the convergence point of every deuterium and tritium line you built at Atomic."
		"The Mekanism route: run the &bElectrolytic Separator&r on heavy water for deuterium, breed &btritium&r from lithium in the &bSolar Neutron Activator&r, combine the two in the &bChemical Infuser&r into D-T fuel, then liquefy it in the &bRotary Condensentrator&r and bucket it."
		"The cross-mod feeds are live. The separator drinks any &bc:heavy_water&r, including MI's. The Rotary Condensentrator accepts MI's deuterium and tritium fluids through the &bc:deuterium&r and &bc:tritium&r tags. Pack bridges decant &6Nuclear Science&r cells into Mekanism chemicals, and MI's centrifuge trickle, 1 mB of tritium per 1000 mB hydrogen cycle, counts toward the same pool."
		"Fill a &bHohlraum&r with D-T fuel to ignite the Mekanism torus; the reward hohlraum is your igniter. The bucket is the program's diploma, and the Draconic reactor at Ascension checks for it."
	]
	quest.4256012000000201.quest_subtitle: "One fuel, three suns."
	quest.4256012000000201.title: "Fusion Fuel Program"
	quest.42BFA7916F2CD4FC.quest_desc: ["Claim the &bMask of Fury&r on its own. It is the combat mask of the pair (Umvuthana, 2 different bosses), leaning hard into offense when you want to end a fight fast."]
	quest.42BFA7916F2CD4FC.quest_subtitle: "The aggressive Umvuthana mask. (Optional)"
	quest.42BFA7916F2CD4FC.title: "Mask of Fury"
	quest.430475E11D259B74.quest_desc: [
		"Build the &bSmeltery&r. The Smelter cooks raw ore into ingots for the colony, freeing your own furnaces for other work."
		"Keep it fed with ore and fuel and it quietly stocks your metal supply."
	]
	quest.430475E11D259B74.quest_subtitle: "Ore into ingots."
	quest.430475E11D259B74.title: "Smeltery"
	quest.430B4618A0BFF120.quest_desc: [
		"Build an &bIcebox&r and ice it up. It radiates cold in a small radius, which keeps you from overheating in a desert biome or next to a wall of lava."
		"Heat is as dangerous as cold once you start mining deep, so it is worth building before you need it."
	]
	quest.430B4618A0BFF120.quest_subtitle: "The cooling counterpart to the boiler."
	quest.430B4618A0BFF120.title: "Icebox"
	quest.4341011000000001.quest_desc: ["Bind an &bAfrit&r. The third tier of &6Occultism&r's spirits takes a harsher ritual than the foliot and djinni you learned earlier, and its book of binding is the key to the age's stronger summons."]
	quest.4341011000000001.quest_subtitle: "A hotter contract."
	quest.4341011000000001.title: "Book of Binding Afrit"
	quest.4341011000000002.quest_desc: ["Set up a full reformation array: source pedestals holding the sulfur you spend, a target pedestal holding the sulfur you want, and the &bResult Pedestal&r where the converted essence lands. At Gilded scale, this is how rare sulfurs stop being rare."]
	quest.4341011000000002.quest_subtitle: "The array, complete."
	quest.4341011000000002.title: "Reformation Result Pedestal"
	quest.4341011000000004.quest_desc: [
		"Build &6Spectrum&r's &bSpirit Instiller&r inside its own focus structure, separate from the Fusion Shrine. The instiller combines the energies of two items, with a third object binding them."
		"The binding, reformation, catalyzer, and orb lines above all feed this capstone, so finish them first. This capstone is required for the atomic age grant."
	]
	quest.4341011000000004.quest_subtitle: "Magic lane capstone."
	quest.4341011000000004.title: "Spirit Instiller"
	quest.4341011000000005.quest_desc: ["Feed mercury shards into a &bMercury Catalyst&r. It slowly burns them down from crystal form into mercury flux, the raw energy that &6Theurgy&r's hungrier apparatus draws on directly."]
	quest.4341011000000005.quest_subtitle: "Optional: alchemy as energy."
	quest.4341011000000005.title: "Mercury Catalyst"
	quest.4341011000000100.quest_desc: ["Seek out &cUmvuthi&r, the Sunbird of &6Mowzie's Mobs&r, in an Umvuthana Grove in the savanna, and end his reign. The charter pays its respects with the &bSol Visage&r, his gilded effigy of the sun."]
	quest.4341011000000100.quest_subtitle: "Optional: an audience with the sun."
	quest.4341011000000100.title: "Umvuthi, the Sunbird"
	quest.43410110000001A0.quest_desc: [
		"Craft the Veneficus, the magician orb, by placing a block of gold on a Tier-2 Ara Vitae with 25,000 Life Essence banked."
		"A blood orb sets how much Life Essence you can hold and how powerful your blood magic can be. The magician orb raises that ceiling well above the apprentice tier. Craft it on an Ara Vitae built to at least tier two, which needs the surrounding runes to reach that rank."
		"This is the first rung of the orb ladder. Build up your altar's tier and essence supply, then step to the master orb next."
	]
	quest.43410110000001A0.quest_subtitle: "Raise the orb to the Magician tier."
	quest.43410110000001A0.title: "The Veneficus Orb"
	quest.43410110000001A1.quest_desc: [
		"Craft the Magus, the master orb, on a Tier-3 Ara Vitae."
		"The master orb lifts your Life Essence capacity another large step, unlocking the more demanding blood rituals and crafts. The recipe runs on a tier-three altar and consumes a weak blood shard, so keep your essence and shards stocked."
		"Raising the orb means raising the altar around it. Push to tier three, then continue to the archmage orb."
	]
	quest.43410110000001A1.quest_subtitle: "Raise the orb to the Master tier."
	quest.43410110000001A1.title: "The Magus Orb"
	quest.43410110000001A2.quest_desc: [
		"Craft the Dominus, the archmage orb, on a Tier-4 Ara Vitae."
		"This is the top orb the Gilded age gives you, with the largest essence capacity of the ladder. The recipe needs a tier-four altar and a hellforged block, so it draws on both your altar investment and the infernal materials you gathered earlier."
		"The archmage orb powers the heaviest blood work available now. It is the payoff for building your altar all the way up."
	]
	quest.43410110000001A2.quest_subtitle: "Raise the orb to the Archmage tier."
	quest.43410110000001A2.title: "The Dominus Orb"
	quest.43410110000001A3.quest_desc: [
		"Optional depth. Craft the Reinforced Augmented Capacity Rune to raise your altar's Life Essence capacity."
		"Altar runes shape what the altar can do, and capacity runes are the ones that let it hold more essence at once. More stored essence means you can complete larger crafts and rituals without the altar running dry mid-recipe."
		"This is optional but genuinely useful if your altar keeps emptying during big jobs. Ring the altar with these runes to give the orb ladder above the buffer it wants."
	]
	quest.43410110000001A3.quest_subtitle: "Why bigger altars matter"
	quest.43410110000001A3.title: "Augmented Capacity"
	quest.4341011000000201.quest_desc: [
		"Somewhere underground waits the &5Weeping Well&r, a ring of warped rock around a pool of primordial soup. &6Malum&r generates it as a real structure, so cave, mine, and keep your eyes open. Nothing you craft can summon it. You have to find it."
		"Spirit-infuse stone into Twisted Rock and Tainted Rock, then craft five of the first and four of the second into &bThe Device&r at a crafting table. Throw The Device into the pool. The well swallows what you feed it and belches the transmuted result back out. Collect &bThe Vessel&r it returns."
		"That is the well's entire interface. Items thrown in come back changed, so every void recipe from here on is a matter of tossing the right feedstock into the soup and picking up what it spits out."
	]
	quest.4341011000000201.quest_subtitle: "Throw it in."
	quest.4341011000000201.title: "The Weeping Well"
	quest.4341011000000202.quest_desc: [
		"Run the well as a production station. Throw in &bHex Ash&r and &bVoid Salts&r come back. Throw in &bRefined Soulstone&r for &bNull Slate&r. Throw in &bCthonic Gold&r for &bMalignant Lead&r. One item in, one item out."
		"Hex Ash is spirit-infused gunpowder with an arcane spirit. Refined Soulstone and Cthonic Gold come from the soulstone and cthonic ore lines you already run. Collect the ejected outputs promptly so nothing despawns in the soup."
		"Stockpile all three products. The pewter work ahead eats Null Slate eight pieces at a time, so a thin soulstone supply will stall the whole tier."
	]
	quest.4341011000000202.quest_subtitle: "Feed the pool."
	quest.4341011000000202.title: "Voidsmelted Materials"
	quest.4341011000000203.quest_desc: [
		"The well rejects living visitors. Step into the primordial soup and it hurls you back out. Survive the rejection and an &5Umbral Spirit&r crystallizes alongside you, the ninth arcana that no creature's death can provide."
		"Pushing mobs into the pool yields nothing. Only a player draws the well's attention. Every umbral recipe from here to the end of the arc spends these crystals, so make the jump a habit whenever you visit."
	]
	quest.4341011000000203.quest_subtitle: "Jump in yourself."
	quest.4341011000000203.title: "The Black Crystal"
	quest.4341011000000204.quest_desc: [
		"At the &bSpirit Altar&r, infuse an iron ingot with four &bRefined Soulstone&r plus wicked, earthen, and arcane spirits to draw out a &bSoulstained Steel Ingot&r."
		"Forge a piece of &bSoulstained Steel armor&r as well. Nothing you make here is wasted: every Malignant Stronghold piece later in this line is an upgrade infused directly onto the matching soulstained piece, so the set you build now is the set you will wear into the void tier."
	]
	quest.4341011000000204.quest_subtitle: "The soldier's alloy."
	quest.4341011000000204.title: "Soulstained Steel"
	quest.4341011000000205.quest_desc: [
		"&bMalignant Pewter&r is the void tier's structural alloy. One ingot infuses four iron ingots with one &bMalignant Lead&r, eight &bNull Slate&r, two netherite scrap, and heavy earthen and eldritch spirit payments."
		"The eight Null Slate per ingot are the real cost, and each slate is one Refined Soulstone fed through the well. Set up a steady soulstone line before you commit to gear, or the pool will feel like a second job."
	]
	quest.4341011000000205.quest_subtitle: "Lead, slate, and scrap."
	quest.4341011000000205.title: "Malignant Pewter"
	quest.4341011000000206.quest_desc: [
		"Upgrade a soulstained armor piece into &bMalignant Stronghold&r plate. Each piece infuses the matching soulstained piece with soulwoven silk, three malignant pewter plating, and a wide spread of earthen, aqueous, wicked, and eldritch spirits."
		"One piece completes this quest. The full set is the natural goal, and with the pewter line running the marginal cost of each extra piece is mostly spirits. This is Malum's terminal armor, built for the soul-ward playstyle the codex has been teaching all along."
	]
	quest.4341011000000206.quest_subtitle: "Pewter over steel."
	quest.4341011000000206.title: "The Stronghold Set"
	quest.4341011000000207.quest_desc: [
		"Build the &bMnemonic Hex Staff&r first: a totemic staff infused with eight &bMnemonic Fragments&r, four soulstained steel ingots, and soulwood planks. Mnemonic Fragments are refined brilliance fed through the well."
		"Then infuse the staff with two malignant pewter ingots, eight void salts, and aqueous, wicked, and eldritch spirits. The result is the &bErosion Scepter&r, the void tier's staff payoff and the most expensive single infusion in this line."
	]
	quest.4341011000000207.quest_subtitle: "The staff that unmakes."
	quest.4341011000000207.title: "Erosion Scepter"
	quest.4341011000000208.quest_desc: [
		"Infuse four alchemical calx, four refined soulstone, and two hex ash with arcane and earthen spirits to craft an &bAlchemical Impetus&r. It is not a consumable. It sits inside the &bSpirit Crucible&r as a durability-bearing catalyst while focusing recipes run against it."
		"Alter an impetus with gunpowder, cthonic gold, and six of a pure metal to tune it to that metal. A tuned impetus focuses spirits into metal nodes three at a time, and each node smelts into six nuggets. That is a standing ore-multiplication loop paid for in impetus durability."
		"When an impetus fractures, restore it at the Repair Pylon with cthonic gold fragments and spirits instead of recrafting it. Spirit Catalyzers speed the crucible up but chew through durability faster, so balance throughput against repair trips."
	]
	quest.4341011000000208.quest_subtitle: "Damage as a resource."
	quest.4341011000000208.title: "The Impetus Loop"
	quest.4348010000010000.quest_desc: ["Assemble &6Mekanism&r's &bfission reactor&r: casing, ports, fuel assemblies, control rods, logic adapter, and glass. Fed fissile fuel, it produces heat that sodium carries to the turbine hall, and consequences if you skip the control rods. Start small. Respect the logic adapter."]
	quest.4348010000010000.quest_subtitle: "First fission core."
	quest.4348010000010000.title: "Fission Reactor"
	quest.4348010000010001.quest_desc: ["Raise the &bIndustrial Turbine&r over the reactor's steam loop: casing, valves, rotors and blades, the rotational complex, coils, and condensers. It swallows the reactor's entire steam output and returns clean current and water to the boiler."]
	quest.4348010000010001.quest_subtitle: "Heat becomes the grid."
	quest.4348010000010001.title: "Industrial Turbine"
	quest.4348010000010002.quest_desc: ["Sink the &bNS fission core&r into its water pool with control rods and interface. It runs hotter than the Mekanism pile across the hall and burns the rods your pipeline presses. Two fission designs, one grid."]
	quest.4348010000010002.quest_subtitle: "The apex pipeline ignites."
	quest.4348010000010002.title: "NS Fission Core"
	quest.4348010000010003.quest_desc: ["Add the &bNuclear Boiler&r. It cooks yellowcake with acid into uranium hexafluoride gas and accepts either mod's yellowcake: Mekanism's enrichment line and NS's extractor pour into the same tank. This is the join that holds the whole nuclear ladder together."]
	quest.4348010000010003.quest_subtitle: "Yellowcake to gas."
	quest.4348010000010003.title: "Nuclear Boiler"
	quest.4348010000010004.quest_desc: ["Rack a finished &bfission fuel assembly&r. Ore to yellowcake to gas to pellet to rod to assembly, all in one object. Feed this into the reactor loop the machine empire chapter opens next."]
	quest.4348010000010004.quest_subtitle: "Full assembly in hand."
	quest.4348010000010004.title: "Fuel Assembly"
	quest.434801000002F001.quest_desc: [
		"Nuclear Science tracks radiation for real. Standing near an exposed core, handling spent fuel, or walking through fallout will poison you. Build the safety kit before it happens: a Geiger Counter to read exposure, Iodine Tablets to block uptake ahead of time, and Antidote to purge a dose you already took."
		"Radiation Shielding blocks the spread. Line your reactor room with it, and use the shielded doors and glass variants where you need access or sightlines. A shielded control room lets you watch the core at full power without a dose."
		"Keep the Geiger Counter on your hotbar whenever you work in the reactor hall. Numbers climb before symptoms do."
	]
	quest.434801000002F001.quest_subtitle: "Survive your own reactor."
	quest.434801000002F001.title: "Radiation Protocol"
	quest.4348011000000100.quest_desc: ["Build a &bThermoelectric Boiler&r between heat and turbine: casing, valves, and spare vents for the hall. It converts the reactor's heated coolant into the steam volume the big rotor actually wants, and the loop closes."]
	quest.4348011000000100.quest_subtitle: "The steam middleman."
	quest.4348011000000100.title: "Thermoelectric Boiler"
	quest.4348011000000101.quest_desc: ["Assemble the &blarge gas-burning&r and &blarge heat generators&r from &6More Machines&r. They are larger generator options for this power tier."]
	quest.4348011000000101.quest_subtitle: "Large gas and heat generators."
	quest.4348011000000101.title: "Large Generators"
	quest.4348011000000102.quest_desc: ["Install &6Nuclear Science&r's &bChemical Extractor&r. It leaches raw uranium into that mod's own &byellowcake&r. It is the first station of the apex fuel pipeline. Your Mekanism enrichment line feeds the same hopper: both yellowcakes pour into one barrel."]
	quest.4348011000000102.quest_subtitle: "The NS pipeline opens."
	quest.4348011000000102.title: "Chemical Extractor"
	quest.4348011000000103.quest_desc: ["Run the boiler's gas through your centrifuge until it presses &benriched pellets&r. Any one pellet type counts: uranium-235, uranium-238, or recovered plutonium. Pellets are the fuel pipeline's currency, and the main reactor recipes ahead spend them."]
	quest.4348011000000103.quest_subtitle: "The centrifuge pays out."
	quest.4348011000000103.title: "Enriched Pellets"
	quest.4348011000000104.quest_desc: ["Press your pellets into &bfuel rods&r. Any one rod grade counts: high-enriched, low-enriched, or plutonium. Each grade trades burn rate against lifetime, and the reactor cores in this chapter each have a favorite."]
	quest.4348011000000104.quest_subtitle: "Pellets, stacked and sealed."
	quest.4348011000000104.title: "Fuel Rods"
	quest.4348011000000105.quest_desc: ["Collect a &bspent rod&r, fissile dust, or fissile salt from the nuclear fuel chain."]
	quest.4348011000000105.quest_subtitle: "Spent fuel materials."
	quest.4348011000000105.title: "Spent Fuel"
	quest.4348011000000106.quest_desc: ["Assemble the &bMSR&r: core, control rods, interface, freeze plug, salt supplier, and fuel preprocessor. Its fuel is already molten salt, so the failure mode is a frozen plug instead of a crater. It is the reactor for operators who like sleeping."]
	quest.4348011000000106.quest_subtitle: "The core that cannot melt down."
	quest.4348011000000106.title: "Molten Salt Reactor"
	quest.4348011000000107.quest_desc: ["Wind &belectromagnets&r and &bboosters&r for the fusion ring. The torus wants a full thirteen-block diamond of them, so set the assembler on the job and clear a floor with a view."]
	quest.4348011000000107.quest_subtitle: "Thirteen by thirteen."
	quest.4348011000000107.title: "Ring Segments"
	quest.4348011000000108.quest_desc: ["Add the &bswitch&r, &bdiode&r, and &bgateway&r segments for the ring-control branch."]
	quest.4348011000000108.quest_subtitle: "Switch, diode, and gateway."
	quest.4348011000000108.title: "Ring Control"
	quest.4348011000000109.quest_desc: ["Fill a &bdeuterium cell&r and a &btritium cell&r. Deuterium distills out of ordinary water at the Chemical Extractor; tritium is made by running a filled deuterium cell through your fission reactor. Together they are what the torus burns."]
	quest.4348011000000109.quest_subtitle: "Heavy water and starlight."
	quest.4348011000000109.title: "Fusion Fuel Cells"
	quest.434801100000010A.quest_desc: ["Seat the &bfusion core&r and interface inside the completed ring and feed it deuterium and tritium cells. Megawatts pour out of fuel you distilled from water and sunlight."]
	quest.434801100000010A.quest_subtitle: "A sun with plumbing."
	quest.434801100000010A.title: "Fusion Reactor"
	quest.434801100000010B.quest_desc: ["Hang &bsteam funnels&r over the reactor pool. They gather the boil-off the core throws and pipe it somewhere useful instead of letting it vanish into the hall."]
	quest.434801100000010B.quest_subtitle: "Catch the boil."
	quest.434801100000010B.title: "Steam Funnel"
	quest.434801100000010C.quest_desc: ["Feed the funnels into &bNS turbines&r. They hand the steam back as current, simple and direct, scaled exactly to the core beneath them."]
	quest.434801100000010C.quest_subtitle: "The pool pays out."
	quest.434801100000010C.title: "NS Turbine"
	quest.434801100000010D.quest_desc: ["Build a &bFallout Scrubber&r. It is part of Nuclear Science's radiation-management toolset."]
	quest.434801100000010D.quest_subtitle: "Optional: clean the air after."
	quest.434801100000010D.title: "Fallout Scrubber"
	quest.434801100000010E.quest_desc: ["Build a &bSiren&r for the Nuclear Science control-room toolkit."]
	quest.434801100000010E.quest_subtitle: "Build a warning siren."
	quest.434801100000010E.title: "Siren"
	quest.434801100000010F.quest_desc: ["Rack the &breactor logistics&r suite: controller, supply, monitor, thermometer, and control rod modules."]
	quest.434801100000010F.quest_subtitle: "Optional: the control room."
	quest.434801100000010F.title: "Reactor Logistics"
	quest.4348011000000110.quest_desc: ["Build a &bQuantum Capacitor&r. It is Nuclear Science's large-capacity energy storage option."]
	quest.4348011000000110.quest_subtitle: "Build a quantum capacitor."
	quest.4348011000000110.title: "Quantum Capacitor"
	quest.4348011000000111.quest_desc: ["Seal a pellet into a &bRadioisotope Generator&r. It is a compact power source in the Nuclear Science branch."]
	quest.4348011000000111.quest_subtitle: "Optional: decades on one pellet."
	quest.4348011000000111.title: "Radioisotope Generator"
	quest.4348011000000112.quest_desc: ["Power up the &bNS Teleporter&r."]
	quest.4348011000000112.quest_subtitle: "Build the teleporter."
	quest.4348011000000112.title: "NS Teleporter"
	quest.4348011000000113.quest_desc: ["Place the &bNS chunkloader&r. It is the chunk-loading utility in the Nuclear Science branch."]
	quest.4348011000000113.quest_subtitle: "Optional: the plant stays on."
	quest.4348011000000113.title: "NS Chunkloader"
	quest.4348011000000114.quest_desc: ["Install the &bParticle Injector&r. It feeds matter into an accelerator loop and slams it together at speeds the fusion ring taught you to generate. The exotic outputs feed the assembler beside it."]
	quest.4348011000000114.quest_subtitle: "The accelerator loads."
	quest.4348011000000114.title: "Particle Injector"
	quest.4348011000000115.quest_desc: ["Set a &bCloud Chamber&r beside the loop. It is a Nuclear Science diagnostic block."]
	quest.4348011000000115.quest_subtitle: "Optional: watch the invisible."
	quest.4348011000000115.title: "Cloud Chamber"
	quest.4348011000000116.quest_desc: ["Finish the physics wing with the &bAtomic Assembler&r. It constructs matter directly from the accelerator's products, the endgame fabricator of the conventional sciences."]
	quest.4348011000000116.quest_subtitle: "Built one atom at a time."
	quest.4348011000000116.title: "Atomic Assembler"
	quest.4348011000000117.quest_desc: ["Roll &6Modern Industrialization&r's &bnuclear casings&r and hatches."]
	quest.4348011000000117.quest_subtitle: "Casings and nuclear hatches."
	quest.4348011000000117.title: "MI Nuclear Casings"
	quest.4348011000000118.quest_desc: ["Commission the &bMI Nuclear Reactor&r. This optional branch covers Modern Industrialization's nuclear reactor path."]
	quest.4348011000000118.quest_subtitle: "Optional: the factory's own pile."
	quest.4348011000000118.title: "MI Nuclear Reactor"
	quest.4348011000000119.quest_desc: ["Build the &bImplosion Compressor&r. It is part of the Modern Industrialization processing toolkit."]
	quest.4348011000000119.quest_subtitle: "Optional: pressure by detonation."
	quest.4348011000000119.title: "Implosion Compressor"
	quest.434801100000011A.quest_desc: ["Scale Refined Storage's chemical line to &b8192 buckets&r, parts, block, and disk."]
	quest.434801100000011A.quest_subtitle: "8192b chemical storage set."
	quest.434801100000011A.title: "Chemical Storage 8192b"
	quest.434801100000011B.quest_desc: ["Craft an &6Applied Mekanistics&r &bchemical cell housing&r."]
	quest.434801100000011B.quest_subtitle: "Optional: ME learns chemistry."
	quest.434801100000011B.title: "Chemical Cell Housing"
	quest.434801100000011C.quest_desc: ["Press any &bchemical storage cell&r, 1k through 256k."]
	quest.434801100000011C.quest_subtitle: "Any 1k-256k chemical cell."
	quest.434801100000011C.title: "Chemical Cells"
	quest.434801100000011D.quest_desc: ["Fabricate &6MEGA&r's &bradioactive cell component&r."]
	quest.434801100000011D.quest_subtitle: "Build the radioactive component."
	quest.434801100000011D.title: "Radioactive Cell Component"
	quest.4348012000000201.quest_desc: [
		"Feed nine &buranium dust&r into the &6Modern Industrialization&r &bCentrifuge&r. The spin splits the isotopes: one &buranium-235 tiny dust&r and eighty &buranium-238 tiny dust&r per batch."
		"The input is the &bc:dusts/uranium&r tag, so every plant in the pack feeds MI. Mekanism enrichment, Oritech grinding, ATO smelter dust: one shared stockpile, one centrifuge hopper. That shared dust economy is the whole point of this island."
		"U-235 is the scarce fissile fraction; U-238 is fertile ballast. Keep both. The blends next door consume them in exact ratios."
	]
	quest.4348012000000201.quest_subtitle: "Nine dusts, two isotopes."
	quest.4348012000000201.title: "Isotope Separation"
	quest.4348012000000202.quest_desc: [
		"Blend the isotopes in the &bMixer&r. &bLE uranium&r is eight parts &buranium-238&r to one part &buranium-235&r; &bHE uranium&r runs hotter at six to three. Both work at dust and tiny-dust scale and return nine per batch."
		"LE is the everyday fuel: cooler, efficient, forgiving. HE burns hotter and richer but demands real cooling and triples your U-235 spend."
		"Your U-235 trickle is the constraint, so budget it. LE stretches one part fissile across nine parts fuel, which is why the first reactor load is always LE."
	]
	quest.4348012000000202.quest_subtitle: "LE for work, HE for heat."
	quest.4348012000000202.title: "Enrichment Blends"
	quest.4348012000000203.quest_desc: [
		"Roll fuel hardware in the &bAssembler&r: LE uranium plus blastproof alloy curved plates, a large motor, soldering alloy, and helium becomes an &bLE Uranium Fuel Rod&r. Double and quad rods come later from the &bPacker&r with &bnuclear alloy plates&r; single rods are enough for first fire."
		"Now the brakes. Cut &bcadmium rods&r on the &bCutting Machine&r, two per cadmium ingot, and assemble a &bCadmium Control Rod&r. Cadmium comes from centrifuging &bmonazite dust&r; monazite ore generates deep underground and Electrodynamics carries its own veins of it."
		"Control rods eat neutrons. Slot them beside fuel to slow the reaction and flatten the heat curve while you learn the reactor's temperament."
	]
	quest.4348012000000203.quest_subtitle: "Fuel rods and the brakes."
	quest.4348012000000203.title: "Rod Assembly"
	quest.4348012000000204.quest_desc: [
		"Assemble the &bMI Nuclear Reactor&r from the casing quest's parts, load an &bLE uranium fuel rod&r behind a control rod, keep water on it, and let it run."
		"This quest asks for a &bdepleted&r LE fuel rod, and no recipe makes one. It exists only after a rod burns out inside a running reactor. That makes this the chain's one true runtime proof: no shortcut, no crafting grid, just a pile that actually went critical."
		"Mind the water flow and the heat while the rod cooks down; the burn also converts some of the rod's fertile U-238 as it runs. When it reads depleted, pull the corpse. The recycling quest wants it."
	]
	quest.4348012000000204.quest_subtitle: "The rod that proves the burn."
	quest.4348012000000204.title: "First Criticality"
	quest.4348012000000205.quest_desc: [
		"Recycle the depleted rod in the &bCentrifuge&r. It returns &buranium-238 tiny dust&r, a little recovered &buranium-235&r, and the prize: &bplutonium tiny dust&r bred inside the rod during the burn."
		"Pack nine tiny dusts into a full &bplutonium dust&r, then run it through the &bBlast Furnace&r for a &bPlutonium Ingot&r."
		"The ingot is proof the fuel cycle closed: ore in, energy out, new fissile material left over. The MOX Program spends it next."
	]
	quest.4348012000000205.quest_subtitle: "The burn left you plutonium."
	quest.4348012000000205.title: "Breeder's Dividend"
	quest.4348012000000206.quest_desc: [
		"Mix MOX in the &bMixer&r: eight &buranium-238 dust&r plus one dust from the &bc:dusts/plutonium&r tag yields nine &bLE MOX dust&r. Blast-furnace it to ingots and assemble an &bLE MOX Fuel Rod&r exactly the way you rolled uranium rods."
		"The plutonium slot is the cross-mod link. Oritech collisions, grinder byproducts, Mekanism pellets, and Nuclear Science reprocessing all land in the same tag; the Plutonium Stockpile quest in the Oritech convergence banked it for exactly this."
		"MOX burns your breeding gains and recycling returns instead of fresh U-235. &bHE MOX&r exists too, six to three, when your plutonium stock can afford it. A fleet that runs MOX is a fuel cycle, not a fuel line."
	]
	quest.4348012000000206.quest_subtitle: "Burn the byproduct."
	quest.4348012000000206.title: "The MOX Program"
	quest.4348012000000207.quest_desc: [
		"Centrifuge plain water: 1000 mB in, 20 mB &bheavy water&r out. It is a trickle by design, so dedicate a machine and let it spin while you work the fuel side."
		"Heavy water is the fusion program's feedstock, and it is shared. MI publishes it to the &bc:heavy_water&r fluid tag, and &6Mekanism&r's &bElectrolytic Separator&r drinks MI heavy water directly through that tag. One pool, two fusion programs, zero conversion steps."
	]
	quest.4348012000000207.quest_subtitle: "Twenty millibuckets at a time."
	quest.4348012000000207.title: "Heavy Water Draw"
	quest.4348012000000208.quest_desc: [
		"Pack a &bMixed Nuclear Plate&r in the &bPacker&r: one blastproof alloy plate, one &bberyllium plate&r, one &bcadmium plate&r. Then detonate it in the &bImplosion Compressor&r with &bindustrial TNT&r; one mixed plate shatters into three &bNuclear Alloy Plates&r."
		"Nuclear alloy is the metal of the reactor family: casing components, and the plating that packs single fuel rods into doubles and quads. Optional depth, but a stack pressed now saves a re-tool when your reactor fleet grows."
	]
	quest.4348012000000208.quest_subtitle: "Optional: plates for the pile."
	quest.4348012000000208.title: "Nuclear Alloy"
	quest.4348012000000209.quest_desc: [
		"Draw the fusion pair and bucket both. Electrolyze &bheavy water&r for &bdeuterium&r: 3000 mB splits into 2000 mB deuterium plus oxygen. That side is fast."
		"Tritium is the slow half. Centrifuging 1000 mB of hydrogen returns 20 mB deuterium and exactly 1 mB of &btritium&r per cycle, so a full bucket is roughly a thousand cycles. Parallelize centrifuges and start the line early. This grind is deliberate; the scale-up is D-D fusion at Otherworldly, where the reactor breeds its own."
		"Both fluids are shared infrastructure: MI publishes them to &bc:deuterium&r and &bc:tritium&r, Mekanism's &bRotary Condensentrator&r accepts those tags natively, and pack bridges fill &6Nuclear Science&r cells from the same tags. The Fusion Fuel Program at Otherworldly cashes all of this in."
	]
	quest.4348012000000209.quest_subtitle: "Deuterium fast, tritium slow."
	quest.4348012000000209.title: "Twin Gases"
	quest.4348012000000210.quest_desc: [
		"Hold any yellowcake from the &bc:yellow_cake_uranium&r tag. Three plants pour into it: &6Nuclear Science&r's &bChemical Extractor&r leaches raw uranium, &6Mekanism&r's &bEnrichment Chamber&r presses one uranium ingot into two &bYellow Cake Uranium&r, and a pack bridge joins &6Create Nuclear&r's compacted yellowcake to the same tag."
		"The consumers are NS machines. The &bNuclear Boiler&r and the &bMSR Fuel Pre-Processor&r both read the tag, so any plant's yellowcake feeds the NS pipeline. That is the interchange: three chemistry lines, one barrel."
		"Create Nuclear's own enrichment line is untouched; it still consumes its literal item. The bridge only lets the surplus flow toward NS instead of sitting in a drawer."
	]
	quest.4348012000000210.quest_subtitle: "Three chemistry lines, one barrel."
	quest.4348012000000210.title: "Yellowcake Interchange"
	quest.4358010000010000.quest_desc: ["Craft the &bender splice&r, a &bperturbed eye&r, and &bradiating ender&r from &6Spectrum&r. The deep arcana converges on the same peak as your reactors, and these three pieces are the entry ticket."]
	quest.4358010000010000.quest_subtitle: "Spectrum reaches deeper."
	quest.4358010000010000.title: "Radiating Ender"
	quest.4358010000010001.quest_desc: [
		"Wake and survive &c&lTremorzilla&r, Alex's Caves' walking catastrophe, and keep the &begg&r. This is a required Atomic fight, not an optional deterrent."
		"Its kill feeds the Atomic age capstone, so the age does not close until Tremorzilla is down. No paperwork. Just teeth."
	]
	quest.4358010000010001.quest_subtitle: "Required Atomic boss."
	quest.4358010000010001.title: "Tremorzilla"
	quest.4358010000010002.quest_desc: ["Defeat &c&lGeburah&r and take the &bjustice core&r it guards. The core is the proof the chaos gate demands; lane capstones and the silenced prophets must be done before it opens."]
	quest.4358010000010002.quest_subtitle: "The gatekeeper of the chaos gate."
	quest.4358010000010002.title: "Geburah"
	quest.4358010000010003.quest_desc: ["Present the &bjustice core&r once dawn, chain, soul, war, the silenced prophets, and &cGeburah&r are done. The Oritech &bCritical Assembly&r fission reactor is on this checklist as a required dependency, so finish it before you present the core. This hands the stage to the &dOtherworldly&r age."]
	quest.4358010000010003.quest_subtitle: "Core and lanes complete."
	quest.4358010000010003.title: "The Chaos Gate"
	quest.4358010000EE0F01.quest_desc: [
		"The &c&lWatcher&r is a required Atomic boss, an occult horror of Alex's Caves' Forlorn Hollows, called forth when the underzealots there sacrifice a gloomoth. It punishes carelessness, so mind what it does when you look at it and keep your approach deliberate."
		"Keep the guaranteed Occult Gem in your inventory to complete this proof."
		"The Watcher follows the Luxtructosaurus kill and feeds into Tremorzilla, which in turn drives the Atomic age capstone. It is the second-to-last link in the Atomic boss ladder."
	]
	quest.4358010000EE0F01.quest_subtitle: "Defeat the Abyssal Chasm horror."
	quest.4358010000EE0F01.title: "The Watcher"
	quest.4358010000EE0F02.quest_desc: [
		"&c&lLuxtructosaurus&r is a required Atomic boss, woken by tossing an &bOminous Catalyst&r into the top of a volcano deep in the Primordial Caves of Alex's Caves. It is a walking mountain of an apex predator, so fight it with room to run and reactor-tier gear on your back."
		"Bring it down and collect the &bTectonic Shard&r it drops in bulk. Turn the shard in here to log the kill."
		"This fight follows the Geburah exam and feeds forward into the Watcher. That lane runs Geburah into Luxtructosaurus into the Watcher into Tremorzilla, and the whole chain fans into the Atomic age capstone."
	]
	quest.4358010000EE0F02.quest_subtitle: "Defeat the Primordial Caves apex."
	quest.4358010000EE0F02.title: "Luxtructosaurus"
	quest.4358011000000100.quest_desc: ["Cut a &bBedrock Anvil&r. It works materials ordinary anvils shatter against, and Spectrum's deepest recipes will accept no other surface."]
	quest.4358011000000100.quest_subtitle: "Optional: forge on the world's floor."
	quest.4358011000000100.title: "Bedrock Anvil"
	quest.4358011000000101.quest_desc: ["Frame the &bDeeper Down portal&r and bottle &bmidnight solution&r from the dark beneath it. Spectrum's hidden depth opens at the height of the atomic age. It hints at what the Otherworldly age has planned."]
	quest.4358011000000101.quest_subtitle: "Open Spectrum's below-bedrock route."
	quest.4358011000000101.title: "Midnight Solution Descent"
	quest.4358011000000102.quest_desc: ["Claim an abyssal weapon from the caves' keepers: the &bortholance&r, the &bsea staff&r, or the &bdesolate dagger&r. Each one is a boss's signature move with a handle on it."]
	quest.4358011000000102.quest_subtitle: "Optional: weapons from the deep caves."
	quest.4358011000000102.title: "Abyssal Arms"
	quest.4358011000000103.quest_desc: ["Recover a relic of the deep caves: the &bmagic conch&r, &bgazing pearl&r, &boccult gem&r, &btelecore&r, or &bnotor gizmo&r. Each came off something that did not want to give it up."]
	quest.4358011000000103.quest_subtitle: "Optional: the deep keeps souvenirs."
	quest.4358011000000103.title: "Cave Relics"
	quest.4358011000000104.quest_desc: ["Hold an &beye&r of Chesed, Geburah, or Malkuth. These &6FD&r boss relics gate the chaos capstone ahead."]
	quest.4358011000000104.quest_subtitle: "Optional: what they saw, you keep."
	quest.4358011000000104.title: "Eyes of the Prophets"
	quest.4358011000000105.quest_desc: ["Take the &bLaser Gatling&r from &6Cataclysm&r's machine horrors. It is the only gun in the pack that feels like it was built by the things you fight, because it was."]
	quest.4358011000000105.quest_subtitle: "Optional: the harbinger's argument."
	quest.4358011000000105.title: "Laser Gatling"
	quest.4358011000000106.quest_desc: ["Charge the &binfinity drill&r and &binfinity saw&r. They eat stored FE instead of durability and reshape terrain in swathes. This is what the gilded charger bay was built for."]
	quest.4358011000000106.quest_subtitle: "Optional: charged past reason."
	quest.4358011000000106.title: "Infinity Tools"
	quest.4358011000000107.quest_desc: ["Finish the set with the &binfinity hammer&r and &binfinity trident&r. One crushes crowds, the other returns to hand through any weather, and both drink from the same bottomless battery."]
	quest.4358011000000107.quest_subtitle: "Optional: the wet and the loud."
	quest.4358011000000107.title: "Infinity Arms"
	quest.4358011000EE0001.quest_desc: ["Grow and harvest a &bCrystal Cluster&r, the keystone material of the Transcendent altar tier. This luminous growth is Blood Magic's highest structural ingredient. Place it in your sanctum and begin constructing the altar that will let you bind a Transcendent Blood Orb."]
	quest.4358011000EE0001.quest_subtitle: "Optional: the altar's keystone crystal."
	quest.4358011000EE0001.title: "Crystalline Resonance"
	quest.4358011000EE0002.quest_desc: ["Craft &bCrystal Cluster Bricks&r to construct the Transcendent altar structure. The altar's power depends on its geometry. The bricks are the load-bearing element that focuses ritual energy into the orb slot above."]
	quest.4358011000EE0002.quest_subtitle: "Optional: build the altar's body."
	quest.4358011000EE0002.title: "The Sacred Masonry"
	quest.4358011000EE0003.quest_desc: ["Attune a &bTranscendent Blood Orb&r at the completed altar. Every blood ritual you have performed leads here. It amplifies your self-sacrifice into ritual power that lesser orbs cannot match."]
	quest.4358011000EE0003.quest_subtitle: "Required: the apex of the covenant."
	quest.4358011000EE0003.title: "Apex of the Covenant"
	quest.4358011000EE0004.quest_desc: ["Forge a &bSimple Key&r from hellforged reagents. The Neo Vitae dungeon does not announce itself. You must locate the entrance yourself and unlock it. The key is the first of three tiers; the corridors demand progressively heavier authorization to descend."]
	quest.4358011000EE0004.quest_subtitle: "Optional: the dungeon's first gate."
	quest.4358011000EE0004.title: "Key to the Pit"
	quest.4358011000EE0005.quest_desc: ["Enter the &bNeo Vitae dungeon&r dimension. The architecture is alien and deliberately hostile. Every room is an obstacle and a source. The chests hold the keys that open deeper doors, and the enemies drop the reagents the dungeon runs on."]
	quest.4358011000EE0005.quest_subtitle: "Optional: descend into the ritual complex."
	quest.4358011000EE0005.title: "Descent into the Dungeon"
	quest.4358011000EE0006.quest_desc: ["Obtain a &bStandard Key&r from the dungeon's chests. The deeper corridors require it. Antechamber and dungeon chests carry them; this key unlocks the passages to the dungeon's most dangerous residents."]
	quest.4358011000EE0006.quest_subtitle: "Optional: clear the mid-level passage."
	quest.4358011000EE0006.title: "Standard Clearance"
	quest.4358011000EE0007.quest_desc: ["Craft a &bHellforged Explosive Cell&r, the dungeon's deep reagent, distilled from demonite and blood ritual. It is weapon and ritual component in one: concentrated destructive energy from the dungeon's own ore, turned against its inhabitants."]
	quest.4358011000EE0007.quest_subtitle: "Optional: the dungeon's signature reagent."
	quest.4358011000EE0007.title: "Hellforged Ordnance"
	quest.4358011000EE0008.quest_desc: ["Mine &bDemonite&r from the dungeon's ore veins. Its dark resonance suits weapon augmentation and trim work. The dungeon yields it in quantity; the trim ingot itself is forged at the Hellfire Forge from a hellforged ingot, an animus mote, and a weak blood shard."]
	quest.4358011000EE0008.quest_subtitle: "Optional: the dungeon's signature ore."
	quest.4358011000EE0008.title: "Demonite Cache"
	quest.4358011000EE0009.quest_desc: ["Fell the &bForeman&r guarding the mine works. His treasure runs to hellforged metal, upgrade tomes, and keys for the deeper doors, and the kill puts the dungeon's most fortified resident off your back."]
	quest.4358011000EE0009.quest_subtitle: "Optional: the Foreman's authorization."
	quest.4358011000EE0009.title: "The Foreman's Gate"
	quest.43EB13F2C3D91789.quest_desc: [
		"Place the &bBlack Foundry Controller&r and raise the foundry around it. The controller runs the multiblock, melting ores and metals into fluid for casting."
		"Follow the layout in the foundry's own guide. A misplaced block keeps the whole structure from forming."
	]
	quest.43EB13F2C3D91789.quest_subtitle: "The brain of the smeltery."
	quest.43EB13F2C3D91789.title: "Black Foundry Controller"
	quest.442C27F2E00B325C.quest_desc: ["Hunt the Hermit Abysswalker far underground. It hits hard in the dark, so carry light and wear real armor before you go looking for it."]
	quest.442C27F2E00B325C.quest_subtitle: "Bring light into the deep."
	quest.442C27F2E00B325C.title: "Hermit Abysswalker"
	quest.44430000EE010000.quest_desc: [
		"The &c&lLunar Monstrosity&r is the apex of Eternal Starlight and a required Otherworldly boss. It cannot be hurt while it is dormant."
		"You must ignite it first. Light it using the saltpeter matchbox before it will take any damage, then keep the pressure up once it wakes. Like Permafrost, it has no loot table, so the kill is its own proof and there is nothing to collect."
		"This is the terminal of the Starlight boss line and a dependency of the Otherworldly chapter grant. Ignite it, break it, and the Forge dimension is settled."
	]
	quest.44430000EE010000.quest_subtitle: "Ignite and defeat the Starlight apex."
	quest.44430000EE010000.title: "Lunar Monstrosity"
	quest.4443010000010001.quest_desc: ["Gather every &bQuantum Ring&r part on the list. The ring is the frame for quantum storage."]
	quest.4443010000010001.quest_subtitle: "Frame for quantum storage."
	quest.4443010000010001.title: "Quantum Ring"
	quest.4443010000010002.quest_desc: ["Gather every &bNetwork Transmitter&r part on the list. It links distant machine rooms without cable spaghetti."]
	quest.4443010000010002.quest_subtitle: "Link distant machine rooms."
	quest.4443010000010002.title: "Network Transmitter"
	quest.4443010000010003.quest_desc: ["Gather every &bQIO Dashboard&r part on the list. The dashboard is how you drive bulk quantum storage."]
	quest.4443010000010003.quest_subtitle: "Drive bulk quantum storage."
	quest.4443010000010003.title: "QIO Dashboard"
	quest.4443010000010004.quest_desc: ["Gather every &bTeleporter&r part on the list. Short-range hops start once the frame is complete."]
	quest.4443010000010004.quest_subtitle: "Short hops once built."
	quest.4443010000010004.title: "Teleporter"
	quest.4443010000010005.quest_desc: ["Gather every &bQuantum Core&r part on the list. The core is what makes the ring worth building."]
	quest.4443010000010005.quest_subtitle: "Core makes the ring work."
	quest.4443010000010005.title: "Quantum Core"
	quest.4443010000010006.quest_desc: ["Complete the set to seal this quantum stage."]
	quest.4443010000010006.quest_subtitle: "Seal the quantum stage."
	quest.4443010000010006.title: "Quantum Multi Threader"
	quest.4443010000010007.quest_desc: ["Hold &bQuantum Storage 128&r. The ring needs bulk quantum storage before the next tier opens."]
	quest.4443010000010007.quest_subtitle: "Bulk storage for the ring."
	quest.4443010000010007.title: "Quantum Storage 128"
	quest.4443010000020001.quest_desc: [
		"The &bMatter Condenser&r is AE2's trash compactor, and at the top end it is a forge for &bSingularities&r. Drop items in and they are destroyed. On the low setting the condenser pays you back in &bMatter Balls&r. Slot a &b64k Storage Component&r into the condenser and switch it to singularity mode, and it will compress 256,000 items worth of matter into a single &bSingularity&r."
		"Feed it anything you do not want. Cobblestone, dirt, and farm overflow all count the same. An import bus or exporter pointed at the condenser turns your junk overflow into singularity progress while you work on other things."
		"Keep a Singularity, a Matter Ball, and a Shattered Singularity in your inventory to move on."
	]
	quest.4443010000020001.quest_subtitle: "Crush a universe of items into one point."
	quest.4443010000020001.title: "Condensed Matter"
	quest.4443010000020002.quest_desc: [
		"The AdvancedAE &bQuantum Computer&r is a multiblock, not a single machine. Its shell is built from &bQuantum Structure&r blocks, crafted from quartz glass and sky stone. Place them as the frame of the structure, then fill the interior with the quantum units and cores you assembled earlier in this chapter."
		"The structure also needs its infusion step. Run a &bShattered Singularity&r through an inscriber press to get &bQuantum Infused Dust&r. That dust preps the infusion fluid the multiblock consumes to come online."
		"Craft a Quantum Structure block and the Quantum Infused Dust for this quest, then get the frame standing. A formed quantum computer is the crafting brain everything in the next quest plugs into."
	]
	quest.4443010000020002.quest_subtitle: "Frame the quantum computer."
	quest.4443010000020002.title: "Quantum Architecture"
	quest.4443010000020003.quest_desc: [
		"The &bQuantum Crafter&r is AdvancedAE's heavy-duty pattern machine. Building one takes &bShattered Singularities&r, &bQuantum Accelerators&r, a &b64k Storage Component&r, and a &bQuantum Unit&r, so keep the condenser from the earlier quest running."
		"Pair it with the &bQuantum Crafter Terminal&r, crafted from a pattern access terminal and a quantum processor. The terminal is where you write and manage the patterns the crafter executes."
		"Craft both and slot them into your network. From here on, bulk endgame crafts run through this pair instead of clogging your regular molecular assemblers."
	]
	quest.4443010000020003.quest_subtitle: "Pattern crafting at quantum scale."
	quest.4443010000020003.title: "The Quantum Crafter"
	quest.4443010000020004.quest_desc: [
		"The &bWireless Quantum Crafter Terminal&r puts the quantum crafter interface in your pocket, so you can edit patterns from anywhere in range."
		"ExtendedAE fills out the rest of the wireless kit. The &bWireless Hub&r broadcasts your network, the &bWireless Connector&r bridges network segments without a physical cable run, and the &bWireless Pattern Terminal&r handles pattern work remotely."
		"Craft all four pieces. With the interdimensional transmitter from the neighboring quest also in hand, your logistics no longer care where you are standing. This lane feeds the chapter capstone."
	]
	quest.4443010000020004.quest_subtitle: "Your whole network, from anywhere."
	quest.4443010000020004.title: "Untethered Networks"
	quest.4443010000020005.quest_desc: [
		"The &bInterdimensional Wireless Transmitter&r does one thing and does it absolutely. Place two paired transmitters and a redstone signal into one comes out of the other, across any distance and across any dimension."
		"The transmitters come in 16 dye colors, and each color is its own channel. That gives you 16 independent cross-dimensional redstone lines before you ever have to think about layout. Craft the black variant for this quest; the other colors work the same way."
		"Use it to arm machines at home while you are offworld, or to let a base in another dimension flip systems here. Combined with the wireless network gear next door, control stops being local."
	]
	quest.4443010000020005.quest_subtitle: "Redstone that ignores dimensions."
	quest.4443010000020005.title: "Signal Across Worlds"
	quest.4443010000020006.quest_desc: [
		"Your QIO drive array is only as good as the drives in it. The &bQIO Drive&r is the base tier and holds 16,000 items. Craft one and slot it into the drive array you built earlier in this chapter."
		"The &bHyper-Dense QIO Drive&r is the first upgrade, eight times the capacity at 128,000 items per drive. It is built on top of base drives, so make a few extras."
		"Craft both tiers for this quest. Two more tiers wait above these, and they will ask for something your Atomic reactors can provide."
	]
	quest.4443010000020006.quest_subtitle: "From 256k to a million items."
	quest.4443010000020006.title: "QIO Drive Ladder I"
	quest.4443010000020007.quest_desc: [
		"The top of the QIO ladder runs on your pellet lines. The &bTime-Dilating QIO Drive&r takes polonium and plutonium pellets, and the &bSupermassive QIO Drive&r at the very top consumes &bAntimatter Pellets&r from the SPS you built back in the Atomic chapters."
		"If your SPS has been idle, spin it up now and let it stockpile. Each pellet is expensive, so budget your antimatter between these drives and the nucleosynthesizer quest in this same lane."
		"Craft one of each drive. A drive array filled with these holds more items than you will ever produce, which is exactly the point."
	]
	quest.4443010000020007.quest_subtitle: "Antimatter as a storage medium."
	quest.4443010000020007.title: "QIO Drive Ladder II"
	quest.4443010000020008.quest_desc: [
		"The &bPortable QIO Dashboard&r is the payoff for the whole QIO lane. It is a handheld item that opens your entire QIO frequency from anywhere, no block placement required."
		"Craft it, then bind it to your frequency the same way you set up the stationary dashboard. Every drive you slotted into the array is now readable and writable from your hotbar."
		"This is a lane end. With bulk storage solved and access made portable, this line feeds directly into the chapter capstone."
	]
	quest.4443010000020008.quest_subtitle: "The whole QIO system in your hand."
	quest.4443010000020008.title: "Dashboard To Go"
	quest.4443010000020009.quest_desc: [
		"The &bAntiprotonic Nucleosynthesizer&r is Mekanism's endgame transmutation machine. It consumes &bAntimatter&r from your Atomic-era SPS to rebuild one material into another at the nuclear level."
		"Its most important product for this chapter is alloy work. The nucleosynthesizer forges the subatomic alloy that unlocks the quantum machine tier, which the Evolved Mekanism quests ahead are built on."
		"Craft the machine and pipe it antimatter and power. Keep it fed; the next several quests all trace their ingredients back to this block."
	]
	quest.4443010000020009.quest_subtitle: "Transmutation, powered by antimatter."
	quest.4443010000020009.title: "Nucleosynthesis"
	quest.4443010000020010.quest_desc: [
		"Evolved Mekanism adds machine tiers above ultimate, and quantum is the first of them. The path runs through the nucleosynthesizer you just built: process &bHypercharged Alloy&r with antimatter to produce &bSubatomic Alloy&r, the signature material of the quantum tier."
		"With subatomic alloy in hand, upgrade your overclocked factories into their quantum versions. This quest wants the &bQuantum Alloying Factory&r, &bQuantum Enriching Factory&r, &bQuantum Smelting Factory&r, and &bQuantum Crushing Factory&r."
		"Build all four. The throughput jump is enormous, and these factories are also the stepping stone for the mekmm multiblock line and the multiversal tier beyond."
	]
	quest.4443010000020010.quest_subtitle: "Factories rebuilt at the subatomic level."
	quest.4443010000020010.title: "Quantum Factories"
	quest.4443010000020011.quest_desc: [
		"Quantum factories need quantum plumbing. This quest covers the storage and transfer half of the tier: the &bQuantum Bin&r for item stockpiles, the &bQuantum Fluid Tank&r and &bQuantum Chemical Tank&r for liquids and gases, and the &bQuantum Universal Cable&r to move power at tier-appropriate rates."
		"All of them build on the ultimate-tier versions with the same subatomic alloy chain from the previous quest, so your nucleosynthesizer keeps earning its antimatter."
		"Craft one of each. Once the buffers and cabling match the factories, nothing in your Mekanism line bottlenecks on logistics."
	]
	quest.4443010000020011.quest_subtitle: "Storage and transfer to match the factories."
	quest.4443010000020011.title: "Quantum Infrastructure"
	quest.4443010000020012.quest_desc: [
		"Your induction matrix gets the quantum treatment too. The &bQuantum Induction Cell&r raises how much energy the matrix can store, and the &bQuantum Induction Provider&r raises how fast it can move that energy in and out."
		"Both parts are built around the quantum energy cube, so finish your quantum machine chain first if you have not."
		"Craft one cell and one provider and swap them into your matrix casing. The matrix formed back in the Atomic age scales up without rebuilding the shell; only the internals change."
	]
	quest.4443010000020012.quest_subtitle: "A power bank for the new tier."
	quest.4443010000020012.title: "Quantum Induction"
	quest.4443010000020013.quest_desc: [
		"Above quantum sits the multiversal tier, the top of the Evolved Mekanism ladder. Its material is &bExoversal Alloy&r, made by infusing &bSingular Alloy&r with &bPlaslitherite&r. Plaslitherite itself comes from netherite, lithium, and HDPE, so your Mekanism chemical line covers every input."
		"Once exoversal alloy is flowing, upgrade your quantum factories. This quest asks for the &bMultiversal Alloying Factory&r, &bMultiversal Enriching Factory&r, and &bMultiversal Smelting Factory&r."
		"Build all three. There is no tier after this one; these factories are the fastest machines Mekanism will ever give you."
	]
	quest.4443010000020013.quest_subtitle: "The tier above quantum."
	quest.4443010000020013.title: "Multiversal Factories"
	quest.4443010000020014.quest_desc: [
		"The multiversal induction parts are the top of the energy ladder. The &bMultiversal Induction Cell&r and &bMultiversal Induction Provider&r use the same exoversal alloy chain as the factories, so extend the production line you already have running."
		"Slot them into your induction matrix in place of the quantum internals. Storage and throughput both jump to their final values, enough to buffer anything the pack can throw at you, Dyson output included."
		"This is a lane end. Craft the pair and the Mekanism line is finished; it feeds straight into the chapter capstone."
	]
	quest.4443010000020014.quest_subtitle: "The last word in energy storage."
	quest.4443010000020014.title: "Multiversal Induction"
	quest.4443010000020015.quest_desc: [
		"Mekanism More Machines extends the factory system to processes the base factories never covered. At this tier, its overclocked multiblock factories upgrade to quantum using &bSubatomic Alloy&r and quantum circuits from your Evolved Mekanism line. The AdvancedAE item named Quantum Alloy is a different material and does not work here."
		"This quest wants three of them: the &bQuantum Centrifuging Factory&r, the &bQuantum Crystallizing Factory&r, and the &bQuantum Pressurised Reacting Factory&r. Together they parallelize your isotope, crystal, and reaction chemistry the same way ordinary factories parallelize smelting."
		"Build all three. If your fissile fuel or polonium lines have been single-machine bottlenecks since the Atomic age, this is where that ends."
	]
	quest.4443010000020015.quest_subtitle: "The big factories go quantum."
	quest.4443010000020015.title: "Quantum Multiblock Factories"
	quest.4443010000020016.quest_desc: [
		"The mekmm line tops out at multiversal, matching the Evolved Mekanism ladder. Upgrade your quantum multiblock factories with the exoversal alloy chain to reach the &bMultiversal Centrifuging Factory&r, &bMultiversal Crystallizing Factory&r, and &bMultiversal Pressurised Reacting Factory&r."
		"These are the last processing machines in the pack's Mekanism tree. Every centrifuge, crystallizer, and reaction chamber recipe you have ever queued now runs at its maximum possible rate."
		"This is a lane end. Craft the trio and the heavy chemistry line is complete, feeding into the chapter capstone."
	]
	quest.4443010000020016.quest_subtitle: "Chemistry at its final scale."
	quest.4443010000020016.title: "Multiversal Multiblock Factories"
	quest.4448010000010001.quest_desc: ["Place the &bChaotic Crafting Injector&r. Chaotic-tier fusion crafts route through this injector."]
	quest.4448010000010001.quest_subtitle: "Chaotic fusion route."
	quest.4448010000010001.title: "Chaotic Crafting Injector"
	quest.4448010000010002.quest_desc: ["Hold a &bChaotic Core&r. The chaotic fusion line wants this core seated first."]
	quest.4448010000010002.quest_subtitle: "Seat the chaotic core."
	quest.4448010000010002.title: "Chaotic Core"
	quest.4448010000010003.quest_desc: ["Place the &bChaos Infuser&r. It feeds chaotic recipes their infusion step."]
	quest.4448010000010003.quest_subtitle: "Feeds chaotic infusions."
	quest.4448010000010003.title: "Chaos Infuser"
	quest.4448010000010004.quest_desc: ["Keep a Chaos Heart in your inventory. Completing this quest advances the chaotic draconic stage."]
	quest.4448010000010004.quest_subtitle: "Turn in the heart."
	quest.4448010000010004.title: "Chaos Heart"
	quest.4448010000010005.quest_desc: ["Keep a Chaos Injector in your inventory. Completing this quest seals this chaotic stage."]
	quest.4448010000010005.quest_subtitle: "Seal chaotic stage."
	quest.4448010000010005.title: "Chaos Injector"
	quest.4448012000000201.quest_desc: [
		"Build the chaos processing line from &6Draconic Additions&r: the &bChaos Liquifier&r, &bChaos Crystalizer&r, &bChaos Extractor&r, and a &bChaos Container&r. Together they turn chaos from a boss trophy into a working fluid."
		"The Liquifier melts &bchaos shards&r into liquid chaos. The Crystalizer runs the loop backward, growing shards out of stored liquid. The Extractor drains &bChaos Hearts&r and any modular item carrying a Chaos Stabilizer module. The Container holds the liquid safely in your inventory; loose chaos is not a survivable storage plan."
		"Keep the container stocked. The &bChaos Infuser&r you just built spends liquid chaos on the tier's top-end work, and a refinery loop means every heart you win keeps paying instead of gathering dust."
	]
	quest.4448012000000201.quest_subtitle: "Chaos as a working fluid."
	quest.4448012000000201.title: "Chaos Refinery"
	quest.44540000EE000000.quest_desc: [
		"The Ender Dragon was never the End's last word. A greater guardian stirs there once the Dragon is gone. This step sends you back through the End portal to hunt it."
		"Entering the End completes the objective. This is a light staging node for the thin Otherworldly boss line, so no items are needed yet."
		"Once you are back in the End, look for the apex construct that spawns after the Dragon. The next step is the fight itself, so land somewhere safe and prepare before you go looking."
	]
	quest.44540000EE000000.quest_subtitle: "Re-enter the End for its apex guardian."
	quest.44540000EE000000.title: "Return to the End"
	quest.4454010000010001.quest_desc: [
		"Draconium is the metal this whole chapter runs on, and the world has finally let you see it. &bDraconium Ore&r generates in stone, deepslate, netherrack, and end stone, but until the Otherworldly age it sat disguised as plain rock. Now the disguise is off and the ore is minable, so go dig."
		"Smelt or process the ore into &bDraconium Dust&r and &bDraconium Ingots&r. Gather every part on this quest's list. Draconic crafting wants the full bundle before anything else moves."
		"Check all four rock types as you stockpile: the overworld layers, the Nether, and the End islands all carry veins. The ingots feed every core, crystal, and machine downstream, so mine more than you think you need."
	]
	quest.4454010000010001.quest_subtitle: "Draconic bundle seated."
	quest.4454010000010001.title: "Draconium Ingot"
	quest.4454010000010002.quest_desc: ["Gather every &bWyvern Core&r part on the list. The core is the first serious Draconic multiblock heart."]
	quest.4454010000010002.quest_subtitle: "First Draconic multiblock heart."
	quest.4454010000010002.title: "Wyvern Core"
	quest.4454010000010003.quest_desc: ["Gather every &bCrafting Core&r part on the list. Fusion crafting routes through this core."]
	quest.4454010000010003.quest_subtitle: "Fusion routes through here."
	quest.4454010000010003.title: "Crafting Core"
	quest.4454010000010004.quest_desc: ["Gather every &bEnergy Core&r part on the list. Bank the power the Draconic line will demand."]
	quest.4454010000010004.quest_subtitle: "Bank Draconic power."
	quest.4454010000010004.title: "Energy Core"
	quest.4454010000010005.quest_desc: ["Keep an Energy Transfuser in your inventory. Completing this quest seals this Draconic stage."]
	quest.4454010000010005.quest_subtitle: "Seal Draconic stage."
	quest.4454010000010005.title: "Energy Transfuser"
	quest.4454010000020001.quest_desc: [
		"Draconic Evolution moves power through crystals instead of cables. A &bBasic Relay Crystal&r is the backbone. Place two of them within range of each other and link them, and flux beams between them with no pipe run in between. Craft one from diamonds around a &bWyvern Energy Core&r."
		"Relays only carry power. To get flux in or out of a machine you need a &bBasic I/O Crystal&r, a shapeless craft from one relay crystal. Place it on a machine face, link it into the relay chain, and set it to input or output. The &bBasic Wireless Crystal&r covers the last case: a relay crystal plus a Particle Generator, an ender pearl, and an eye of ender makes a crystal that links straight to blocks that have no crystal attached."
		"Linking is done with the Crystal Binder tool. Click one crystal, then the other, and the beam forms. Craft the three crystal types here and sketch out your first network. Your Energy Core from the last step is the obvious thing to wire up first."
	]
	quest.4454010000020001.quest_subtitle: "Draconic energy, point to point"
	quest.4454010000020001.title: "Basic Energy Crystals"
	quest.4454010000020002.quest_desc: [
		"Basic crystals cap out fast once real Draconic machines come online. The wyvern tier widens the pipe. A &bWyvern Relay Crystal&r carries far more flux per tick and accepts more simultaneous links, so one relay can serve a whole bank of machines instead of one or two."
		"The upgrade path reuses what you have. A basic relay crystal plus a &bWyvern Energy Core&r and a &bDraconium Core&r crafts the wyvern relay. The &bWyvern I/O Crystal&r is shapeless from one wyvern relay, and the &bWyvern Wireless Crystal&r takes the relay with a Particle Generator, an ender pearl, and an eye of ender, the same pattern as the basic tier."
		"Rebuild your trunk lines at wyvern tier and keep the basic crystals for low-draw branches. This is the end of the crystal lane. The Energy Transfuser capstone is waiting once the other lanes are done."
	]
	quest.4454010000020002.quest_subtitle: "Wider pipes, more links"
	quest.4454010000020002.title: "Wyvern Energy Crystals"
	quest.4454010000020003.quest_desc: [
		"The &bParticle Generator&r is a small block with two jobs. Craft it from a block of redstone, a blaze rod, and a &bDraconium Core&r."
		"First job: it is a crafting ingredient. Every wireless crystal, basic and wyvern alike, wants one in the recipe, so you will be making several as your network grows."
		"Second job: it feeds the Energy Core multiblock. Particle Generators convert into the stabilizers that pin the core's energy sphere in place. Make a few spares now and both roles are covered."
	]
	quest.4454010000020003.quest_subtitle: "Stabilizer fuel and light shows"
	quest.4454010000020003.title: "Particle Generator"
	quest.4454010000020004.quest_desc: [
		"Draconic Evolution ships a compact power option of its own. The &bGenerator&r burns ordinary furnace fuel and pushes out RF. Craft it from nether bricks, iron, a furnace, and a &bDraconium Core&r. It will not run your endgame, but it keeps a fusion setup or a grinder fed without dragging your main grid over."
		"The &bPotentiometer&r is the control half of this node. Planks, redstone dust, draconium dust, and a stone slab make a wall-mounted dial that emits an adjustable redstone signal. Right click to step the strength up or down."
		"Craft both. The generator covers spot power, the potentiometer covers fine throttle control on anything redstone-aware. Together they make the small-machine corner of the mod self-sufficient."
	]
	quest.4454010000020004.quest_subtitle: "Small furnace power, fine control"
	quest.4454010000020004.title: "Generator and Potentiometer"
	quest.4454010000020005.quest_desc: [
		"The &bMob Grinder&r turns RF into kills. Place it facing a mob pen, give it power, and it strikes down anything that wanders into the zone in front of it, then collects the drops."
		"The recipe reflects what it does: iron, a draconium ingot, a diamond sword, a &bWyvern Energy Core&r, and a skull. Feed it from your crystal network or park the furnace Generator next to it."
		"Point it at a dark-room spawner or a funnel of mobs and let it run. Pull the drops out with a hopper underneath. The Disenchanter in the next step gives all that dropped gear somewhere useful to go."
	]
	quest.4454010000020005.quest_subtitle: "Automated slaughter, player-grade loot"
	quest.4454010000020005.title: "Mob Grinder"
	quest.4454010000020006.quest_desc: [
		"The &bDisenchanter&r pulls enchantments off gear and writes them onto books. Craft it from an emerald, a &bDraconium Core&r, an enchanted book, an enchanting table, and a bookshelf."
		"Put an enchanted item in one slot and a plain book in the other. The machine strips the enchantment onto the book, ready to apply to something better on an anvil."
		"This pairs directly with the grinder feeding it. Mob drops arrive pre-enchanted, the Disenchanter harvests the enchantments, and the junk gear goes to whatever scrap line you like. Free books, no lapis, no grind."
	]
	quest.4454010000020006.quest_subtitle: "Strip enchantments onto books"
	quest.4454010000020006.title: "Disenchanter"
	quest.4454010000020007.quest_desc: [
		"The &bDraconium Chest&r is your first fusion recipe in the machines lane, so treat this quest as fusion practice. Set a chest in the Fusion Crafting Core as the catalyst. Load the injectors with five furnaces, two &bDraconium Cores&r, two crafting tables, and a block of draconium, then power the injectors and start the craft."
		"What comes out is worth the ceremony. The chest holds an enormous number of stacks, runs built-in furnaces that smelt from its own inventory, and carries a crafting grid in the same interface. One block replaces a wall of chests, a furnace bank, and a work table."
		"Craft one and move your Draconic stockpile into it. This closes the machines lane. The Energy Transfuser capstone opens once the other lanes catch up."
	]
	quest.4454010000020007.quest_subtitle: "Storage, smelting, and crafting in one block"
	quest.4454010000020007.title: "Draconium Chest"
	quest.4454010000020008.quest_desc: [
		"The &bDislocator&r is a teleport charm made on a plain crafting table. Ring blaze powder around draconium dust and an eye of ender and it is done. No fusion needed."
		"Bind it by sneaking and using it where you want to return to. From then on, using the charm teleports you back to that spot, spending a little of its stored charge each jump. Recharge it and it keeps working."
		"Bind one to your base before you go dragon hunting. Everything in the rest of this lane, the magnet, the pedestal, the portal receptacle, builds on this one charm."
	]
	quest.4454010000020008.quest_subtitle: "A teleport charm in your pocket"
	quest.4454010000020008.title: "Dislocator"
	quest.4454010000020009.quest_desc: [
		"The &bItem Dislocator&r is a magnet. While it is toggled on in your inventory, dropped items nearby fly straight to you. No more chasing drops off ledges or into lava lips."
		"It is built directly on the last quest: redstone dust, draconium ingots, iron, and a crafted &bDislocator&r in the middle. Make a second charm if you already bound your first one to home."
		"Toggle it with a use, and leave it on for mining and mob farming. It pairs especially well with the Mob Grinder room, hoovering anything the grinder's own pickup misses."
	]
	quest.4454010000020009.quest_subtitle: "The magnet that never sleeps"
	quest.4454010000020009.title: "Item Dislocator"
	quest.4454010000020010.quest_desc: [
		"Dislocators can serve a whole base, not just your pocket. The &bDislocator Pedestal&r is a mounted pad crafted from a stone pressure plate, stone, a slab, and blaze powder. Place a bound dislocator on it and anyone who uses the pedestal takes the jump. Set one at each end and you have a public two-way line."
		"The &bDislocator Receptacle&r goes further and holds a dislocator inside a portal frame, making a walk-through gateway. Its recipe is iron, a &bDraconium Core&r, and infused obsidian. Infused obsidian itself is a simple craft: obsidian with draconium dust and blaze powder."
		"Craft both. Pedestals for cheap point-to-point hops, receptacle portals for the routes your whole team walks daily. Charge the dislocators inside and the network runs itself."
	]
	quest.4454010000020010.quest_subtitle: "Public transit for dislocators"
	quest.4454010000020010.title: "Pedestal and Receptacle"
	quest.4454010000020011.quest_desc: [
		"Teleportation cuts both ways. The &bDislocation Inhibitor&r projects a field that blocks dislocator teleportation in its area, so nobody pops into your vault uninvited."
		"The recipe is iron, iron bars, and an &bItem Dislocator&r, which is why the magnet came first. Place the inhibitor where you want the dead zone and dislocator jumps into that space simply fail."
		"Set one over anything you would hate to lose. This closes the dislocation lane. The Energy Transfuser capstone unlocks once the other lanes are finished too."
	]
	quest.4454010000020011.quest_subtitle: "No teleporting past this sign"
	quest.4454010000020011.title: "Dislocation Inhibitor"
	quest.4454010000020012.quest_desc: [
		"Wyvern gear is your diamond kit reforged in the Fusion Crafting Core. The &bWyvern Pickaxe&r, &bWyvern Shovel&r, and &bWyvern Axe&r each use the matching diamond tool as the catalyst, with a &bDraconium Core&r, draconium ingots, basic relay crystals, and a &bWyvern Energy Core&r loaded in the injectors."
		"These tools run on RF instead of durability. They arrive empty, so charge them before you swing. Your Energy Core plus a charging path handles that. As long as flux remains they never break."
		"They also accept modules, upgrades slotted in through the tool's own configuration screen, so a wyvern tool grows with you instead of being replaced. Fuse all three and retire your diamond set for good."
	]
	quest.4454010000020012.quest_subtitle: "Diamond tools, fusion reforged"
	quest.4454010000020012.title: "Wyvern Tools"
	quest.4454010000020013.quest_desc: [
		"The same fusion treatment works on weapons. The &bWyvern Sword&r fuses on a diamond sword catalyst and the &bWyvern Bow&r on a bow, each with the familiar ingredient family: draconium core, draconium ingots, relay crystals, and a wyvern energy core in the injectors."
		"Like the tools, both draw RF instead of durability. Keep them charged and they never dull or snap mid-fight. Both accept modules too, so damage, speed, and utility upgrades slot in as you find better ones."
		"Fuse the pair and you have weapons that scale into the rest of the Otherworldly age. The chestpiece in the next step completes the combat set."
	]
	quest.4454010000020013.quest_subtitle: "Sword and bow with a flux budget"
	quest.4454010000020013.title: "Wyvern Arms"
	quest.4454010000020014.quest_desc: [
		"The &bWyvern Chestpiece&r is the armor core of the Draconic line. Fuse it on a diamond chestplate catalyst, same tier and same ingredient family as your tools and weapons."
		"It does not work like normal armor. Instead of raw armor points it projects an energy shield that soaks damage and recharges from the chestpiece's RF buffer. Keep it charged and the shield keeps standing back up."
		"It is also the main module host of the armor set. Shield capacity, recharge rate, and utility modules all slot in here. Fuse it, charge it, and configure the modules before your next hard fight."
	]
	quest.4454010000020014.quest_subtitle: "A shield generator you can wear"
	quest.4454010000020014.title: "Wyvern Chestpiece"
	quest.4454010000020015.quest_desc: [
		"A full wyvern kit drains fast in the field, and running home to the Energy Core mid-expedition is not a plan. The &bWyvern Capacitor&r fixes that. It is a portable battery that recharges the wyvern gear in your inventory as you go."
		"It fuses at wyvern tier on a &bWyvern Core&r catalyst, with several &bWyvern Energy Cores&r and draconium ingots in the injectors. Fill it at base before you leave and it quietly tops up your tools, weapons, and chestpiece."
		"This closes the gear lane. With crystals, machines, dislocation, and gear all done, the Energy Transfuser capstone is the only thing left in the chapter spine."
	]
	quest.4454010000020015.quest_subtitle: "Pocket flux for hungry gear"
	quest.4454010000020015.title: "Wyvern Capacitor"
	quest.4454010000020016.quest_desc: [
		"The &bCelestial Manipulator&r spends RF to change the time of day and the weather. Skip the night, summon a thunderstorm, or clear the rain on command. It is the flavor apex of this chapter."
		"The price is the recipe. It crafts on a plain table from blocks of redstone, a clock, draconium ingots, iron, a &bWyvern Core&r, and a &bDragon Egg&r. There is exactly one way to get that egg: kill the Ender Dragon. You have already returned to the End in this chapter, so the fight is the last errand."
		"Claim the egg carefully after the kill, bring it home, and craft the manipulator. Wire it to your crystal network, and the sky itself answers to your flux budget."
	]
	quest.4454010000020016.quest_subtitle: "Wind the sun with a dragon's egg"
	quest.4454010000020016.title: "Celestial Manipulator"
	quest.451E7BC527C955B7.quest_desc: [
		"Grow the first plants: blood rose, bubblis, cloudelion, glow fungus, and toxic cap. Each is an alchemy ingredient. A small bed of every kind keeps your brewing stocked."
		"Plant them in &bmixed soil&r and harvest as they mature."
	]
	quest.451E7BC527C955B7.quest_subtitle: "Start the garden."
	quest.451E7BC527C955B7.title: "First Herbs"
	quest.4646010000010000.quest_desc: ["Hunt down Valamon in the Macabre dark and keep the heart it drops."]
	quest.4646010000010000.quest_subtitle: "First prophet fight."
	quest.4646010000010000.title: "Valamon"
	quest.4646010000010001.quest_desc: ["Face &cGomoria&r next. The fight is crueler than Valamon's and the &bheart&r harder won. Bring the best of your war chapter; the prophets have stopped underestimating you."]
	quest.4646010000010001.quest_subtitle: "The second false prophet."
	quest.4646010000010001.title: "Gomoria"
	quest.4646010000010002.quest_desc: ["Break &cGargamaw&r. The third &bheart&r goes in the reliquary beside the first two, and the last prophet starts paying attention to its own mortality."]
	quest.4646010000010002.quest_subtitle: "The third false prophet."
	quest.4646010000010002.title: "Gargamaw"
	quest.4646010000010003.quest_desc: ["End the roster with &cBaal&r. His &bheart&r is the fourth of the five the summoning needs, and only &cMorphegor&r still stands. What waits past the prophets is worse, and it has been watching you work."]
	quest.4646010000010003.quest_subtitle: "The last false prophet."
	quest.4646010000010003.title: "Baal"
	quest.4646010000010004.quest_desc: ["Hunt &cMorphegor&r, the fifth prophet, through the Pit and tear out the &bheart&r. This one breaks into copies when it is hurt, so cut the splits down fast before they close around you. The heart you pull from the tyrant completes the set of five, and it is the last piece the summoning still needs."]
	quest.4646010000010004.quest_subtitle: "The splitting tyrant."
	quest.4646010000010004.title: "Morphegor"
	quest.464601000001000A.quest_desc: [
		"The &6Macabre&r horror has no door, only a wound. To reach &4The Pit&r you turn yourself into the key. Craft a &bSacrificial Dirk&r from a netherite ingot, a blaze rod, a nether wart block, and a gold nugget. If you would rather pay in flesh, use raw blood clot, skin tissue, a ferrum ingot, and a bone."
		"Hold the dirk and use it on yourself. It cuts you and grows darker in your hand. Use it again and again, four cuts in all, until it becomes &cCrystalized Blood&r. Heal between the cuts so the ritual does not kill you. When you hold the Crystalized Blood, use it to drop into the Pit. You keep a &cCracked Crystalized Blood&r as you fall, and that shard carries you home whenever you want out."
		"Know what you are walking into. Five false prophets wait below and every one of them must die. This is a long campaign in a hostile world, not a single boss fight. Pack food, healing, and armor you trust, and plan to make the trip more than once."
	]
	quest.464601000001000A.quest_subtitle: "Bleed a key and fall into the Pit."
	quest.464601000001000A.title: "The Sacrificial Descent"
	quest.46BC26894174159C.quest_desc: [
		"Make &bMixed Soil&r and a Mixed Soil Pot. The magical plants ahead root only in this enriched soil, so lay down a bed of it before you start planting."
		"The pot lets you keep a plant or two indoors near your brewing setup."
	]
	quest.46BC26894174159C.quest_subtitle: "The only bed they will grow in."
	quest.46BC26894174159C.title: "Mixed Soil"
	quest.4757011000000002.quest_desc: ["Build the &bAdvanced Crafting Table&r, &6Extended Crafting&r's five-by-five grid. In this pack its slate bed is replaced by an Oritech &bprocessing unit&r from the silicon chapter. That unit seats the workshop's centerpiece. The elite and ultimate tiers unlock in this same age, so keep climbing from here."]
	quest.4757011000000002.quest_subtitle: "A 5x5 with a logic bed."
	quest.4757011000000002.title: "Advanced Crafting Table"
	quest.4757011000000003.quest_desc: ["Set up an &bEnder Crafter&r ringed with &bender alternators&r. It works through its recipes slowly on its own; every alternator nearby speeds the craft. Surround it as densely as you can spare."]
	quest.4757011000000003.quest_subtitle: "Optional: crafting over time."
	quest.4757011000000003.title: "Ender Crafter"
	quest.4757011000000004.quest_desc: ["Assemble a &bFlux Crafter&r and back it with &bflux alternators&r. It spends Forge Energy to run its recipes. It is the powered sibling of the ender crafter for bases with grid to spare."]
	quest.4757011000000004.quest_subtitle: "Optional: crafting on RF."
	quest.4757011000000004.title: "Flux Crafter"
	quest.4757011000000100.quest_desc: ["Craft the &bAdvanced Auto Table&r and load it with a recipe from its larger grid. It repeats that craft on its own whenever ingredients arrive, so pipe components in and let the table work through the queue while you build elsewhere."]
	quest.4757011000000100.quest_subtitle: "Optional: the 5x5, hands-free."
	quest.4757011000000100.title: "Advanced Auto Table"
	quest.4757011000000101.quest_desc: ["Upgrade your ender crafting line with the &bAuto Ender Crafter&r. Give it a stored recipe and a supply of inputs and it grinds through ender crafts without you standing at the block. Alternators you already placed keep speeding it up."]
	quest.4757011000000101.quest_subtitle: "Optional: slow crafts, queued."
	quest.4757011000000101.title: "Auto Ender Crafter"
	quest.4757011000000102.quest_desc: ["Set an &bAuto Flux Crafter&r beside your energy grid. It holds a recipe, draws Forge Energy, and produces the result for as long as you feed it materials and power. Pair it with your logistics so finished parts move straight to storage."]
	quest.4757011000000102.quest_subtitle: "Optional: powered crafting, automated."
	quest.4757011000000102.title: "Auto Flux Crafter"
	quest.4757011000000103.quest_desc: ["Assemble a &bCrystal Furnace&r from &6Iron Furnaces&r. It burns through ore faster than anything you have owned so far and accepts augments that change how it works. One of these can carry a whole base's smelting on its own."]
	quest.4757011000000103.quest_subtitle: "Optional: smelting at gem speed."
	quest.4757011000000103.title: "Crystal Furnace"
	quest.4757011000000104.quest_desc: ["Press on to the &bObsidian Furnace&r. It tops the crystal tier for raw speed, and the upgrade item preserves whatever is inside the old furnace. Swapping tiers costs nothing but the casing."]
	quest.4757011000000104.quest_subtitle: "Optional: the next furnace tier."
	quest.4757011000000104.title: "Obsidian Furnace"
	quest.4757011000000105.quest_desc: ["Craft the &bblasting&r and &bsmoking&r augments and slot them into an Iron Furnaces body. Each augment swaps the furnace's recipe set, so a single fast furnace can stand in for a blast furnace or a smoker the moment you click the augment in."]
	quest.4757011000000105.quest_subtitle: "Optional: one furnace, every job."
	quest.4757011000000105.title: "Furnace Augments"
	quest.4757011000000106.quest_desc: ["Forge a &bpaxel&r from &6Mekanism&r: pickaxe, axe, and shovel fused into one tool. Iron, gold, or diamond all satisfy this quest, so build whichever matches your material stock. A bronze paxel comes with the reward to round out the rack."]
	quest.4757011000000106.quest_subtitle: "Optional: three tools, one head."
	quest.4757011000000106.title: "The Paxel"
	quest.4757011000000107.quest_desc: ["Smith a full suit of &bosmium armor&r. The same metal that frames your Mekanism machines turns out to hold an edge under fire, and a full set is cheap insurance for the dimension trips this age keeps asking of you."]
	quest.4757011000000107.quest_subtitle: "Osmium armor set."
	quest.4757011000000107.title: "Osmium Armor"
	quest.4757011000000108.quest_desc: ["Build the &6Electrodynamics&r &bjetpack&r and pressurize it with hydrogen from your electrolyzer line. Hold jump to climb and feather the throttle to hover; it turns scaffold work and shaft drops into a non-event."]
	quest.4757011000000108.quest_subtitle: "Optional: thrust on demand."
	quest.4757011000000108.title: "Jetpack"
	quest.4757011000000109.quest_desc: ["Wire up a set of &bnight vision goggles&r. They draw from an internal battery and paint the dark like noon for as long as the charge lasts. Keep a charger by the mine entrance and caves stop costing torches."]
	quest.4757011000000109.quest_subtitle: "Optional: dark mines, lit screens."
	quest.4757011000000109.title: "Night Vision Goggles"
	quest.475701100000010A.quest_desc: ["Assemble the &belectric baton&r. It spends battery charge per swing and hits with a jolt that knocks mobs well clear of you. Not a boss weapon, but unbeatable for clearing a workshop of creeper guests."]
	quest.475701100000010A.quest_subtitle: "Optional: crowd control, charged."
	quest.475701100000010A.title: "Electric Baton"
	quest.475701100000010B.quest_desc: ["Claim any second-rank unique blade from &6Arsenal&r: claymore, dagger, sickle, or mace. Each carries its own moveset and trait, so chase the one that fits how you already fight."]
	quest.475701100000010B.quest_subtitle: "Optional: a cut above."
	quest.475701100000010B.title: "Unique Blades"
	quest.475701100000010C.quest_desc: ["Take up a second-rank unique polearm: spear, glaive, double axe, or hammer. The heavy frames trade swing speed for reach and impact, and the unique versions layer a bonus trait on top."]
	quest.475701100000010C.quest_subtitle: "Optional: reach and weight."
	quest.475701100000010C.title: "Unique Polearms"
	quest.475701100000010D.quest_desc: ["Secure a second-rank unique longbow, heavy crossbow, or shield. The launchers reward drawn, deliberate shots; the shield holds a line no vanilla heater can. Any one of the three completes the set piece."]
	quest.475701100000010D.quest_subtitle: "Optional: fight from cover."
	quest.475701100000010D.title: "Unique Ranged and Guard"
	quest.475701100000010E.quest_desc: ["Acquire a unique &6Arsenal&r staff, whether a damage rank or the healing rank. Staves channel their effect in a line and chew through charge instead of durability, which makes the healing staff a quiet lifesaver in team fights."]
	quest.475701100000010E.quest_subtitle: "Optional: war at wand range."
	quest.475701100000010E.title: "Unique Staves"
	quest.475701100000010F.quest_desc: ["Return to the &6Aether&r and enchant gravitite ore into &bEnchanted Gravitite&r at an altar. The Renaissance let you walk those islands; the Gilded Age finally unlocks the metal they were hiding. Everything in the gravitite line starts from this block."]
	quest.475701100000010F.quest_subtitle: "Optional: the Aether's prize metal."
	quest.475701100000010F.title: "Enchanted Gravitite"
	quest.4757011000000110.quest_desc: ["Forge the full &bgravitite toolset&r. Each tool floats blocks upward when you use its ability, which sounds like a parlor trick until you levitate a whole vein out of a cliff face. A full rack of five finishes the gravitite tool line."]
	quest.4757011000000110.quest_subtitle: "Optional: tools that lift."
	quest.4757011000000110.title: "Gravitite Toolset"
	quest.4757011000000111.quest_desc: ["Plate yourself in &bgravitite armor&r, gloves included. A full set lets you spring far higher than any boot enchant and shrug the landing. Cliffside bases and island hopping stop being a logistics problem."]
	quest.4757011000000111.quest_subtitle: "Optional: wear the updraft."
	quest.4757011000000111.title: "Gravitite Armor"
	quest.4757011000000112.quest_desc: ["Smelt quicksoil into &bAerogel&r. It is the Aether's answer to obsidian, light enough to build with freely and tough enough to shrug blasts. Bring a stack home; it makes striking trim against gold and marble."]
	quest.4757011000000112.quest_subtitle: "Optional: solidified updraft."
	quest.4757011000000112.title: "Aerogel"
	quest.4757011000000113.quest_desc: ["Brave the &6Aether&r's gold dungeon and carry out a &bGold Dungeon Key&r. It only leaves the dungeon with whoever bested its master, so the key itself is the trophy. The sun altar that comes with this quest lets you command the daylight, but only while you stand inside the Aether."]
	quest.4757011000000113.quest_subtitle: "Optional: the Sun Spirit's vault."
	quest.4757011000000113.title: "Gold Dungeon Key"
	quest.4757011000000114.quest_desc: ["Recover any piece of &bphoenix gear&r from the gold dungeon's hoard. Phoenix armor swims through lava like water and the bow looses burning shots. One piece satisfies the quest; a full set makes the Nether feel like a beach."]
	quest.4757011000000114.quest_subtitle: "Optional: fireproof plumage."
	quest.4757011000000114.title: "Phoenix Regalia"
	quest.4757011000000115.quest_desc: ["Collect an Aether accessory: an &bice pendant&r or ring that freezes water as you wade, an iron bubble that holds your breath for you, or a life shard that permanently lengthens your health bar. The dungeons and their guardians hold all four."]
	quest.4757011000000115.quest_subtitle: "Optional: charms from the islands."
	quest.4757011000000115.title: "Aether Keepsakes"
	quest.4757011000000116.quest_desc: ["Win one of the Aether's storied swords. The &bvampire blade&r feeds your health bar with every strike it lands; the &bpig slayer&r does exactly what its name promises, with prejudice. Both surface from the islands' dungeon loot."]
	quest.4757011000000116.quest_subtitle: "Optional: storied steel."
	quest.4757011000000116.title: "Blades of the Islands"
	quest.4757011000000117.quest_desc: ["Push past the familiar islands into &6Deep Aether&r territory and refine &bskyjade&r. The gem sits a tier over the gear you arrived with and opens its own armor line."]
	quest.4757011000000117.quest_subtitle: "Optional: deeper islands, greener stone."
	quest.4757011000000117.title: "Skyjade"
	quest.4757011000000118.quest_desc: ["Cut and fit a full suit of &bskyjade armor&r. It wears light, holds a respectable line against the deep islands' fauna, and its set bonus keeps you nimble at altitude where a misstep is the real threat."]
	quest.4757011000000118.quest_subtitle: "Optional: jade against the wind."
	quest.4757011000000118.title: "Skyjade Armor"
	quest.4757011000000119.quest_desc: ["Alloy a &bStratus Ingot&r, Deep Aether's apex metal. The forging chain runs through the deep islands' rarest drops, and every piece of stratus gear starts here."]
	quest.4757011000000119.quest_subtitle: "Optional: metal of the high storms."
	quest.4757011000000119.title: "Stratus Ingot"
	quest.475701100000011A.quest_desc: ["Forge the complete &bstratus armor&r set. It is the finest plate the sky has to offer in this age, and the full suit's bonus makes the deep islands' storms feel like weather instead of warfare."]
	quest.475701100000011A.quest_subtitle: "Optional: dressed for the stratosphere."
	quest.475701100000011A.title: "Stratus Armor"
	quest.475701100000011B.quest_desc: ["Claim any piece of &bstormforged armor&r from the Deep Aether. The set channels the islands' storms into its wearer, and even a single piece carries enough charge to be worth the hunt."]
	quest.475701100000011B.quest_subtitle: "Optional: armor with thunder in it."
	quest.475701100000011B.title: "Stormforged Plate"
	quest.475701100000011C.quest_desc: ["Beat the Deep Aether's brass dungeon and walk out with its &bkey&r. Like the gold key below, it cannot be looted, traded, or faked; holding one means you went in and finished the job."]
	quest.475701100000011C.quest_subtitle: "Optional: the storm's inner vault."
	quest.475701100000011C.title: "Brass Dungeon Key"
	quest.475701100000011D.quest_desc: ["Gather one of the Deep Aether's prize reagents: a &bbio crystal&r, a &bgolden swet ball&r, or a &bsun core&r. Each comes off a specific island dweller and feeds the deep gear recipes you have been circling."]
	quest.475701100000011D.quest_subtitle: "Optional: rare matter from rare beasts."
	quest.475701100000011D.title: "Deep Aether Reagents"
	quest.475701100000011E.quest_desc: ["Fit a Deep Aether accessory: the &baercloud necklace&r softens falls, the &bgravitite ring&r lightens your step, and the &bafterburner&r feeds your momentum. Any one of the three closes this quest."]
	quest.475701100000011E.quest_subtitle: "Optional: trinkets with lift."
	quest.475701100000011E.title: "Sky Accessories"
	quest.475701100000011F.quest_desc: ["Forge the full set of &bwarden armor&r from &6Deeper and Darker&r. The plate is built on reinforced echo shards pulled from the Otherside, and wearing all four pieces quiets your steps to sculk."]
	quest.475701100000011F.quest_subtitle: "Optional: wear what hunted you."
	quest.475701100000011F.title: "Warden Armor"
	quest.4757011000000120.quest_desc: ["Claim one of the six &bspirit helmets&r of &6Unusual End&r. Each mask carries a different temperament and a different gift, and the End's strange residents do not part with them lightly. One mask completes the quest; collectors will want the wall of six."]
	quest.4757011000000120.quest_subtitle: "Unusual End spirit helmet."
	quest.4757011000000120.title: "Spirit Helmets"
	quest.4757011000000121.quest_desc: ["Secure a &bVoid Totem&r. Held like its vanilla cousin, it catches you the moment the void would take you and sets you back on solid ground. For End-side construction over open sky, there is no better insurance."]
	quest.4757011000000121.quest_subtitle: "Optional: one free fall."
	quest.4757011000000121.title: "Void Totem"
	quest.4757011000000130.quest_desc: [
		"The brass dungeon's stormforged line does not end at armor. At a smithing table, the &bStormforged Smithing Template&r turns a skyjade sword into the &bStorm Sword&r and a plain bow into the &bStorm Bow&r, each with a squall plate as the addition. &bStormforged Gloves&r upgrade from skyjade gloves the same way."
		"The &bCloud Cape&r is loot only, pulled from brass dungeon reward chests, so keep clearing vaults until it drops."
		"Any one of the four completes this quest. Between them they finish what the stormforged armor started: a full storm-forged kit out of one dungeon line."
	]
	quest.4757011000000130.quest_subtitle: "What the storm left behind."
	quest.4757011000000130.title: "Storm Armaments"
	quest.4757011020010001.quest_desc: ["Construct and activate the &bAthanor&r, Neo Vitae's apex Vitae-refinement station and the heart of the Gilded workshop. The Athanor channels life-force at the scale the chapters beyond require."]
	quest.4757011020010001.quest_subtitle: "Required: the Athanor, Neo Vitae's Vitae apex station."
	quest.4757011020010001.title: "The Athanor"
	quest.48AC8545D66B71B7.quest_desc: [
		"Upgrade the &bBuilder's Hut&r to level two. A higher-level Builder works faster and handles taller, more complex buildings."
		"Every upgrade after this pays back in build speed."
	]
	quest.48AC8545D66B71B7.quest_subtitle: "A faster, more capable builder."
	quest.48AC8545D66B71B7.title: "Builder, Level 2"
	quest.490628CE108A833A.quest_desc: [
		"Build the &bCourier's Hut&r. Couriers move items between the &bwarehouse&r and every working building. Without them, a busy colony grinds to a halt."
		"Hire one the moment the &bwarehouse&r is up, or deliveries stall."
	]
	quest.490628CE108A833A.quest_subtitle: "Keep the goods moving."
	quest.490628CE108A833A.title: "Courier's Hut"
	quest.493B9FC17C3CF3CA.quest_desc: [
		"Build the &bRabbit Hutch&r. It raises rabbits for meat, hide, and the occasional foot. A small, reliable addition to the larder."
		"Hand the keeper a few rabbits and a carrot to start the warren."
	]
	quest.493B9FC17C3CF3CA.quest_subtitle: "A tidy little food source."
	quest.493B9FC17C3CF3CA.title: "Rabbit Hutch"
	quest.494D010000010001.quest_desc: ["Hold a &bDraconic Core&r. Wyvern-tier fusion wants this core before higher crafts open."]
	quest.494D010000010001.quest_subtitle: "Core before wyvern crafts."
	quest.494D010000010001.title: "Draconic Core"
	quest.494D010000010002.quest_desc: ["Place the &bDraconic Fusion Crafting Injector&r. Draconic-tier fusion crafts route through this injector."]
	quest.494D010000010002.quest_subtitle: "Draconic fusion route."
	quest.494D010000010002.title: "Draconic Fusion Crafting Injector"
	quest.494D010000010003.quest_desc: ["Place the &bReactor Core&r. The draconic reactor multiblock starts here."]
	quest.494D010000010003.quest_subtitle: "Reactor multiblock starts here."
	quest.494D010000010003.title: "Reactor Core"
	quest.494D010000010004.quest_desc: ["Place the &bReactor Energy Injector&r. It pumps power into the core to charge it and hold the containment field."]
	quest.494D010000010004.quest_subtitle: "Power in, field held."
	quest.494D010000010004.title: "Reactor Energy Injector"
	quest.494D010000010005.quest_desc: ["Place the &bReactor Stabilizer&r. Keeps the core in its safe operating band."]
	quest.494D010000010005.quest_subtitle: "Keep the core stable."
	quest.494D010000010005.title: "Reactor Stabilizer"
	quest.494D010000010006.quest_desc: ["Hold a &bDraconic Energy Controller&r. It is a draconic-tier crafting component, consumed by the Reactor Stabilizer and draconic gear recipes."]
	quest.494D010000010006.quest_subtitle: "A draconic-tier component."
	quest.494D010000010006.title: "Draconic Energy Controller"
	quest.494D012000000201.quest_desc: [
		"Forge the stabilizer internals before the reactor goes up: the &bStabilizer Frame&r, &bInner Rotor&r, &bFull Rotor&r, and &bFocus Ring&r. All four are shaped crafts from your Draconic material line, bundled here because they build one machine."
		"Four assembled &bReactor Stabilizers&r project the containment field around the &6Draconic Evolution&r reactor core, and the &bReactor Energy Injector&r keeps that field fed with power. Under-build the containment and the core does not wobble. It detonates."
		"The Reactor Core quest ahead checks both this forging run and the Otherworldly Fusion Fuel Program. Forged containment plus fusion literacy is the price of admission to a chaos-fueled star."
	]
	quest.494D012000000201.quest_subtitle: "Containment before criticality."
	quest.494D012000000201.title: "Stabilizer Forging"
	quest.4954001000000003.quest_desc: ["Craft the &bEngineer's Manual&r. It diagrams every multiblock's shape and wiring. Read it before you build."]
	quest.4954001000000003.quest_subtitle: "Read the machine."
	quest.4954001000000003.title: "Engineer's Manual"
	quest.4954001000000004.quest_desc: ["Forge an &bEngineer's Hammer&r. It assembles multiblocks, rotates blocks, and links wire connectors. Keep it in your hotbar."]
	quest.4954001000000004.quest_subtitle: "Form, rotate, connect."
	quest.4954001000000004.title: "Engineer's Hammer"
	quest.4954011000000001.quest_desc: [
		"Craft an &bEngineer's Crafting Table&r. It is the workbench &6Immersive Engineering&r is built on: it holds its own inventory and remembers the last recipe you used."
		"Everything in this chapter is assembled here or at the machines it builds."
	]
	quest.4954011000000001.quest_subtitle: "Where the factory begins."
	quest.4954011000000001.title: "Engineer's Crafting Table"
	quest.4954011000000003.quest_desc: ["Bake &bCoal Coke&r in the oven. It burns hotter and longer than coal and is what drives the blast furnace."]
	quest.4954011000000003.quest_subtitle: "Fuel for steel."
	quest.4954011000000003.title: "Coal Coke"
	quest.4954011000000004.quest_desc: [
		"Raise a &bCrude Blast Furnace&r and run iron through it with &bcoal coke&r to make &bsteel&r, the backbone metal of every &6Immersive Engineering&r machine."
		"Slag falls out as a by-product; keep it for concrete."
	]
	quest.4954011000000004.quest_subtitle: "Iron and coke into steel."
	quest.4954011000000004.title: "Crude Blast Furnace"
	quest.4954011000000006.quest_desc: ["Press &bSteel Mechanical Components&r. They are the shared internal part of nearly every IE machine. Make them in bulk before you build."]
	quest.4954011000000006.quest_subtitle: "The universal machine part."
	quest.4954011000000006.title: "Steel Mechanical Component"
	quest.4954011000000007.quest_desc: ["Build the &bCrusher&r multiblock. It grinds ore into two dusts apiece, doubling every vein you mine from here on."]
	quest.4954011000000007.quest_subtitle: "Double your ore."
	quest.4954011000000007.title: "Crusher"
	quest.4954011000000009.quest_desc: ["Build the &bMetal Press&r and feed it molds. With the right mold it stamps ingots into plates, rods, gears, and wire far faster than hand-crafting."]
	quest.4954011000000009.quest_subtitle: "Plates, rods, and wire."
	quest.4954011000000009.title: "Metal Press"
	quest.495401100000000B.quest_desc: ["Build the &bMixer&r. It stirs fluids and dry goods together, most immediately &bconcrete&r, the cheap blast-resistant block the rest of the factory is poured from."]
	quest.495401100000000B.quest_subtitle: "Blend fluids."
	quest.495401100000000B.title: "Mixer"
	quest.495401100000000F.quest_desc: ["Raise a &bSilo&r. It holds one item type in enormous quantity. Use it as the dump for the dusts and ingots your machines churn out."]
	quest.495401100000000F.quest_subtitle: "Bulk item storage."
	quest.495401100000000F.title: "Silo"
	quest.4954011000000011.quest_desc: ["Craft an &bEngineer's Blueprint&r. Slotted into the &bEngineer's Workbench&r, it unlocks IE's component, tool, and ammunition recipes."]
	quest.4954011000000011.quest_subtitle: "Recipes for the workbench."
	quest.4954011000000011.title: "Engineer's Blueprint"
	quest.4954011000000012.quest_desc: ["Craft &bConveyor Belts&r. They carry items between machines and feed the routing gear that comes next."]
	quest.4954011000000012.quest_subtitle: "Move items across the floor."
	quest.4954011000000012.title: "Conveyor Belt"
	quest.4954011000000013.quest_desc: ["Craft &bFluid Pipes&r to run &bcreosote&r, water, and fuel between tanks and machines. Keep two fluids off the same line."]
	quest.4954011000000013.quest_subtitle: "Move fluids."
	quest.4954011000000013.title: "Fluid Pipe"
	quest.4954011000000014.quest_desc: ["Wire up a &bPowered Lantern&r. On a trickle of RF it fills a work floor with brighter, steadier light than torches."]
	quest.4954011000000014.quest_subtitle: "Clean, bright RF light."
	quest.4954011000000014.title: "Powered Lantern"
	quest.4954011000000016.quest_desc: ["Assemble an &bEngineer's Toolbox&r. It holds tools, blocks, and wiring in dedicated slots so a build trip needs one item, not a full inventory."]
	quest.4954011000000016.quest_subtitle: "Carry the whole kit."
	quest.4954011000000016.title: "Engineer's Toolbox"
	quest.4954011000000019.quest_desc: ["Craft &bGenerator Blocks&r, the steel shells IE's generators and the diesel-generator structure are built from. Power generation starts here."]
	quest.4954011000000019.quest_subtitle: "Casing for power."
	quest.4954011000000019.title: "Generator Block"
	quest.495401100000001A.quest_desc: ["Build a &bKinetic Dynamo&r. Attach a water wheel or windmill to its shaft and it turns that spin into RF, IE's first real power."]
	quest.495401100000001A.quest_subtitle: "Rotation into RF."
	quest.495401100000001A.title: "Kinetic Dynamo"
	quest.495401100000001B.quest_desc: ["Place a &bThermoelectric Generator&r between hot and cold, lava beside ice say, and the gradient trickles out steady RF."]
	quest.495401100000001B.quest_subtitle: "Power from temperature."
	quest.495401100000001B.title: "Thermoelectric Generator"
	quest.495401100000001C.quest_desc: ["Assemble a &bWater Wheel&r on a dynamo. Moving water turns it; larger arrays spin faster and feed more RF."]
	quest.495401100000001C.quest_subtitle: "Spin from flowing water."
	quest.495401100000001C.title: "Water Wheel"
	quest.495401100000001D.quest_desc: ["Assemble a &bWindmill&r on a dynamo. The higher and more exposed it sits, the more RF the wind pulls out of it."]
	quest.495401100000001D.quest_subtitle: "Spin from open sky."
	quest.495401100000001D.title: "Windmill"
	quest.495401100000001E.quest_desc: ["Wire a &bCharging Station&r. Set RF tools, drills, and revolvers on it and the grid keeps them charged."]
	quest.495401100000001E.quest_subtitle: "Top up powered gear."
	quest.495401100000001E.title: "Charging Station"
	quest.495401100000001F.quest_desc: ["Build a &bGarden Cloche&r. Given seeds, water, and fertilizer it grows crops on its own, freeing you from tending fields."]
	quest.495401100000001F.quest_subtitle: "Hands-free farming."
	quest.495401100000001F.title: "Garden Cloche"
	quest.4954011000000020.quest_desc: ["Place an &bItem Batcher&r. It emits a set number of items only when a full batch is ready, timing control for an automated line."]
	quest.4954011000000020.quest_subtitle: "Release items in counts."
	quest.4954011000000020.title: "Item Batcher"
	quest.4954011000000021.quest_desc: ["Build an &bItem Router&r. Filtered per side, it sorts a conveyor stream to the right machines and chests."]
	quest.4954011000000021.quest_subtitle: "Split items by filter."
	quest.4954011000000021.title: "Item Router"
	quest.4954011000000022.quest_desc: ["Set up a &bCore Sample Drill&r. It reports which mineral vein sits under a chunk, the survey step before an Excavator."]
	quest.4954011000000022.quest_subtitle: "Survey the ground."
	quest.4954011000000022.title: "Core Sample Drill"
	quest.4954011000000023.quest_desc: ["Craft an &bElectromagnet&r, the powered magnet IE uses to gather and move metal items around an automated line."]
	quest.4954011000000023.quest_subtitle: "Powered item magnet."
	quest.4954011000000023.title: "Electromagnet"
	quest.4954011000000024.quest_desc: ["Attach an &bExternal Heater&r to a vanilla furnace. Fed RF, it smelts without fuel and can keep a blast furnace hot."]
	quest.4954011000000024.quest_subtitle: "Run furnaces on RF."
	quest.4954011000000024.title: "External Heater"
	quest.4954011000000025.quest_desc: ["Mount a &bBlast Furnace Preheater&r on the &bCrude Blast Furnace&r. Powered, it speeds every steel smelt; add a second for more."]
	quest.4954011000000025.quest_subtitle: "Speed the steel."
	quest.4954011000000025.title: "Blast Furnace Preheater"
	quest.4954011000000026.quest_desc: ["Craft a &bRadiator Block&r. Fed water, it sheds the heat a Diesel Generator builds up so it can keep running."]
	quest.4954011000000026.quest_subtitle: "Cool the generator."
	quest.4954011000000026.title: "Radiator Block"
	quest.4954011000000027.quest_desc: ["Build a &bCircuit Table&r. It assembles the logic circuits that drive IE's routers, batchers, and automation controls."]
	quest.4954011000000027.quest_subtitle: "Wire logic."
	quest.4954011000000027.title: "Circuit Table"
	quest.4954011000000028.quest_desc: ["Build an &bHV Accumulator&r. It stores a large RF buffer so the grid rides out demand spikes between generation and use."]
	quest.4954011000000028.quest_subtitle: "Bank your RF."
	quest.4954011000000028.title: "HV Accumulator"
	quest.4954011000000029.quest_desc: ["Refine &bHigh-Cetane Biodiesel&r and fill a bucket. Burned in a Diesel Generator it yields far more power per drop than plain biodiesel."]
	quest.4954011000000029.quest_subtitle: "Premium engine fuel."
	quest.4954011000000029.title: "High-Cetane Biodiesel"
	quest.495401100000002F.quest_desc: ["Craft an &bEngineer's Workbench&r. Slot a blueprint and it assembles the IE components, tools, and ammunition no crafting grid can make."]
	quest.495401100000002F.quest_subtitle: "Build with blueprints."
	quest.495401100000002F.title: "Engineer's Workbench"
	quest.4954011000000030.quest_desc: ["Build the &bRefinery&r multiblock. It combines plant oil and ethanol into &bbiodiesel&r, the fuel your generators run on."]
	quest.4954011000000030.quest_subtitle: "Brew biodiesel."
	quest.4954011000000030.title: "Refinery"
	quest.4954011000000031.quest_desc: ["Build the &bFermenter&r multiblock. It ferments plant matter into &bethanol&r and seed oil, the feedstock the Refinery turns into fuel."]
	quest.4954011000000031.quest_subtitle: "Crops into ethanol."
	quest.4954011000000031.title: "Fermenter"
	quest.4954011000000102.quest_desc: [
		"Form the Improved Blast Furnace multiblock. This quest completes on its build advancement, so assemble the full structure using the Engineer's Manual rather than crafting a single block."
		"The Improved Blast Furnace smelts iron and other inputs into steel far faster than the crude version, and it produces slag as a useful by-product. Steel is the backbone material for the Immersive Engineering machine fleet, so this furnace is what keeps your builds fed."
		"It upgrades the Crude Blast Furnace you built before. Once it is running, you have the steel supply the rest of this chapter's machines assume."
	]
	quest.4954011000000102.quest_subtitle: "The real steel workhorse"
	quest.4954011000000102.title: "Improved Blast Furnace"
	quest.4954011000000104.quest_desc: [
		"Craft the Alloy Smelter. It is a single block, no multiblock to assemble, that combines two metals into an alloy."
		"Feed it the right pair of inputs and it produces alloys the Immersive Engineering fleet needs, along with other mixed metals. Because it is a plain machine rather than a structure, it is a quick and cheap addition next to your blast furnace."
		"Set it beside the Improved Blast Furnace so your steel and your alloys come off the same corner of the workshop."
	]
	quest.4954011000000104.quest_subtitle: "Combine metals into alloys"
	quest.4954011000000104.title: "Alloy Smelter"
	quest.4954011000000106.quest_desc: [
		"Form the Squeezer multiblock. This quest completes on its build advancement, so raise the full structure from the Engineer's Manual."
		"The Squeezer presses seeds and plant matter into plant oil, a fluid that feeds biodiesel production and later chemistry. It is your first taste of Immersive Engineering's fluid side, where machines make and move liquids rather than items."
		"Set it near a supply of seeds or crops. Its plant oil becomes an input for the Bottling Machine and the fuel line ahead."
	]
	quest.4954011000000106.quest_subtitle: "Press seeds and plants to oil"
	quest.4954011000000106.title: "Squeezer"
	quest.4954011000000107.quest_desc: [
		"Craft the Bottling Machine, a single block that fills buckets and other containers from a piped fluid supply."
		"Point a fluid pipe into the bottling machine and drop empty containers in, and it fills them automatically. It is how you package the plant oil, water, or other fluids your workshop produces into portable form."
		"It pairs naturally with the Squeezer, whose plant oil is a ready fluid to bottle. This is the packaging end of the IE fluid chain."
	]
	quest.4954011000000107.quest_subtitle: "Fill containers from a fluid feed"
	quest.4954011000000107.title: "Bottling Machine"
	quest.4954011000000108.quest_desc: [
		"Craft the Sawmill, a single block that processes logs into planks plus a sawdust by-product at scale."
		"The sawmill turns raw logs into more planks than hand-crafting and gives sawdust on top, which compresses into useful materials. Feed it with a conveyor of logs and it keeps your plank and sawdust supply flowing without manual work."
		"It slots into the Immersive Engineering line after the Mixer. Next comes the Auto Workbench, which can craft finished items from feeds like these."
	]
	quest.4954011000000108.quest_subtitle: "Logs to planks and sawdust at scale"
	quest.4954011000000108.title: "Sawmill"
	quest.4954011000000109.quest_desc: [
		"Craft the Auto Workbench, a single block that runs one crafting recipe automatically from an item feed."
		"Insert an Engineer's Blueprint to set the recipe, then feed the workbench its ingredients on conveyors. It crafts the output continuously as long as the inputs arrive, turning a raw supply into finished parts hands-off."
		"Combined with the Sawmill and the rest of the fleet, the Auto Workbench lets you automate the small crafting steps that otherwise clog your inventory. This is a strong end to the early IE factory lane."
	]
	quest.4954011000000109.quest_subtitle: "Blueprint-driven crafting from feed"
	quest.4954011000000109.title: "Auto Workbench"
	quest.4954021000000002.quest_desc: [
		"Craft a &bForge Hammer&r. Before any machines, it lets you beat ingots into the plates, rods, and curved plates &6Modern Industrialization&r runs on."
		"Slow going, but it is how the whole tech tree gets its first parts."
	]
	quest.4954021000000002.quest_subtitle: "Bootstrap by hand."
	quest.4954021000000002.title: "Forge Hammer"
	quest.4954021000000004.quest_desc: [
		"Raise a &bCoke Oven&r. It bakes coal into coke and gives &bcreosote&r on the side, the fuel the steam &bfurnace&r needs to reach steel."
		"A small multiblock, the first real structure of the MI line."
	]
	quest.4954021000000004.quest_subtitle: "Coal into coke."
	quest.4954021000000004.title: "Coke Oven"
	quest.4954021000000006.quest_desc: [
		"Assemble the &bSteam Blast Furnace&r. Fed iron and coke and driven by steam, it produces &bsteel&r, the metal nearly every machine ahead is built from."
		"This is the steam tier doing real work, no electricity in sight yet."
	]
	quest.4954021000000006.quest_subtitle: "Your first steel."
	quest.4954021000000006.title: "Steam Blast Furnace"
	quest.4954021000000007.quest_desc: [
		"Raise a &bLarge Steam Boiler&r. Heat and water in, steam out, and that steam powers the bronze tier before you touch a cable."
		"Pipe it to your machines and keep the water flowing."
	]
	quest.4954021000000007.quest_subtitle: "Make the steam."
	quest.4954021000000007.title: "Large Steam Boiler"
	quest.4954021000000009.quest_desc: [
		"Set up a &bSteam Quarry&r. It digs an area on steam. Hands-off ore for your macerators to double."
		"Set it over good ground and walk away."
	]
	quest.4954021000000009.quest_subtitle: "Mine on steam."
	quest.4954021000000009.title: "Steam Quarry"
	quest.495402100000000A.quest_desc: [
		"Raise the &bLarge Tank&r multiblock. It banks steam from your &bboiler&r and any fluid on the line so machines do not stall."
		"Bigger tanks mean your steam survives a demand spike."
	]
	quest.495402100000000A.quest_subtitle: "Store steam and fluids."
	quest.495402100000000A.title: "Large Tank"
	quest.495402100000000C.quest_desc: [
		"Install a &bBronze Macerator&r. It grinds ore into two dusts each, doubling metal before smelting. The most important step in MI ore processing."
		"Run everything through it; the extra ingots add up fast."
	]
	quest.495402100000000C.quest_subtitle: "Double your ore."
	quest.495402100000000C.title: "Bronze Macerator"
	quest.495402100000000D.quest_desc: [
		"Craft a &bBronze Compressor&r. It presses ingots into plates, rods, and wire on steam, automating the parts the &bforge hammer&r made by hand."
		"Retire the hammer for bulk work once this is running."
	]
	quest.495402100000000D.quest_subtitle: "Press plates and rods."
	quest.495402100000000D.title: "Bronze Compressor"
	quest.495402100000000E.quest_desc: [
		"Install a &bSteel Wiremill&r. It draws ingots into wire by the stack so cables and electronics stop eating hand-crafting time."
		"Wire is everywhere ahead, so automate it early."
	]
	quest.495402100000000E.quest_subtitle: "Spin wire on steam."
	quest.495402100000000E.title: "Steel Wiremill"
	quest.495402100000000F.quest_desc: [
		"Craft a &bBronze Mixer&r. It blends materials and fluids for the recipes that need more than one input, rounding out the steam-tier processing set."
		"Macerate, compress, mix: the bronze trio covers most early needs."
	]
	quest.495402100000000F.quest_subtitle: "Combine your inputs."
	quest.495402100000000F.title: "Bronze Mixer"
	quest.4954021000000010.quest_desc: [
		"Raise the &6Extended Industrialization&r &bLarge Steam Furnace&r. It smelts many stacks at once on steam when single furnaces choke your supply."
		"A big steam machine for a big base."
	]
	quest.4954021000000010.quest_subtitle: "Smelt in bulk."
	quest.4954021000000010.title: "Large Steam Furnace"
	quest.4954021000000011.quest_desc: [
		"Install the &bLarge Steam Macerator&r. It grinds ore in volume, the high-throughput version of the &bbronze macerator&r for a quarry running flat out."
		"Keep your ore-doubling ahead of your mining."
	]
	quest.4954021000000011.quest_subtitle: "Double ore at scale."
	quest.4954021000000011.title: "Large Steam Macerator"
	quest.4954021000000012.quest_desc: [
		"Set up a &bSteam Farmer&r. It plants and harvests on steam, an &6Extended Industrialization&r machine for hands-off crops."
		"Useful for feeding fermenters, composters, and yourself."
	]
	quest.4954021000000012.quest_subtitle: "Automate the fields."
	quest.4954021000000012.title: "Steam Farmer"
	quest.4954021000000014.quest_desc: [
		"Craft a &bSteel Barrel&r. It holds a deep stack of a single item, the cheap, sturdy storage for the piles of dust and ingot the steam line produces."
		"Line a wall with them and stop overflowing chests."
	]
	quest.4954021000000014.quest_subtitle: "Bulk item storage."
	quest.4954021000000014.title: "Steel Barrel"
	quest.4954021000000016.quest_desc: [
		"With a &bcoke oven&r, a &bsteam blast furnace&r, boilers, and the bronze machines all running, the steam tier is complete. You can make &bsteel&r and double ore without a single cable."
		"This is the launch point into the electric machines that follow."
	]
	quest.4954021000000016.quest_subtitle: "The bronze age of MI is done."
	quest.4954021000000016.title: "Steam Tier Complete"
	quest.4954021000000017.quest_desc: [
		"Upgrade to a &bSteel Boiler&r. It feeds heavier machines under load better than bronze."
		"Step up before your demand outgrows the bronze tier."
	]
	quest.4954021000000017.quest_subtitle: "A sturdier steam source."
	quest.4954021000000017.title: "Steel Boiler"
	quest.4954021000000018.quest_desc: [
		"Assemble an &bAssembler&r. It crafts multi-part components, circuits, and machine pieces hand-crafting cannot."
		"Most LV machines trace a part or two back through here."
	]
	quest.4954021000000018.quest_subtitle: "Build the complex parts."
	quest.4954021000000018.title: "Assembler"
	quest.4954021000000019.quest_desc: [
		"Craft a &bBasic Machine Hull&r. It is the casing every LV electric machine is built around, the part that marks your shift from steam to electricity."
		"Make a stack; the electric tier wants one for each machine."
	]
	quest.4954021000000019.quest_subtitle: "The shell of every electric machine."
	quest.4954021000000019.title: "Basic Machine Hull"
	quest.495402100000001A.quest_desc: [
		"Install an &bElectric Furnace&r. It smelts on &6EU&r instead of steam, the first LV machine most bases make."
		"Feed it from an energy hatch and a cable."
	]
	quest.495402100000001A.quest_subtitle: "Smelt on EU."
	quest.495402100000001A.title: "Electric Furnace"
	quest.495402100000001B.quest_desc: [
		"Craft an &bElectric Macerator&r. It doubles ore like the bronze unit but on &6EU&r, faster and able to keep pace with a fully electric base."
		"Move your ore processing here once the power is steady."
	]
	quest.495402100000001B.quest_subtitle: "Ore doubling, electrified."
	quest.495402100000001B.title: "Electric Macerator"
	quest.495402100000001C.quest_desc: [
		"Install an &bElectric Compressor&r. The electric pressing line. Plates, rods, and wire faster than steam."
		"Throughput climbs the moment you electrify it."
	]
	quest.495402100000001C.quest_subtitle: "Press on power."
	quest.495402100000001C.title: "Electric Compressor"
	quest.495402100000001D.quest_desc: [
		"Craft an &bElectric Cutting Machine&r. It slices ingots and rods into bolts, rings, and finer stock, a part of the chain the &bcompressor&r cannot cover."
		"Several recipes dead-end without cut parts."
	]
	quest.495402100000001D.quest_subtitle: "Cut rods and bolts."
	quest.495402100000001D.title: "Electric Cutting Machine"
	quest.495402100000001E.quest_desc: [
		"Install an &bElectric Mixer&r. It handles multi-input recipes at speed, the powered successor to the &bbronze mixer&r."
		"Faster blends keep the alloy lines fed."
	]
	quest.495402100000001E.quest_subtitle: "Blend on EU."
	quest.495402100000001E.title: "Electric Mixer"
	quest.495402100000001F.quest_desc: [
		"Craft an &bElectric Packer&r. It bundles items into blocks, crates, and packed forms, tidying storage and feeding recipes that want the packed shape."
		"The compact half of MI's packing pair."
	]
	quest.495402100000001F.quest_subtitle: "Pack into blocks and more."
	quest.495402100000001F.title: "Electric Packer"
	quest.4954021000000020.quest_desc: [
		"Install an &bElectric Unpacker&r. It splits packed blocks and bundles back into parts, the other half of the packer pair."
		"Pack for storage, unpack for use."
	]
	quest.4954021000000020.quest_subtitle: "Break packed forms apart."
	quest.4954021000000020.title: "Electric Unpacker"
	quest.4954021000000021.quest_desc: [
		"Install an &bElectric Water Pump&r. It feeds boilers and chemistry without bucket runs."
		"Set it on water and pipe the output where it is needed."
	]
	quest.4954021000000021.quest_subtitle: "Draw water on demand."
	quest.4954021000000021.title: "Electric Water Pump"
	quest.4954021000000022.quest_desc: [
		"Raise the &bElectric Blast Furnace&r. With enough heat and &6EU&r it smelts the advanced alloys &bsteel&r cannot reach."
		"Add heating coils to raise its temperature for the tougher recipes."
	]
	quest.4954021000000022.quest_subtitle: "Advanced alloy smelting."
	quest.4954021000000022.title: "Electric Blast Furnace"
	quest.4954021000000023.quest_desc: [
		"Craft a &bPolarizer&r. It magnetizes &bsteel&r rods into the magnetic parts that motors, coils, and the better machines depend on."
		"Small machine, large unlock."
	]
	quest.4954021000000023.quest_subtitle: "Magnetize your rods."
	quest.4954021000000023.title: "Polarizer"
	quest.4954021000000024.quest_desc: [
		"Wire an &bLV Diesel Generator&r. It burns diesel from your oil chain for low-voltage power."
		"Pair it with a fuel tank and let it run."
	]
	quest.4954021000000024.quest_subtitle: "Fuel into EU."
	quest.4954021000000024.title: "LV Diesel Generator"
	quest.4954021000000025.quest_desc: [
		"Wire an &bLV Steam Turbine&r. It turns steam you already make into &6EU&r, bridging bronze boilers into the electric tier."
		"The cleanest bridge between steam and electricity in MI."
	]
	quest.4954021000000025.quest_subtitle: "Steam into electricity."
	quest.4954021000000025.title: "LV Steam Turbine"
	quest.4954021000000026.quest_desc: [
		"Craft an &bLV Storage Unit&r. It stores &6EU&r so your generators can run steadily through demand spikes and dips. It is the &bbattery&r of the low-voltage grid."
		"Size storage to cover the gap between supply and peak draw."
	]
	quest.4954021000000026.quest_subtitle: "Bank your power."
	quest.4954021000000026.title: "LV Storage Unit"
	quest.4954021000000027.quest_desc: [
		"Install an &bLV to MV Transformer&r. It steps power from low to medium voltage for the next machine tier."
		"MI runs in voltage tiers, and this is how you climb one."
	]
	quest.4954021000000027.quest_subtitle: "Step up a tier."
	quest.4954021000000027.title: "LV to MV Transformer"
	quest.4954021000000028.quest_desc: [
		"Craft a &bConfigurable Chest&r. You set exactly what each slot accepts and which faces feed in or out, smart storage that sorts itself."
		"The backbone of an organized MI item network."
	]
	quest.4954021000000028.quest_subtitle: "Storage that filters."
	quest.4954021000000028.title: "Configurable Chest"
	quest.4954021000000029.quest_desc: [
		"Install a &bConfigurable Tank&r. It holds one fluid and routes it through chosen faces like the configurable chest does for items."
		"Pair chests and tanks for a tidy base."
	]
	quest.4954021000000029.quest_subtitle: "Fluids, filtered."
	quest.4954021000000029.title: "Configurable Tank"
	quest.495402100000002A.quest_desc: [
		"Craft a &bLarge Tank Hatch&r. It is the input or output port set into a Large Tank multiblock, the connection between the bank of fluid and your pipes."
		"Multiblocks talk to the world through their hatches."
	]
	quest.495402100000002A.quest_subtitle: "Access the big tank."
	quest.495402100000002A.title: "Large Tank Hatch"
	quest.495402100000002B.quest_desc: [
		"Set up an &bAutomatic Trash Can&r. It voids unwanted items or fluids on contact."
		"&eFilter it carefully.&r It only eats what you route to it."
	]
	quest.495402100000002B.quest_subtitle: "Void the overflow."
	quest.495402100000002B.title: "Automatic Trash Can"
	quest.495402100000002C.quest_desc: [
		"Craft a &bSteel Item Input Hatch&r. Set into a multiblock's casing it accepts the items the structure processes, the inbound port for the big machines."
		"Every multiblock needs a way to be fed."
	]
	quest.495402100000002C.quest_subtitle: "Feed a multiblock."
	quest.495402100000002C.title: "Item Input Hatch"
	quest.495402100000002D.quest_desc: [
		"Install a &bSteel Item Output Hatch&r. It is the port a multiblock pushes finished items through."
		"Input and output hatches complete the machine's plumbing."
	]
	quest.495402100000002D.quest_subtitle: "Take the products off."
	quest.495402100000002D.title: "Item Output Hatch"
	quest.495402100000002E.quest_desc: [
		"Craft an &bLV Energy Input Hatch&r. It feeds &6EU&r into a multiblock from your cables, the power connection the electric structures cannot run without."
		"Match the hatch tier to the voltage you are supplying."
	]
	quest.495402100000002E.quest_subtitle: "Power the multiblock."
	quest.495402100000002E.title: "Energy Input Hatch"
	quest.495402100000002F.quest_desc: [
		"Build an &bLV Energy Output Hatch&r. It pushes &6EU&r out of a generating multiblock into your grid, the outbound power port for turbines and generators."
		"Wire it into your storage and machines."
	]
	quest.495402100000002F.quest_subtitle: "Export generated power."
	quest.495402100000002F.title: "Energy Output Hatch"
	quest.4954021000000030.quest_desc: [
		"Build a &bSteel Solar Boiler&r. It makes steam from sunlight with no fuel, an &6Extended Industrialization&r route to free steam for a daytime base."
		"Stack them for more steam, then turbine it into power."
	]
	quest.4954021000000030.quest_subtitle: "Steam from sunlight."
	quest.4954021000000030.title: "Steel Solar Boiler"
	quest.4954021000000031.quest_desc: [
		"Craft an &bElectric Alloy Smelter&r. It combines metals into alloys in a single machine, with no multiblock needed for the lighter recipes."
		"Convenient for the lighter alloying jobs."
	]
	quest.4954021000000031.quest_subtitle: "Alloys without the multiblock."
	quest.4954021000000031.title: "Electric Alloy Smelter"
	quest.4954021000000032.quest_desc: [
		"Build an &bElectric Brewery&r. It produces brewed fluids for the recipes that need them. It is an &6Extended Industrialization&r machine for the chemistry-adjacent steps."
		"Fills a gap the base MI machines leave open."
	]
	quest.4954021000000032.quest_subtitle: "Brew fluids at scale."
	quest.4954021000000032.title: "Electric Brewery"
	quest.4954021000000033.quest_desc: [
		"Craft an &bElectric Canning Machine&r. It loads fluids and items into cans and cells and pulls them back out, handy for handling fuels and gases by the unit."
		"The packaging step for fluids."
	]
	quest.4954021000000033.quest_subtitle: "Fill and empty containers."
	quest.4954021000000033.title: "Electric Canning Machine"
	quest.4954021000000034.quest_desc: [
		"Build an &bElectric Composter&r. It converts plant matter into compost and &bfertilizer&r on &6EU&r, closing the loop between your farms and your soil."
		"Feed it the surplus your steam farm produces."
	]
	quest.4954021000000034.quest_subtitle: "Turn scraps into compost."
	quest.4954021000000034.title: "Electric Composter"
	quest.4954021000000035.quest_desc: [
		"Craft an &bElectric Honey Extractor&r. It pulls honey and comb from filled hives automatically, an &6Extended Industrialization&r machine for the apiary side of a base."
		"Niche, but a clean source of honey at volume."
	]
	quest.4954021000000035.quest_subtitle: "Harvest the hives."
	quest.4954021000000035.title: "Electric Honey Extractor"
	quest.4954021000000036.quest_desc: [
		"Build an &bElectric Waste Collector&r. It collects waste and stray output from busy machines, keeping the floor clear and recovering what it can."
		"The tidy end of a heavy &dindustrial&r setup."
	]
	quest.4954021000000036.quest_subtitle: "Gather the byproducts."
	quest.4954021000000036.title: "Electric Waste Collector"
	quest.4954021000000040.quest_desc: [
		"Modern Industrialization's steam mining drill runs on the same steam you already make. Craft it at the steel tier and fill it from any boiler or steam-holding tank."
		"It digs faster than iron tools and never breaks. It only stops when the steam runs out, so top it up before long trips."
		"This is the first rung of MI's handheld ladder. Diesel tools come later in the refinery age, and titanium after that."
	]
	quest.4954021000000040.quest_subtitle: "Your first powered digger."
	quest.4954021000000040.title: "Steam Mining Drill"
	quest.4954051000000001.quest_desc: [
		"Craft an &6Immersive Engineering&r &bLV Wire Connector&r. It is the attachment point that lets LV wire carry power into and out of a machine, the first piece of any wired setup."
		"Two connectors and a length of wire make your first real power line."
	]
	quest.4954051000000001.quest_subtitle: "Tap the low-voltage grid."
	quest.4954051000000001.title: "LV Wire Connector"
	quest.4954051000000002.quest_desc: [
		"Build an &bLV Accumulator&r. It banks the power your generators make so machines keep running when production dips, the simplest &bbattery&r in the IE line."
		"Wire it between your source and your load to smooth out the flow."
	]
	quest.4954051000000002.quest_subtitle: "Store a low-voltage charge."
	quest.4954051000000002.title: "LV Accumulator"
	quest.4954051000000003.quest_desc: [
		"Craft a &6Create Addition&r &bAlternator&r. Spun by a &6Create&r &bshaft&r, it turns rotational force into FE. It bridges your windmills and water wheels to an electric grid."
		"Faster rotation means more power, up to the machine's limit."
	]
	quest.4954051000000003.quest_subtitle: "Rotation becomes current."
	quest.4954051000000003.title: "Alternator"
	quest.4954051000000004.quest_desc: [
		"Build a &6Create Addition&r &bElectric Motor&r. It runs the &balternator&r in reverse, spending FE to spin a shaft, so stored power can drive your kinetic contraptions on demand."
		"Together the two let you move freely between rotation and electricity."
	]
	quest.4954051000000004.quest_subtitle: "Current becomes rotation."
	quest.4954051000000004.title: "Electric Motor"
	quest.4954051000000005.quest_desc: [
		"Craft a &6Create Addition&r &bAccumulator&r. It stores a larger charge than the IE unit and stacks with its neighbors. It keeps a growing grid steady."
		"Size storage to cover peak draw."
	]
	quest.4954051000000005.quest_subtitle: "A bigger FE bank."
	quest.4954051000000005.title: "Accumulator"
	quest.4954051000000007.quest_desc: ["Build an &6Oritech&r &bBasic Generator&r. It burns fuel for a steady trickle of energy. It is a no-rotation starter for the Oritech machines that want &6FE&r straight away."]
	quest.4954051000000007.quest_subtitle: "Oritech's first power source."
	quest.4954051000000007.title: "Basic Generator"
	quest.4954051000000008.quest_desc: [
		"Place an &6EnderIO&r &bCapacitor Bank&r. It is a multiblock &bbattery&r you extend by adding more banks together, scaling capacity as your demands grow."
		"Start with one and bolt on more once the grid outpaces it."
	]
	quest.4954051000000008.quest_subtitle: "EnderIO's modular storage."
	quest.4954051000000008.title: "Capacitor Bank"
	quest.4954051000000009.quest_desc: [
		"Craft a &bSmall Connector&r. It is &6Create Addition&r's low-throughput wire tap, fine for a single machine without the bulk of a heavier connector."
		"Use these for light runs and save the big connectors for trunk lines."
	]
	quest.4954051000000009.quest_subtitle: "Create Addition's wire tap."
	quest.4954051000000009.title: "Small Connector"
	quest.495405100000000B.quest_desc: [
		"Craft a &6PowerGrid&r &bBattery&r. It stores energy you can carry between setups, the entry point into PowerGrid's deeper electrical engineering."
		"&6PowerGrid&r models real circuits, so expect to think in voltage and current rather than FE in a pipe."
	]
	quest.495405100000000B.quest_subtitle: "PowerGrid's portable charge."
	quest.495405100000000B.title: "Battery"
	quest.495405100000000C.quest_desc: [
		"Build a &6Create Addition&r &bTesla Coil&r. Charged with &6FE&r it arcs power to nearby coils and zaps hostile mobs that wander too close, part utility and part defense."
		"Handy for short wireless hops and for guarding a perimeter."
	]
	quest.495405100000000C.quest_subtitle: "Power through the air."
	quest.495405100000000C.title: "Tesla Coil"
	quest.495405100000000D.quest_desc: [
		"You built the &bRolling Mill&r back in the Medieval mill, so there is nothing new to craft here. This node just confirms you still have one, because the mill is what turns your ingots into the pressed plates and copper spools every electric machine below needs."
		"If this quest is not already complete, go back and finish the Medieval Rolling Mill quest. The rolled stock it makes feeds directly into the connectors and wire work in this chapter."
	]
	quest.495405100000000D.quest_subtitle: "Rolled stock, already earned."
	quest.495405100000000D.title: "Rolling Mill"
	quest.495405100000000F.quest_desc: [
		"Craft a &6Create&r &bRedstone Link&r. A linked pair passes a redstone signal across any distance, the clean way to switch a remote machine without trailing dust everywhere."
		"Set the frequency with the items in its slots."
	]
	quest.495405100000000F.quest_subtitle: "Wireless redstone signals."
	quest.495405100000000F.title: "Redstone Link"
	quest.4954051000000011.quest_desc: [
		"With an &belectric motor&r, &balternator&r, &baccumulator&r, and an Oritech generator in hand, your core power loop is complete. You can make FE, store it, and turn it back into rotation at will."
		"This is the foundation the rest of the chapter's grids and machines plug into."
	]
	quest.4954051000000011.quest_subtitle: "The power core is online."
	quest.4954051000000011.title: "Rotation and Current, Joined"
	quest.4954051000000012.quest_desc: [
		"Build a &bPortable Energy Interface&r. It transfers &6FE&r to and from a &6Create&r contraption as it passes, the way to keep a moving rig charged without a trailing cable."
		"Mount one on the contraption and one on the track."
	]
	quest.4954051000000012.quest_subtitle: "Power a moving contraption."
	quest.4954051000000012.title: "Portable Energy Interface"
	quest.4954051000000013.quest_desc: [
		"Craft a &bDigital Adapter&r. It reads and reports the state of &6Create&r blocks as redstone or computer signals, the bridge between kinetic machinery and control logic."
		"The start of automating your factory's decisions as well as its motions."
	]
	quest.4954051000000013.quest_subtitle: "Wire Create into logic."
	quest.4954051000000013.title: "Digital Adapter"
	quest.4954051000000014.quest_desc: [
		"Craft a &6PowerGrid&r &bGenerator Housing&r. It is the frame a custom generator is assembled inside, holding the rotor, commutator, and &bclutch&r you fit into it."
		"From here, PowerGrid gives you parts, not finished machines."
	]
	quest.4954051000000014.quest_subtitle: "The shell of a real generator."
	quest.4954051000000014.title: "Generator Housing"
	quest.4954051000000015.quest_desc: [
		"Build a &bVertical Generator Housing&r. It is the same shell oriented for a vertical drive, for when your rotation comes down a column rather than across the floor."
		"Pick the housing that matches how your shafts run."
	]
	quest.4954051000000015.quest_subtitle: "The upright variant."
	quest.4954051000000015.title: "Vertical Generator Housing"
	quest.4954051000000016.quest_desc: [
		"Craft a &bGenerator Induction Rotor&r. Spun inside the housing it is what actually induces current, the moving core every &6PowerGrid&r generator turns on."
		"Match the rotor to the rotation speed you can supply."
	]
	quest.4954051000000016.quest_subtitle: "The spinning heart."
	quest.4954051000000016.title: "Generator Induction Rotor"
	quest.4954051000000017.quest_desc: [
		"Build a &bGenerator Commutator&r. It picks the current off the spinning rotor and feeds it to your wiring, the contact piece between motion and output."
		"Without it the rotor spins for nothing."
	]
	quest.4954051000000017.quest_subtitle: "Collect the current."
	quest.4954051000000017.title: "Generator Commutator"
	quest.4954051000000018.quest_desc: [
		"Craft a &bVertical Generator Commutator&r. It is the commutator sized for the vertical housing, completing the upright generator's output path."
		"Use it where your housing stands on end."
	]
	quest.4954051000000018.quest_subtitle: "The upright pickup."
	quest.4954051000000018.title: "Vertical Commutator"
	quest.4954051000000019.quest_desc: [
		"Build a &bGenerator Clutch&r. It couples or frees the rotor from the drive, letting you spin a generator up or idle it without tearing down the rotation behind it."
		"Useful for cutting output without stopping the whole line."
	]
	quest.4954051000000019.quest_subtitle: "Engage and disengage."
	quest.4954051000000019.title: "Generator Clutch"
	quest.495405100000001A.quest_desc: [
		"Craft a &bConstant Speed Motor&r. It spends electricity to turn at a fixed rate regardless of load, the dependable drive for machines that need an even rotation."
		"Where a &6Create&r motor wavers under strain, this holds its speed."
	]
	quest.495405100000001A.quest_subtitle: "Steady rotation from power."
	quest.495405100000001A.title: "Constant Speed Motor"
	quest.495405100000001B.quest_desc: [
		"Build the &bCircuit Design Table&r. Draft &6PowerGrid&r's control circuits here, arranging the logic before committing it to a card."
		"The bench the punch cards come off."
	]
	quest.495405100000001B.quest_subtitle: "Lay out a control circuit."
	quest.495405100000001B.title: "Circuit Design Table"
	quest.495405100000001C.quest_desc: [
		"Craft a &bPunch Card Reader&r. It executes the circuits you punch out at the design table. A working layout becomes a card you can plug in and reuse."
		"Design once, stamp a card, run it anywhere."
	]
	quest.495405100000001C.quest_subtitle: "Run a saved program."
	quest.495405100000001C.title: "Punch Card Reader"
	quest.495405100000001D.quest_desc: [
		"Build a &bCathode Ray Tube&r. It is &6PowerGrid&r's display, showing circuit and grid state at a glance."
		"A screen on the wall beats chasing faults by hand."
	]
	quest.495405100000001D.quest_subtitle: "Read the grid at a glance."
	quest.495405100000001D.title: "Cathode Ray Tube"
	quest.495405100000001E.quest_desc: ["Craft a &bCarbon Pile Coil&r. It is the item form used to build PowerGrid's adjustable resistance assembly."]
	quest.495405100000001E.quest_subtitle: "Build the resistor coil."
	quest.495405100000001E.title: "Carbon Pile Coil"
	quest.495405100000001F.quest_desc: [
		"Build a &bCarbon Pile Coil&r. It is the wound component the carbon pile is built around, the piece that gives the load its adjustable range."
		"Make it before you can finish the pile itself."
	]
	quest.495405100000001F.quest_subtitle: "The pile's wound core."
	quest.495405100000001F.title: "Carbon Pile Coil"
	quest.4954051000000020.quest_desc: [
		"Craft a &bBasin Heater&r. It warms a &6Create&r basin using electricity instead of a &bblaze burner&r, swapping a fuel run for a wire once your grid can spare the draw."
		"Clean heat for the mixing and cooking recipes that need it."
	]
	quest.4954051000000020.quest_subtitle: "Heat a basin with power."
	quest.4954051000000020.title: "Basin Heater"
	quest.4954051000000023.quest_desc: [
		"Build a &bContactor&r. It is a heavy electrical switch, opening or closing a circuit on a signal so you can cut power to a section without pulling wire."
		"The relay behind any automated grid control."
	]
	quest.4954051000000023.quest_subtitle: "Switch power under load."
	quest.4954051000000023.title: "Contactor"
	quest.4954051000000024.quest_desc: [
		"Craft a &bVariac&r. It is a variable &btransformer&r, letting you trim output voltage smoothly rather than in fixed steps, for fine-tuning a finicky machine."
		"Where the &btransformer&r sets a tier, the variac sets the exact level."
	]
	quest.4954051000000024.quest_subtitle: "Dial the voltage by hand."
	quest.4954051000000024.title: "Variac"
	quest.4954051000000025.quest_desc: [
		"Build a &bRheostat&r. It is a variable resistor you set by hand to limit current in a line, useful for throttling a load without rewiring it."
		"Another knob for the grid engineer's panel."
	]
	quest.4954051000000025.quest_subtitle: "Adjustable resistance."
	quest.4954051000000025.title: "Rheostat"
	quest.4954051000000026.quest_desc: [
		"Craft a &6PowerGrid&r &bElectric Motor&r. It converts electricity back into rotation. It is the output end of everything you built upstream."
		"Generator to grid to motor to machine."
	]
	quest.4954051000000026.quest_subtitle: "PowerGrid's drive output."
	quest.4954051000000026.title: "Electric Motor"
	quest.4954051000000027.quest_desc: [
		"Craft a &6Modern Dynamics&r &bLV EU Cable&r. It carries low-voltage power with tidy, connectable runs, the cleaner alternative to scattering connectors everywhere."
		"&6Modern Dynamics&r is the logistics backbone for cables, pipes, and item routing both."
	]
	quest.4954051000000027.quest_subtitle: "Modern Dynamics, low voltage."
	quest.4954051000000027.title: "LV EU Cable"
	quest.4954051000000028.quest_desc: [
		"Build a &6Modern Dynamics&r &bItem Pipe&r. It moves items between machines and storage along a routed network, the item side of the same tidy logistics system."
		"Set filters and priorities to keep the flow going where you want."
	]
	quest.4954051000000028.quest_subtitle: "Route items cleanly."
	quest.4954051000000028.title: "Item Pipe"
	quest.4954051000000029.quest_desc: [
		"Craft a &bMachine Extender&r. It exposes a machine's input or output to the side you need, so a pipe or cable can reach a face that is otherwise boxed in."
		"A small fix for the tight spots in a packed build."
	]
	quest.4954051000000029.quest_subtitle: "Reach into a machine's guts."
	quest.4954051000000029.title: "Machine Extender"
	quest.495405100000002A.quest_desc: [
		"Build a &6Dynamic Electricity&r &bAlternator&r. It is a parallel route from rotation to current, giving you a second mod's take on the same conversion step."
		"Pick whichever &balternator&r slots best into the gear you already run."
	]
	quest.495405100000002A.quest_subtitle: "Another rotation-to-power option."
	quest.495405100000002A.title: "Dynamic Electricity Alternator"
	quest.495405100000002B.quest_desc: [
		"Craft an &6Electrodynamics&r &bTriple Electric Furnace&r. It smelts three stacks in parallel on electric power, a serious throughput jump over single furnaces."
		"&6Electrodynamics&r machines run on real voltage tiers, so feed it the power it expects."
	]
	quest.495405100000002B.quest_subtitle: "Smelt three at once."
	quest.495405100000002B.title: "Triple Electric Furnace"
	quest.495405100000002C.quest_desc: [
		"Build a &bTriple Electric Arc Furnace&r. It runs alloying and high-heat recipes three at a time, the heavy smelter for when one arc furnace is a bottleneck."
		"Reserve it for the recipes a plain &bfurnace&r cannot do."
	]
	quest.495405100000002C.quest_subtitle: "Alloys at volume."
	quest.495405100000002C.title: "Triple Electric Arc Furnace"
	quest.495405100000002D.quest_desc: ["Craft a &bTriple Mineral Grinder&r. It crushes ore into dust three lines at once, turning each ore into two ingots' worth of output."]
	quest.495405100000002D.quest_subtitle: "Double your ore yield, in bulk."
	quest.495405100000002D.title: "Triple Mineral Grinder"
	quest.495405100000002E.quest_desc: [
		"Build a &bTriple Wire Mill&r. It draws ingots into wire three at a time, feeding the constant wire demand of an electrical base without hand-crafting."
		"Wire is cheap to make and tedious to make by hand, so automate it early."
	]
	quest.495405100000002E.quest_subtitle: "Spin wire at scale."
	quest.495405100000002E.title: "Triple Wire Mill"
	quest.495405100000002F.quest_desc: [
		"Craft an &6Electrodynamics&r &bSolar Panel&r. It generates a quiet stream of power in sunlight with no fuel and no upkeep."
		"Output drops at night and in bad weather, so pair it with storage."
	]
	quest.495405100000002F.quest_subtitle: "Power from daylight."
	quest.495405100000002F.title: "Solar Panel"
	quest.4954051000000030.quest_desc: ["Build an &bAdvanced Solar Panel&r. It produces considerably more than the basic panel for the same footprint. Switch to these before roof space gets tight."]
	quest.4954051000000030.quest_subtitle: "More watts per tile."
	quest.4954051000000030.title: "Advanced Solar Panel"
	quest.4954051000000031.quest_desc: ["Craft a &bThermoelectric Generator&r. It makes power from the difference between a hot side and a cold side. Site it wherever you already have lava and ice or water."]
	quest.4954051000000031.quest_subtitle: "Power from a heat gap."
	quest.4954051000000031.title: "Thermoelectric Generator"
	quest.4954051000000032.quest_desc: ["Build a &bHydroelectric Generator&r. Set in moving water, it spins out steady power with no fuel near any river or fall."]
	quest.4954051000000032.quest_subtitle: "Power from flowing water."
	quest.4954051000000032.title: "Hydroelectric Generator"
	quest.4954051000000033.quest_desc: [
		"Craft an &6Electrodynamics&r &bWindmill&r. Mounted high in open air it turns wind into power, output rising with altitude and exposure."
		"Put it up where nothing blocks the sky for the best yield."
	]
	quest.4954051000000033.quest_subtitle: "Power from the breeze."
	quest.4954051000000033.title: "Windmill"
	quest.4954051000000034.quest_desc: [
		"Build an &6Electrodynamics&r &bCoal Generator&r. It burns solid fuel for dependable output regardless of weather."
		"Not clean, but it never cares whether the sun is up."
	]
	quest.4954051000000034.quest_subtitle: "Burn for reliable power."
	quest.4954051000000034.title: "Coal Generator"
	quest.4954051000000035.quest_desc: ["Craft a &bCombustion Chamber&r. It burns liquid fuels for a stronger output than solid fuel. Feed it with a &brefinery&r for the best return."]
	quest.4954051000000035.quest_subtitle: "Liquid fuel, more power."
	quest.4954051000000035.title: "Combustion Chamber"
	quest.4954051000000036.quest_desc: [
		"Build an &6Electrodynamics&r &bCompressor&r. It presses materials into denser forms and the plates and parts other &6Electrodynamics&r machines need."
		"Several of the mod's recipes dead-end without it."
	]
	quest.4954051000000036.quest_subtitle: "Squeeze materials into shape."
	quest.4954051000000036.title: "Compressor"
	quest.4954051000000037.quest_desc: [
		"Craft the Mineral Grinder, Electrodynamics' entry ore processor."
		"The grinder chews ore into extra dust for a doubling gain, running on Forge Energy from your Electrodynamics power setup. It is the first processing machine in this lane and the reason to build the coal generator before it."
		"Wire it to your generator and feed it ore. The ground output goes to the Electric Furnace next for smelting."
	]
	quest.4954051000000037.quest_subtitle: "Electrodynamics base ore grinding"
	quest.4954051000000037.title: "Mineral Grinder"
	quest.4954051000000038.quest_desc: [
		"Craft the Electric Furnace, Electrodynamics' powered smelting machine."
		"It smelts the grinder's output using Forge Energy instead of fuel, so once your power is running there is no coal to feed. Together the grinder and furnace form the base Electrodynamics doubling loop: grind ore to dust, then smelt dust to ingots."
		"Set it beside the Mineral Grinder so both run off the same power line. This completes the entry processing pair for the lane."
	]
	quest.4954051000000038.quest_subtitle: "Electrodynamics base powered smelting"
	quest.4954051000000038.title: "Electric Furnace"
	quest.4954051000000040.quest_desc: [
		"Craft a &bCopper Spool&r. This is how &6Create Crafts and Additions&r wires machines together. Wind a spool, right-click one &bConnector&r and then a second, and a wire link forms between them while the spool stays in your hand."
		"There are two current levels and they do not mix. A &bCopper Spool&r with small &bConnectors&r carries &blow current&r and reaches up to four links per connector. A &bGold&r or &bElectrum Spool&r with a &bLarge Connector&r carries &bhigh current&r and reaches up to six. Feed a hungry machine off a low-current copper line and it tells you it needs a high-current wire instead."
		"A wrench on a connector cycles its mode between &bPush&r, &bPull&r, and &bNone&r, so one node can send energy, draw it, or sit idle. Start with copper and small connectors; the high-current gear below is only worth it once a copper line cannot keep up."
	]
	quest.4954051000000040.quest_subtitle: "Low current versus high current."
	quest.4954051000000040.title: "Low vs High Current"
	quest.4954051000000041.quest_desc: [
		"Build the high-current path. Alloy an &bElectrum Ingot&r from gold and silver, wind it into an &bElectrum Spool&r, and craft a &bCapacitor&r for buffering. Electrum spools feed &bLarge Connectors&r, which is the only wiring a big machine will accept."
		"This branch is optional. A copper low-current line already runs the early electric machines. Come back here when a single machine draws more than a copper wire can deliver and starts asking for high current."
	]
	quest.4954051000000041.quest_subtitle: "Wire for the hungry machines."
	quest.4954051000000041.title: "High-Current Materials"
	quest.4954051000000042.quest_desc: [
		"Set up a renewable fuel loop. Compost or process organic matter into &bBiomass&r, give a &bBlaze Burner&r a &bStraw&r so it accepts liquid fuel, and it becomes a &bLiquid Blaze Burner&r you can feed by bucket or pipe. &bStraw&r itself comes from milling wheat or hay."
		"This is optional. It gives &6Create Crafts and Additions&r a fuel source you can farm instead of mining, handy for keeping a heat source lit without burning through coal."
	]
	quest.4954051000000042.quest_subtitle: "Farm your own burner fuel."
	quest.4954051000000042.title: "Renewable Blaze Fuel"
	quest.4954061000000001.quest_desc: [
		"Build an &bAir Compressor&r. It burns fuel to pack air into pressure, the force every &6PneumaticCraft&r machine runs on, measured in bar."
		"Watch the gauge: push a machine past its danger pressure and it does not warn you twice. It explodes."
	]
	quest.4954061000000001.quest_subtitle: "Make your first pressure."
	quest.4954061000000001.title: "Air Compressor"
	quest.4954061000000002.quest_desc: [
		"Craft Pressure Tubes and a &bPressure Gauge&r. Tubes move compressed air between machines, and the gauge tells you how close to the danger line you are running."
		"Plumb the gauge in early. Flying blind on pressure is how bases lose walls."
	]
	quest.4954061000000002.quest_subtitle: "Carry air, and read it."
	quest.4954061000000002.title: "Pressure Tube"
	quest.4954061000000003.quest_desc: [
		"Build the &bPressure Chamber&r from valve and wall blocks around a hollow space. Seal it completely first, then pressurize it. It compresses items inside into new forms."
		"A leak means no pressure builds, so close every face before you pump it up."
	]
	quest.4954061000000003.quest_subtitle: "Seal it before you pressurize it."
	quest.4954061000000003.title: "Pressure Chamber"
	quest.4954061000000005.quest_desc: [
		"Make an &bEmpty PCB&r in the &bpressure chamber&r. It is the blank board the whole circuit chain begins from, before any pattern is etched into it."
		"Printed circuits gate most of the mod's machines, so set up to make these steadily."
	]
	quest.4954061000000005.quest_subtitle: "Start a circuit board."
	quest.4954061000000005.title: "Empty PCB"
	quest.4954061000000006.quest_desc: [
		"Produce a &bTransistor&r and a &bCapacitor&r. Cut from a finished circuit board, they are the small electronics that the mod's machines and upgrades are built from."
		"Each finished board yields a handful, so good boards mean cheap parts."
	]
	quest.4954061000000006.quest_subtitle: "The electronic parts."
	quest.4954061000000006.title: "Transistor and Capacitor"
	quest.4954061000000007.quest_desc: [
		"Turn an empty board into a &bFinished PCB&r. Expose it under UV light to set the pattern, then bathe it in &betching acid&r to wash away the rest, leaving the working circuit."
		"This is the keystone crafting component for &6PneumaticCraft&r's machinery."
	]
	quest.4954061000000007.quest_subtitle: "Etch, expose, finish."
	quest.4954061000000007.title: "Finished PCB"
	quest.4954061000000009.quest_desc: [
		"Craft an &bAssembly Controller&r. It coordinates the Assembly Line robots. Set it up and the drills and lasers become an automated factory cell."
		"Build it now; the robots that follow are useless without it."
	]
	quest.4954061000000009.quest_subtitle: "Run the robot line."
	quest.4954061000000009.title: "Assembly Controller"
	quest.495406100000000B.quest_desc: [
		"Build a &bHeat Sink&r. Bolted to a machine that runs hot it carries the heat away, keeping temperatures in the band the recipe wants."
		"Heat management is half of running &6PneumaticCraft&r well."
	]
	quest.495406100000000B.quest_subtitle: "Shed unwanted heat."
	quest.495406100000000B.title: "Heat Sink"
	quest.495406100000000C.quest_desc: [
		"Craft a &bVacuum Pump&r. It produces negative pressure, the opposite of the &bcompressor&r, which a handful of recipes and the assembly setup specifically need."
		"Negative bar has its own danger line, so watch that gauge too."
	]
	quest.495406100000000C.quest_subtitle: "Pull instead of push."
	quest.495406100000000C.title: "Vacuum Pump"
	quest.495406100000000E.quest_desc: ["Build an &bAerial Interface&r. Linked to a player it pipes items, fluids, and experience to and from them. Drones and machines use it to interact with your stored inventory."]
	quest.495406100000000E.quest_subtitle: "Bridge to a player inventory."
	quest.495406100000000E.title: "Aerial Interface"
	quest.495406100000000F.quest_desc: [
		"Craft a &bDrone&r. Given a program at a drone interface it flies set routes to dig, build, farm, or haul, &6PneumaticCraft&r's flexible answer to automation."
		"The programming has a learning curve, but a good &bdrone&r replaces a wall of machines."
	]
	quest.495406100000000F.quest_subtitle: "Programmable automation."
	quest.495406100000000F.title: "Drone"
	quest.4954061000000010.quest_desc: [
		"Add a &bPressure Chamber Interface&r to your chamber. It imports raw items and exports the compressed results without breaking the seal, the automation port for the chamber."
		"Two interfaces, one in and one out, make the chamber hands-free."
	]
	quest.4954061000000010.quest_subtitle: "Get items in and out."
	quest.4954061000000010.title: "Pressure Chamber Interface"
	quest.4954061000000011.quest_desc: [
		"Produce a &bBlock of Compressed Iron&r. Iron squeezed in the &bpressure chamber&r, or blown up with explosives, becomes the compressed iron most &6PneumaticCraft&r machines are built from."
		"Stockpile it; nearly everything ahead wants some."
	]
	quest.4954061000000011.quest_subtitle: "The mod's base metal."
	quest.4954061000000011.title: "Block of Compressed Iron"
	quest.4954061000000012.quest_desc: [
		"Make an &bUnassembled PCB&r. It is the board after etching but before the last step, the stage between a raw blank and a working finished circuit."
		"A checkpoint in the circuit chain worth understanding."
	]
	quest.4954061000000012.quest_subtitle: "The etched, unfinished board."
	quest.4954061000000012.title: "Unassembled PCB"
	quest.4954061000000013.quest_desc: [
		"Brew a bucket of &bEtching Acid&r. Dunking an exposed board in it strips the unwanted &bcopper&r, leaving the printed circuit behind."
		"Handle with the usual respect you give a bucket of something corrosive."
	]
	quest.4954061000000013.quest_subtitle: "Wash the boards clean."
	quest.4954061000000013.title: "Etching Acid"
	quest.4954061000000014.quest_desc: [
		"Craft a &bLogistic Default Storage Frame&r. Slapped on a chest it marks that container as a storage target in the logistics network, directing where drones drop goods."
		"The frames are how a &bdrone&r fleet knows the layout of your base."
	]
	quest.4954061000000014.quest_subtitle: "Tell drones what goes where."
	quest.4954061000000014.title: "Logistics Frame"
	quest.4954061000000016.quest_desc: [
		"Craft an &bAir Canister&r. It stores compressed air you can carry, topping up pneumatic tools and armor away from a &bcharging station&r."
		"A full canister is a portable tank of power."
	]
	quest.4954061000000016.quest_subtitle: "Bottle some pressure."
	quest.4954061000000016.title: "Air Canister"
	quest.4954061000000017.quest_desc: [
		"Build a &bCharging Station&r. Pressurized air from it tops up pneumatic tools, armor, and drones, the refuel point for everything air-powered you carry."
		"Park it where your gear sits between jobs."
	]
	quest.4954061000000017.quest_subtitle: "Refuel your gear."
	quest.4954061000000017.title: "Charging Station"
	quest.4954061000000019.quest_desc: [
		"Craft a &bPressure Gauge Tube Module&r. Clipped onto a &bpressure tube&r it shows the pressure at that point, letting you spot a problem section at a glance."
		"More eyes on the line means fewer surprises."
	]
	quest.4954061000000019.quest_subtitle: "Read a tube in place."
	quest.4954061000000019.title: "Pressure Gauge Module"
	quest.495406100000001A.quest_desc: [
		"Build an &bAir Grate Tube Module&r. Fed pressure it pulls in or pushes away mobs and items in range, a tube-mounted tool for crowd control and gathering."
		"Reverse it with vacuum to draw things in instead."
	]
	quest.495406100000001A.quest_subtitle: "Vent or pull mobs."
	quest.495406100000001A.title: "Air Grate Module"
	quest.495406100000001B.quest_desc: [
		"Build the &bThermopneumatic Processing Plant&r. It combines heat, pressure, and fluids to run the mod's chemistry, from cracking oil to producing the liquid &bplastic&r this chapter is named for."
		"Feed it the right temperature and bar and it produces recipes no other machine can match."
	]
	quest.495406100000001B.quest_subtitle: "Heat, pressure, and fluids."
	quest.495406100000001B.title: "Thermopneumatic Processing Plant"
	quest.495406100000001C.quest_desc: [
		"Craft a &bUV Light Box&r. It exposes a blank board to set the circuit pattern before etching, the first half of finishing a &bPCB&r."
		"Expose, then etch. Skip the light and the acid eats everything."
	]
	quest.495406100000001C.quest_subtitle: "Expose the boards."
	quest.495406100000001C.title: "UV Light Box"
	quest.495406100000001D.quest_desc: [
		"With a &bcompressor&r, a sealed &bpressure chamber&r, a finished circuit chain, and the processing plant all running, the core of &6PneumaticCraft&r is in place."
		"From here the assembly line and the advanced compressors are yours to build out."
	]
	quest.495406100000001D.quest_subtitle: "The PneumaticCraft core is running."
	quest.495406100000001D.title: "Pressure and Circuits Complete"
	quest.495406100000001E.quest_desc: [
		"Build an &bAdvanced Air Compressor&r. It produces pressure faster and to a higher ceiling than the basic unit, for when one compressor cannot keep the bar up."
		"Higher ceilings mean higher stakes, so mind the danger line."
	]
	quest.495406100000001E.quest_subtitle: "More pressure, faster."
	quest.495406100000001E.title: "Advanced Air Compressor"
	quest.495406100000001F.quest_desc: [
		"Craft an &bAdvanced Liquid Compressor&r. It runs on liquid fuels for strong, steady pressure, pairing neatly with the oil chain you built last chapter."
		"&bDiesel&r in, bar out, efficiently."
	]
	quest.495406100000001F.quest_subtitle: "Burn fuel, make pressure."
	quest.495406100000001F.title: "Advanced Liquid Compressor"
	quest.4954061000000020.quest_desc: [
		"Build a &bThermal Compressor&r. It turns a difference in temperature into pressure. Site it wherever you can keep one side hot and the other cold."
		"A clean source if you already manage heat."
	]
	quest.4954061000000020.quest_subtitle: "Pressure from a heat gap."
	quest.4954061000000020.title: "Thermal Compressor"
	quest.4954061000000021.quest_desc: [
		"Craft an &bElectrostatic Compressor&r. Built tall to catch lightning strikes, it converts the jolt into a burst of pressure. Output is irregular but free."
		"Site it where storms roll through and the sky does the work."
	]
	quest.4954061000000021.quest_subtitle: "Pressure from lightning."
	quest.4954061000000021.title: "Electrostatic Compressor"
	quest.4954061000000022.quest_desc: [
		"Build a &bSolar Compressor&r. In direct sun it makes a quiet stream of pressure with no fuel. A hands-off baseline for daytime needs."
		"Modest output, but it asks nothing of you."
	]
	quest.4954061000000022.quest_subtitle: "Pressure from sunlight."
	quest.4954061000000022.title: "Solar Compressor"
	quest.4954061000000023.quest_desc: [
		"Craft a &bFlux Compressor&r. It converts &6FE&r into pressure, the bridge that lets your electrical grid feed your pneumatic one."
		"Use it when your electrical grid has spare capacity."
	]
	quest.4954061000000023.quest_subtitle: "Spend FE for pressure."
	quest.4954061000000023.title: "Flux Compressor"
	quest.4954061000000024.quest_desc: [
		"Build a &bManual Compressor&r. Right-click it to pump a little pressure by hand, the bootstrap source for charging your first tool before any automation exists."
		"Slow and tiring, but it needs nothing but you."
	]
	quest.4954061000000024.quest_subtitle: "Pump it by hand."
	quest.4954061000000024.title: "Manual Compressor"
	quest.4954061000000026.quest_desc: [
		"Craft a &bPneumatic Dynamo&r. It spends pressure to make &6FE&r, the reverse of the &bflux compressor&r, closing the loop between your air and electrical systems."
		"Convert whichever way your surplus runs."
	]
	quest.4954061000000026.quest_subtitle: "Pressure back into power."
	quest.4954061000000026.title: "Pneumatic Dynamo"
	quest.4954061000000028.quest_desc: [
		"Build Reinforced Pressure Tubes. They tolerate far more pressure than the basic kind before bursting. Use them for high-bar trunk lines."
		"Upgrade your mains to these before you push the pressure up."
	]
	quest.4954061000000028.quest_subtitle: "Hold a higher bar."
	quest.4954061000000028.title: "Reinforced Pressure Tube"
	quest.4954061000000029.quest_desc: ["Craft a &bTube Junction&r. It branches a pressure line in a controlled way, keeping a tangled air network tidy and predictable."]
	quest.4954061000000029.quest_subtitle: "Split the air cleanly."
	quest.4954061000000029.title: "Tube Junction"
	quest.495406100000002A.quest_desc: [
		"Build a &bReinforced Pressure Chamber Valve&r. With reinforced walls it lets the pressure chamber run at a higher bar, compressing recipes the basic chamber cannot reach."
		"The upgrade path for serious compression work."
	]
	quest.495406100000002A.quest_subtitle: "A tougher chamber."
	quest.495406100000002A.title: "Reinforced Chamber Valve"
	quest.495406100000002B.quest_desc: [
		"Craft an &bEtching Tank&r. It holds &betching acid&r as a station rather than a bucket, letting you finish boards in volume instead of one dunk at a time."
		"The automation upgrade for the circuit line."
	]
	quest.495406100000002B.quest_subtitle: "Etch boards in bulk."
	quest.495406100000002B.title: "Etching Tank"
	quest.495406100000002C.quest_desc: [
		"Build a &bGas Lift&r. It draws fluids up from underground lakes and wells, &6PneumaticCraft&r's way to harvest oil or water in bulk from the depths."
		"Another route to feed the oil chain."
	]
	quest.495406100000002C.quest_subtitle: "Pump fluids from below."
	quest.495406100000002C.title: "Gas Lift"
	quest.495406100000002D.quest_desc: [
		"Craft an &bAir Cannon&r. Charged with pressure it fires items across distance, useful for flinging produce into storage or launching a &bdrone&r payload."
		"A blunt tool with a surprising number of uses."
	]
	quest.495406100000002D.quest_subtitle: "Launch items, or yourself."
	quest.495406100000002D.title: "Air Cannon"
	quest.495406100000002E.quest_desc: [
		"Build a &bVortex Tube&r. Fed pressure it produces a hot end and a cold end at once, the cleanest way to supply heat and cold to recipes that need both."
		"The heart of any serious heat-management setup."
	]
	quest.495406100000002E.quest_subtitle: "Split air into hot and cold."
	quest.495406100000002E.title: "Vortex Tube"
	quest.495406100000002F.quest_desc: [
		"Craft Heat Pipes. They carry heat between machines and heat sinks, the plumbing that moves warmth from the &bvortex tube&r to where a recipe wants it."
		"Lay them like wire, but for temperature."
	]
	quest.495406100000002F.quest_subtitle: "Conduct the heat."
	quest.495406100000002F.title: "Heat Pipe"
	quest.4954061000000030.quest_desc: [
		"Apply &bThermal Lagging&r. It insulates a &bheat pipe&r or machine so the heat goes where you route it instead of bleeding into the room."
		"The difference between a tuned heat loop and a warm mess."
	]
	quest.4954061000000030.quest_subtitle: "Insulate the line."
	quest.4954061000000030.title: "Thermal Lagging"
	quest.4954061000000031.quest_desc: ["Build a &bHuge Fluid Tank&r. It banks large volumes of oil, fuel, or &bplastic&r. Size the tank to the chemistry it feeds."]
	quest.4954061000000031.quest_subtitle: "Store fluids at scale."
	quest.4954061000000031.title: "Huge Fluid Tank"
	quest.4954061000000032.quest_desc: [
		"Craft a &bLiquid Hopper&r. It pulls fluids from one container into another the way a hopper moves items, simple plumbing without a full pipe network."
		"Handy for the short fluid hops."
	]
	quest.4954061000000032.quest_subtitle: "Move fluids like items."
	quest.4954061000000032.title: "Liquid Hopper"
	quest.4954061000000033.quest_desc: [
		"Build an &bOmnidirectional Hopper&r. It moves items between any two faces you set, a more flexible hopper for the awkward corners of a packed build."
		"Where a vanilla hopper only points down, this points wherever you need."
	]
	quest.4954061000000033.quest_subtitle: "Hopper, any direction."
	quest.4954061000000033.title: "Omnidirectional Hopper"
	quest.4954061000000034.quest_desc: [
		"Build an &bAssembly Platform&r. It is the base the assembly robots stand on, the foundation that the drill, laser, and IO units attach around."
		"Set the platform first, then add the tools that work over it."
	]
	quest.4954061000000034.quest_subtitle: "Lay the robot floor."
	quest.4954061000000034.title: "Assembly Platform"
	quest.4954061000000035.quest_desc: [
		"Craft an &bAssembly Drill&r. Mounted on the platform it performs the drilling steps of complex recipes, one of the robots the controller directs."
		"Drill and laser together cover most of what the line builds."
	]
	quest.4954061000000035.quest_subtitle: "The line's first robot."
	quest.4954061000000035.title: "Assembly Drill"
	quest.4954061000000036.quest_desc: [
		"Build an &bAssembly Laser&r. It handles the cutting and engraving steps of assembly recipes, the partner to the drill on the automated line."
		"With both in place the controller can build the harder items."
	]
	quest.4954061000000036.quest_subtitle: "The line's second robot."
	quest.4954061000000036.title: "Assembly Laser"
	quest.4954061000000037.quest_desc: [
		"Craft an &bAssembly IO Unit&r set to import. It brings raw materials onto the platform for the robots to work, the inbound end of the assembly cell."
		"Nothing gets built if nothing gets fed in."
	]
	quest.4954061000000037.quest_subtitle: "Feed the line."
	quest.4954061000000037.title: "Assembly IO Unit (Import)"
	quest.4954061000000038.quest_desc: [
		"Build an &bAssembly IO Unit&r set to export. It carries finished items off the platform into your storage, completing the assembly line from feed to output."
		"Import, work, export: the full cell is now running."
	]
	quest.4954061000000038.quest_subtitle: "Take the products off."
	quest.4954061000000038.title: "Assembly IO Unit (Export)"
	quest.4954071000000001.quest_desc: [
		"Craft an &6Immersive Petroleum&r &bProjector&r. It shows a ghost preview of a multiblock so you can build the &bderrick&r and pumpjack correctly the first time."
		"Immersive Petroleum owns the oil chain here, and the projector is its opening move."
	]
	quest.4954071000000001.quest_subtitle: "Preview the oil multiblocks."
	quest.4954071000000001.title: "Projector"
	quest.4954071000000002.quest_desc: [
		"Build the &bDerrick&r multiblock. It drills down to find and tap an underground oil reservoir, the first structure of the petroleum chain."
		"Use the &bprojector&r to lay it out, then power it and wait for it to strike oil."
	]
	quest.4954071000000002.quest_subtitle: "Drill for a reservoir."
	quest.4954071000000002.title: "Derrick"
	quest.4954071000000003.quest_desc: [
		"Assemble the &bPumpjack&r multiblock. Once the &bderrick&r has found a reservoir, the pumpjack draws the &bcrude oil&r up steadily for as long as the field holds out."
		"A single field can run a base for a very long time."
	]
	quest.4954071000000003.quest_subtitle: "Extract the crude."
	quest.4954071000000003.title: "Pumpjack"
	quest.4954071000000004.quest_desc: [
		"Collect a &bBucket of Crude Oil&r from your &bpumpjack&r. On its own it does little, but refined it becomes the &bdiesel&r, gasoline, and lubricant the whole industrial age runs on."
		"Everything downstream starts as this thick black fluid."
	]
	quest.4954071000000004.quest_subtitle: "The raw feedstock."
	quest.4954071000000004.title: "Crude Oil"
	quest.4954071000000005.quest_desc: [
		"Build the &bOil Tank&r multiblock. It stores the crude your &bpumpjack&r produces so extraction never stalls waiting on refining, the buffer between well and tower."
		"Size your storage to the gap between pumping and processing."
	]
	quest.4954071000000005.quest_subtitle: "Buffer the crude."
	quest.4954071000000005.title: "Oil Tank"
	quest.4954071000000006.quest_desc: [
		"Raise the &bDistillation Tower&r multiblock. It splits &bcrude oil&r into its useful fractions, &bdiesel&r, gasoline, lubricant, and naphtha, the core of the petroleum chain."
		"This is the machine that turns raw sludge into power and plastic."
	]
	quest.4954071000000006.quest_subtitle: "Crack crude into fuels."
	quest.4954071000000006.title: "Distillation Tower"
	quest.4954071000000007.quest_desc: [
		"Refine a &bBucket of Diesel&r at the tower. Diesel is the staple fuel of the &dindustrial&r age, burned in engines for serious, steady power."
		"Keep a tank of it; the &bdiesel&r engines are thirsty."
	]
	quest.4954071000000007.quest_subtitle: "The workhorse fuel."
	quest.4954071000000007.title: "Diesel"
	quest.4954071000000008.quest_desc: [
		"Build the &bCoker Unit&r multiblock. It processes the heaviest leftovers of distillation into &bbitumen&r and further products, squeezing value from what the tower cannot."
		"The deep end of the refining chain."
	]
	quest.4954071000000008.quest_subtitle: "Work the heavy residue."
	quest.4954071000000008.title: "Coker Unit"
	quest.4954071000000009.quest_desc: [
		"Produce &bBitumen&r from the coker. It is the tarry bottom of the &bbarrel&r, a building and crafting material that puts the last fraction of crude to use."
		"Nothing from the oil chain has to go to waste."
	]
	quest.4954071000000009.quest_subtitle: "The thick residue."
	quest.4954071000000009.title: "Bitumen"
	quest.495407100000000A.quest_desc: [
		"Build the &bHydrotreater&r multiblock. It refines the tower's output further, cleaning fuels and lifting their grade for the recipes that demand the better product."
		"The finishing step for high-quality fuel."
	]
	quest.495407100000000A.quest_subtitle: "Clean and upgrade the fuels."
	quest.495407100000000A.title: "Hydrotreater"
	quest.495407100000000B.quest_desc: [
		"Craft a &bRefinery Controller&r. Stacked refinery blocks crack oil into fractions by temperature, &6PneumaticCraft&r's route to LPG, kerosene, and the &bdiesel&r that follows."
		"Taller stacks split out more products at once."
	]
	quest.495407100000000B.quest_subtitle: "PneumaticCraft's oil cracking."
	quest.495407100000000B.title: "Refinery Controller"
	quest.495407100000000D.quest_desc: [
		"Produce a &bPlastic Sheet&r. Cooled liquid plastic from the refining chain sets into sheets, the material a great deal of &6PneumaticCraft&r and modern tech is built from."
		"&bPlastic&r is a quiet bottleneck, so start a steady supply early."
	]
	quest.495407100000000D.quest_subtitle: "Mold oil into plastic."
	quest.495407100000000D.title: "Plastic Sheet"
	quest.495407100000000E.quest_desc: [
		"Craft a &bPumpjack Bearing&r. &6Create Diesel Generators&r offers its own kinetic pumpjack built from Create parts, and the bearing is the first piece of that rig."
		"A rotation-driven alternative to the &6Immersive Petroleum&r multiblock."
	]
	quest.495407100000000E.quest_subtitle: "A Create-style pumpjack part."
	quest.495407100000000E.title: "Pumpjack Bearing"
	quest.495407100000000F.quest_desc: [
		"Build a &bDistillation Tank&r and Controller. &6Create Diesel Generators&r distills crude through stacked tanks, a kinetic counterpart to the &6Immersive Petroleum&r tower."
		"Pick the refining route that fits the gear you already run."
	]
	quest.495407100000000F.quest_subtitle: "Create-side refining."
	quest.495407100000000F.title: "Distillation Controller"
	quest.4954071000000010.quest_desc: [
		"Assemble the &bModular Diesel Engine&r. Fed diesel or &bbiodiesel&r it puts out heavy power, the payoff that makes the whole oil chain worth refining."
		"Build it modular, so you can scale the engine to your fuel supply."
	]
	quest.4954071000000010.quest_subtitle: "Burn fuel for big power."
	quest.4954071000000010.title: "Modular Diesel Engine"
	quest.4954071000000011.quest_desc: [
		"Build a &bBulk Fermenter&r. It ferments biomass into &bbiodiesel&r, a renewable fuel that frees the &bdiesel&r engine from the finite oil fields."
		"Pair it with a big farm and the engines never run dry."
	]
	quest.4954071000000011.quest_subtitle: "Grow your own fuel."
	quest.4954071000000011.title: "Bulk Fermenter"
	quest.4954071000000012.quest_desc: [
		"Produce a &bBiodiesel&r Bucket from the fermenter. It burns in the same engines as petroleum &bdiesel&r, a grown-not-drilled fuel for a base that wants to stay self-sufficient."
		"Crops in, power out, indefinitely."
		"&6Create Diesel Generators&r fuels are not all equal. Raw &bethanol&r or &bplant oil&r burn weakest, &bbiodiesel&r blended from plant oil and ethanol is the renewable sweet spot you just made, and refined &bdiesel&r from crude oil burns hottest of the three. Match the fuel to how much power the engine needs rather than always reaching for the strongest."
	]
	quest.4954071000000012.quest_subtitle: "Renewable engine fuel."
	quest.4954071000000012.title: "Biodiesel"
	quest.4954071000000014.quest_desc: [
		"Refine a &bBucket of Lubricant&r. Several heavy machines and the better engines run smoother or faster with it, a side product of the tower well worth bottling."
		"A small input that pays back in throughput."
	]
	quest.4954071000000014.quest_subtitle: "Keep the machines running."
	quest.4954071000000014.title: "Lubricant"
	quest.4954071000000015.quest_desc: [
		"Refine a &bBucket of Gasoline&r. It is the lighter, more energetic fuel from the tower, demanded by the fastest engines and certain vehicles."
		"Reserve it for the machines that specifically ask for it."
	]
	quest.4954071000000015.quest_subtitle: "The high-octane fraction."
	quest.4954071000000015.title: "Gasoline"
	quest.4954071000000101.quest_desc: [
		"Craft the Seismic Survey Tool from Immersive Petroleum and use it to locate oil reservoirs before you commit to a drill site."
		"Oil is hidden underground in reservoirs of varying size. The survey tool reads the chunk you are standing in and tells you whether there is oil below and roughly how much, so you drill where it pays instead of guessing."
		"This sits right after the Engineer's Projector. Survey first, then place your Pumpjack over the best reservoir you find."
	]
	quest.4954071000000101.quest_subtitle: "Scan for oil before you drill"
	quest.4954071000000101.title: "Seismic Survey"
	quest.4954071000000102.quest_desc: [
		"Build the Flarestack to burn off excess gas and pressure from an oil extraction site."
		"A working oil well produces gas as well as crude, and that gas has to go somewhere. The flarestack vents and burns it safely so your rig does not back up. It is a standard fixture on any pumpjack installation."
		"Attach it near your Pumpjack once the well is running. It keeps extraction flowing rather than stalling on trapped gas."
	]
	quest.4954071000000102.quest_subtitle: "Vent excess gas from the rig"
	quest.4954071000000102.title: "Flarestack"
	quest.4954071000000103.quest_desc: [
		"Craft the Portable Generator from Immersive Petroleum. It burns gasoline to make RF away from your fixed power grid."
		"Built from an Immersive Engineering generator, a low-voltage capacitor, and iron plates, it is a compact power source you can drop at a remote site. Refine crude into gasoline and the generator turns that fuel into usable energy on the spot."
		"This node follows the Pumpjack, since your well is where the fuel comes from. Use the portable generator to power outposts and machines far from your main base."
	]
	quest.4954071000000103.quest_subtitle: "Burn gasoline for field power"
	quest.4954071000000103.title: "Portable Generator"
	quest.4954081000000001.quest_desc: [
		"Craft a &bPrecision Mechanism&r. It is the keystone part behind &6Create&r's advanced machinery, built by &bsequenced assembly&r: deploy cogwheels and an iron nugget onto a gold sheet, then press it to finish."
		"Almost everything in this chapter wants one, so set up to make them in quantity."
	]
	quest.4954081000000001.quest_subtitle: "Create's advanced part."
	quest.4954081000000001.title: "Precision Mechanism"
	quest.4954081000000002.quest_desc: [
		"Build Mechanical Crafters. Arranged in a grid and driven by rotation they assemble shaped recipes automatically, a workhorse for the many multi-part Create components ahead."
		"Lay them out to match the recipe's shape and pipe the ingredients in."
	]
	quest.4954081000000002.quest_subtitle: "Automate the crafting grid."
	quest.4954081000000002.title: "Mechanical Crafter"
	quest.4954081000000003.quest_desc: [
		"Craft a &bMechanical Saw&r. Fixed in place it processes logs and cutting recipes; mounted on a contraption it fells whole trees, the heart of an automated tree farm."
		"Point it the right way before you spin it up."
	]
	quest.4954081000000003.quest_subtitle: "Cut wood and stone on power."
	quest.4954081000000003.title: "Mechanical Saw"
	quest.4954081000000004.quest_desc: [
		"Build a &bSteam Engine&r. Mounted on a water-filled &bboiler&r it delivers strong, scalable rotation, the power source that carries &6Create&r past water wheels."
		"Scale it by adding more boilers and burners."
	]
	quest.4954081000000004.quest_subtitle: "Rotation from a boiler."
	quest.4954081000000004.title: "Steam Engine"
	quest.4954081000000005.quest_desc: [
		"Craft a &bMechanical Drill&r. Stationary it processes crushing recipes; on a moving contraption it bores through stone, the digging half of an automated mining rig."
		"Pair it with a gantry or a train for serious excavation."
	]
	quest.4954081000000005.quest_subtitle: "Break blocks under power."
	quest.4954081000000005.title: "Mechanical Drill"
	quest.4954081000000006.quest_desc: [
		"Craft an &bOre Vein Finder&r. &6Create Ore Excavation&r seeds large ore veins deep underground, and this tool tells you what lies beneath where you stand."
		"Bulk mining starts with knowing where to dig."
	]
	quest.4954081000000006.quest_subtitle: "Locate the deep veins."
	quest.4954081000000006.title: "Ore Vein Finder"
	quest.4954081000000007.quest_desc: [
		"Build a &bDrilling Machine&r. Set over a located vein it bores straight down and pulls the entire deposit up to the surface, no shafts or torches required."
		"Feed it power and let it work the vein dry."
	]
	quest.4954081000000007.quest_subtitle: "Mine a whole vein from the top."
	quest.4954081000000007.title: "Drilling Machine"
	quest.4954081000000009.quest_desc: [
		"Craft a &bFluid Well Extractor&r. Where the &bdrilling machine&r pulls ore, this one taps the underground fluid wells, drawing oil or lava up in volume."
		"The surface-side answer to a buried lake of fuel."
	]
	quest.4954081000000009.quest_subtitle: "Pump a fluid well."
	quest.4954081000000009.title: "Fluid Well Extractor"
	quest.495408100000000A.quest_desc: [
		"Make an &bOre Vein Atlas&r. It records the veins you locate so you can plan a mining route instead of rediscovering the same deposits, a logbook for the prospector."
		"Handy once you are working more than one site."
	]
	quest.495408100000000A.quest_subtitle: "Map what you have found."
	quest.495408100000000A.title: "Ore Vein Atlas"
	quest.495408100000000B.quest_desc: [
		"Build a &bSample Drill&r. It takes a quick core sample of what is below, confirming a vein is worth the full &bdrilling machine&r before you haul one out."
		"Cheaper to sample than to set up over nothing."
	]
	quest.495408100000000B.quest_subtitle: "Test before you commit."
	quest.495408100000000B.title: "Sample Drill"
	quest.495408100000000D.quest_desc: [
		"Craft a &bMechanical Arm&r. It picks items from set inputs and drops them on set outputs, the flexible robot that loads crafters, depots, and belts on a schedule."
		"Program its targets in order to control where everything goes."
	]
	quest.495408100000000D.quest_subtitle: "Sort and place items."
	quest.495408100000000D.title: "Mechanical Arm"
	quest.495408100000000E.quest_desc: [
		"Build a &bPortable Storage Interface&r. A fixed and a moving half exchange items as a contraption passes, the way to fill and empty a cart or train without stopping it."
		"The item counterpart to the energy interface."
	]
	quest.495408100000000E.quest_subtitle: "Load a moving contraption."
	quest.495408100000000E.title: "Portable Storage Interface"
	quest.495408100000000F.quest_desc: [
		"Craft a &bSmart Chute&r. It moves items straight up or down with a &bfilter&r and a count limit, the tidy vertical link between belts and storage."
		"Use it where a funnel cannot reach across height."
	]
	quest.495408100000000F.quest_subtitle: "Filtered vertical transfer."
	quest.495408100000000F.title: "Smart Chute"
	quest.4954081000000010.quest_desc: ["Craft a &bReinforced Motor&r. &6Create New Age&r builds electric generation and drive from magnets and coils, and the reinforced motor is its sturdy workhorse output."]
	quest.4954081000000010.quest_subtitle: "Create New Age's drive."
	quest.4954081000000010.title: "Reinforced Motor"
	quest.4954081000000011.quest_desc: [
		"Build a &bReinforced Energiser&r. It is &6Create New Age&r's stronger energy handler, moving and banking the current the magnets and coils produce."
		"The storage side of this addon's electrical setup."
	]
	quest.4954081000000011.quest_subtitle: "Charge and store."
	quest.4954081000000011.title: "Reinforced Energiser"
	quest.4954081000000012.quest_desc: [
		"Forge a &bNetherite Magnet&r. It is the top magnet in &6Create New Age&r's ladder, the field strength behind its best generators and motors."
		"Worth the netherite once you are running the addon seriously."
	]
	quest.4954081000000012.quest_subtitle: "The strongest field."
	quest.4954081000000012.title: "Netherite Magnet"
	quest.4954081000000013.quest_desc: [
		"Craft an &bAdvanced Motor Extension&r. Bolted to a &breinforced motor&r it raises what the drive can deliver, the upgrade for a strained &6Create New Age&r line."
		"Add it when the base motor stops keeping up."
	]
	quest.4954081000000013.quest_subtitle: "Push the motor further."
	quest.4954081000000013.title: "Advanced Motor Extension"
	quest.4954081000000014.quest_desc: ["Craft a &bGenerator Coil&r. Spun past a magnet it induces current, the wound core every &6Create New Age&r generator turns on."]
	quest.4954081000000014.quest_subtitle: "Wind the windings."
	quest.4954081000000014.title: "Generator Coil"
	quest.4954081000000015.quest_desc: [
		"Make &bCarbon Brushes&r. They draw the induced current off a spinning generator, the contact piece between the moving coil and your wiring."
		"Small, consumable, and necessary."
	]
	quest.4954081000000015.quest_subtitle: "Pick off the current."
	quest.4954081000000015.title: "Carbon Brushes"
	quest.4954081000000016.quest_desc: [
		"Craft a &bHeat Pipe&r. It carries heat between blocks, the conductor &6Create New Age&r's thermal machines use to feed and shed warmth."
		"The plumbing for the addon's heat side."
	]
	quest.4954081000000016.quest_subtitle: "Move heat where you need it."
	quest.4954081000000016.title: "Heat Pipe"
	quest.4954081000000017.quest_desc: [
		"Build a &bHeater&r. It is the source feeding the heat pipes, generating the warmth &6Create New Age&r's heat-driven recipes consume."
		"Pair it with the pipes to run a thermal loop."
		"One thing to know with &6Create Cold Sweat&r installed: hot blocks radiate real body-temperature heat. A lit blaze burner or a running boiler warms you nearby, scaling up from smouldering to seething, and hot fluid sitting in pipes or tanks heats the room around it while cold fluid cools it. Keep this in mind when you build a thermal loop indoors."
	]
	quest.4954081000000017.quest_subtitle: "Make the heat."
	quest.4954081000000017.title: "Heater"
	quest.4954081000000018.quest_desc: [
		"Craft a &bRedstone Magnet&r. It is the entry magnet in &6Create New Age&r's ladder, fine for the early generators before you reach the layered and netherite tiers."
		"Start here, then build up."
	]
	quest.4954081000000018.quest_subtitle: "The base magnet."
	quest.4954081000000018.title: "Redstone Magnet"
	quest.4954081000000019.quest_desc: [
		"Build a &bLayered Magnet&r. It is the mid magnet, a clear step over redstone and the prerequisite for the netherite tier above it."
		"The middle rung of the magnet climb."
	]
	quest.4954081000000019.quest_subtitle: "A stronger field."
	quest.4954081000000019.title: "Layered Magnet"
	quest.495408100000001A.quest_desc: [
		"Craft an &bElectrical Connector&r. It is the attachment point for &6Create New Age&r's wiring, linking its motors and generators into a working circuit."
		"Where the addon's power enters and leaves a machine."
	]
	quest.495408100000001A.quest_subtitle: "Wire the New Age grid."
	quest.495408100000001A.title: "Electrical Connector"
	quest.495408100000001B.quest_desc: [
		"Craft a &6Create Addition&r &bRedstone Relay&r. It opens or closes an &6FE&r line on a redstone signal, the simple switch for cutting power to a circuit on command."
		"A light-duty control piece for the wired grid."
	]
	quest.495408100000001B.quest_subtitle: "Switch a power line."
	quest.495408100000001B.title: "Redstone Relay"
	quest.495408100000001C.quest_desc: [
		"Build a &bLarge Connector&r. It carries far more power than the &bsmall connector&r, the trunk-line tap for feeding heavy machines or whole subgrids."
		"Use it where the &bsmall connector&r would bottleneck."
	]
	quest.495408100000001C.quest_subtitle: "High-throughput wire point."
	quest.495408100000001C.title: "Large Connector"
	quest.495408100000001D.quest_desc: ["Craft a &bSmall Connector With Light&r. It taps a light run of power and lights the area while doing it, a tidy two-in-one for a working corner."]
	quest.495408100000001D.quest_subtitle: "A connector that glows."
	quest.495408100000001D.title: "Small Connector With Light"
	quest.495408100000001E.quest_desc: ["Craft the &bPumpjack Bearing&r. It couples the rig's nodding mechanism to the rotating drive that powers the pumpjack."]
	quest.495408100000001E.quest_subtitle: "Build the pumpjack's drive bearing."
	quest.495408100000001E.title: "Pumpjack Bearing"
	quest.495408100000001F.quest_desc: [
		"Build the &bPumpjack Head&r. It is the visible arm that rocks up and down over the well, the working end of the &6Create Diesel Generators&r pumpjack."
		"Set it over the hole to draw the oil."
	]
	quest.495408100000001F.quest_subtitle: "The nodding donkey's head."
	quest.495408100000001F.title: "Pumpjack Head"
	quest.4954081000000020.quest_desc: [
		"Place a &bPumpjack Hole&r. It is the cased well the head pumps from, the bottom of the &6Create&r-style oil rig that reaches the reservoir."
		"Line up the head, the hole, and the drive to complete the rig."
	]
	quest.4954081000000020.quest_subtitle: "Drill the well casing."
	quest.4954081000000020.title: "Pumpjack Hole"
	quest.4954081000000030.quest_desc: [
		"You already crafted the &bGenerator Coil&r; this node teaches how it actually makes power. A &bGenerator Coil&r only produces electricity when two things are true at once: it is being spun by &6Create&r kinetics, and it is ringed by &bmagnets&r on its sides. It does not turn anything itself. Instead it &beats&r stress units off the shaft driving it and converts that rotation into current."
		"The &bCarbon Brushes&r are what collect the electricity the coil generates, so a working setup is shaft into coil, magnets around the coil, brushes pulling the output. Stronger magnets raise how much of the incoming rotation becomes electricity, going &bRedstone&r to &bLayered&r to &bNetherite&r, but a stronger field also draws more stress units, so size your kinetic source to match."
	]
	quest.4954081000000030.quest_subtitle: "How the coil makes power."
	quest.4954081000000030.title: "First Electricity"
	quest.4954081000000031.quest_desc: [
		"Craft &bCopper Wire&r to carry the current your coil produces. &6Create New Age&r wire runs between its &belectrical connectors&r, and each connector has a mode you set with a wrench: &bInert&r leaves it idle, while &bPull&r has it actively draw power down the line."
		"A wire run has a maximum length, so plan connector placement for long hauls and hop through intermediate connectors when a single span will not reach. Keep the source connector pushing and the far end pulling and the power flows where you want it."
	]
	quest.4954081000000031.quest_subtitle: "Run the current down a wire."
	quest.4954081000000031.title: "Move the Power"
	quest.4954081000000032.quest_desc: [
		"Turn the electricity back into work. Craft a &bBasic Motor&r and a &bBasic Energiser&r. The &bBasic Motor&r takes the current your line delivers and spins a shaft with it, the reverse of the generator coil, giving you rotation wherever you have wire instead of dragging a driveshaft across the base. It turns at a fixed speed you tune with a wrench."
		"The &bBasic Energiser&r is the other half of the tier. Fed enough power it energises materials into &bovercharged iron&r, &bovercharged gold&r, and &bovercharged diamond&r, and it can turn a plain glass bottle into an &bexperience bottle&r. You do not need to craft those here; just know the Energiser is where that chain begins."
	]
	quest.4954081000000032.quest_subtitle: "Electricity back to rotation."
	quest.4954081000000032.title: "Use the Power"
	quest.4954081000000033.quest_desc: [
		"Craft a &bMolten Iron Bucket&r to learn &6Create Metalwork&r's yield loop. Crush your raw material as usual, then heat-mix the crushed item in a &bBasin&r until it becomes a &bmolten fluid&r. That fluid is buffered at roughly 111 mB per ingot and can be piped and stored like any other."
		"Pour or compact the molten metal back into ingots and you get more metal per ore than a plain furnace would give. The crushing itself is the same ore doubling your Medieval crushing wheels already do; what Metalwork adds is the molten buffer in the middle, which lets you batch and pipe the metal instead of smelting one item at a time."
	]
	quest.4954081000000033.quest_subtitle: "Crush, melt, pour for more."
	quest.4954081000000033.title: "Molten Metalwork"
	quest.4954081000000034.quest_desc: [
		"Crush four gold and four netherite scrap, heat-mix them, and pour the result from the Molten Netherite Bucket."
		"This node is optional. It is the one distinctive result &6Create Metalwork&r offers over ordinary crushing, and it carries you into the netherite you will lean on heading toward the Gilded Age."
	]
	quest.4954081000000034.quest_subtitle: "Pour your own netherite."
	quest.4954081000000034.title: "Molten Netherite"
	quest.4954081000000035.quest_desc: [
		"An optional detour into &6Create Confectionery&r. Press and crush cocoa beans down the chain into &bCocoa Powder&r, the base ingredient the addon's caramel and chocolate recipes build on."
		"Nothing on the main line needs this. It is here as a food branch if you want to run a small sweets factory alongside your machines."
	]
	quest.4954081000000035.quest_subtitle: "Press beans into powder."
	quest.4954081000000035.title: "Cocoa Powder"
	quest.4954081000000036.quest_desc: [
		"Dress up the workshop. Craft a &bBrass Chair&r from &6Create New Furnitures&r, a purely decorative branch of matching factory-styled furniture."
		"This is optional flavor. It grants no progression, just a place to sit while the machines run."
	]
	quest.4954081000000036.quest_subtitle: "A seat for the shop floor."
	quest.4954081000000036.title: "Workshop Dressing"
	quest.4954081000000040.quest_desc: [
		"Assemble a &bBrass Drone&r and its &bDrone Controller&r from &6Create Stuff 'N Additions&r. Deploy the drone, link the controller, and operate it from where you stand."
		"Use it to scout shafts, canyons, and hostile ground without walking them yourself. The drone is a scout, not a hauler, and it keeps its pilot out of harm's way."
	]
	quest.4954081000000040.quest_subtitle: "Eyes without wings."
	quest.4954081000000040.title: "Brass Drone"
	quest.4954081000000041.quest_desc: [
		"&6Immersive Machinery&r adds the &bTunnel Digger&r, a rideable boring machine. Craft an &bIron Drill&r, then frame it with iron, copper, redstone, and an aircraft engine to build the vehicle."
		"Mount up and drive it into the rock face. It bores as it moves and leaves a clean walkable tunnel behind, which makes it the fastest way to cut long access galleries between mining sites."
	]
	quest.4954081000000041.quest_subtitle: "The mining vehicle."
	quest.4954081000000041.title: "Tunnel Digger"
	quest.4954081000000042.quest_desc: [
		"Upgrade at a smithing table: an iron block as the template, your &bIron Drill&r as the base, and a diamond as the addition produce the &bDiamond Drill&r."
		"Swap it onto the Tunnel Digger for faster boring through harder ground. The vehicle stays the same; only the teeth change."
	]
	quest.4954081000000042.quest_subtitle: "Harder teeth."
	quest.4954081000000042.title: "Diamond Drill"
	quest.49540A1000000004.quest_desc: [
		"Craft a &6ProjectRed&r &bDeployer&r. On a redstone pulse it uses whatever item it holds on the block in front, right-clicking for you: tilling, planting, bucketing, and more."
		"The first building block of hands-off automation."
	]
	quest.49540A1000000004.quest_subtitle: "Use an item on the world."
	quest.49540A1000000004.title: "Deployer"
	quest.49540A1000000005.quest_desc: [
		"Build a &6ProjectRed&r &bBlock Breaker&r. Pulsed with redstone it breaks the block in front and drops it for collection, the harvesting half of an automated farm or quarry."
		"Pair it with a &bdeployer&r and a tube to close the loop."
	]
	quest.49540A1000000005.quest_subtitle: "Mine on a signal."
	quest.49540A1000000005.title: "Block Breaker"
	quest.49540A1000000006.quest_desc: [
		"Craft a &bTransposer&r. It draws items out of an adjacent inventory and pushes them into a &bpneumatic tube&r, the on-ramp that feeds the routing network."
		"Where the tubes meet your chests, a &btransposer&r does the loading."
	]
	quest.49540A1000000006.quest_subtitle: "Pull items into tubes."
	quest.49540A1000000006.title: "Transposer"
	quest.49540A1000000007.quest_desc: [
		"Build a &6ProjectRed&r &bAuto Crafter&r. Loaded with a recipe and fed ingredients it assembles the result automatically, the crafting node of a routed factory."
		"Set the pattern once and let the tubes keep it stocked."
	]
	quest.49540A1000000007.quest_subtitle: "Craft on demand."
	quest.49540A1000000007.title: "Auto Crafter"
	quest.49540A1000000009.quest_desc: [
		"Craft a &bLogic Programmer&r and a &bVariable Card&r. The programmer is where you write &6Integrated Dynamics&r logic onto cards, the start of a system that reads the world and reacts to it."
		"Integrated Dynamics is powerful and fiddly, so start small and build up."
	]
	quest.49540A1000000009.quest_subtitle: "Write logic onto cards."
	quest.49540A1000000009.title: "Logic Programmer"
	quest.49540A100000000D.quest_desc: [
		"Build a &bFrame Motor&r. It shifts a connected frame of blocks on a signal, the basis for moving platforms, doors, and simple machines built from frames."
		"Motion without a &6Create&r contraption, the &6ProjectRed&r way."
	]
	quest.49540A100000000D.quest_subtitle: "Move a frame of blocks."
	quest.49540A100000000D.title: "Frame Motor"
	quest.49540A100000000F.quest_desc: ["With deployers, crafters, conduits, tubes, and an &6Integrated Dynamics&r network all in hand, your base can now sense and act on its own. The &bmaterializer&r ties the logic layer to real items."]
	quest.49540A100000000F.quest_subtitle: "The control layer is running."
	quest.49540A100000000F.title: "Logic and Routing Complete"
	quest.49540A1000000011.quest_desc: [
		"Craft an &6Integrated Dynamics&r &bProxy&r. It exposes a distant part of your network as if it were right here, letting logic read and write across a sprawling base."
		"The piece that keeps a big network from needing everything in one room."
	]
	quest.49540A1000000011.quest_subtitle: "Reach the network from afar."
	quest.49540A1000000011.title: "Proxy"
	quest.49540A1000000012.quest_desc: [
		"Build a &bMaterializer&r. It reads a variable from your logic network and produces the matching item, or writes an item's value back, the bridge between data and stuff."
		"Where the logic meets the chest."
	]
	quest.49540A1000000012.quest_subtitle: "Turn values into items."
	quest.49540A1000000012.title: "Materializer"
	quest.49540A1000000013.quest_desc: [
		"Craft a &bMechanical Squeezer&r. It presses items for their fluids and byproducts, an &6Integrated Dynamics&r processing block that feeds its own crafting chains."
		"Powered, it runs faster than the hand-cranked version."
	]
	quest.49540A1000000013.quest_subtitle: "Squeeze for fluids."
	quest.49540A1000000013.title: "Mechanical Squeezer"
	quest.49540A1000000014.quest_desc: [
		"Build a &bDrying Basin&r. It slowly processes items by drying them, the patient counterpart to the squeezer in the &6Integrated Dynamics&r recipe set."
		"Set it and let time do the work."
	]
	quest.49540A1000000014.quest_subtitle: "Dry and cure inputs."
	quest.49540A1000000014.title: "Drying Basin"
	quest.49540A1000000015.quest_desc: [
		"Craft the &6Integrated Dynamics&r Generator. It burns fuel to power the network's machines, the small dedicated source that keeps your logic running."
		"Modest, but enough to drive a squeezer and a &bbasin&r."
	]
	quest.49540A1000000015.quest_subtitle: "Power the logic network."
	quest.49540A1000000015.title: "Generator"
	quest.49540A1000000016.quest_desc: [
		"Make &bConduit Binder&r. It is the base material &6EnderIO&r conduits and machines are built from. It opens that mod's all-in-one routing."
		"&6EnderIO&r bundles power, items, and fluids into one slim conduit. This is worth a stack."
	]
	quest.49540A1000000016.quest_subtitle: "EnderIO's routing material."
	quest.49540A1000000016.title: "Conduit Binder"
	quest.49540A1000000017.quest_desc: [
		"Craft an &6EnderIO&r &bConduit&r. Several conduit types share a single block space. Power, items, fluids, and redstone can all run down the same tidy line."
		"The neatest wiring in the pack, once you learn its filters."
	]
	quest.49540A1000000017.quest_subtitle: "One block, many networks."
	quest.49540A1000000017.title: "Conduit"
	quest.49540A1000000018.quest_desc: [
		"Build a &bBasic Item Filter&r. Slotted into a &bconduit&r it whitelists or blacklists what passes, the control that keeps the right items going to the right machine."
		"Filters turn a pile of conduits into an actual sorting system."
	]
	quest.49540A1000000018.quest_subtitle: "Control what items flow."
	quest.49540A1000000018.title: "Basic Item Filter"
	quest.49540A1000000019.quest_desc: [
		"Craft a &bBasic Fluid Filter&r. The fluid counterpart to the item filter, it keeps your oils, fuels, and waters from mixing in a shared &bconduit&r run."
		"Essential once more than one fluid shares a line."
	]
	quest.49540A1000000019.quest_subtitle: "Control what fluids flow."
	quest.49540A1000000019.title: "Basic Fluid Filter"
	quest.49540A100000001C.quest_desc: [
		"Lay Pneumatic Tubes. They carry items between transposers and inventories on air, &6ProjectRed&r's item-routing network alongside its redstone logic."
		"Color and &bfilter&r them to keep the flows separate."
	]
	quest.49540A100000001C.quest_subtitle: "Route items by suction."
	quest.49540A100000001C.title: "Pneumatic Tube"
	quest.49540A100000001D.quest_desc: [
		"Build a &bBattery Box&r. It stores the power &6ProjectRed&r's machinery runs on, the buffer that keeps your deployers and breakers fed during a spike."
		"Charge it from your generators and draw it down as needed."
	]
	quest.49540A100000001D.quest_subtitle: "Store electrotine power."
	quest.49540A100000001D.title: "Battery Box"
	quest.49540A100000001E.quest_desc: [
		"Produce &bSilicon&r. It is the raw material &6ProjectRed&r's integrated circuits start from, melted and cut into the chips that drive its logic gates."
		"The first step of the chip-making chain."
	]
	quest.49540A100000001E.quest_subtitle: "The base of every chip."
	quest.49540A100000001E.title: "Silicon"
	quest.49540A100000001F.quest_desc: [
		"Cut a &bSilicon Chip&r from raw silicon. It is the plain chip behind the simpler &6ProjectRed&r gates, the workhorse component of small circuits."
		"Make these in quantity; gates eat them."
	]
	quest.49540A100000001F.quest_subtitle: "Cut the wafer."
	quest.49540A100000001F.title: "Silicon Chip"
	quest.49540A1000000020.quest_desc: [
		"Make &bInfused Silicon&r. Treated with redstone, it carries the charge the more capable chips need, the step between plain silicon and energized."
		"The middle of the &bsilicon&r ladder."
	]
	quest.49540A1000000020.quest_subtitle: "Charge the silicon."
	quest.49540A1000000020.title: "Infused Silicon"
	quest.49540A1000000021.quest_desc: [
		"Produce &bEnergized Silicon&r. It is the highest grade of &6ProjectRed&r silicon, infused with electrotine for the most capable circuits the mod builds."
		"Reserved for the complex gates and timing chips."
	]
	quest.49540A1000000021.quest_subtitle: "The top-grade wafer."
	quest.49540A1000000021.title: "Energized Silicon"
	quest.49540A1000000022.quest_desc: [
		"Cut an &bEnergized Silicon Chip&r. It drives &6ProjectRed&r's most advanced gates, the chip behind anything that counts, times, or remembers."
		"The keystone of serious circuitry."
	]
	quest.49540A1000000022.quest_subtitle: "The best chip."
	quest.49540A1000000022.title: "Energized Silicon Chip"
	quest.49540A1000000023.quest_desc: [
		"Build a &bState Cell&r gate. It produces a timed pulse you can tune, the clock behind any &6ProjectRed&r circuit that needs to act on a schedule."
		"Set the interval and let it tick."
	]
	quest.49540A1000000023.quest_subtitle: "A timing gate."
	quest.49540A1000000023.title: "State Cell"
	quest.49540A1000000024.quest_desc: [
		"Lay &bLogic Cable&r. It is the backbone that carries &6Integrated Dynamics&r variables and signals between your parts, the wiring your whole logic network rides on."
		"Run it everywhere the network needs to reach."
	]
	quest.49540A1000000024.quest_subtitle: "Carry the network."
	quest.49540A1000000024.title: "Logic Cable"
	quest.49540A1000000025.quest_desc: [
		"Build a &bSAG Mill&r. It crushes ore into dust and, with grinding balls loaded, squeezes out bonus output. It is &6EnderIO&r's answer to ore doubling."
		"Keep it stocked with grinding balls for the best yield."
	]
	quest.49540A1000000025.quest_subtitle: "Grind ore, with bonuses."
	quest.49540A1000000025.title: "SAG Mill"
	quest.49540A1000000026.quest_desc: [
		"Craft an &6EnderIO&r &bAlloy Smelter&r. It fuses up to three inputs into an alloy in one machine, a compact route to the metals other machines need."
		"Handy for the everyday alloys without a multiblock."
	]
	quest.49540A1000000026.quest_subtitle: "Combine into alloys."
	quest.49540A1000000026.title: "Alloy Smelter"
	quest.49540A1000000027.quest_desc: ["Build a &bStirling Generator&r. It burns solid fuel for a steady stream of power, the simple starter source for an &6EnderIO&r machine room."]
	quest.49540A1000000027.quest_subtitle: "Burn fuel for EnderIO power."
	quest.49540A1000000027.title: "Stirling Generator"
	quest.49540A1000000028.quest_desc: [
		"Build a &bVAT&r. It mixes items and fluids into new fluids, the chemistry station behind several &6EnderIO&r materials."
		"The mod's processing branches lean on it."
	]
	quest.49540A1000000028.quest_subtitle: "Run fluid chemistry."
	quest.49540A1000000028.title: "VAT"
	quest.49540A1000000029.quest_desc: [
		"Craft a &bPainting Machine&r. It paints one block to wear the texture of another. Your conduits, anchors, and machine covers can blend into any build."
		"Function stays the same; only the look changes."
	]
	quest.49540A1000000029.quest_subtitle: "Disguise your blocks."
	quest.49540A1000000029.title: "Painting Machine"
	quest.49540A100000002A.quest_desc: [
		"Build an &bImpulse Hopper&r. It transfers a filtered batch of items between inventories on a signal, a precise alternative to a constant hopper stream."
		"Good where you want exactly so many items moved, not a trickle."
	]
	quest.49540A100000002A.quest_subtitle: "Move a batch at once."
	quest.49540A100000002A.title: "Impulse Hopper"
	quest.49540A100000002B.quest_desc: [
		"Craft a &bDrain&r. It pulls fluid from the world into your conduits, or places it back, the &6EnderIO&r way to harvest a lake or fill a pool."
		"Pair it with a fluid &bconduit&r and a tank."
	]
	quest.49540A100000002B.quest_subtitle: "Pump fluids in or out."
	quest.49540A100000002B.title: "Drain"
	quest.49540A100000002C.quest_desc: [
		"Build a &bWired Charger&r. Fed power through a &bconduit&r it recharges your tools and armor, a fixed charging point wherever the grid reaches."
		"Park your gear on it between jobs."
	]
	quest.49540A100000002C.quest_subtitle: "Charge items off the grid."
	quest.49540A100000002C.title: "Wired Charger"
	quest.49540A100000002D.quest_desc: [
		"Craft a &bVacuum Chest&r. It pulls nearby items off the ground straight into itself, the collector under a mob farm or beside a harvester."
		"&bFilter&r it so it only grabs what you want."
	]
	quest.49540A100000002D.quest_subtitle: "Hoover up drops."
	quest.49540A100000002D.title: "Vacuum Chest"
	quest.49540A100000002E.quest_desc: [
		"Build an &bXP Vacuum&r. It gathers nearby experience orbs and banks them, feeding your enchanting setup without you standing in the drop zone."
		"Pairs naturally with a mob farm and an &benchanter&r."
	]
	quest.49540A100000002E.quest_subtitle: "Collect experience."
	quest.49540A100000002E.title: "XP Vacuum"
	quest.49540A100000002F.quest_desc: [
		"Craft an &6EnderIO&r &bEnchanter&r. Given a book, lapis, and the right material it produces an enchanted book directly, picking exactly the enchantment you want."
		"No more gambling at the enchanting table."
	]
	quest.49540A100000002F.quest_subtitle: "Craft your enchantments."
	quest.49540A100000002F.title: "Enchanter"
	quest.49540A1000000030.quest_desc: [
		"Place Travel Anchors. With a travel staff or the right armor you teleport between them at a glance, a fast transit network across your base and beyond."
		"Set anchors at the spots you visit most."
	]
	quest.49540A1000000030.quest_subtitle: "Hop between points."
	quest.49540A1000000030.title: "Travel Anchor"
	quest.49540A1000000031.quest_desc: [
		"Build a &bBasic Capacitor Bank&r. It banks &6EnderIO&r power and grows by adding more banks, the storage wall that smooths your generation."
		"Start with one and extend it as the base grows."
	]
	quest.49540A1000000031.quest_subtitle: "EnderIO power storage."
	quest.49540A1000000031.title: "Basic Capacitor Bank"
	quest.49540A1000000032.quest_desc: [
		"Craft a &bBasic Capacitor&r. It is the core component that powers and upgrades most &6EnderIO&r machines, slotted in to set their tier."
		"Nearly every &6EnderIO&r machine wants one, so make a stack."
	]
	quest.49540A1000000032.quest_subtitle: "The upgrade component."
	quest.49540A1000000032.title: "Basic Capacitor"
	quest.49540A1000000033.quest_desc: [
		"Build an &6Assembly Line&r &bConveyor Belt&r. It carries items and even mobs along its length, the foundation of that mod's belt-based factories."
		"Everything in this branch rides the belt."
	]
	quest.49540A1000000033.quest_subtitle: "Assembly Line's mover."
	quest.49540A1000000033.title: "Conveyor Belt"
	quest.49540A1000000034.quest_desc: [
		"Craft a &bSorter Belt&r. It pulls chosen items off the conveyor onto a side branch, the sorting junction of a belt factory."
		"&bFilter&r it to route each item where it belongs."
	]
	quest.49540A1000000034.quest_subtitle: "Split the stream."
	quest.49540A1000000034.title: "Sorter Belt"
	quest.49540A1000000035.quest_desc: [
		"Build an &6Assembly Line&r &bBlock Breaker&r. Set over the belt it breaks blocks and drops the harvest straight onto the line, the breaking station of a belt farm."
		"The belt does the hauling for you."
	]
	quest.49540A1000000035.quest_subtitle: "Belt-fed mining."
	quest.49540A1000000035.title: "Block Breaker (Belt)"
	quest.49540A1000000036.quest_desc: [
		"Craft a &bBlock Placer&r. Fed blocks from the belt it sets them in the world, the planting and building counterpart to the breaker."
		"Breaker and placer together make a closed farm loop."
	]
	quest.49540A1000000036.quest_subtitle: "Belt-fed building."
	quest.49540A1000000036.title: "Block Placer"
	quest.49540A1000000037.quest_desc: [
		"Build a &bDetector&r. It reads what passes on the belt and emits a signal, the sensor that lets a belt factory make decisions."
		"Wire it to gate the rest of the line."
	]
	quest.49540A1000000037.quest_subtitle: "Sense the belt."
	quest.49540A1000000037.title: "Detector"
	quest.49540A1000000038.quest_desc: [
		"Craft an &6Assembly Line&r &bFarmer&r. It tends and harvests crops onto the belt, closing the loop from seed to storage with no hands involved."
		"The capstone of a self-running belt farm."
	]
	quest.49540A1000000038.quest_subtitle: "Automate the harvest."
	quest.49540A1000000038.title: "Farmer"
	quest.49540A1000000039.quest_desc: [
		"Craft the Ender IO Fluid Tank. It stores and buffers a single fluid so the machines that use it never starve or back up."
		"A machine like the Vat needs its input fluid delivered steadily and its output drained promptly. A tank sits between them, holding a reserve on the input side and catching product on the output side, smoothing out the flow."
		"Place a tank on the fluid machine you already built, the Vat, to keep it running without babysitting. The pressurized tank next raises capacity for busier networks."
	]
	quest.49540A1000000039.quest_subtitle: "Buffer fluids for your machines"
	quest.49540A1000000039.title: "Fluid Tank"
	quest.49540A100000003A.quest_desc: [
		"Craft the Ender IO Pressurized Fluid Tank, the upgraded tank with more capacity and higher throughput."
		"Where the basic tank suits a single machine, the pressurized tank holds far more and moves fluid faster, which matters once several machines share one fluid network. It is the tank you reach for when the basic one keeps running dry."
		"Swap it in on your busiest fluid lines. It builds directly on the basic Fluid Tank you just made."
	]
	quest.49540A100000003A.quest_subtitle: "Higher-capacity fluid storage"
	quest.49540A100000003A.title: "Pressurized Fluid Tank"
	quest.49540A1000000101.quest_desc: [
		"&6Multipart Machines: Farming&r builds its farms from parts made in its own machine. Craft &bWorld Fertilizer&r from crops and bone meal, then combine it with iron, planks, a crafting table, and a chest into the &bFarm Crafter&r."
		"The crafter's interface fabricates every controller the mod uses, and its built-in help pages show each farm's layout. Keep spare fertilizer on hand; it is both an ingredient here and a consumable for the farms themselves."
	]
	quest.49540A1000000101.quest_subtitle: "The field fabricator."
	quest.49540A1000000101.title: "The Farm Crafter"
	quest.49540A1000000102.quest_desc: [
		"Fabricate a &bSystem Controller&r and an &bInput Controller&r in the Farm Crafter. The System Controller runs the farm and the Input Controller is where supplies go in."
		"Place them as the crafter's help pages direct. These two blocks are shared across every farm type the mod offers, so this pair is the one-time cost of entry."
	]
	quest.49540A1000000102.quest_subtitle: "Brain and mouth."
	quest.49540A1000000102.title: "Field Controllers"
	quest.49540A1000000103.quest_desc: [
		"Fabricate a &bFarm Controller&r for crops and a &bTree Farm Controller&r for timber, and attach each to its own controller pair. Feed them World Fertilizer and they plant, grow, and harvest without you."
		"Speed upgrades from the crafter raise the work rate when you want more throughput. Ignore the Pam's HarvestCraft variant controller in the crafter's list; that mod is not in this pack, so the variant has nothing to farm."
	]
	quest.49540A1000000103.quest_subtitle: "Two farms, one crafter."
	quest.49540A1000000103.title: "Plant and Timber"
	quest.49540B1000000001.quest_desc: [
		"Build a &6Malum&r &bSpirit Crucible&r. It processes captured spirits into the refined forms industry can use, the first step in feeding magic into your machines."
		"This chapter wires the magic systems into the factory, so think of spirits as another raw material."
	]
	quest.49540B1000000001.quest_subtitle: "Refine spirits into feedstock."
	quest.49540B1000000001.title: "Spirit Crucible"
	quest.49540B1000000002.quest_desc: [
		"Craft a &bSpirit Catalyzer&r. It accelerates the crucible's processing, turning a trickle of refined spirit into a supply worth piping into other systems."
		"Pair it with the crucible to keep the feedstock flowing."
	]
	quest.49540B1000000002.quest_subtitle: "Speed the spirit work."
	quest.49540B1000000002.title: "Spirit Catalyzer"
	quest.49540B1000000003.quest_desc: ["Build a &bSpirit Jar&r. It banks the spirits you harvest so the crucible never idles waiting on fresh souls, the buffer for the whole spirit line."]
	quest.49540B1000000003.quest_subtitle: "Stockpile your spirits."
	quest.49540B1000000003.title: "Spirit Jar"
	quest.49540B1000000004.quest_desc: ["Right-click the &bHellfire Forge&r. It is &6Neo Vitae&r's master crafting station, where blood and hellfire fuse raw materials into the mod's highest-tier outputs."]
	quest.49540B1000000004.quest_subtitle: "Use the hellfire crucible."
	quest.49540B1000000004.title: "Hellfire Forge"
	quest.49540B1000000005.quest_desc: [
		"Build the &6Oritech&r &bFoundry&r. Here the recipe is coupled to &6Neo Vitae&r and &6Forbidden Arcanus&r: the foundry accepts Hellforged and Deorum (magic feedstock) as inputs, burning them into industrial catalysts. This is the first of three deliberate bridges between magic and industry."
		"Magic feedstock becomes an industrial input."
	]
	quest.49540B1000000005.quest_subtitle: "Magic feeds the foundry."
	quest.49540B1000000005.title: "Aureal Foundry"
	quest.49540B1000000006.quest_desc: [
		"Write a &bBook of Calling&r for a Djinni Machine Operator. A bound Djinni reads and works your machines on command, &6Occultism&r's spirit-powered automation."
		"Magic labor, slotted into an &dindustrial&r base."
	]
	quest.49540B1000000006.quest_subtitle: "A spirit that runs machines."
	quest.49540B1000000006.title: "Djinni Machine Operator"
	quest.49540B1000000007.quest_desc: [
		"Craft a &bDimensional Crystal Matrix&r. It is the core of &6Occultism&r's dimensional storage, a Djinni-held pocket that keeps far more than any chest."
		"The start of a spirit-bound storage network."
	]
	quest.49540B1000000007.quest_subtitle: "Spirit item storage core."
	quest.49540B1000000007.title: "Dimensional Crystal Matrix"
	quest.49540B1000000008.quest_desc: [
		"Build a &bDimensional Storage Actuator&r and a &bStable Wormhole&r. Together they open access to the matrix's pocket dimension, &6Occultism&r's answer to mass storage."
		"A magical alternative to a wall of drawers."
	]
	quest.49540B1000000008.quest_subtitle: "Bank items in a pocket."
	quest.49540B1000000008.title: "Dimensional Storage"
	quest.49540B1000000009.quest_desc: [
		"Place a &bReformation Result Pedestal&r. It is the output side of &6Theurgy&r's reformation, where the replicated &bAlchemical Sulfur&r appears once the mercury does its work."
		"Pair it with the source pedestals and the &bmercurial wand&r to copy sulfurs; the incubator later spends them as items."
	]
	quest.49540B1000000009.quest_subtitle: "Complete the reformation array."
	quest.49540B1000000009.title: "Reformation Result Pedestal"
	quest.49540B100000000A.quest_desc: [
		"Craft a &bCaloric Flux Emitter&r and a &bSulfuric Flux Emitter&r. They beam &6Theurgy&r's heat and sulfur flux to its machines, the wireless power of the alchemy line."
		"Aim them at the machines that need feeding."
	]
	quest.49540B100000000A.quest_subtitle: "Power machines with flux."
	quest.49540B100000000A.title: "Flux Emitters"
	quest.49540B100000000B.quest_desc: [
		"Build a &6Theurgy&r &bIncubator&r. Fed sulfur, salt, and mercury it recombines them into the real item that sulfur represents, the cash-out step of the whole alchemy line."
		"The reformation array copies sulfur; the incubator spends it."
	]
	quest.49540B100000000B.quest_subtitle: "Turn sulfur into items."
	quest.49540B100000000B.title: "Incubator"
	quest.49540B100000000C.quest_desc: [
		"Gather a &bPaltaeria Gem&r, a &bMidnight Chip&r, and &bStardust&r. These are the entry materials of Spectrum, the light-and-ink magic line, and the gate to its many machines."
		"Collect these before you build its altars."
	]
	quest.49540B100000000C.quest_subtitle: "Enter the Spectrum network."
	quest.49540B100000000C.title: "Spectrum Materials"
	quest.49540B100000000D.quest_desc: [
		"Build a &bFusion Shrine&r. Under the open sky it fuses items with light into &6Spectrum&r's stranger materials, the workhorse altar of the mod's midgame. A few recipes also ask for a specific time or weather."
		"It needs a view of the sky, so roof it carefully or not at all."
	]
	quest.49540B100000000D.quest_subtitle: "Fuse under the open sky."
	quest.49540B100000000D.title: "Fusion Shrine"
	quest.49540B100000000E.quest_desc: [
		"Build the &bSpirit Instiller&r structure. It binds spirit into items for &6Spectrum&r's higher crafts, a multiblock for the dedicated practitioner."
		"Optional depth for the &6Spectrum&r enthusiast."
	]
	quest.49540B100000000E.quest_subtitle: "Optional: instill a soul."
	quest.49540B100000000E.title: "Spirit Instiller"
	quest.49540B1000000011.quest_desc: [
		"Attach an &bIncubator Sulfur Vessel&r. It holds the &bAlchemical Sulfur&r the incubator consumes, one of the three vessels that feed the machine."
		"No sulfur in the vessel, no items out the other end."
	]
	quest.49540B1000000011.quest_subtitle: "Feed the incubator its sulfur."
	quest.49540B1000000011.title: "Incubator Sulfur Vessel"
	quest.49540B1000000012.quest_desc: [
		"Place a &bRitual Plinth&r. It anchors &6Malum&r's rituals, the focus that drives the larger spirit-alchemy workings beyond the basic altar."
		"Set it where you have room for a ritual to play out."
	]
	quest.49540B1000000012.quest_subtitle: "Run the spirit rituals."
	quest.49540B1000000012.title: "Ritual Plinth"
	quest.49540B1000000015.quest_desc: [
		"Craft a &6PneumaticCraft&r &bSpawner Agitator&r, coupled to &6Malum&r's arcane spirit. It caps the chapter once your foundry, logic, storage, spirit, and incubator lines all run."
		"Completing this item proof supplies one of the six checks required by the Iron Era finale."
	]
	quest.49540B1000000015.quest_subtitle: "The magic-feedstock capstone."
	quest.49540B1000000015.title: "Spirit-Bound Agitator"
	quest.49540B1000000016.quest_desc: [
		"Produce &bArcane Spirit&r. It is the worked spirit the bridges downstream demand, including the agitator that caps this chapter."
		"Stock it before the finale turn-in."
	]
	quest.49540B1000000016.quest_subtitle: "The refined product."
	quest.49540B1000000016.title: "Arcane Spirit"
	quest.49540B1000000017.quest_desc: [
		"Craft an &6Integrated Dynamics&r &bLogic Director&r, coupled here to &6Spectrum&r resonance. Its recipe takes a Spectrum component, the second bridge wiring magic into your automation."
		"The director is a powerful logic part, now with a magical price of entry."
	]
	quest.49540B1000000017.quest_subtitle: "Spectrum feeds the logic grid."
	quest.49540B1000000017.title: "Resonant Logic Director"
	quest.49540B1000000018.quest_desc: [
		"Craft a &bHellforged Block&r at the &bHellfire Forge&r. It packs blood-forged metal into a dense storable form and feeds the &bfoundry&r bridge that comes next."
		"Stockpile it; the Oritech Foundry uses it as direct feedstock."
	]
	quest.49540B1000000018.quest_subtitle: "Blood-forged metal, in bulk."
	quest.49540B1000000018.title: "Hellforged Block"
	quest.49540B1000000019.quest_desc: [
		"Build a &bBlood Tank&r. It stores the blood that fuels &6Neo Vitae&r's rituals and the &bHellfire Forge&r, the buffer that keeps the line from starving mid-run."
		"Blood handling at scale starts here."
	]
	quest.49540B1000000019.quest_subtitle: "Store the lifeblood reserve."
	quest.49540B1000000019.title: "Blood Tank"
	quest.49540B100000001A.quest_desc: [
		"Forge a &bHellforged Resonator&r at the &bHellfire Forge&r. It is a blood-imbued amplifier that extends &6Neo Vitae&r's rituals, pushing their range and intensity beyond base."
		"A forge product that unlocks deeper ritual work."
	]
	quest.49540B100000001A.quest_subtitle: "Amplify your rituals."
	quest.49540B100000001A.title: "Hellforged Resonator"
	quest.49540B100000001B.quest_desc: ["Forge a &bSentient Helmet&r at the &bHellfire Forge&r. The sentient set is &6Neo Vitae&r's blood-imbued combat armor, crafted from hellforged metal and attuned to the wearer's life force."]
	quest.49540B100000001B.quest_subtitle: "Optional: blood-imbued armor."
	quest.49540B100000001B.title: "Sentient Helmet"
	quest.49540B100000001C.quest_desc: ["Forge a &bSentient Plate&r, the chestpiece of &6Neo Vitae&r's sentient set. Like the helmet it is built at the &bHellfire Forge&r from hellforged metal, blood-bound to increase with your vitality."]
	quest.49540B100000001C.quest_subtitle: "Sentient armor: chestpiece."
	quest.49540B100000001C.title: "Sentient Plate"
	quest.49540B100000001D.quest_desc: ["Forge &bSentient Leggings&r to cover the lower half of the &6Neo Vitae&r sentient set. Blood-bound and hellforged like the rest of the suit."]
	quest.49540B100000001D.quest_subtitle: "Lower-half armor for the sentient set."
	quest.49540B100000001D.title: "Sentient Leggings"
	quest.49540B100000001E.quest_desc: ["Forge &bSentient Boots&r to complete the sentient set, &6Neo Vitae&r's finest blood-imbued combat armor."]
	quest.49540B100000001E.quest_subtitle: "Complete the sentient armor set."
	quest.49540B100000001E.title: "Sentient Boots"
	quest.49540B100000001F.quest_desc: [
		"Build a &bDimensional Mineshaft&r. Bound to a spirit it pulls ore from the Otherworld on its own, &6Occultism&r's hands-off mining, no quarry required."
		"Magic labor replacing the pickaxe entirely."
	]
	quest.49540B100000001F.quest_subtitle: "Mine through a spirit."
	quest.49540B100000001F.title: "Dimensional Mineshaft"
	quest.49540B1000000020.quest_desc: [
		"Craft a &bDimensional Extractor&r. The djinni inside gathers whatever your dimensional workers produce and pushes it into the inventory below, the output hopper of the spirit operation."
		"Set it beneath the mineshaft and let the Otherworld pile up."
	]
	quest.49540B1000000020.quest_subtitle: "Collect what the spirits mine."
	quest.49540B1000000020.title: "Dimensional Extractor"
	quest.49540B1000000021.quest_desc: ["Build a &bSpirit Grindstone&r. The bound spirit strips curses off your gear and refunds the full enchantment experience, &6Occultism&r's answer to a bad enchant."]
	quest.49540B1000000021.quest_subtitle: "Uncurse gear by spirit."
	quest.49540B1000000021.title: "Spirit Grindstone"
	quest.49540B1000000022.quest_desc: [
		"Assemble a &bBook of Binding&r for a Djinni. The Djinni is a stronger spirit than the Foliot, the class that runs the machine operators and storage you have been building."
		"Summon and bind it through the proper ritual."
	]
	quest.49540B1000000022.quest_subtitle: "Bind a higher spirit."
	quest.49540B1000000022.title: "Book of Binding: Djinni"
	quest.49540B1000000023.quest_desc: [
		"Build a &bDigestion Vat&r. Fed sal ammoniac and purified metals it converts &bAlchemical Niter&r between rarity tiers, the step &6Theurgy&r calls exaltation."
		"The acid stomach of the alchemy setup."
	]
	quest.49540B1000000023.quest_subtitle: "Shift niter between tiers."
	quest.49540B1000000023.title: "Digestion Vat"
	quest.49540B1000000024.quest_desc: [
		"Build a &bSpell Programmer&r. It is the bench where you lay out &6Psi&r spells as a grid of components, the programming half of the mod paired to the CAD that casts them."
		"Start simple; &6Psi&r spells grow complex fast."
	]
	quest.49540B1000000024.quest_subtitle: "Write your spells."
	quest.49540B1000000024.title: "Spell Programmer"
	quest.49540B1000000025.quest_desc: [
		"Craft a &bCAD Assembler&r. It is where you assemble a CAD, the &6Psi&r device that casts the spells you write, the entry point to that mod's programmable magic."
		"&6Psi&r is logic and magic both, so expect to tinker."
	]
	quest.49540B1000000025.quest_subtitle: "Build a spell device."
	quest.49540B1000000025.title: "CAD Assembler"
	quest.49540B1000000026.quest_desc: [
		"Build a &6Spectrum&r &bEnchanter&r. It applies enchantments through the mod's light magic, an alternative path to the gear bonuses you want."
		"A &6Spectrum&r-flavored route around the vanilla table."
	]
	quest.49540B1000000026.quest_subtitle: "Enchant with light."
	quest.49540B1000000026.title: "Spectrum Enchanter"
	quest.49540B1000000027.quest_desc: [
		"Craft a &bCrystallarieum&r. It grows the gems and crystals &6Spectrum&r's recipes consume, turning a seed into a renewable supply."
		"The farm behind the mod's crystal economy."
	]
	quest.49540B1000000027.quest_subtitle: "Grow Spectrum crystals."
	quest.49540B1000000027.title: "Crystallarieum"
	quest.49540B1000000028.quest_desc: [
		"Build a &bCinderhearth&r. It smelts ores and produces the mod's metals with bonus output, &6Spectrum&r's &dindustrial&r-grade furnace."
		"Feed it well and it pays back in extra ingots."
	]
	quest.49540B1000000028.quest_subtitle: "Smelt the Spectrum way."
	quest.49540B1000000028.title: "Cinderhearth"
	quest.49540B1000000029.quest_desc: ["Craft a &bCrystal Apothecary&r. It collects the pigments, gems, and growths that gather around your &6Spectrum&r setup, an automated harvester for the mod's odder yields."]
	quest.49540B1000000029.quest_subtitle: "Gather pigments and resources."
	quest.49540B1000000029.title: "Crystal Apothecary"
	quest.49540B1000000101.quest_desc: [
		"Craft the Vas Maleficum, Neo Vitae's demon-will collection vessel."
		"The infernal tier of Neo Vitae runs on demonic will rather than life essence. The Vas Maleficum stores that will, gathering the tartaric and demonic essence you draw from mobs and rituals so you have a reserve to craft with."
		"This is the entry point of the infernal segment, built after you begin using the Hellfire Forge. Set up a vessel first, then learn to route the will it holds."
	]
	quest.49540B1000000101.quest_subtitle: "The infernal will-vessel"
	quest.49540B1000000101.title: "Vas Maleficum"
	quest.49540B1000000102.quest_desc: [
		"Craft the Spira Infernalis. It moves demon will between vessels, acting as the plumbing of your infernal network."
		"A single vessel is a dead end. The Spira Infernalis pumps and routes will from one container to another, letting you gather it in one place and feed it where the crafting happens. It is what turns scattered vessels into a working supply line."
		"With will moving on its own, you can start converting it into a crafting feedstock at the crystallarium next."
	]
	quest.49540B1000000102.quest_subtitle: "Route the demon will"
	quest.49540B1000000102.title: "Spira Infernalis"
	quest.49540B1000000103.quest_desc: [
		"Craft the Crystallarium Maleficum. It grows will-infused crystals, the solid feedstock the infernal recipes consume."
		"Feed the crystallarium demon will and it slowly grows crystals charged with that will. These crystals are the material you break down for the higher infernal crafts, so a running crystallarium is what keeps the tier supplied."
		"This turns raw will into something you can stockpile and use. From here the segment moves on to the living-armor upgrade tablets."
	]
	quest.49540B1000000103.quest_subtitle: "Grow will-infused crystals"
	quest.49540B1000000103.title: "Crystallarium Maleficum"
	quest.49540B1000000104.quest_desc: [
		"Craft the Teleposer, a redstone-triggered pad that teleports blocks and entities between two linked points."
		"Program it with a Teleposition Focus to bind a destination, then power it with redstone to swap whatever sits on the pad to the far end. It moves mobs, items, and even blocks, which opens up automation and travel tricks a hopper never could."
		"This is a side branch off the Vas Maleficum, not a step toward the tablets. Build it for the utility whenever you want fast, powered transport."
	]
	quest.49540B1000000104.quest_subtitle: "Bend space with blood"
	quest.49540B1000000104.title: "Teleposer"
	quest.49540B1000000105.quest_desc: [
		"Craft the Tabula Robur, the strength upgrade tablet for Neo Vitae's living armor."
		"Living armor grows stronger as you wear and use it, and tablets applied at the Hellfire Forge steer that growth. The Tabula Robur pushes the armor toward physical strength and defense, hardening it as you take damage and fight."
		"Apply it once your living armor has some experience to shape. The second tablet, next, adds the animation behavior on top of this."
	]
	quest.49540B1000000105.quest_subtitle: "Strength living-armor tablet"
	quest.49540B1000000105.title: "Tabula Robur"
	quest.49540B1000000106.quest_desc: [
		"Craft the Tabula Animata, the animation upgrade tablet for living armor."
		"Where the Tabula Robur adds strength, the Tabula Animata adds animation and attack behavior, letting the armor respond and strike as part of its growth. Applied at the Hellfire Forge, it rounds out the living-armor build."
		"This is the tail of the infernal segment. With both tablets applied your living armor reaches the shape this tier is meant to produce."
	]
	quest.49540B1000000106.quest_subtitle: "Animation living-armor tablet"
	quest.49540B1000000106.title: "Tabula Animata"
	quest.49540C1000000001.quest_desc: [
		"Track down a &bSoul Blacksmith&r. &6Cataclysm&r's forge generates in the Nether across the crimson forests, warped forests, soul sand valleys, and nether wastes. The &c&lNetherite Monstrosity&r waits inside on the arena floor."
		"If the arena is empty, the boss was already felled or never spawned. Craft an &bEye of Monstrous&r and use it on the &bBoss Respawner&r block in the forge to call it back. The eye takes four lava buckets, two netherite scrap, two blackstone, and an Eye of Ender."
		"This chapter is the iron era's combat finale, so come geared and come ready."
	]
	quest.49540C1000000001.quest_subtitle: "Find the Nether forge."
	quest.49540C1000000001.title: "Soul Blacksmith"
	quest.49540C1000000002.quest_desc: [
		"Fight the &c&lNetherite Monstrosity&r inside the Soul Blacksmith. The molten golem charges, slams the ground, and hurls debris. Keep moving, punish the recovery, and do not get cornered."
		"If the arena is empty when you arrive, the boss did not spawn or was already killed. Craft an &bEye of Monstrous&r (four lava buckets, two netherite scrap, two blackstone, an Eye of Ender) and use it on the &bBoss Respawner&r to summon it."
		"Bring fire resistance and your best armor. Its horn is the prize."
	]
	quest.49540C1000000002.quest_subtitle: "Wake the forge's heart."
	quest.49540C1000000002.title: "Netherite Monstrosity"
	quest.49540C1000000003.quest_desc: [
		"Claim a &bMonstrous Horn&r from the fallen golem. Sounded, it unleashes a devastating blast, a boss-grade weapon earned only by beating the citadel."
		"A trophy that hits back."
	]
	quest.49540C1000000003.quest_subtitle: "The Monstrosity's drop."
	quest.49540C1000000003.title: "Monstrous Horn"
	quest.49540C1000000004.quest_desc: [
		"Locate the &c&lObsidilith&r Arena out in the End. The &6Bosses of Mass Destruction&r obelisk waits at its center, dormant until you approach."
		"Scout the open ground before you wake it; you will need room to move."
	]
	quest.49540C1000000004.quest_subtitle: "Find the obelisk's seat."
	quest.49540C1000000004.title: "Obsidilith Arena"
	quest.49540C1000000005.quest_desc: [
		"Defeat the &c&lObsidilith&r. The obelisk cycles through four attacks, raising spike lines, pillars, and bursts in telegraphed patterns, so learn the tells and dodge rather than tank."
		"Mobility and ranged damage win this fight. Its &bObsidian Heart&r drops when it falls."
	]
	quest.49540C1000000005.quest_subtitle: "Break the obelisk."
	quest.49540C1000000005.title: "Obsidilith"
	quest.49540C1000000006.quest_desc: [
		"Secure the &bObsidian Heart&r from &c&lObsidilith&r. The iron era capstone wants it in hand."
		"Store it somewhere safe until the finale turn-in."
	]
	quest.49540C1000000006.quest_subtitle: "The Obsidilith's core."
	quest.49540C1000000006.title: "Obsidian Heart"
	quest.49540C100000000C.quest_desc: ["Craft a &bLava Power Cell&r. It stores a charge drawn from the citadel's molten core. A &6Cataclysm&r power item that later recipes call for."]
	quest.49540C100000000C.quest_subtitle: "Bottled molten power."
	quest.49540C100000000C.title: "Lava Power Cell"
	quest.49540C100000000D.quest_desc: [
		"Forge an &bEarthdive Spear&r from the &c&lObsidilith&r's drops. Thrown, it phases through solid blocks and teleports you to where it lands. Short-range blink and working weapon in one."
		"The drop that makes the obelisk fight worth revisiting."
	]
	quest.49540C100000000D.quest_subtitle: "Optional: Obsidilith's weapon."
	quest.49540C100000000D.title: "Earthdive Spear"
	quest.49540C100000000E.quest_desc: [
		"Craft a &bTable of Elevation&r from &c&lObsidilith&r materials. Placed, it grants creative-style flight in a 7x7 column above it. Steady lift for towers and cliff faces."
		"Mobility without a &bjetpack&r's fuel."
	]
	quest.49540C100000000E.quest_subtitle: "Optional: a lift you build."
	quest.49540C100000000E.title: "Table of Elevation"
	quest.49540C100000000F.quest_desc: [
		"Build a &bStaff of Suppression&r. Placed or held, it wards an area against hostile spawns. Handy for a base or an active work site."
		"Quiet nights, by design."
	]
	quest.49540C100000000F.quest_subtitle: "Optional: keep mobs out."
	quest.49540C100000000F.title: "Staff of Suppression"
	quest.49540C1000000010.quest_desc: [
		"Build an &bEmerald Furnace&r. One of the higher &6Iron Furnaces&r tiers: fast, fuel-thrifty, and accepts augments for extra tricks."
		"The tier to land on before you start augmenting."
	]
	quest.49540C1000000010.quest_subtitle: "Optional: higher up the ladder."
	quest.49540C1000000010.title: "Emerald Furnace"
	quest.49540C1000000011.quest_desc: [
		"Craft the Factory augment. Slotted into an &bIron Furnace&r it boosts throughput, turning a single furnace into a small smelting line."
		"Augments are how the better furnaces earn their tier."
	]
	quest.49540C1000000011.quest_subtitle: "Optional: supercharge the furnace."
	quest.49540C1000000011.title: "Augment: Factory"
	quest.49540C1000000012.quest_desc: ["Forge a &bCrystalite&r Helmet. &6Better End&r's crystal armor is light and protective, the head of a set worth assembling for the End-side endgame."]
	quest.49540C1000000012.quest_subtitle: "Optional: Better End armor."
	quest.49540C1000000012.title: "Crystalite Helmet"
	quest.49540C1000000013.quest_desc: ["Craft a &bCrystalite&r Chestplate. The heaviest defense of the &6Better End&r crystal set, the piece to make first if you make only one."]
	quest.49540C1000000013.quest_subtitle: "Optional: the body piece."
	quest.49540C1000000013.title: "Crystalite Chestplate"
	quest.49540C1000000014.quest_desc: ["Build &bCrystalite&r Leggings. They cover the lower half of the crystal set, second only to the chest in protection."]
	quest.49540C1000000014.quest_subtitle: "Optional: the leg piece."
	quest.49540C1000000014.title: "Crystalite Leggings"
	quest.49540C1000000015.quest_desc: ["Forge &bCrystalite&r Boots to complete the set. A full &6Better End&r crystal suit carries its own small bonus over mismatched pieces."]
	quest.49540C1000000015.quest_subtitle: "Optional: finish the set."
	quest.49540C1000000015.title: "Crystalite Boots"
	quest.49540C1000000016.quest_desc: ["Forge an &bAeternium&r Helmet. Aeternium is &6Better End&r's top metal. The head piece of the strongest armor the dimension offers, a clear step above &bcrystalite&r."]
	quest.49540C1000000016.quest_subtitle: "Optional: Better End's best."
	quest.49540C1000000016.title: "Aeternium Helmet"
	quest.49540C1000000017.quest_desc: ["Craft an &bAeternium&r Chestplate. The chest of &6Better End&r's premier set, heavy protection from the dimension's hardest-won metal."]
	quest.49540C1000000017.quest_subtitle: "Optional: the body piece."
	quest.49540C1000000017.title: "Aeternium Chestplate"
	quest.49540C1000000018.quest_desc: ["Build &bAeternium&r Leggings. They round out the lower half of &6Better End&r's best suit."]
	quest.49540C1000000018.quest_subtitle: "Optional: the leg piece."
	quest.49540C1000000018.title: "Aeternium Leggings"
	quest.49540C1000000019.quest_desc: ["Forge &bAeternium&r Boots to complete the suit. The full set is among the toughest armor an End diver can wear."]
	quest.49540C1000000019.quest_subtitle: "Optional: finish the set."
	quest.49540C1000000019.title: "Aeternium Boots"
	quest.49540C100000001A.quest_desc: ["Forge a &bStarlit Diamond&r Helmet. &6Eternal Starlight&r's charged diamond armor is strong and faintly glowing, the head of a fine set for the moonlit dimension and beyond."]
	quest.49540C100000001A.quest_subtitle: "Optional: Eternal Starlight armor."
	quest.49540C100000001A.title: "Starlit Diamond Helmet"
	quest.49540C100000001B.quest_desc: ["Craft a &bStarlit Diamond&r Chestplate, the heaviest piece of &6Eternal Starlight&r's diamond set and the one to prioritize."]
	quest.49540C100000001B.quest_subtitle: "Optional: the body piece."
	quest.49540C100000001B.title: "Starlit Diamond Chestplate"
	quest.49540C100000001C.quest_desc: ["Build &bStarlit Diamond&r Leggings to cover the lower half of the set."]
	quest.49540C100000001C.quest_subtitle: "Optional: the leg piece."
	quest.49540C100000001C.title: "Starlit Diamond Leggings"
	quest.49540C100000001D.quest_desc: ["Forge &bStarlit Diamond&r Boots to complete &6Eternal Starlight&r's diamond suit."]
	quest.49540C100000001D.quest_subtitle: "Optional: finish the set."
	quest.49540C100000001D.title: "Starlit Diamond Boots"
	quest.49540C100000001E.quest_desc: ["Forge an &bUnrealium&r Helmet. Unrealium is &6Eternal Starlight&r's strongest metal, the head of the dimension's premier armor set."]
	quest.49540C100000001E.quest_subtitle: "Optional: Starlight's top metal."
	quest.49540C100000001E.title: "Unrealium Helmet"
	quest.49540C100000001F.quest_desc: ["Craft an &bUnrealium&r Chestplate, the heaviest defense of &6Eternal Starlight&r's best armor."]
	quest.49540C100000001F.quest_subtitle: "Optional: the body piece."
	quest.49540C100000001F.title: "Unrealium Chestplate"
	quest.49540C1000000020.quest_desc: ["Build &bUnrealium&r Leggings to round out the lower half of the top Starlight set."]
	quest.49540C1000000020.quest_subtitle: "Optional: the leg piece."
	quest.49540C1000000020.title: "Unrealium Leggings"
	quest.49540C1000000021.quest_desc: ["Forge &bUnrealium&r Boots to complete &6Eternal Starlight&r's finest suit."]
	quest.49540C1000000021.quest_subtitle: "Optional: finish the set."
	quest.49540C1000000021.title: "Unrealium Boots"
	quest.49540C1000000022.quest_desc: ["Craft an &bAethersent&r Hood. The aethersent set is &6Eternal Starlight&r's lighter armor: less plate, more movement. The hood is the first piece."]
	quest.49540C1000000022.quest_subtitle: "Optional: a lighter set."
	quest.49540C1000000022.title: "Aethersent Hood"
	quest.49540C1000000023.quest_desc: ["Build an &bAethersent&r Cape, the chest piece of Starlight's light armor, trading some protection for movement."]
	quest.49540C1000000023.quest_subtitle: "Starlight mobility over heavy plate."
	quest.49540C1000000023.title: "Aethersent Cape"
	quest.49540C1000000024.quest_desc: ["Craft &bAethersent&r Bottoms to cover the lower half of the light set."]
	quest.49540C1000000024.quest_subtitle: "Lower half of the light Starlight suit."
	quest.49540C1000000024.title: "Aethersent Bottoms"
	quest.49540C1000000025.quest_desc: ["Forge &bAethersent&r Boots to complete the light Starlight suit, for a fighter who values speed over plate."]
	quest.49540C1000000025.quest_subtitle: "Complete the speed-focused Starlight suit."
	quest.49540C1000000025.title: "Aethersent Boots"
	quest.49540C1000000026.quest_desc: [
		"Forge the full &bFroststeel&r set: helmet, chestplate, leggings, and boots. Cold-forged in the &6Undergarden&r, it is a solid suit with a chilly edge."
		"Reliable armor from the underworld's metal."
	]
	quest.49540C1000000026.quest_subtitle: "Optional: Undergarden cold armor."
	quest.49540C1000000026.title: "Froststeel Armor Set"
	quest.49540C1000000027.quest_desc: [
		"Assemble the full &bUtherium&r set: helmet, chestplate, leggings, and boots. Cut from the &6Undergarden&r's red crystal, it is the dimension's stronger armor tier."
		"The reward for working &bUtherium&r past tools into plate."
	]
	quest.49540C1000000027.quest_subtitle: "Optional: Undergarden crystal armor."
	quest.49540C1000000027.title: "Utherium Armor Set"
	quest.49540C1000000028.quest_desc: [
		"Forge the Ancient set: helmet, chestplate, and leggings from the &6Undergarden&r's forgotten metal. It is the deepest tier the &bcatacombs&r offer."
		"Hard-won from the dimension's most dangerous corners."
	]
	quest.49540C1000000028.quest_subtitle: "Optional: the forgotten plate."
	quest.49540C1000000028.title: "Ancient Armor Set"
	quest.49540C1000000029.quest_desc: [
		"Assemble the full &bResonarium&r set: helmet, chestplate, leggings, and boots. Forged from &6Deeper Darker&r's signature metal, it carries the Otherside's quiet weight."
		"The sculk dimension's endgame plate."
	]
	quest.49540C1000000029.quest_subtitle: "Optional: Otherside armor."
	quest.49540C1000000029.title: "Resonarium Armor Set"
	quest.49540C100000002A.quest_desc: [
		"Craft &bNetherite Horse Armor&r. It is the toughest barding available, keeping a hard-won mount alive through the fights you ride it into."
		"A small mercy for a loyal horse."
	]
	quest.49540C100000002A.quest_subtitle: "Optional: armor your mount."
	quest.49540C100000002A.title: "Netherite Horse Armor"
	quest.49540C100000002D.quest_desc: [
		"The Qliphoth trials answer the sephirah bosses you have already fought. Chesed is Mercy, and reaching it starts with a tracking eye. Craft the &bEye of Chesed&r by placing four &bSculk&r in a plus shape around one &bEye of Ender&r in the crafting grid."
		"The eye is unlocked at the Industrial Revolution tier, so build it once your factory footing is solid. It behaves like an Eye of Ender, but instead of a stronghold it hunts the Chesed Arena that generates naturally out in the Overworld."
		"Make one eye to start. Throw it in the next step to read the direction and close the distance to the arena."
	]
	quest.49540C100000002D.quest_subtitle: "Craft the locator eye."
	quest.49540C100000002D.title: "Eye of Chesed"
	quest.49540C100000002E.quest_desc: [
		"Throw the &bEye of Chesed&r and follow the direction it points, the same way you would track a stronghold. Keep throwing and walking until you stand inside the &bChesed Arena&r. Entering the structure completes this step."
		"Chesed cannot be hurt with a normal swing. During its Lightning Ray it summons crystals. Break a crystal with an &baxe&r to gain the Energized effect, then stand at one of the arena's ray reflectors so Chesed's beam strikes the reflector. Each redirected beam deals one point of damage, and that is the only way through its guard."
		"Watch the monoliths around the arena. Kill them as they appear, because if any are still active when Chesed reaches its finisher the attack cannot be survived. Clear them, ride the reflector loop, and keep your Energized window open."
	]
	quest.49540C100000002E.quest_subtitle: "Find and enter Chesed's arena."
	quest.49540C100000002E.title: "The Mercy Monolith"
	quest.49540C100000002F.quest_desc: [
		"Keep the Lightning Core; its possession records the kill."
		"This is the Industrial Revolution exam. Completing it grants the Chesed proof and feeds the age capstone alongside Obsidilith, so the step from Industrial Revolution into the Gilded Age now needs both bosses down, not just one."
		"Keep the Lightning Core for more than a trophy. Combine it with any weapon in a crafting table and that weapon gains a chance to shock what it hits."
	]
	quest.49540C100000002F.quest_subtitle: "Defeat Chesed, claim the Lightning Core."
	quest.49540C100000002F.title: "Chesed, No Mercy"
	quest.49540C1000000030.quest_desc: [
		"Optional. Obtain the Warden Upgrade Smithing Template from Deeper Darker and apply it to netherite-tier gear at a smithing table."
		"The warden upgrade completes the deep-dark armor set the citadel is themed around, layering warden-flavored properties onto your best netherite equipment. Use the smithing table the same way you applied the netherite upgrade itself."
		"This is optional gear depth for players who want the full deep-dark set. Skip it if your netherite armor already serves you."
	]
	quest.49540C1000000030.quest_subtitle: "Deep-dark netherite upgrade"
	quest.49540C1000000030.title: "Warden Smithing Template"
	quest.49540C1000000031.quest_desc: [
		"Optional. Obtain the Resonarium Upgrade Smithing Template and apply it at a smithing table."
		"Resonarium is Deeper Darker's own upgrade material, and this template is how you fit it onto armor for the resonarium set. Follow the smithing-table pattern the mod's other upgrades use."
		"It branches off the resonarium helmet you already have. Take this path for the matching upgraded armor, or leave it as optional depth."
	]
	quest.49540C1000000031.quest_subtitle: "Resonarium armor upgrade path"
	quest.49540C1000000031.title: "Resonarium Smithing Template"
	quest.49540D1000000002.quest_desc: [
		"Hunt &c&lSkor, the Yeti&r, a &6Block Factory's Bosses&r fight. It hits with heavy cold and raw force, so warm gear and a fast weapon serve you best."
		"A side boss with its own drops for the trophy hunter."
	]
	quest.49540D1000000002.quest_subtitle: "Frozen boss encounter."
	quest.49540D1000000002.title: "Skor, the Yeti"
	quest.49540D1000000003.quest_desc: [
		"Take on the &c&lEnder Guardian&r, a &6Cataclysm&r boss that guards the End. It teleports and strikes hard, so bring your best End-tier gear and watch the void."
		"Its gauntlet drop is a prize worth the fight."
	]
	quest.49540D1000000003.quest_subtitle: "End sentinel encounter."
	quest.49540D1000000003.title: "Ender Guardian"
	quest.49540D1000000004.quest_desc: [
		"Forge &bSpectral Leggings&r from &6Unusual End&r materials. They are a solid mid-tier piece and the unlock point for most of the optional gear in this chapter."
		"Everything else in this wing branches from here."
	]
	quest.49540D1000000004.quest_subtitle: "Unusual End armor."
	quest.49540D1000000004.title: "Spectral Leggings"
	quest.49540D1000000005.quest_desc: [
		"Craft an &6Immersive Engineering&r &bRevolver&r. It fires cartridges you load yourself, from buckshot to specialized rounds. Your call."
		"Reload between fights and match the cartridge to the target."
	]
	quest.49540D1000000005.quest_subtitle: "Immersive Engineering sidearm."
	quest.49540D1000000005.title: "Revolver"
	quest.49540D1000000006.quest_desc: [
		"Build the &bRailgun&r. Charged from your power grid, it fires metal rods at brutal velocity. A heavy-hitting ranged weapon for the toughest targets."
		"Keep it charged; an empty &brailgun&r is an awkward club."
	]
	quest.49540D1000000006.quest_subtitle: "Power-fed precision."
	quest.49540D1000000006.title: "Railgun"
	quest.49540D1000000007.quest_desc: [
		"Craft a &bPneumatic Chestplate&r. Charged with compressed air and fitted with upgrades, it can grant flight, protection, and more. The centerpiece of &6PneumaticCraft&r armor."
		"Slot upgrades to tune it, and keep a &bcharging station&r handy."
	]
	quest.49540D1000000007.quest_subtitle: "Air-powered armor."
	quest.49540D1000000007.title: "Pneumatic Chestplate"
	quest.49540D1000000008.quest_desc: [
		"Build an &6Oritech&r &bJetpack&r. Fueled and worn, it lifts you off the ground. The simplest flight option in the &dindustrial&r age."
		"Mind the fuel gauge before a long climb."
	]
	quest.49540D1000000008.quest_subtitle: "Oritech flight."
	quest.49540D1000000008.title: "Jetpack"
	quest.49540D1000000009.quest_desc: [
		"Craft an &6Immersive Engineering&r &bMining Drill&r. Powered and fitted with a head it breaks blocks in a wide pattern, clearing tunnels far faster than a pickaxe."
		"Swap heads and keep it charged for serious digging."
	]
	quest.49540D1000000009.quest_subtitle: "Tear through stone."
	quest.49540D1000000009.title: "Mining Drill"
	quest.49540D100000000A.quest_desc: [
		"Build the &bChemical Thrower&r. Loaded with a fluid it sprays fire, acid, or other effects in a stream, a crowd weapon and a tool both."
		"What it does depends entirely on what you fill it with."
	]
	quest.49540D100000000A.quest_subtitle: "Spray fire or worse."
	quest.49540D100000000A.title: "Chemical Thrower"
	quest.49540D100000000B.quest_desc: [
		"Forge a &bValkyrie Lance&r from the queen's drop. It strikes with reach and power and carries a piece of the &6Aether&r's grace, one of the best melee weapons available."
		"The reward for surviving the &bSilver Dungeon&r."
	]
	quest.49540D100000000B.quest_subtitle: "The queen's weapon."
	quest.49540D100000000B.title: "Valkyrie Lance"
	quest.49540D100000000D.quest_desc: [
		"Craft the &bFaraday Chestplate&r. It shields you from electrical damage, the tesla coils and lightning that would otherwise punish a careless engineer."
		"Niche, but invaluable around high-voltage gear."
	]
	quest.49540D100000000D.quest_subtitle: "Insulate against shock."
	quest.49540D100000000D.title: "Faraday Chestplate"
	quest.49540D100000000E.quest_desc: [
		"Forge an &6Immersive Engineering&r &bSteel&r Chestplate. Dependable mid-tier armor built from your own steel. A clean step up from iron for the &dindustrial&r era."
		"A reliable default while you chase the fancier sets."
	]
	quest.49540D100000000E.quest_subtitle: "Immersive Engineering's solid plate."
	quest.49540D100000000E.title: "Steel Chestplate"
	quest.49540D100000000F.quest_desc: [
		"Craft a &bPneumatic Jackhammer&r. Powered by compressed air, it breaks stone in a wide swing. &6PneumaticCraft&r's tunneling tool."
		"Keep the air topped up and the tunnels fly by."
	]
	quest.49540D100000000F.quest_subtitle: "Dig on air."
	quest.49540D100000000F.title: "Pneumatic Jackhammer"
	quest.49540D1000000010.quest_desc: [
		"Build the &bMinigun&r. Spun up on compressed air it pours out a stream of fire, the &6PneumaticCraft&r weapon for when one shot is never enough."
		"Thirsty for both ammo and air, but devastating up close."
	]
	quest.49540D1000000010.quest_subtitle: "Sustained fire."
	quest.49540D1000000010.title: "Minigun"
	quest.49540D1000000011.quest_desc: [
		"Craft an &bEngineer's Skyhook&r. Hooked onto a wire connection it zips you along the line, turning your power cables into a fast transit network."
		"String connectors across the base and travel by skyhook."
	]
	quest.49540D1000000011.quest_subtitle: "Ride the wires."
	quest.49540D1000000011.title: "Engineer's Skyhook"
	quest.49540D1000000012.quest_desc: [
		"Acquire &bCataclysm's Edge&r, a unique claymore from &6Arsenal&r. The mod adds new weapon classes with their own movesets; the named uniques are the standouts of each."
		"A heavy two-hander for the front line."
	]
	quest.49540D1000000012.quest_subtitle: "Unique claymore."
	quest.49540D1000000012.title: "Cataclysm's Edge"
	quest.49540D1000000013.quest_desc: [
		"Claim &bFrost Fang&r, &6Arsenal&r's unique dagger. Daggers strike fast and reward mobility, and this one carries a chill into every hit."
		"For the player who fights light and quick."
	]
	quest.49540D1000000013.quest_subtitle: "Unique dagger."
	quest.49540D1000000013.title: "Frost Fang"
	quest.49540D1000000014.quest_desc: [
		"Wield the &bDual-blade Butcher&r, a unique &6Arsenal&r double axe. It is a wide, brutal weapon that rewards swinging into a crowd."
		"Heavy, slow, and merciless."
	]
	quest.49540D1000000014.quest_subtitle: "Unique double axe."
	quest.49540D1000000014.title: "Dual-blade Butcher"
	quest.49540D1000000015.quest_desc: [
		"Take up &bHellreaver&r, &6Arsenal&r's unique glaive. Glaives sweep with reach, keeping enemies at the end of the blade where you want them."
		"Control the space and they never close in."
	]
	quest.49540D1000000015.quest_subtitle: "Unique glaive."
	quest.49540D1000000015.title: "Hellreaver"
	quest.49540D1000000016.quest_desc: [
		"Swing the &bHammer of Destiny&r, a unique &6Arsenal&r warhammer. Hammers land slow but stagger and crush, trading speed for sheer impact."
		"One good hit is worth three quick ones here."
	]
	quest.49540D1000000016.quest_subtitle: "Unique hammer."
	quest.49540D1000000016.title: "Hammer of Destiny"
	quest.49540D1000000017.quest_desc: [
		"Load the &bHeavy Crossbow of the Phoenix&r, a unique &6Arsenal&r ranged weapon. It hits harder than a bow at the cost of a slower draw."
		"For measured, heavy ranged shots."
	]
	quest.49540D1000000017.quest_subtitle: "Unique heavy crossbow."
	quest.49540D1000000017.title: "Heavy Crossbow of the Phoenix"
	quest.49540D1000000018.quest_desc: [
		"Draw the &bSunfury Hawk-Bow&r, &6Arsenal&r's unique longbow. Longbows reach further and fly straighter, the choice for picking targets off at range."
		"Range and accuracy over rate of fire."
	]
	quest.49540D1000000018.quest_subtitle: "Unique longbow."
	quest.49540D1000000018.title: "Sunfury Hawk-Bow"
	quest.49540D1000000019.quest_desc: [
		"Take &bBonecracker&r, &6Arsenal&r's unique mace. Maces are blunt and punishing, built to break guards and bones alike."
		"Simple, heavy, effective."
	]
	quest.49540D1000000019.quest_subtitle: "Unique mace."
	quest.49540D1000000019.title: "Bonecracker"
	quest.49540D100000001A.quest_desc: [
		"Raise the &bBulwark of Azzinoth&r, &6Arsenal&r's unique shield. A good shield turns a deadly hit into a glancing one, and this is among the best the mod offers."
		"Defense as a weapon in its own right."
	]
	quest.49540D100000001A.quest_subtitle: "Unique shield."
	quest.49540D100000001A.title: "Bulwark of Azzinoth"
	quest.49540D100000001B.quest_desc: [
		"Harvest with the &bToxic Sickle&r, &6Arsenal&r's unique sickle. Sickles sweep wide and suit both farming and fighting, and this one leaves poison in its wake."
		"A tool and a weapon at once."
	]
	quest.49540D100000001B.quest_subtitle: "Unique sickle."
	quest.49540D100000001B.title: "Toxic Sickle"
	quest.49540D100000001C.quest_desc: [
		"Level the &bSonic Spear&r, &6Arsenal&r's unique spear. Spears thrust with reach and speed, the disciplined dueling weapon of the set."
		"Keep the point between you and the threat."
	]
	quest.49540D100000001C.quest_subtitle: "Unique spear."
	quest.49540D100000001C.title: "Sonic Spear"
	quest.49540D100000001D.quest_desc: [
		"Wield &bAntonidas's Staff&r of Rapt Concentration, an &6Arsenal&r damage staff. Staves cast at range and lean on power rather than muscle, for a more arcane fighter."
		"Magic as your main hand."
	]
	quest.49540D100000001D.quest_subtitle: "Unique damage staff."
	quest.49540D100000001D.title: "Antonidas's Staff"
	quest.49540D100000001E.quest_desc: [
		"Carry the &bCrystalline Life-Staff&r, &6Arsenal&r's unique healing staff. It mends rather than harms, a support weapon for keeping yourself or allies standing."
		"The healer's choice among the uniques."
	]
	quest.49540D100000001E.quest_subtitle: "Unique healing staff."
	quest.49540D100000001E.title: "Crystalline Life-Staff"
	quest.49540D100000001F.quest_desc: [
		"Craft a &bWood Paxel&r from &6Mekanism Tools&r. A paxel is a pickaxe, axe, and shovel in one, freeing hotbar slots from the moment you make the first."
		"Mekanism gear starts at the &dindustrial&r age here, paxels included."
	]
	quest.49540D100000001F.quest_subtitle: "Wood-tier paxel."
	quest.49540D100000001F.title: "Wood Paxel"
	quest.49540D1000000020.quest_desc: [
		"Build a &bStone Paxel&r. It is the second rung of the paxel ladder, the same three-in-one convenience with a little more durability."
		"The paxels climb the same tiers your tools do."
	]
	quest.49540D1000000020.quest_subtitle: "Stone-tier paxel."
	quest.49540D1000000020.title: "Stone Paxel"
	quest.49540D1000000021.quest_desc: ["Forge a &bLapis Lazuli Helmet&r from &6Mekanism Tools&r. The lapis set is a colorful mid-tier armor with respectable protection, the first piece of a matching suit."]
	quest.49540D1000000021.quest_subtitle: "Lapis armor piece."
	quest.49540D1000000021.title: "Lapis Lazuli Helmet"
	quest.49540D1000000022.quest_desc: ["Craft a &bLapis Lazuli Chestplate&r. The chest is the heaviest defense of the set, the piece worth making first if you only make one."]
	quest.49540D1000000022.quest_subtitle: "Main armor piece for the lapis side set."
	quest.49540D1000000022.title: "Lapis Lazuli Chestplate"
	quest.49540D1000000023.quest_desc: ["Build &bLapis Lazuli Leggings&r. They round out the lower half of the lapis set, second only to the chest in protection."]
	quest.49540D1000000023.quest_subtitle: "Lower-half armor for the lapis side set."
	quest.49540D1000000023.title: "Lapis Lazuli Leggings"
	quest.49540D1000000024.quest_desc: ["Craft &bLapis Lazuli Boots&r. They complete the lapis suit, and a full set carries its own small bonus over mismatched pieces."]
	quest.49540D1000000024.quest_subtitle: "Complete the Mekanism lapis suit."
	quest.49540D1000000024.title: "Lapis Lazuli Boots"
	quest.49540D1000000025.quest_desc: [
		"Forge the complete &6Mekanism Tools&r &bSteel&r armor: helmet, chestplate, leggings, and boots. It is a sturdy &dindustrial&r-grade suit, a dependable wall between you and the world."
		"All &6Mekanism Tools&r gear is now forged on the &6Overgeared&r &bSmithing Anvil&r, not the crafting grid. The old grid recipes are gone. Place the ingots in the anvil's forging pattern, then strike the glowing metal with a hammer until the piece is finished. This applies to every material set: bronze, steel, lapis lazuli, osmium, refined glowstone, and refined obsidian."
		"A solid default set built from metal you already smelt."
	]
	quest.49540D1000000025.quest_subtitle: "Mekanism steel armor set."
	quest.49540D1000000025.title: "Steel Armor Set"
	quest.49540D1000000026.quest_desc: [
		"Assemble the full Valkyrie set: helmet, chestplate, leggings, boots, and gloves, all from the queen's drops. Worn together, it grants flight and the &6Aether&r's best protection."
		"The reward for clearing the &bSilver Dungeon&r in full."
	]
	quest.49540D1000000026.quest_subtitle: "Aether armor set."
	quest.49540D1000000026.title: "Valkyrie Armor Set"
	quest.49540D1000000027.quest_desc: [
		"Forge a &bPearlescent Pickaxe&r. Cut from &6Unusual End&r's pearlescent alloy it is a fast, durable miner, the tool tier above the dimension's earlier gear."
		"The pick that finishes the pearlescent set."
	]
	quest.49540D1000000027.quest_subtitle: "Pearlescent mining tool."
	quest.49540D1000000027.title: "Pearlescent Pickaxe"
	quest.49540D1000000028.quest_desc: [
		"Craft a &bPearlescent Sword&r. The same alloy makes a strong, light blade, a fitting weapon to carry alongside the pickaxe."
		"Pearlescent gear is the End-side endgame here."
	]
	quest.49540D1000000028.quest_subtitle: "Optional: the matching blade."
	quest.49540D1000000028.title: "Pearlescent Sword"
	quest.49540D1000000029.quest_desc: ["Craft a &bPearlescent Ring&r. Worn, it grants a passive bonus drawn from the End's pearlescent alloy, a trinket for the well-equipped explorer."]
	quest.49540D1000000029.quest_subtitle: "Optional: a worn charm."
	quest.49540D1000000029.title: "Pearlescent Ring"
	quest.49540D100000002A.quest_desc: [
		"Build the &bPearlescent Infuser&r. It is the workstation that fuses &6Unusual End&r materials into pearlescent alloy, the source of the whole pearlescent tier."
		"Everything pearlescent passes through here first."
	]
	quest.49540D100000002A.quest_subtitle: "Optional: the alloy station."
	quest.49540D100000002A.title: "Pearlescent Infuser"
	quest.49540D100000002B.quest_desc: [
		"Produce a &bBlock of Pearlescent Alloy&r. It is the dense, storable form of the End's top alloy, the material behind the mirror and the rest of the pearlescent endgame."
		"Stockpile it for the highest &6Unusual End&r crafts."
	]
	quest.49540D100000002B.quest_subtitle: "Optional: the refined metal."
	quest.49540D100000002B.title: "Block of Pearlescent Alloy"
	quest.49540E1000000001.quest_desc: [
		"Craft a &bGolden Furnace&r from &6Iron Furnaces&r. It smelts quicker and more efficiently than iron, a rung on the upgrade ladder that climbs through better metals."
		"Worth swapping in for any hand smelting you still do."
	]
	quest.49540E1000000001.quest_subtitle: "Optional: a faster smelter."
	quest.49540E1000000001.title: "Golden Furnace"
	quest.49540E1000000006.quest_desc: [
		"Assemble a &bGreenhouse Core&r and a Spring core. It keeps a sheltered plot in growing weather year-round, an &6Ecliptic Seasons&r answer to a harsh climate."
		"Steady crops no matter what the &bcalendar&r says."
	]
	quest.49540E1000000006.quest_subtitle: "Optional: grow against the season."
	quest.49540E1000000006.title: "Greenhouse Core"
	quest.4954101000000001.quest_desc: [
		"Craft the ME Controller. It is the core of an Applied Energistics network, and nearly every AE2 device you build has to reach one to function."
		"Power flows into the controller, and it hands out channels that let devices talk to the network. It works as the switchboard and power inlet in one block. A small network can run without it, but the moment you want drives, terminals, and automation together, the controller is what ties them into one grid."
		"This is the entry point of the AE2 lane. From here you feed it power, then start attaching storage."
	]
	quest.4954101000000001.quest_subtitle: "AE2 network core"
	quest.4954101000000001.title: "The ME Controller"
	quest.4954101000000002.quest_desc: [
		"Craft the Energy Acceptor. It converts the Forge Energy your machines already produce into the AE energy the network runs on."
		"AE2 uses its own internal power unit, so raw FE has to be translated before the grid can use it. Wire your generator or energy conduit into the acceptor, and the acceptor into the network, and your controller comes to life."
		"Without an acceptor the controller has no fuel. Build this right after the controller, then add a buffer so the grid rides through spikes."
	]
	quest.4954101000000002.quest_subtitle: "Power into the grid"
	quest.4954101000000002.title: "Energy Acceptor"
	quest.4954101000000003.quest_desc: [
		"Craft the Energy Cell. It stores AE energy so the network keeps running when demand briefly outpaces supply."
		"Autocrafting and bulk import can draw a sudden burst of power. A charged energy cell smooths those spikes, letting the grid pull from its buffer instead of stalling when your generators cannot keep up for a moment."
		"Add a cell or two to any busy network. With power stored, the network is stable enough to start holding items."
	]
	quest.4954101000000003.quest_subtitle: "Buffer AE energy"
	quest.4954101000000003.title: "Energy Cell"
	quest.4954101000000004.quest_desc: [
		"Craft the ME Drive. It is the bay that houses storage cells, and it is where your items actually live inside the network."
		"Slot formatted cells into the drive and their contents become part of the grid, searchable and pullable from any terminal. One drive holds several cells, so it scales your storage as you add more cells rather than more blocks."
		"The drive is the storage backbone. Next you make a cell to put in it."
	]
	quest.4954101000000004.quest_subtitle: "The disk bay"
	quest.4954101000000004.title: "ME Drive"
	quest.4954101000000005.quest_desc: [
		"Craft a 1k Item Storage Cell, your first piece of network storage."
		"A 1k cell holds a large number of item types and a bulk count of each. Slot it into a drive and the network can store items in it. You format and tune cells at a cell workbench, which is the next step."
		"Start with 1k cells while you learn the system. Larger tiers come later, but the pattern of drive plus cell stays the same all the way up."
	]
	quest.4954101000000005.quest_subtitle: "First ME cell"
	quest.4954101000000005.title: "1k Storage Cell"
	quest.4954101000000006.quest_desc: [
		"Craft the Cell Workbench. It lets you pre-partition a storage cell so it only accepts the item types you assign to it."
		"By default a cell fills with whatever reaches it. Partitioning locks a cell to specific items, which keeps your ores out of your gears and reserves space for exactly what you plan to store. It is the difference between a tidy network and a cluttered one."
		"Set up a workbench once you have more than a couple of cells. Then move items in and out at scale with an IO port."
	]
	quest.4954101000000006.quest_subtitle: "Partition your cells"
	quest.4954101000000006.title: "Cell Workbench"
	quest.4954101000000007.quest_desc: [
		"Craft the ME Chest. It reads a single storage cell directly, giving you the cheapest way to view and use a cell without a full drive."
		"The chest exposes one cell as an accessible inventory with a small built-in view. It is handy early, when you have one cell and do not yet want to commit to a drive and terminals."
		"Use it as a stepping stone. As your network grows you will move that cell into a drive and read everything through a terminal instead."
	]
	quest.4954101000000007.quest_subtitle: "Single-cell access"
	quest.4954101000000007.title: "ME Chest"
	quest.4954101000000008.quest_desc: [
		"Craft the IO Port. It moves items in bulk between storage cells and the network, or between cells and an attached inventory, in one action."
		"Loading a stack of cells into the IO port lets you dump their contents into the grid or pull the grid's contents onto them all at once. It is how you migrate storage, empty out old cells, or seed a new network quickly."
		"This is your bulk transfer tool. With storage and IO in place, you are ready to look into the grid through a terminal."
	]
	quest.4954101000000008.quest_subtitle: "Bulk import/export"
	quest.4954101000000008.title: "IO Port"
	quest.4954101000000009.quest_desc: [
		"Craft the ME Terminal. It is your window into the network, showing every item stored across all your drives in one searchable list."
		"From a terminal you search, sort, and pull stored items without walking to each drive. Place terminals wherever you work so the whole network is one reach away. This is the interface you will use most."
		"The plain terminal only views and extracts. The crafting terminal, next, adds a grid so you can build from stock on the spot."
	]
	quest.4954101000000009.quest_subtitle: "Window into the grid"
	quest.4954101000000009.title: "ME Terminal"
	quest.495410100000000A.quest_desc: [
		"Craft the Crafting Terminal. It is a terminal with a crafting grid built in, so you can craft straight from network stock."
		"Instead of pulling ingredients out, crafting them at a bench, and putting the result back, the crafting terminal does it all in place. Set a recipe, click, and it draws the ingredients from storage and returns the product to you."
		"This is the quality-of-life jump that makes AE2 storage feel worth it. Next you begin the autocrafting side, starting with a CPU shell."
	]
	quest.495410100000000A.quest_subtitle: "Craft from stock"
	quest.495410100000000A.title: "Crafting Terminal"
	quest.495410100000000B.quest_desc: [
		"Craft the Crafting Unit, the blank building block of an autocrafting CPU."
		"A crafting CPU is a small cluster of blocks the network uses to run automated crafting jobs. The crafting unit is the plain filler that forms the cluster's body. Combine it with storage and accelerators to build a working CPU."
		"Note that the CPU you assemble here is complete at the IR tier, but the pattern providers that feed it recipes come later in the Gilded age. For now you build the CPU shell and learn its parts."
	]
	quest.495410100000000B.quest_subtitle: "Blank CPU block"
	quest.495410100000000B.title: "Crafting Unit"
	quest.495410100000000C.quest_desc: [
		"Craft the 1k Crafting Storage. It is the memory of a crafting CPU, deciding how large and how many autocraft jobs the CPU can hold at once."
		"A CPU with more crafting storage can plan bigger recipe trees and run more of them in parallel. Add crafting storage blocks to the cluster to raise its capacity for complex jobs."
		"Pair storage with accelerators, next, to make the CPU both bigger and faster."
	]
	quest.495410100000000C.quest_subtitle: "CPU job memory"
	quest.495410100000000C.title: "1k Crafting Storage"
	quest.495410100000000D.quest_desc: [
		"Craft the Crafting Co-Processor, the accelerator that speeds up a crafting CPU."
		"Each co-processor lets the CPU work on more sub-steps of a recipe per tick. A CPU with many accelerators finishes a deep crafting tree far faster than one without. Storage sets how big a job can be, accelerators set how fast it runs."
		"With units, storage, and accelerators you can assemble a full CPU. The last piece of the lane is where you write the recipes it follows."
	]
	quest.495410100000000D.quest_subtitle: "Speed the CPU"
	quest.495410100000000D.title: "Crafting Co-Processor"
	quest.495410100000000E.quest_desc: [
		"Craft the Pattern Encoding Terminal, the capstone of the AE2 foundation lane. Here you encode crafting patterns, the recipe list an autocraft CPU will follow."
		"A pattern records inputs and the output they produce. You encode one pattern per recipe you want the network to make on demand. Building a library of patterns is what turns storage into a factory that crafts anything you ask for."
		"This is the ceiling of AE2 for the Industrial Revolution. You now have the full network, CPUs, and patterns. The Gilded age adds the molecular assembler and pattern providers that actually run the encoded jobs across your machines."
	]
	quest.495410100000000E.quest_subtitle: "AE2 foundation capstone"
	quest.495410100000000E.title: "Pattern Encoding Terminal"
	quest.4954101000000020.quest_desc: [
		"Craft the Refined Storage Controller. It supplies energy to the network and gives every connected device its shared identity."
		"Where Applied Energistics uses channels, Refined Storage is simpler: cable everything to one controller, keep it powered, and the whole network acts as a single pool of storage. The controller is both the power inlet and the hub."
		"This is the entry point of the RS lane. From here you run cable, then attach drives and disks."
	]
	quest.4954101000000020.quest_subtitle: "Refined Storage core"
	quest.4954101000000020.title: "RS Controller"
	quest.4954101000000021.quest_desc: [
		"Craft Refined Storage Cable. Devices only join the network when they are cabled back to the controller."
		"Run cable from the controller to each block you want on the grid: drives, grids, importers, and the rest. A device that is not connected does nothing, so plan your cable routes as you expand."
		"Cable is the connective tissue of the whole system. With a run in place, add a disk drive to hold storage."
	]
	quest.4954101000000021.quest_subtitle: "Wire the network"
	quest.4954101000000021.title: "RS Cable"
	quest.4954101000000022.quest_desc: [
		"Craft the Disk Drive. It houses storage disks, and the network's item capacity lives inside it."
		"Slot disks into the drive and their space becomes part of the network. One drive holds several disks, so you scale storage by adding disks first and more drives after. Cable the drive to the controller to bring it online."
		"The drive is the RS storage backbone. Next you make a disk to fill it."
	]
	quest.4954101000000022.quest_subtitle: "Holds storage disks"
	quest.4954101000000022.title: "Disk Drive"
	quest.4954101000000023.quest_desc: [
		"Craft a 1k Storage Disk, your first piece of Refined Storage capacity."
		"Unlike AE2 cells, an RS disk needs no formatting before use. Slot it into a drive and the network can store items in it right away. This makes RS the quicker system to get running, at the cost of the fine control AE2's partitioning gives."
		"Start with 1k disks and add more as you fill up. To actually see and use what is stored, you need a grid."
	]
	quest.4954101000000023.quest_subtitle: "First RS disk"
	quest.4954101000000023.title: "1k Storage Disk"
	quest.4954101000000024.quest_desc: [
		"Craft the Grid. It is the Refined Storage access window, letting you search, sort, and extract everything stored on the network."
		"The grid lists the whole network's contents in one place. Search by name, sort by count, and pull items straight into your inventory. Place grids wherever you work so storage is always one click away."
		"The plain grid views and extracts. Most of the network's other tools, the crafting grid, detector, monitor, and security manager, branch off from here."
	]
	quest.4954101000000024.quest_subtitle: "RS access window"
	quest.4954101000000024.title: "The Grid"
	quest.4954101000000025.quest_desc: [
		"Craft the Crafting Grid. It is a grid with a crafting area that pulls ingredients from network stock and remembers the recipes you use."
		"Set a recipe once and the crafting grid can refill it from storage with a click, tracking recent recipes so you do not re-enter them. Note that this is hand-crafting from network stock, not automated crafting."
		"The RS autocrafter that runs jobs on its own comes later in the Gilded age. For now the crafting grid covers on-demand building from your stored materials."
	]
	quest.4954101000000025.quest_subtitle: "Craft + remember"
	quest.4954101000000025.title: "Crafting Grid"
	quest.4954101000000026.quest_desc: [
		"Craft the Detector. It emits a redstone signal based on how much of an item the network holds."
		"Set the detector to watch an item and a threshold. When stock drops below or rises above that number, it changes its redstone output. That signal is the trigger you wire into machines to auto-restock or shut down a production line."
		"The detector is how a Refined Storage network reacts to its own contents. Use it to keep buffers full without manual checking."
	]
	quest.4954101000000026.quest_subtitle: "Redstone on thresholds"
	quest.4954101000000026.title: "Detector"
	quest.4954101000000027.quest_desc: [
		"Craft the Storage Monitor. It displays the live count of a single item as a wall-mounted readout."
		"Point a monitor at an item and it shows how many the network holds, updating in real time. A row of monitors over your workbench turns storage levels into an at-a-glance dashboard, so you notice a shortage before it stalls a build."
		"Monitors are pure information. Pair them with detectors when you want the network to act on those counts automatically."
	]
	quest.4954101000000027.quest_subtitle: "Stock at a glance"
	quest.4954101000000027.title: "Storage Monitor"
	quest.4954101000000028.quest_desc: [
		"Craft the Security Manager. It controls who may use the network and what they are allowed to do."
		"On a shared server you set per-player permissions: who can insert, who can extract, who can autocraft, and who is locked out entirely. On a single-player world it is a way to hard-lock a network you do not want touched."
		"This is the network's access control. Set it up once your storage holds anything worth protecting."
	]
	quest.4954101000000028.quest_subtitle: "Lock the network"
	quest.4954101000000028.title: "Security Manager"
	quest.4954101000000029.quest_desc: [
		"Craft the Portable Grid. It gives you handheld access to a storage disk out in the field, away from your network."
		"Load a disk into the portable grid and carry it. You can deposit and withdraw from that disk anywhere, which is ideal for mining trips where you want to offload ore without hauling it home. It works off-network, on its own battery."
		"This is the mobile companion to your fixed grids. Keep one charged for expeditions."
	]
	quest.4954101000000029.quest_subtitle: "Handheld access"
	quest.4954101000000029.title: "Portable Grid"
	quest.495410100000002A.quest_desc: [
		"Craft the Disk Interface, the capstone of the Refined Storage foundation lane. It moves items in bulk between storage disks and the network."
		"The disk interface is the network's I/O ceiling for this age, handling high-volume transfer that keeps disks loaded and drained without manual shuffling. It also anchors the elite Cable Tiers extension below it."
		"Note that the Refined Storage autocrafter, which runs jobs on its own, is Gilded-age content and is taught later. For now you have the full storage network, and the elite cable tail adds throughput on top of it."
	]
	quest.495410100000002A.quest_subtitle: "RS foundation capstone"
	quest.495410100000002A.title: "Disk Interface"
	quest.4954101000000030.quest_desc: [
		"Craft the Elite Importer from Cable Tiers, a higher-throughput version of the base Refined Storage importer."
		"A base importer pulls a modest number of items per operation. The elite tier moves many stacks at a time through a single cable, so one importer can keep up with a fast machine that a base importer would bottleneck."
		"This roots the elite Cable Tiers tail. From here you branch into the matching elite exporter, constructor, destructor, and disk interface."
	]
	quest.4954101000000030.quest_subtitle: "High-throughput import"
	quest.4954101000000030.title: "Elite Importer"
	quest.4954101000000031.quest_desc: [
		"Craft the Elite Exporter, the high-throughput counterpart that pushes items out of the network into machines."
		"Where the importer pulls in, the exporter feeds out. At elite tier it delivers many stacks per operation, keeping a hungry processing line supplied without a queue of slower exporters."
		"Pair it with the elite importer to run a fast in-and-out loop through a single network connection."
	]
	quest.4954101000000031.quest_subtitle: "Push stacks fast"
	quest.4954101000000031.title: "Elite Exporter"
	quest.4954101000000032.quest_desc: [
		"Craft the Elite Constructor. It places blocks from the network into the world at elite speed."
		"A constructor takes blocks from storage and sets them in front of itself, useful for automated building, cobble walls, or feeding block-consuming machines. The elite tier places far faster than the base version."
		"This is one of the action cables in the elite tail. Use it wherever the network needs to build rather than store."
	]
	quest.4954101000000032.quest_subtitle: "Place blocks fast"
	quest.4954101000000032.title: "Elite Constructor"
	quest.4954101000000033.quest_desc: [
		"Craft the Elite Destructor. It breaks blocks in front of it and pulls the drops straight into the network at elite speed."
		"A destructor is the mirror of the constructor: instead of placing, it harvests. Point it at crops, a cobble generator, or a mined face and it feeds the results into storage automatically. The elite tier keeps up with fast producers."
		"Together with the constructor it lets a network shape and harvest the world hands-off."
	]
	quest.4954101000000033.quest_subtitle: "Break + ingest fast"
	quest.4954101000000033.title: "Elite Destructor"
	quest.4954101000000034.quest_desc: [
		"Craft the Elite Disk Interface, the elite-tier bulk transfer between storage disks and the network."
		"Like the base disk interface but faster, it shuffles large volumes between loose disks and network storage in far less time. Use it when you regularly move whole disks in and out and the base interface is too slow."
		"This closes the elite Cable Tiers tail. With it your Refined Storage network handles both storage and high-throughput I/O at scale."
	]
	quest.4954101000000034.quest_subtitle: "Bulk disk transfer"
	quest.4954101000000034.title: "Elite Disk Interface"
	quest.4954101000000040.quest_desc: [
		"&6More Red&r condenses redstone logic into single placeable plates. Craft the &bSoldering Table&r, then mix an alloyable ingot with four redstone dust for &bRed Alloy Ingots&r, the mod's conductive base metal."
		"The soldering table is the dedicated bench for the mod's logic gates. Where a discrete redstone build spreads a circuit across a room, More Red packs the same function into one block face."
	]
	quest.4954101000000040.quest_subtitle: "Gates in one block."
	quest.4954101000000040.title: "Soldering and Red Alloy"
	quest.4954101000000041.quest_desc: [
		"Spool up &bBundled Cable&r and place &bBundled Network Cable&r runs. A bundled cable carries all sixteen colored redstone channels side by side without crosstalk."
		"Use it to move a machine hall's worth of control signals through a single duct, then break individual colors out at each destination. It sits comfortably beside your ProjectRed lines and speaks the same colored-channel language."
	]
	quest.4954101000000041.quest_subtitle: "Sixteen signals, one cable."
	quest.4954101000000041.title: "Bundled Cabling"
	quest.4954101000000042.quest_desc: [
		"Solder a &bMultiplexer&r and a &bLatch&r. The multiplexer selects between two inputs with a control line. The latch holds one bit of state until told otherwise."
		"Those two functions, selection and memory, carry most practical automation circuits. The rest of More Red's gate catalog follows the same soldering pattern whenever a build calls for it."
	]
	quest.4954101000000042.quest_subtitle: "Selection and memory."
	quest.4954101000000042.title: "Showpiece Logic"
	quest.4954104000000001.quest_desc: ["Gather Certus Quartz Crystal and Charged Certus Quartz Crystal, then craft a Growth Accelerator and Charger. This starts the Applied Energistics 2 crystal line."]
	quest.4954104000000001.quest_subtitle: "Grow and charge the crystal line."
	quest.4954104000000001.title: "Certus Quartz and Charging"
	quest.4954104000000002.quest_desc: ["Craft an Inscriber, Silicon Press, and Logic Press. These parts start the processor-making branch."]
	quest.4954104000000002.quest_subtitle: "Presses for the processor line."
	quest.4954104000000002.title: "Inscriber"
	quest.4954104000000003.quest_desc: ["Craft the Calculation Press and Engineering Press alongside the existing processor tools. Keep the presses available for the three processor tiers."]
	quest.4954104000000003.quest_subtitle: "Build the three processor presses."
	quest.4954104000000003.title: "Processor Presses"
	quest.4954104000000004.quest_desc: ["Craft Logic Processors, Calculation Processors, and Engineering Processors with the Inscriber. These are the processor outputs used by the ME network."]
	quest.4954104000000004.quest_subtitle: "Craft the logic, calculation, and engineering processors."
	quest.4954104000000004.title: "Processors"
	quest.4954104000000005.quest_desc: ["Craft an ME Import Bus, ME Export Bus, and ME Storage Bus. Use them to move items between inventories and the network."]
	quest.4954104000000005.quest_subtitle: "Import, export, and store items."
	quest.4954104000000005.title: "Item Routing"
	quest.4954104000000006.quest_desc: ["Craft an ME Interface, ME Annihilation Plane, and ME Formation Plane. These components connect the network to machines and world-facing actions."]
	quest.4954104000000006.quest_subtitle: "Build the interface and plane tools."
	quest.4954104000000006.title: "ME Interface"
	quest.4954104000000007.quest_desc: ["Craft an ME Level Emitter and ME P2P Tunnel. Use the emitter for threshold signals and the tunnel for network links."]
	quest.4954104000000007.quest_subtitle: "Control and tunnel the network."
	quest.4954104000000007.title: "Level Emitter and P2P"
	quest.4954104000000008.quest_desc: ["Craft the 4k, 16k, 64k, and 256k ME Item Storage Cells. Capacity rises by tier, so build the cell size your network can support."]
	quest.4954104000000008.quest_subtitle: "Build the 4k through 256k cells."
	quest.4954104000000008.title: "ME Item Storage"
	quest.4954111000000001.quest_desc: [
		"Craft the Enrichment Chamber, Mekanism's entry ore processor and your first step into stage machine processing."
		"The Enrichment Chamber is stage one of the ore-doubling ladder: feed it raw ore and it produces two dusts, which you then smelt into two ingots. That is a clean doubling of every ore you mine, and it is the reason Mekanism is worth setting up early."
		"The chamber runs on Forge Energy and needs feeder metals like steel and osmium to build the rest of the fleet. This node roots the whole chapter, so get one running and start doubling your ores."
	]
	quest.4954111000000001.quest_subtitle: "Stage-1 ore doubling"
	quest.4954111000000001.title: "Enrichment Chamber"
	quest.4954111000000002.quest_desc: [
		"Craft the Crusher. It turns ingots and items back into dust, closing the loop with the Enrichment Chamber."
		"Some processing tiers work on dust, not ore. The crusher lets you convert stray ingots back into dust so they can re-enter the doubling chain, and it handles the reverse leg of several Mekanism recipes."
		"Together the crusher and enrichment chamber form the base two-machine loop. Build both, then decide whether to climb the higher-tier gas chain or the alloy branch."
	]
	quest.4954111000000002.quest_subtitle: "Ingots back to dust"
	quest.4954111000000002.title: "Crusher"
	quest.4954111000000003.quest_desc: [
		"Craft the Energized Smelter, Mekanism's electric furnace."
		"The Energized Smelter smelts on Forge Energy instead of burning fuel, so once your power is running you never feed it coal again. It handles the dust-to-ingot step at the end of the doubling chain and any ordinary smelting besides."
		"This machine also feeds into the factory tier later, where parallel smelting scales your output. For now it completes the base processing trio."
	]
	quest.4954111000000003.quest_subtitle: "Powered smelting"
	quest.4954111000000003.title: "Energized Smelter"
	quest.4954111000000004.quest_desc: [
		"Craft the Osmium Compressor. It compresses osmium onto dust to make enriched materials, the feedstock the higher processing tiers need."
		"The compressor is the gateway to stage three. It uses gaseous osmium to produce enriched alloys and refined obsidian, which the purification chamber and injection chamber consume to reach three and four times ore yield."
		"Set the compressor up when you want more than doubling. It sits between the base loop and the gas-fed tiers ahead."
	]
	quest.4954111000000004.quest_subtitle: "3x-tier feeder"
	quest.4954111000000004.title: "Osmium Compressor"
	quest.4954111000000005.quest_desc: [
		"Craft the Purification Chamber, the stage-three machine that turns ore into three clumps using oxygen gas."
		"Purification needs a steady oxygen feed, so it does not run on its own. Pipe oxygen from the electrolytic separator into it, and each ore becomes three clumps that grind and smelt into three ingots. That is a fifty percent gain over doubling."
		"This is your first gas-fed machine. Build the electrolytic separator next to supply the oxygen it depends on."
	]
	quest.4954111000000005.quest_subtitle: "Stage-3 gas processing"
	quest.4954111000000005.title: "Purification Chamber"
	quest.4954111000000006.quest_desc: [
		"Craft the Electrolytic Separator. It splits water into hydrogen and oxygen, the gases that drive the higher processing tiers."
		"Feed it water and power and it produces two gas streams. Oxygen goes to the purification chamber; hydrogen feeds the chemical infuser toward the four-times tier. The separator is the gas plant your whole advanced chain hangs off."
		"Pipe its outputs into gas tanks so supply never runs dry. With gas flowing you can push ore processing past three times yield."
	]
	quest.4954111000000006.quest_subtitle: "Water into hydrogen and oxygen"
	quest.4954111000000006.title: "Electrolytic Separator"
	quest.4954111000000007.quest_desc: [
		"Craft the Chemical Injection Chamber, the stage-four machine that turns ore into four shards using hydrogen chloride."
		"This is the four-times tier. Each ore becomes four shards, which wash and smelt down to four ingots. It needs hydrogen chloride piped in, so it depends on both the purification chamber before it and the chemical infuser that makes the gas."
		"Getting here means every ore you mine is worth four ingots. Build the chemical infuser to supply the hydrogen chloride this chamber runs on."
	]
	quest.4954111000000007.quest_subtitle: "Stage-4 ore doubling"
	quest.4954111000000007.title: "Chemical Injection Chamber"
	quest.4954111000000008.quest_desc: [
		"Craft the Chemical Infuser. It combines two gases into a third, and here its job is turning hydrogen and chlorine into hydrogen chloride."
		"The injection chamber needs hydrogen chloride, and the infuser is what makes it. Feed hydrogen from the electrolytic separator and chlorine from a salt source into the infuser, and it outputs the acid gas the four-times tier consumes."
		"This closes the gas supply chain: water splits into hydrogen, hydrogen combines into HCl, and HCl drives the injection chamber. With it your advanced ore line is self-sufficient."
	]
	quest.4954111000000008.quest_subtitle: "Combine gases into HCl"
	quest.4954111000000008.title: "Chemical Infuser"
	quest.4954111000000009.quest_desc: [
		"Craft the Pressurized Reaction Chamber, the most versatile machine in the Mekanism fleet."
		"The PRC runs recipes that need an item, a fluid, and a gas all at once, which no other single machine handles. It makes substrate, bio-fuel intermediates, and many of the advanced components later Mekanism tiers depend on."
		"Think of the PRC as the reaction workhorse you return to constantly. Build it once the gas chain is running so you have the inputs it needs."
	]
	quest.4954111000000009.quest_subtitle: "Item, fluid, and gas reactions"
	quest.4954111000000009.title: "Pressurized Reaction Chamber"
	quest.495411100000000A.quest_desc: [
		"Craft the Metallurgic Infuser. It infuses dusts such as carbon, redstone, and diamond into base metals to produce alloys."
		"This is how you make Mekanism's infused and reinforced alloys and steel dust, the building materials for the rest of its machines and cables. It branches off the enrichment chamber rather than sitting on the gas chain."
		"Set the infuser up early, because almost every advanced Mekanism recipe wants an alloy it produces. Keep the common infusion materials stocked beside it."
	]
	quest.495411100000000A.quest_subtitle: "Infuse dusts into alloys"
	quest.495411100000000A.title: "Metallurgic Infuser"
	quest.495411100000000B.quest_desc: [
		"Build the Thermal Evaporation Plant, the multiblock capstone of this chapter. Assemble the tower from thermal evaporation blocks and valves, then place the controller as the tasked piece."
		"The plant boils brine down to lithium and provides the five-times salt-refining tier, evaporating fluids under heat to concentrate what they carry. It is the largest structure in the Ore Works and the gateway to Mekanism's chemical endgame."
		"Follow Mekanism's guide for the exact block count and layout, and give it a hot biome or a heat source to work efficiently. Completing it proves you can build and run a full Mekanism multiblock."
	]
	quest.495411100000000B.quest_subtitle: "Spine capstone multiblock"
	quest.495411100000000B.title: "Thermal Evaporation Plant"
	quest.4954111000000010.quest_desc: [
		"Craft the Basic Smelting Factory. A factory is several copies of one machine packed into a single block, so this one smelts many items in parallel."
		"Where the energized smelter processes one stream, a factory processes several side by side, sharing power and upgrades. You raise its slot count with factory installers and speed it with upgrades, turning a single machine into a small production line."
		"This is the throughput answer once single machines cannot keep up. It scales the smelting step you learned on the energized smelter."
	]
	quest.4954111000000010.quest_subtitle: "Parallel smelting tier"
	quest.4954111000000010.title: "Basic Smelting Factory"
	quest.4954111000000011.quest_desc: [
		"Craft the Basic Enriching Factory. It runs several enrichment operations in parallel for scaled ore doubling."
		"This is the factory form of the enrichment chamber. Instead of one ore at a time, it doubles many streams at once, which matters as your mining output grows beyond what a lone chamber can process."
		"Tie it back to the enrichment chamber tier you built at the start of the chapter. Same recipe, far more throughput."
	]
	quest.4954111000000011.quest_subtitle: "Parallel ore-doubling"
	quest.4954111000000011.title: "Basic Enriching Factory"
	quest.4954111000000012.quest_desc: [
		"Craft the Basic Crushing Factory. It runs several crushing operations in parallel for the return leg of the processing loop at scale."
		"This is the factory form of the crusher. When you are processing enough material that a single crusher backs up, the factory keeps the ingot-to-dust leg flowing to match your enriching and smelting factories."
		"With smelting, enriching, and crushing all in factory form, your ore-processing loop scales as a unit. This closes the factory lane of the Ore Works."
	]
	quest.4954111000000012.quest_subtitle: "Parallel crushing"
	quest.4954111000000012.title: "Basic Crushing Factory"
	quest.4954121000000001.quest_desc: [
		"Craft the Primitive Machine Core. It is the tier marker for Oritech's first processing rank, and building it opens the entry machines."
		"Be aware that Oritech machines do not craft from the core the way some mods work. Each machine has its own explicit recipe of intermediates, so treat this core as proof you have reached the tier rather than as a part you feed into the next machine."
		"This is the start of the Oritech lane. From here you build the generator, pulverizer, and powered furnace that make up the base processing set."
	]
	quest.4954121000000001.quest_subtitle: "The shared processing-tier marker"
	quest.4954121000000001.title: "Primitive Machine Core"
	quest.4954121000000002.quest_desc: [
		"Reach the Basic Generator. Every Oritech machine needs power, and this generator is the simplest source, burning fuel to produce RF."
		"The Oritech chapter reuses the Basic Generator built in Power, Motion, and Grid. No second craft is needed; keep a generator feeding the machines."
		"Make sure a generator is feeding your machines before you expect the pulverizer or furnace to work. Power first, processing second."
	]
	quest.4954121000000002.quest_subtitle: "Burns fuel for RF"
	quest.4954121000000002.title: "Basic Generator"
	quest.4954121000000003.quest_desc: [
		"Craft the Pulverizer, Oritech's entry ore processor."
		"The pulverizer grinds ore into dust, and two dusts smelt into two ingots, so it doubles the yield of everything you mine. It is the first machine most Oritech setups build, because the return pays for itself quickly."
		"Wire it to your generator and feed it ore. The dust it makes goes to the Powered Furnace next."
	]
	quest.4954121000000003.quest_subtitle: "Ore to dust doubling"
	quest.4954121000000003.title: "Pulverizer"
	quest.4954121000000004.quest_desc: [
		"Craft the Powered Furnace. It smelts on RF instead of fuel, handling the dust your pulverizer produces."
		"Running on power means no coal to feed and steadier throughput than a fuel furnace. It completes the base doubling loop: pulverize ore into dust, then smelt dust into ingots, all on electricity."
		"With the generator, pulverizer, and furnace running, you have Oritech's starter processing chain. The next core tier unlocks the foundry and refinery."
	]
	quest.4954121000000004.quest_subtitle: "Electric smelting"
	quest.4954121000000004.title: "Powered Furnace"
	quest.4954121000000005.quest_desc: [
		"Craft the Basic Machine Core, Oritech's second processing tier. It unlocks the foundry and refinery."
		"As with the primitive core, this is a tier marker, not a crafting ingredient. Oritech machines still assemble from their own explicit intermediates. Reaching this core simply proves you can build the mid-tier machines."
		"From here the lane splits into alloying at the foundry and fluid work at the refinery, which later converge on the machine frame."
	]
	quest.4954121000000005.quest_subtitle: "The second processing tier"
	quest.4954121000000005.title: "Basic Machine Core"
	quest.4954121000000006.quest_desc: [
		"Reach the Foundry, Oritech's multi-input alloying machine for bronze, steel, and machine plating."
		"The Oritech chapter reuses the Foundry built in Magic Feedstock and Spectrum Network. No second craft is needed; use it for the bronze and plating inputs."
		"The foundry is one of the two mid-tier branches. Together with the refinery, it leads into the shared machine frame."
	]
	quest.4954121000000006.quest_subtitle: "Multi-input alloying"
	quest.4954121000000006.title: "Foundry"
	quest.4954121000000007.quest_desc: [
		"Craft the Refinery, Oritech's fluid-processing machine."
		"Fitted with the refinery module, it refines fluids into more useful forms for the machines and fuels further up the chain. It is the fluid counterpart to the foundry's alloying, covering the liquid side of Oritech production."
		"The refinery is the second mid-tier branch. Its output and the foundry's converge at the machine frame next."
	]
	quest.4954121000000007.quest_subtitle: "Fluid refining"
	quest.4954121000000007.title: "Refinery"
	quest.4954121000000008.quest_desc: [
		"Craft the Machine Frame, the shared chassis Oritech's higher machines are built on."
		"Once you have both the foundry and the refinery producing, their materials come together here. The frame is the common body that the top-tier machines assemble around, so it marks the point where the two mid-tier branches merge."
		"This node depends on both branches for a reason: you need alloying and fluid refining working before the frame is worth building. It leads directly to the chapter capstone."
	]
	quest.4954121000000008.quest_subtitle: "The shared chassis"
	quest.4954121000000008.title: "Machine Frame"
	quest.4954121000000009.quest_desc: [
		"Craft the Improved Machine Core, the capstone of this chapter and Oritech's ceiling for the Industrial Revolution."
		"This is the highest processing tier you can reach at this age. It marks a complete Oritech setup: power, base processing, alloying, refining, and the frame that ties them together."
		"The Gilded age builds on this with a further core tier and the assembler, but those are later content and are not part of this chapter. Finishing this core is the proof that your Oritech foundry is fully established."
	]
	quest.4954121000000009.quest_subtitle: "The IR ceiling"
	quest.4954121000000009.title: "Improved Machine Core"
	quest.495412100000000A.quest_desc: [
		"Optional. Craft the Small Storage block, an RF battery that buffers power off your generator."
		"A battery stores energy so your machines keep running through a fuel gap or a demand spike, the same idea as an energy cell in other power systems. It is a convenience, not a requirement, for a foundry this size."
		"Add one if your generator sometimes falls behind. Otherwise the direct feed is enough at this tier."
	]
	quest.495412100000000A.quest_subtitle: "Optional RF buffer"
	quest.495412100000000A.title: "Small Storage (Battery)"
	quest.495412100000000B.quest_desc: [
		"Optional. Craft the Steam Engine, an alternate Oritech power source."
		"The steam engine offers another way to generate RF besides the basic generator, useful if you prefer a steam setup or want a second power line. It is a side option rather than a step on the main chain."
		"Take it if you want the variety, but the basic generator already covers the foundry's needs."
	]
	quest.495412100000000B.quest_subtitle: "Optional alt power"
	quest.495412100000000B.title: "Steam Engine"
	quest.4954121000000020.quest_desc: [
		"Craft the Extended Crafting Frame, the shell that becomes the Basic Crafting Table."
		"The frame is built from Black Iron, Extended Crafting's core material. You do not task the bare ingot here, but you will make plenty of Black Iron to assemble this frame and the table it wraps."
		"This begins the standalone Extended Crafting lane. Many later mods rely on its oversized crafting grid, so setting it up now saves trouble down the line."
	]
	quest.4954121000000020.quest_subtitle: "The crafting-table shell"
	quest.4954121000000020.title: "Machine Frame (Extended Crafting)"
	quest.4954121000000021.quest_desc: [
		"Craft the Basic Crafting Table, a five-by-five crafting grid."
		"Where a vanilla table gives you three by three, this one gives twenty-five slots. A number of later recipes across the pack are shaped larger than three by three and simply cannot be made anywhere else."
		"Treat this table as a prerequisite you will keep coming back to. Build it now so those oversized recipes are unlocked when you reach them."
	]
	quest.4954121000000021.quest_subtitle: "A 5x5 oversized-recipe grid"
	quest.4954121000000021.title: "Basic Crafting Table"
	quest.4954121000000022.quest_desc: [
		"Craft the Handheld Crafting Table, a portable crafting grid you carry in hand."
		"It gives you a three-by-three grid anywhere, without placing a workbench, which is handy on expeditions or in the middle of a build. It complements the big table rather than replacing it."
		"This is a pure quality-of-life pickup. Keep one on your hotbar and you will rarely be stuck without a crafting grid again."
	]
	quest.4954121000000022.quest_subtitle: "Portable 3x3 access"
	quest.4954121000000022.title: "Handheld Crafting Table"
	quest.4954631000000000.quest_desc: ["Complete the six industrial checks and the citadel boss proof. That closes the Iron Era and opens the Gilded Age."]
	quest.4954631000000000.quest_subtitle: "Heart and six checks."
	quest.4954631000000000.title: "The Iron Era Complete"
	quest.49793060345FB28C.quest_desc: [
		"Build the &bCowboy's Hut&r. The Cowboy raises cattle for a steady supply of beef, leather, and milk."
		"Fence off some grass nearby and keep wheat handy for breeding the herd."
	]
	quest.49793060345FB28C.quest_subtitle: "Beef, leather, and milk."
	quest.49793060345FB28C.title: "Cowboy's Hut"
	quest.49BBE54BCF735A82.quest_desc: [
		"Craft a &bMixed Soil Pot&r. This is the first real step into the relics chapter: get the pot in hand so the garden line can start."
		"The magical plants ahead root only in enriched soil, so lay down a bed of it before you start planting."
	]
	quest.49BBE54BCF735A82.quest_subtitle: "Pot before plants."
	quest.49BBE54BCF735A82.title: "Mixed Soil Pot"
	quest.4B2D3C5E8F7A7B10.quest_desc: [
		"Stock the full homestead kit: &6Farmer's Delight&r cooking gear, Cooking for Blockheads kitchen blocks, botany pots, fishing tackle, and farming station blocks. A deep dive into the pack's food mods for anyone who wants the table to match the colony."
		"Skip it if you are racing ahead, or settle in and turn the garden into a proper kitchen."
	]
	quest.4B2D3C5E8F7A7B10.quest_subtitle: "Optional: settle in and cook."
	quest.4B2D3C5E8F7A7B10.title: "The Homestead Pantry"
	quest.4B2D3C5E8F7A7C00.quest_desc: [
		"Craft an &bExplorer's Compass&r. It locates a chosen structure type, which cuts a lot of aimless wandering when you are hunting down burrows, groves, and the like."
		"Optional, but a real time-saver for an exploration-heavy chapter."
	]
	quest.4B2D3C5E8F7A7C00.quest_subtitle: "Point yourself at a structure."
	quest.4B2D3C5E8F7A7C00.title: "Explorer's Compass"
	quest.4B2D3C5E8F7C0001.quest_desc: [
		"Craft a &bSlicer&r from &6Create: Slice & Dice&r. It is a machine in the Mechanical Mixer and Mechanical Press family that automates &6Farmer's Delight&r cutting-board work. Give it rotation from below or the side, then right-click a knife or an axe into it to load the cutting tool."
		"It sits on a basin or takes items from a belt or Mechanical Arm, so it slots into a normal Create line. Note that many cutting outputs are plain vanilla items, so this quest asks for the Slicer block itself, not a cut result."
	]
	quest.4B2D3C5E8F7C0001.quest_subtitle: "Optional. Automate the cutting board."
	quest.4B2D3C5E8F7C0001.title: "Slicer"
	quest.4B2D3C5E8F7C0002.quest_desc: [
		"Close the fertilizer loop. You need a &bBucket of Liquid Fertilizer&r and a &bSprinkler&r. There is no crafting recipe for the bucket. First make the fluid with Create Mixing from Farmer's Delight Organic Compost and water in a basin, which yields Liquid Fertilizer. Then take an empty bucket and fill it from that fluid, either by right-clicking the source or by draining it through a Create Spout or Item Drain."
		"Place a Sprinkler below a fluid pipe and it sprays the fluid over the area beneath it. Fed Liquid Fertilizer it grows crops like bonemeal. You can also fill Rich Soil directly with Create Filling using compost and the fertilizer fluid. A Sprinkler also works mounted on a moving contraption, applying its effect as the contraption advances."
	]
	quest.4B2D3C5E8F7C0002.quest_subtitle: "Optional. Liquid fertilizer and spray."
	quest.4B2D3C5E8F7C0002.title: "Liquid Fertilizer Loop"
	quest.4C57010000010001.quest_desc: ["Gather every &brocket engine&r part on the list. The launch pad wants the full set before it fires."]
	quest.4C57010000010001.quest_subtitle: "Engine parts before launch."
	quest.4C57010000010001.title: "Rocket Engine"
	quest.4C57010000010002.quest_desc: ["Gather every &boxygen distributor&r part on the list. Life support needs it before you leave atmosphere."]
	quest.4C57010000010002.quest_subtitle: "Life support before launch."
	quest.4C57010000010002.title: "Oxygen Distributor"
	quest.4C57010000010003.quest_desc: ["Gather every &brocket launch pad&r part on the list. Stack the pad before you load the rocket."]
	quest.4C57010000010003.quest_subtitle: "Stack the pad first."
	quest.4C57010000010003.title: "Rocket Launch Pad"
	quest.4C57010000010004.quest_desc: ["Have a built rocket in your inventory once the pad and life support are ready."]
	quest.4C57010000010004.quest_subtitle: "Rocket ready on the pad."
	quest.4C57010000010004.title: "Rocket"
	quest.4C57010000020001.quest_desc: [
		"Stellaris machines are built from &bheavy metal plates&r. Smelt a full iron block in a furnace or blast furnace to get one. The ingot has its own separate route: blast an &6Overgeared&r &bheated iron ingot&r and it comes out as a &bheavy metal ingot&r."
		"Plates do not break back down into ingots, so run both lines: iron blocks for plates, heated iron for ingots. Every machine in this chapter eats this metal."
		"Craft an &bengine fan&r too. It takes steel ingots and steel nuggets, and any steel in the pack satisfies the recipe. The fan goes into rocketry components down the line, so make it now while the steel is out."
	]
	quest.4C57010000020001.quest_subtitle: "Iron blocks become aerospace plating."
	quest.4C57010000020001.title: "Heavy Metal Foundations"
	quest.4C57010000020002.quest_desc: [
		"Stellaris machines run on FE, the same energy your industrial gear already produces. You need a way to move it and a place to store it. Craft &bcables&r first. One recipe of steel ingots, a steel nugget, and wool yields six."
		"Next craft a &bbattery&r from steel and heavy metal ingots and nuggets. The battery is a portable charge cell and an ingredient in the bank."
		"Finish with the &bTier 1 Energy Bank&r, built from steel, heavy metal, and the battery. Wire your generators into the bank and run cable out to the machines. The pumpjack, refinery, and water separator coming next all pull from this grid. Higher-tier cables and banks exist, but they belong to a later chapter. Tier 1 covers everything here."
	]
	quest.4C57010000020002.quest_subtitle: "Cable, battery, bank. Tier 1 power."
	quest.4C57010000020002.title: "Starter Grid"
	quest.4C57010000020003.quest_desc: [
		"Rocket fuel starts as crude oil, and oil hides in underground deposits. Craft the &boil finder&r from a redstone torch, steel nuggets, and a glass pane."
		"Use the finder in hand as you travel. It reads the ground below and tells you when a deposit is near. Sweep an area until the readings point you to a pocket."
		"Do this before you build anything. A pumpjack only pays off when it sits on top of a real deposit, so confirm the site first and mark it."
	]
	quest.4C57010000020003.quest_subtitle: "Dowse the overworld for crude."
	quest.4C57010000020003.title: "Oil Finder"
	quest.4C57010000020004.quest_desc: [
		"The pumpjack needs a drill head before it can be assembled. Craft the &bpumpjack drill&r from heavy metal ingots, a diamond, and steel nuggets."
		"The drill is a component, not a placeable machine. It slots into the pumpjack recipe in the machines quest that opens next."
		"Craft it now, keep it in a chest with your other rocketry parts, and get your iron block smelter running. The pumpjack itself takes more heavy metal."
	]
	quest.4C57010000020004.quest_subtitle: "The bit that bites the bedrock."
	quest.4C57010000020004.title: "Pumpjack Drill"
	quest.4C57010000020005.quest_desc: [
		"Place your &bpumpjack&r directly on the deposit the oil finder located. Wire it into the starter grid. It needs FE to run."
		"With power flowing, the pumpjack drills down and pulls crude from the pocket. It fills its internal tank as it works."
		"Keep one bucket of oil for the next fuel step."
	]
	quest.4C57010000020005.quest_subtitle: "Bucket the black stuff."
	quest.4C57010000020005.title: "First Crude"
	quest.4C57010000020006.quest_desc: [
		"Crude oil does not burn in a rocket. Set up the &bfuel refinery&r from the machines quest and give it FE from your grid."
		"Feed oil into the refinery. Every 10 mb of oil refines into 5 mb of fuel and 5 mb of diesel. Fuel is the launch product. Diesel is a side stream covered in the next quest."
		"Bucket out one &bbucket of fuel&r. The rocket must be filled with this before it will lift off, so keep the refinery running. Launches are not one-time purchases and you will want reserves for return trips."
	]
	quest.4C57010000020006.quest_subtitle: "Refine crude into launch-grade fuel."
	quest.4C57010000020006.title: "Rocket Fuel"
	quest.4C57010000020007.quest_desc: [
		"Half of what the refinery makes is &bdiesel&r. It comes out alongside fuel at the same 5 mb per 10 mb of crude, whether you want it or not."
		"Bucket some and store it. Diesel powers the Stellaris diesel generator, a compact FE source you will meet in a later chapter. You do not need to build the generator now."
		"The point of this quest is simple. Do not void the diesel. Tank it, and your future power problem is already half solved."
	]
	quest.4C57010000020007.quest_subtitle: "The refinery's other half."
	quest.4C57010000020007.title: "Diesel Side Stream"
	quest.4C57010000020008.quest_desc: [
		"Space has no air. Yours travels in an &boxygen tank&r. Craft one from steel ingots and steel nuggets."
		"The tank is an ingredient twice over. One goes into the space suit chestplate, where it carries your breathing supply. Another goes into the water separator, the machine that actually produces oxygen."
		"Craft at least two now. Filling happens through the water separator chain from the machines quest, which splits water into oxygen and hydrogen. Empty tanks keep nobody alive."
	]
	quest.4C57010000020008.quest_subtitle: "Portable air for hostile skies."
	quest.4C57010000020008.title: "Oxygen Tank"
	quest.4C57010000020009.quest_desc: [
		"Start the space suit with the top half. The &bspace suit helmet&r takes tinted glass, white wool, steel, and a redstone lamp. The visor is what stands between your face and vacuum."
		"The &bspace suit chestplate&r takes copper, redstone, white wool, steel, and one of your oxygen tanks. The chestplate is the piece that holds your air supply, which is why the tank is baked into the recipe."
		"Craft both. A partial suit protects nothing off-world. The full set is mandatory before launch, and the legs and boots come next."
	]
	quest.4C57010000020009.quest_subtitle: "The half that keeps you breathing."
	quest.4C57010000020009.title: "Suit Up: Helmet and Chest"
	quest.4C5701000002000A.quest_desc: [
		"Finish the suit. The &bspace suit leggings&r and &bspace suit boots&r each take copper, white wool, and steel. Cheaper than the top half, and just as mandatory."
		"The suit only works as a full set. All four pieces must be worn any time you are off-world, or the environment kills you regardless of how much oxygen the chestplate carries."
		"With the seal complete, you have met one of the three launch requirements. Fuel and a built rocket are the others. The launch quest opens once all three are in hand."
	]
	quest.4C5701000002000A.quest_subtitle: "Complete the pressure seal."
	quest.4C5701000002000A.title: "Suit Up: Legs and Boots"
	quest.4C5701000002000B.quest_desc: [
		"The &bwater separator&r splits water with FE. Every 5 mb of water becomes 10 mb of hydrogen and 5 mb of oxygen. Oxygen is the product you need right now. Hydrogen comes along for free."
		"Bucket some &bhydrogen&r to complete this quest, then tank the rest. Hydrogen fuels later-tier Stellaris systems, so a stockpile started now costs nothing."
		"This is an optional stop. If your separator is already running for oxygen, the hydrogen is sitting there waiting for a bucket."
	]
	quest.4C5701000002000B.quest_subtitle: "The separator's other output."
	quest.4C5701000002000B.title: "Hydrogen Byproduct"
	quest.4C5701000002000C.quest_desc: [
		"Two pieces of kit make a landing official. The &btablet&r crafts from steel, a glass pane, and a heavy metal nugget. Open it to read data on planets, their hazards, and what they hold."
		"The &bflag&r crafts from steel and gray wool. Plant it at your landing site so the spot is yours on record and easy to find again."
		"Neither is required to fly. Both are cheap, and the tablet in particular is worth carrying before you commit fuel to a destination you know nothing about."
	]
	quest.4C5701000002000C.quest_subtitle: "Tablet and flag for the history books."
	quest.4C5701000002000C.title: "Mission Patch"
	quest.4C5701000002000F.quest_desc: [
		"Everything converges here. Stack the launch pad into its full 3x3 surface and place the &brocket&r on it. Right-click the rocket with fuel buckets until the tank reads full."
		"Put on all four space suit pieces. Then board the rocket and hold the launch key. The engine spools, the pad drops away, and you climb."
		"As you leave the atmosphere the planet selection screen opens. Pick &bEarth Orbit&r for this first flight. It is the nearest destination and the safest shakedown for your suit and fuel math."
		"You are now off-world. Mind your oxygen, and mind the drop. There is no ground under an orbit station except the one you build."
	]
	quest.4C5701000002000F.quest_subtitle: "First burn to Earth orbit."
	quest.4C5701000002000F.title: "Launch Window"
	quest.4C57010000020010.quest_desc: [
		"From orbit, board the rocket again and select the &bMoon&r on the planet screen. Descend and set down on the regolith."
		"The Moon has no oxygen. Keep the full suit sealed the entire time you are on the surface, and watch the chestplate's air supply. Running dry out here is fatal."
		"This landing is the doorway to the next chapter. The Moon's crust carries metals the overworld never had, and Strange Dimension Operations picks up right where your boots touch down. Plant the flag if you brought one."
	]
	quest.4C57010000020010.quest_subtitle: "First boots on the lunar regolith."
	quest.4C57010000020010.title: "Moonfall"
	quest.4C57010000020011.quest_desc: [
		"Walking a planet in a pressure suit is slow. Craft the &brover&r from iron, a Stellaris cable, a bucket, heavy metal, and redstone."
		"Place it on the surface and climb in. The rover runs on the same fuel as your rocket, so top it up before long trips and carry a spare fuel bucket in your inventory."
		"Use it to sweep the lunar surface for ore fields and future base sites. Distance stops costing oxygen time once you have wheels."
	]
	quest.4C57010000020011.quest_subtitle: "Wheels for the regolith."
	quest.4C57010000020011.title: "Rover Deployment"
	quest.4C580000EE000000.quest_desc: [
		"The Aether hides its bosses behind a ladder of dungeons: Bronze, then Silver, then Gold. The &bGold Dungeon&r is the top of that ladder and it holds the Sun Spirit. Reach it here."
		"Travel back into the Aether and search its islands for the Gold Dungeon's sealed entrance. Entering the dimension for this hunt completes the step. This is a light scouting node, so no items are required yet."
		"Treat the Gold Dungeon as the Sun Spirit's chamber. Once you are inside and staged, the fight in the next step is what actually matters."
	]
	quest.4C580000EE000000.quest_subtitle: "Locate the Aether Gold Dungeon."
	quest.4C580000EE000000.title: "Sun Altar Chamber"
	quest.4C580000EE010000.quest_desc: [
		"The &c&lSun Spirit&r is the apex of the Aether Gold Dungeon and a required Otherworldly boss. It burns too hot to strike while it blazes."
		"Use the fight's ice crystals to chill the Sun Spirit before your hits can land, then attack during the window while it is cold. Repeat until it falls."
		"The &bGold Dungeon Key&r is guaranteed on a real player kill. Keep it for the dungeon route; this quest completes from the kill and does not consume the key."
	]
	quest.4C580000EE010000.quest_subtitle: "Defeat the Aether Gold Dungeon boss."
	quest.4C580000EE010000.title: "The Sun Spirit"
	quest.4C580000EE020000.quest_desc: [
		"Above the Gold Dungeon sits the Deep Aether's &bBrass Dungeon&r, guarded by the &c&lEye of the Storm&r. This is a required Otherworldly boss and the terminal of this dungeon line."
		"Attack the storm's controller, not its body. The boss floats behind rotating segments, but only the eye at the center takes damage. Ignore the segments and drive everything into the controller."
		"Down it and claim the &bBrass Dungeon Key&r, guaranteed on your kill. This node feeds the Otherworldly chapter grant for the strange dimensions, so the whole Aether ladder counts toward the age only once the Eye is beaten."
	]
	quest.4C580000EE020000.quest_subtitle: "Defeat the Deep Aether Brass Dungeon boss."
	quest.4C580000EE020000.title: "Eye of the Storm"
	quest.4C58010000010001.quest_desc: ["Gather every &braw desh&r part on the list. Desh is the first metal this dimension wants processed."]
	quest.4C58010000010001.quest_subtitle: "First metal in this dimension."
	quest.4C58010000010001.title: "Raw Desh Ingot"
	quest.4C58010000010002.quest_desc: ["Gather every &btharsite&r part on the list. The ingot feeds higher-tier space recipes."]
	quest.4C58010000010002.quest_subtitle: "Feeds higher space recipes."
	quest.4C58010000010002.title: "Tharsite Ingot"
	quest.4C58010000010003.quest_desc: ["Gather every &bcorronium&r part on the list. Corronium is the tough alloy this chapter builds toward."]
	quest.4C58010000010003.quest_subtitle: "Tough alloy for this chapter."
	quest.4C58010000010003.title: "Corronium Ingot"
	quest.4C58010000010004.quest_desc: ["Gather every &bvacuumator&r part on the list. It handles fluids in vacuum recipes ahead."]
	quest.4C58010000010004.quest_subtitle: "Vacuum fluid handling."
	quest.4C58010000010004.title: "Vacuumator"
	quest.4C58010000010005.quest_desc: ["Keep a Desh Ingot in your inventory. Completing this quest seals the dimension's metal stage."]
	quest.4C58010000010005.quest_subtitle: "Seal the metal stage."
	quest.4C58010000010005.title: "Desh Ingot"
	quest.4C58010000020001.quest_desc: [
		"Fuel the rocket, board, and pick &bMars&r on the planet screen. Set down on the red plains."
		"Mars has no breathable air and the surface sits at -63C. The full space suit stays sealed the entire visit, same rules as the Moon."
		"The stone here is worth the trip. Mars stone carries tharsite ore, diamond, iron, and ice shards. Tharsite is the metal the next refining quest wants, so bring a good pickaxe and dig while you are down."
	]
	quest.4C58010000020001.quest_subtitle: "Set down on the red planet."
	quest.4C58010000020001.title: "Mars Landing"
	quest.4C58010000020002.quest_desc: [
		"Select &bVenus&r on the planet screen and descend. This is the most hostile rock on the route. The surface runs 462C and acid storms sweep the sky. Full suit and a charged oxygen supply are mandatory, no exceptions."
		"Venus pays for the risk. Its stone carries corronium ore, plus coal, gold, and diamond. Corronium is one half of the alloy chapter goal."
		"Mine raw corronium and get back to the rocket. Together with the solerium from Mercury, it feeds the corronium refining quest. Keep the visits short until you trust your gear."
	]
	quest.4C58010000020002.quest_subtitle: "Brave the hottest stop on the route."
	quest.4C58010000020002.title: "Venus Landing"
	quest.4C58010000020003.quest_desc: [
		"Pick &bMercury&r on the planet screen and land. Smallest world, shortest horizon, and the best mining stop of the three."
		"Mercury stone carries solerium, uranium, and iron. Note that solerium generates here, not on Venus, despite what the color scheme suggests. You need it for the corronium alloy line."
		"Dig raw solerium for the refining quest and mark the uranium veins while you are down. The next quest sends you back for them. Suit sealed at all times, as always."
	]
	quest.4C58010000020003.quest_subtitle: "Closest to the sun, richest in fissiles."
	quest.4C58010000020003.title: "Mercury Landing"
	quest.4C58010000020004.quest_desc: [
		"Return to the uranium veins you marked on Mercury and mine &braw uranium&r."
		"Smelt or blast the raw ore into &buranium ingots&r. A stack of raw ore processed now saves a second interplanetary trip later."
		"This is fuel, not decoration. Uranium ingots feed the Stellaris radioactive generator, a power source the Dyson chapter builds around. Bank the ingots and keep the vein location on record."
	]
	quest.4C58010000020004.quest_subtitle: "Fissile stock from the first rock."
	quest.4C58010000020004.title: "Mercury Uranium"
	quest.4C58010000020005.quest_desc: [
		"The space suit keeps you alive. The &bjet suit&r keeps you alive and moves you. Craft all four pieces: helmet, chestplate, leggings, and boots."
		"The jet suit replaces the basic suit as your off-world skin. It carries your life support the same way, and on top of that it accepts modules that add flight, endurance, and utility."
		"Modules install at the Upgrade Station, a machine covered in the Dyson chapter. You do not need to build it yet. Craft the suit now, wear it, and the next two quests fill its slots."
	]
	quest.4C58010000020005.quest_subtitle: "Trade the space suit for thrust."
	quest.4C58010000020005.title: "Jet Suit"
	quest.4C58010000020006.quest_desc: [
		"Jet suit upgrades come as modules. Craft a &bTier 1 base module&r first. Base modules are the foundation piece that opens module slots on the suit. Nothing else installs without them."
		"Then craft the &bfuel module&r. Fuel extends how long the suit's thrusters burn. Together with the base module they turn the suit from a short hop into a working shift."
		"Install everything at the Upgrade Station. Put the suit and the modules in, and the station writes the upgrade onto the gear. This is the entry tier. Heavier modules come next."
	]
	quest.4C58010000020006.quest_subtitle: "First slots filled."
	quest.4C58010000020006.title: "Basic Suit Modules"
	quest.4C58010000020007.quest_desc: [
		"Tier 2 finishes the suit. Craft the &bTier 2 base module&r to open the deeper slots, then fill them with three working modules."
		"The &bjet module&r powers true suit flight and changes how planets feel underfoot."
		"The &boil finder module&r builds the handheld oil finder into the suit, feeding the same fuel chain you built in Launch Window. The &bauto feeder&r eats from your inventory so hunger never interrupts a mining run."
		"Install the set at the Upgrade Station. This completes the gear lane. With the suit finished, the chapter capstone waits on your metallurgy."
	]
	quest.4C58010000020007.quest_subtitle: "Full planetary loadout."
	quest.4C58010000020007.title: "Advanced Suit Modules"
	quest.4C58010000020008.quest_desc: [
		"Every planet on the route has an orbit station layer registered above it. Mars Orbit, Venus Orbit, and Mercury Orbit are all selectable from the rocket's planet screen, just like the surface destinations."
		"Fly to all three. Orbit is a good place to stage fuel, park a return rocket, or build a platform clear of surface weather. Venus Orbit in particular puts you above the acid."
		"Two warnings. Gravity in orbit runs at 0.7, so you drift further than you expect. And there is no ground except what you place. Step off the platform and the fall is the entire atmosphere. Build rails before you build anything else."
	]
	quest.4C58010000020008.quest_subtitle: "Optional: park above all three worlds."
	quest.4C58010000020008.title: "Orbital Surveys"
	quest.4C59010000010001.quest_desc: ["Hold a &bRadioactive Generator&r. Cheap orbital power while heavier reactors come online."]
	quest.4C59010000010001.quest_subtitle: "Cheap orbital power."
	quest.4C59010000010001.title: "Radioactive Generator"
	quest.4C59010000010002.quest_desc: ["Gather every &bT4 tank&r part on the list. Bulk fluid storage keeps the space base fed."]
	quest.4C59010000010002.quest_subtitle: "Bulk fluid for the base."
	quest.4C59010000010002.title: "T4 Tank"
	quest.4C59010000010003.quest_desc: ["Gather every &bT3 cable&r part on the list. Higher throughput wiring for the orbital grid."]
	quest.4C59010000010003.quest_subtitle: "Higher throughput wiring."
	quest.4C59010000010003.title: "Cable T3"
	quest.4C59010000010004.quest_desc: ["Complete the set to open long-range comms."]
	quest.4C59010000010004.quest_subtitle: "Long-range comms frame."
	quest.4C59010000010004.title: "Antenna"
	quest.4C59010000010005.quest_desc: ["Gather every &bcoal generator&r part on the list. Cheap power while the big reactors spin up."]
	quest.4C59010000010005.quest_subtitle: "Backup power while scaling."
	quest.4C59010000010005.title: "Coal Generator"
	quest.4C59010000020001.quest_desc: [
		"Generator Galore's ladder tops out here. Build a &bNetherite Generator&r and a &bNetherstar Generator&r, the two highest base tiers. The netherite block burns netherite-class fuel and the netherstar block burns nether stars."
		"You do not craft these from scratch. Upgrade the tiers you built back in Nuclear Dawn: a &bDiamond to Netherite Upgrade&r converts your diamond generator, then a &bNetherite to Netherstar Upgrade&r lifts the netherite one to the final tier."
		"Raw output at this scale needs a buffer. Place a &bT2 Bank&r from Stellaris next to the pair and dump the generators into it, then draw from the bank. That keeps your grid stable while the rest of the megascale build comes online."
	]
	quest.4C59010000020001.quest_subtitle: "The top base generators, buffered."
	quest.4C59010000020001.title: "Netherite Furnaces"
	quest.4C59010000020002.quest_desc: [
		"One netherite generator is a furnace. Eight in one block is infrastructure. Craft the &bNetherite Generator 8x&r and the &bNetherstar Generator 8x&r, the compressed versions of the pair you just built."
		"Each 8x block carries eight fuel slots and eight times the output of its base version. Same fuels, same behavior, one machine footprint instead of eight. Keep them fed and cabled into your bank and the Dyson ledger starts to look plausible."
		"This is the middle rung. The 64x tier above it is the real target, and it is built up from blocks like these."
	]
	quest.4C59010000020002.quest_subtitle: "Same fuel, eight slots wide."
	quest.4C59010000020002.title: "Eightfold Output"
	quest.4C59010000020003.quest_desc: [
		"This is the megascale row. Build the full 64x set: &bDiamond Generator 64x&r, &bEmerald Generator 64x&r, &bEnder Generator 64x&r, &bNetherite Generator 64x&r, and &bNetherstar Generator 64x&r. Each one packs sixty-four base generators of its tier into a single block."
		"Work up through the compression tiers for each fuel line. The diamond, emerald, and ender lines date back to Nuclear Dawn, so dust off those old generators and start compressing. The netherite and netherstar lines come from the 8x pair you just finished."
		"Five blocks, five fuel economies, one wall of power. This row is a pillar of the Dyson Project capstone, so wire all five into your storage before you move on."
	]
	quest.4C59010000020003.quest_subtitle: "Every 64x generator in the ledger."
	quest.4C59010000020003.title: "The Sixty-Four Stack"
	quest.4C59010000020004.quest_desc: [
		"Modern Industrialization's storage line ends at the &bSuperconductor Storage Unit&r. Craft one. It is the top energy buffer the mod offers, built for the kind of throughput the Dyson lanes generate."
		"The materials come out of your fusion-era production from Beyond the Veil. The superconductor coils and quantum hulls you assembled there feed directly into this storage lane, so if a component is missing, that chapter's quantum line is where to make it."
		"Park the unit at the heart of your grid. The transformers, hatches, and casings ahead all assume a superconductor-tier buffer behind them."
	]
	quest.4C59010000020004.quest_subtitle: "MI's endgame energy buffer."
	quest.4C59010000020004.title: "Superconductor Storage"
	quest.4C59010000020005.quest_desc: [
		"Superconductor-tier power does not plug straight into your older EV machinery. Craft the &bSuperconductor EV Transformer&r and the &bEV Superconductor Transformer&r to convert voltage in both directions."
		"One steps superconductor current down to EV for the machines you already run. The other steps EV up to superconductor so your existing generation can charge the new storage unit. Place each with the correct face toward the higher-voltage side."
		"With both transformers in the network, the old grid and the new one become a single system. That is the point of this lane: nothing you built before gets stranded."
	]
	quest.4C59010000020005.quest_subtitle: "EV and superconductor, both directions."
	quest.4C59010000020005.title: "Stepping the Current"
	quest.4C59010000020006.quest_desc: [
		"MI multiblocks take power through energy hatches, and the biggest machines need the biggest hatches. Craft a &bSuperconductor Energy Input Hatch&r and a &bSuperconductor Energy Output Hatch&r."
		"The input hatch replaces a casing block in a multiblock shell and feeds it superconductor-tier current. The output hatch does the reverse, letting a generating multiblock push at full tier into your cables and storage."
		"Swap these into your heaviest machines. Anything plasma-facing or quantum-tier upstream will expect this class of I/O."
	]
	quest.4C59010000020006.quest_subtitle: "Superconductor I/O for multiblocks."
	quest.4C59010000020006.title: "Hatches for the Big Rigs"
	quest.4C59010000020007.quest_desc: [
		"Extended Industrialization's tesla line ends here. Craft the &bSuperconductor Tesla Winding&r and the &bSuperconductor Tesla Receiver Hatch&r, the top tier of wireless power."
		"You built the tower itself in earlier ages: the coil, the tower structure, and the hv, mv, and ev windings and hatches. This winding upgrades the tower to beam superconductor-voltage power, and the receiver hatch mounts on a multiblock to catch it."
		"No cable run, no transformer chain, just power through the air at the pack's highest tier. This is the last rung of the wireless lane and it feeds straight into the chapter capstone."
	]
	quest.4C59010000020007.quest_subtitle: "Superconductor power without cables."
	quest.4C59010000020007.title: "Wireless at Last"
	quest.4C59010000020008.quest_desc: [
		"Fusion-tier machines run hot enough that ordinary casings fail. Craft the &bPlasma Handling Iridium Machine Casing&r, the iridium-based shell block used wherever a multiblock faces plasma directly."
		"Iridium is the cost and the point. It is the one material in MI's ladder rated for plasma contact, so every plasma-facing multiblock wall wants this casing in its shell."
		"Stockpile more than one. The quantum casing tier above this builds on the same line, and the big machines eat casings by the dozen."
	]
	quest.4C59010000020008.quest_subtitle: "Iridium that shrugs off plasma."
	quest.4C59010000020008.title: "Plasma-Rated Casing"
	quest.4C59010000020009.quest_desc: [
		"Above plasma handling sits the &bQuantum Machine Casing&r, the structural tier behind MI's quantum machines. Craft one."
		"It builds on the plasma-rated iridium work you just finished, so keep that production line running. Where plasma casing lines the walls of fusion machinery, quantum casing frames the machines that come after it."
		"This block is the gateway to quantum-tier storage. The tanks and barrels in the next quest are built around it."
	]
	quest.4C59010000020009.quest_subtitle: "The shell above plasma-rated."
	quest.4C59010000020009.title: "Quantum Casing"
	quest.4C5901000002000A.quest_desc: [
		"Bulk storage tops out at the quantum tier. Craft a &bQuantum Tank&r and a &bQuantum Barrel&r, MI's endgame answer to fluids and items respectively."
		"Both are built around the quantum machine casing from the previous quest. The tank holds fluid volumes far beyond any steel tier and the barrel does the same for items, so one of each covers most of a base's overflow problems."
		"This closes the MI storage lane. With superconductor power, quantum casings, and quantum storage in place, this line is ready to feed the chapter capstone."
	]
	quest.4C5901000002000A.quest_subtitle: "Tanks and barrels, absurd capacity."
	quest.4C5901000002000A.title: "Quantum Storage"
	quest.4C5901000002000B.quest_desc: [
		"Nuclear Science makes antimatter the hard way: the particle injector and accelerator chain you built back in the Atomic age. Run it, collect the output, and fill the cell tiers: a &bSmall Antimatter Cell&r, a &bLarge Antimatter Cell&r, and a &bVery Large Antimatter Cell&r."
		"The accelerator does the work, you supply the patience. Antimatter accumulates slowly, so set the chain running early and let it produce while you build the rest of the Dyson lanes."
		"Handle the cells like what they are. Every warhead in the ordnance lane ahead is built from these, and the large tiers take real production time to fill."
	]
	quest.4C5901000002000B.quest_subtitle: "Antimatter cells from the accelerator."
	quest.4C5901000002000B.title: "Bottled Annihilation"
	quest.4C5901000002000C.quest_desc: [
		"Ballistix scales up from fission to annihilation. Craft the &bAntimatter Explosive&r by surrounding a &bNuclear Explosive&r with eight large antimatter cells."
		"The nuclear core is the same warhead you built back in Threshold of War, so pull one from that production line or make another. The eight large cells come from your accelerator chain, which is why the previous quest told you to start it early."
		"The result is ordnance in a different class from anything fission could do. And it is still not the top of the lane."
	]
	quest.4C5901000002000C.quest_subtitle: "Large cells around a nuclear core."
	quest.4C5901000002000C.title: "The Antimatter Warhead"
	quest.4C5901000002000D.quest_desc: [
		"The top of the Ballistix ledger is a two-step climb. First craft the &bLarge Antimatter Explosive&r by surrounding an antimatter warhead with four very large antimatter cells."
		"Then go past antimatter entirely. Produce a &bDark Matter Cell&r from Nuclear Science and use it to build the &bDark Matter Explosive&r, the final ordnance tier in the pack."
		"Three warheads, each built from the one before it, each fed by the accelerator chain. This lane ends here and feeds the chapter capstone. What you detonate, and where, is your own business."
	]
	quest.4C5901000002000D.quest_subtitle: "Large antimatter and dark matter."
	quest.4C5901000002000D.title: "Beyond the Blast"
	quest.4C59010000030001.quest_desc: [
		"The gravichestplate is MI's flight chestpiece, built on superconductor parts from your fusion-age line. It grants creative-style flight while charged."
		"Its energy buffer is huge but not infinite. Wire a charging station into your base loop and top it up between trips."
		"This replaces the diesel jetpack for good. Fuel stops mattering; only your grid does."
	]
	quest.4C59010000030001.quest_subtitle: "Superconductor flight."
	quest.4C59010000030001.title: "Gravichestplate"
	quest.4C59010000030002.quest_desc: [
		"MI's endgame loop turns raw power into matter. Compress a singularity, then run it in the electrolyzer line to draw UU matter."
		"Feed UU matter into the replicator you built earlier. Select a target item and the machine prints it at a steep energy cost."
		"This closes MI's tree: with enough fusion power, anything the replicator knows becomes printable."
	]
	quest.4C59010000030002.quest_subtitle: "Singularity, UU matter, replicator."
	quest.4C59010000030002.title: "Matter From Energy"
	quest.4C59010000030003.quest_desc: [
		"The nano gravichestplate merges nano armor with gravichestplate flight. The nano quantum chestplate and nyano quantum helmet push protection to the ceiling of the EI tree."
		"All three build on the nano set you made in the atomic age plus superconductor and quantum parts from this one."
		"Charged, this is the best armor MI's family offers. Only draconic gear goes further."
	]
	quest.4C59010000030003.quest_subtitle: "The gravi and quantum upgrades."
	quest.4C59010000030003.title: "Quantum Nano Gear"
	quest.4C59010000030004.quest_desc: [
		"Industrialization Overdrive's terminal places entire MI multiblocks from your inventory in one click. Point it at a valid controller spot and it assembles the whole frame."
		"It pays for itself the first time you rebuild a fusion reactor or a distillation tower. Keep the parts in your pack and let the terminal do the bricklaying."
	]
	quest.4C59010000030004.quest_subtitle: "Build big structures in one click."
	quest.4C59010000030004.title: "Multiblock Terminal"
	quest.4C59011000000120.quest_desc: ["Craft the Oritech Exo Helmet, Exo Chestplate, Exo Leggings, and Exo Boots. Wear the complete set before relying on the suit as field gear."]
	quest.4C59011000000120.quest_subtitle: "Wear the complete Exo Suit."
	quest.4C59011000000120.title: "Oritech Exo Suit"
	quest.4D41487500000001.quest_desc: [
		"Optional. Craft the Mahou Tsukai guidebook, the Knowledge Compendium, and read it before you cast anything."
		"Mahou Tsukai is a self-contained magic-circle system that never touches the main progression. It runs on projected circles called mahoujin, and the compendium explains the spells, the components, and the order to unlock them in."
		"This chapter is pure optional flavor. Start here to learn the system, then work down the tab at your own pace."
	]
	quest.4D41487500000001.quest_subtitle: "Read before you cast"
	quest.4D41487500000001.title: "Knowledge Compendium"
	quest.4D41487500000002.quest_desc: [
		"Optional. Craft the Attuner. It charges ordinary gems into attuned gems that store the mana your spells draw on."
		"Feed diamonds or emeralds into the attuner to make attuned diamonds and attuned emeralds. These act as your mana reserve, and casting spells drains them, so keep a supply charged before you go out to use magic."
		"Attuning is the fuel step of Mahou Tsukai. With charged gems ready, the next block projects the circle you cast from."
	]
	quest.4D41487500000002.quest_subtitle: "Charge attuning gems"
	quest.4D41487500000002.title: "Attuner"
	quest.4D41487500000003.quest_desc: [
		"Optional. Craft the Mahoujin Projector, the core block that projects a magic circle into the world."
		"Mahou Tsukai casting happens on projected circles rather than through wands alone. The projector lays down the mahoujin you need for a given spell, and you interact with that circle to trigger the effect."
		"This is the mechanical heart of the system. Once you can project a circle, you need a focus to channel spells through it."
	]
	quest.4D41487500000003.quest_subtitle: "Project the magic circle"
	quest.4D41487500000003.title: "Mahoujin Projector"
	quest.4D41487500000004.quest_desc: [
		"Optional. Craft the Mystic Code, the held focus that channels spells from a projected circle."
		"The Mystic Code is what you keep in hand to cast. It ties your attuned mana and the projected mahoujin together into an actual spell, and it is the item you will use for most Mahou Tsukai magic."
		"From here the tab branches. One leaf covers spell scrolls for familiars and utility, and the other upgrades your focus into the Mystic Staff."
	]
	quest.4D41487500000004.quest_subtitle: "Your casting focus"
	quest.4D41487500000004.title: "Mystic Code"
	quest.4D41487500000005.quest_desc: [
		"Optional. Obtain one of the Mahou Tsukai spell scrolls. This quest accepts the familiar's garden scroll, the gandr scroll, or the fay sight scroll."
		"Scrolls hold specific spells you can learn and cast. The familiar's garden scroll summons and manages familiars, while the utility scrolls add ranged and vision effects to your kit."
		"Pick the scrolls that match how you want to play. They are side content off the Mystic Code, not steps toward anything required."
	]
	quest.4D41487500000005.quest_subtitle: "Familiars and utility"
	quest.4D41487500000005.title: "Spell Scrolls"
	quest.4D41487500000006.quest_desc: [
		"Optional. Craft the Mystic Staff, the upgraded casting focus that sits at the top of this tab."
		"The staff is a stronger channel than the Mystic Code, giving you more reach and power over the circles you project. It is the finished form of the focus for anyone who commits to this magic."
		"This is the peak of the optional Mahou Tsukai line. Reach it if the system clicks for you, otherwise the earlier focus is enough to cast with."
	]
	quest.4D41487500000006.quest_subtitle: "The finished focus"
	quest.4D41487500000006.title: "Mystic Staff"
	quest.4D4D011000000001.quest_desc: ["Build the &6PneumaticCraft&r &bProgrammer&r. Its puzzle-piece interface writes the routines your drones will run: dig here, fetch that, patrol there. Every drone job in this wing starts as a program on this bench."]
	quest.4D4D011000000001.quest_subtitle: "Logic you can hold."
	quest.4D4D011000000001.title: "Programmer"
	quest.4D4D011000000002.quest_desc: ["Set up a &bSecurity Station&r to claim and guard the machines around it. Intruders have to hack it node by node while it fights back. Your pressure network now has an immune system."]
	quest.4D4D011000000002.quest_subtitle: "The firewall is literal."
	quest.4D4D011000000002.title: "Security Station"
	quest.4D4D011000000003.quest_desc: ["Bridge the two halves of this chapter with the &bME Pressure Interface&r from &6Applied Pneumatics&r. It exposes your pressure network to the ME grid, so storage and autocrafting can finally see what the compressors are doing."]
	quest.4D4D011000000003.quest_subtitle: "Air meets the grid."
	quest.4D4D011000000003.title: "ME Pressure Interface"
	quest.4D4E011000000001.quest_desc: ["Place a &bMolecular Assembler&r on your ME network. Handed a pattern, it performs the craft on demand, and a wall of them becomes the workshop your storage system orders around. Autocrafting starts here."]
	quest.4D4E011000000001.quest_subtitle: "The grid learns to craft."
	quest.4D4E011000000001.title: "Molecular Assembler"
	quest.4D4E011000000002.quest_desc: ["Mount a &bWireless Access Point&r and craft the receiver and boosters that serve it. Boosters stretch the radius; the receiver is the part every handheld terminal is built around. Your grid now covers the base instead of the one wall it hangs on."]
	quest.4D4E011000000002.quest_subtitle: "Cut the cable."
	quest.4D4E011000000002.title: "Wireless Access"
	quest.4D4E011000000003.quest_desc: ["Add an &6Advanced AE&r &bReaction Chamber&r. It runs its reaction recipes as ordinary network jobs, the first machine here that makes the grid feel like a refinery instead of a warehouse."]
	quest.4D4E011000000003.quest_subtitle: "Chemistry for the network."
	quest.4D4E011000000003.title: "Reaction Chamber"
	quest.4D4E011000000005.quest_desc: ["Slot an &bexpanded crafting unit&r into your crafting CPU. &6ExpandedAE&r parts raise what a single multiblock can plan and hold; the accelerator quests that follow raise how fast it crafts."]
	quest.4D4E011000000005.quest_subtitle: "A bigger brain for the CPU."
	quest.4D4E011000000005.title: "Expanded Crafting Unit"
	quest.4D4E011000000006.quest_desc: ["Run &6Refined Storage&r beside AE2. Its &bAutocrafter&r and manager handle RS-pattern jobs, and Mekanism storage blocks put chemicals on disks AE2 cannot carry here. Completing this quest signs off the infinite-grid proof lane for the astral threshold."]
	quest.4D4E011000000006.quest_subtitle: "Grid lane capstone."
	quest.4D4E011000000006.title: "Autocrafter"
	quest.4D4E011000000007.quest_desc: ["Upgrade your &6Refined Storage&r autocrafting with an &bIron Crafter&r from &6ExtraStorage&r. More pattern slots, faster cycles, same grid. The tier ladder runs upward from here."]
	quest.4D4E011000000007.quest_subtitle: "RS picks up the pace."
	quest.4D4E011000000007.title: "Iron Crafter"
	quest.4D4E011000000008.quest_desc: ["Place an &bElite Autocrafter&r from &6CableTiers&r. It packs more parallel patterns than the stock RS crafter at a fraction of the footprint, and the ultra tier above it is unapologetic overkill."]
	quest.4D4E011000000008.quest_subtitle: "CableTiers steps in."
	quest.4D4E011000000008.title: "Elite Autocrafter"
	quest.4D4E011000000009.quest_desc: ["Frame an &6ExtendedAE&r &bCrystal Assembler&r in its machine frames. The multiblock packs a whole wall of molecular assemblers into one structure, and it grows by adding frames. Pattern-heavy networks breathe easier the day it goes up."]
	quest.4D4E011000000009.quest_subtitle: "ExtendedAE assembler multiblock."
	quest.4D4E011000000009.title: "Crystal Assembler"
	quest.4D4E01100000000A.quest_desc: ["Begin the &6MEGA&r tier with the &bMEGA crafting unit&r. Its CPU parts dwarf even the expanded line, sized for the storage cells this wing builds."]
	quest.4D4E01100000000A.quest_subtitle: "MEGA Cells crafting tier."
	quest.4D4E01100000000A.title: "MEGA Crafting Unit"
	quest.4D4E01100000000B.quest_desc: ["Press &baccumulation processors&r and print your first MEGA cell. Any of them satisfies this quest (item, fluid, or chemical) from 1M up to 64M; the 256M tier waits for the atomic age. Pick the family your grid is drowning in."]
	quest.4D4E01100000000B.quest_subtitle: "Live MEGA storage cell."
	quest.4D4E01100000000B.title: "MEGA Storage Cells"
	quest.4D4E011000000100.quest_desc: ["Install a &bProgrammable Controller&r. It executes drone programs from a fixed block, with an inventory and pressure line of its own, which makes it the steady workhorse for jobs a flying drone would only complicate."]
	quest.4D4E011000000100.quest_subtitle: "A drone without wings."
	quest.4D4E011000000100.title: "Programmable Controller"
	quest.4D4E011000000101.quest_desc: ["Add a &bDrone Interface&r beside your computer setups. It lets external automation read and steer a drone mid-program, so the swarm can take orders from the rest of your base instead of flying blind."]
	quest.4D4E011000000101.quest_subtitle: "Talk to the swarm."
	quest.4D4E011000000101.title: "Drone Interface"
	quest.4D4E011000000102.quest_desc: ["Raise a &bUniversal Sensor&r and feed it upgrade cards. It watches for whatever you tune it to, players, weather, item counts, and turns observations into redstone."]
	quest.4D4E011000000102.quest_subtitle: "The base grows nerves."
	quest.4D4E011000000102.title: "Universal Sensor"
	quest.4D4E011000000103.quest_desc: ["Bolt down a &bSentry Turret&r and load it with minigun ammo. It tracks and fires on whatever its gauge says is hostile, holding the perimeter while your drones work. Set the safe list before you stand in front of it."]
	quest.4D4E011000000103.quest_subtitle: "Minigun on a tripod."
	quest.4D4E011000000103.title: "Sentry Turret"
	quest.4D4E011000000104.quest_desc: ["Craft a &bSmart Chest&r. It filters per-slot, pushes and pulls on its own, and void-overflows when you tell it to. As buffer storage between machines it replaces a whole rack of hoppers."]
	quest.4D4E011000000104.quest_subtitle: "Storage with opinions."
	quest.4D4E011000000104.title: "Smart Chest"
	quest.4D4E011000000105.quest_desc: ["Add the &bME Temperature Interface&r next. Heat is half of PneumaticCraft's chemistry, and once the grid can read it your autocrafting can wait for the right temperature instead of guessing."]
	quest.4D4E011000000105.quest_subtitle: "The grid reads the thermometer."
	quest.4D4E011000000105.title: "ME Temperature Interface"
	quest.4D4E011000000106.quest_desc: ["Set up the &bAmadron process stations&r, standard and extended. They let the ME grid fill Amadron sky-trade orders automatically, turning the drone courier service into one more crafting backend."]
	quest.4D4E011000000106.quest_subtitle: "Amadron orders through ME."
	quest.4D4E011000000106.title: "Amadron Process Stations"
	quest.4D4E011000000107.quest_desc: ["Raise the &6Immersive Engineering&r &bRadio Tower&r. The mast carries redstone signals across kilometers to its twin, which is how a far-flung mining site reports back to the room where your grid lives."]
	quest.4D4E011000000107.quest_subtitle: "Long-range signal mast."
	quest.4D4E011000000107.title: "Radio Tower"
	quest.4D4E011000000108.quest_desc: ["Craft a &bPattern Provider&r and its cable-mounted form. Providers hold your encoded patterns and push ingredients into assemblers or any machine you face them against. They are the dispatch desks of the autocrafting floor."]
	quest.4D4E011000000108.quest_subtitle: "Recipes, delivered."
	quest.4D4E011000000108.title: "Pattern Providers"
	quest.4D4E011000000109.quest_desc: ["Link a &bWireless Terminal&r to the access point. The whole ME inventory rides in your hotbar anywhere inside coverage. Walking back to a screen stops being a thing you do."]
	quest.4D4E011000000109.quest_subtitle: "Storage in your pocket."
	quest.4D4E011000000109.title: "Wireless Terminal"
	quest.4D4E01100000010A.quest_desc: ["Upgrade to the &bWireless Crafting Terminal&r and the crafting grid comes along. Pull, craft, push, all from the far end of the mine."]
	quest.4D4E01100000010A.quest_subtitle: "A bench in your pocket too."
	quest.4D4E01100000010A.title: "Wireless Crafting Terminal"
	quest.4D4E01100000010B.quest_desc: ["Combine your handhelds into the &bWireless Universal Terminal&r. It folds the crafting, pattern, and storage screens into a single device, and the quantum upgrades it accepts later remove the range limit entirely."]
	quest.4D4E01100000010B.quest_subtitle: "Combined wireless terminal."
	quest.4D4E01100000010B.title: "Universal Terminal"
	quest.4D4E01100000010C.quest_desc: ["Add the wireless &bpattern access&r and &bpattern encoding&r terminals. Reading and rewriting your pattern library from the field means the autocrafting floor never waits on your walk home."]
	quest.4D4E01100000010C.quest_subtitle: "Wireless pattern access."
	quest.4D4E01100000010C.title: "Pattern Terminals"
	quest.4D4E01100000010D.quest_desc: ["Fit an &bexpanded IO port&r to move cell contents at a rate the stock port cannot match. When you start rebalancing megabyte cells, the difference is measured in coffee breaks."]
	quest.4D4E01100000010D.quest_subtitle: "Cells in, cells out, faster."
	quest.4D4E01100000010D.title: "Expanded IO Port"
	quest.4D4E01100000010E.quest_desc: ["Swap busy dispatch points to the &bexpanded pattern provider&r. It holds a deeper pattern library in one block, which keeps the assembler wall compact as your recipe count climbs into the hundreds."]
	quest.4D4E01100000010E.quest_subtitle: "More patterns per face."
	quest.4D4E01100000010E.title: "Expanded Pattern Provider"
	quest.4D4E01100000010F.quest_desc: ["Encode at the &bexpanded encoding terminal&r when plain encoding starts to chafe. Quality-of-life for the person who writes a hundred patterns a session. By now, that's you."]
	quest.4D4E01100000010F.quest_subtitle: "Expanded pattern encoding."
	quest.4D4E01100000010F.title: "Expanded Encoding Terminal"
	quest.4D4E011000000110.quest_desc: ["Build any low-band &bcrafting accelerator&r, two-thread through sixteen-thread. Each one slotted into a CPU lets it run that many more crafts in parallel. The ladder above this quest only gets steeper."]
	quest.4D4E011000000110.quest_subtitle: "Co-processors, first rung."
	quest.4D4E011000000110.title: "Accelerators I"
	quest.4D4E011000000111.quest_desc: ["Climb to the mid-band &baccelerators&r, thirty-two through two hundred fifty-six threads. One block now does the work of a whole early-game accelerator wall."]
	quest.4D4E011000000111.quest_subtitle: "Expanded accelerator tier."
	quest.4D4E011000000111.title: "Accelerators II"
	quest.4D4E011000000112.quest_desc: ["Press into the kilothread band, five hundred twelve through 8k. The material bill turns serious here, and so does the CPU that carries one."]
	quest.4D4E011000000112.quest_subtitle: "Higher accelerator tier."
	quest.4D4E011000000112.title: "Accelerators III"
	quest.4D4E011000000113.quest_desc: ["Top out the ladder anywhere from 16k to the &bone-megathread accelerator&r. Nothing this age crafts actually needs it. Build one anyway and the crafting monitor becomes a spectator sport."]
	quest.4D4E011000000113.quest_subtitle: "High-end accelerator tier."
	quest.4D4E011000000113.title: "Accelerators IV"
	quest.4D4E011000000114.quest_desc: ["Step up to the &bGold Crafter&r for another jump in speed and slots. The recipe cost stays gentle; the throughput does not."]
	quest.4D4E011000000114.quest_subtitle: "Refined Storage crafter upgrade."
	quest.4D4E011000000114.title: "Gold Crafter"
	quest.4D4E011000000115.quest_desc: ["Finish the crafter ladder with the &bDiamond Crafter&r. One block now clears pattern queues that used to need a bank of machines."]
	quest.4D4E011000000115.quest_subtitle: "Refined Storage crafter cap."
	quest.4D4E011000000115.title: "Diamond Crafter"
	quest.4D4E011000000116.quest_desc: ["Craft the &b64-bucket chemical storage&r block and disk. They teach Refined Storage to hold &6Mekanism&r gases the way it holds items, which the circuits chapter's gas lines will lean on hard."]
	quest.4D4E011000000116.quest_subtitle: "Gases join the grid."
	quest.4D4E011000000116.title: "Chemical Storage 64b"
	quest.4D4E011000000117.quest_desc: ["Scale the chemical line to &b256 buckets&r, part, block, and disk."]
	quest.4D4E011000000117.quest_subtitle: "256b chemical storage set."
	quest.4D4E011000000117.title: "Chemical Storage 256b"
	quest.4D4E011000000118.quest_desc: ["Cap the ladder with the &b1024-bucket&r part and disk."]
	quest.4D4E011000000118.quest_subtitle: "1024b part and disk."
	quest.4D4E011000000118.title: "Chemical Storage 1024b"
	quest.4D4E011000000119.quest_desc: ["Build the &bUltra Autocrafter&r. One block, an absurd pattern count, and cycle times that make the iron crafter look ornamental. The grid's last word in dedicated crafting."]
	quest.4D4E011000000119.quest_subtitle: "High-capacity autocrafter."
	quest.4D4E011000000119.title: "Ultra Autocrafter"
	quest.4D4E01100000011A.quest_desc: ["Assemble the &bultra&r importer, exporter, constructor, and destructor. They are the stock RS cable parts with the throttle removed, draining or flooding whole inventories per tick. Use them where the elite parts choke."]
	quest.4D4E01100000011A.quest_subtitle: "Movers without a speed limit."
	quest.4D4E01100000011A.title: "Ultra Cable Kit"
	quest.4D4E01100000011B.quest_desc: ["Add the &bultra interface&r and &bultra disk interface&r. The first keeps huge stock levels pinned in a single block; the second moves entire disks of items in and out of the network at once."]
	quest.4D4E01100000011B.quest_subtitle: "Bulk Cable Tiers interfaces."
	quest.4D4E01100000011B.title: "Ultra Interfaces"
	quest.4D4E01100000011C.quest_desc: ["Craft &bME connectors&r and relays for &6Immersive Engineering&r wiring. They let channels ride the same pylons as your power lines, so the grid reaches outbuildings without a trench of fluix cable."]
	quest.4D4E01100000011C.quest_subtitle: "ME channel wire connectors."
	quest.4D4E01100000011C.title: "ME Wire Connectors"
	quest.4D4E01100000011D.quest_desc: ["Spin up &bME wire coils&r, standard and dense. Strung between connectors they carry eight or thirty-two channels per line, which turns cross-base networking into a wiring job instead of a tunneling job."]
	quest.4D4E01100000011D.quest_subtitle: "ME channel wire spans."
	quest.4D4E01100000011D.title: "ME Wire Coils"
	quest.4D4E01100000011E.quest_desc: ["Wire a &bcrafting interface&r and &bcrafting writer&r from &6Integrated Crafting&r into your logic cables. They run recipe jobs through Integrated Dynamics networks, useful where you want crafting decisions made by logic you wrote yourself."]
	quest.4D4E01100000011E.quest_subtitle: "Logic-driven crafting parts."
	quest.4D4E01100000011E.title: "Integrated Crafting"
	quest.4D4E01100000011F.quest_desc: ["Run &6Modern Dynamics&r &bMV&r and &bHV cables&r through the server room. They carry the heavier current your stacked grid hardware draws, in the same slim profile as the item pipes beside them."]
	quest.4D4E01100000011F.quest_subtitle: "Higher-tier MD power cable."
	quest.4D4E01100000011F.title: "MV and HV Cables"
	quest.4D4E011000000120.quest_desc: ["Add the &bMEGA pattern provider&r. It is the pattern provider rebuilt at MEGA scale, with room for the pattern libraries a megabyte-cell network accumulates."]
	quest.4D4E011000000120.quest_subtitle: "MEGA-scale pattern delivery."
	quest.4D4E011000000120.title: "MEGA Pattern Provider"
	quest.4D4E011000000121.quest_desc: ["Mount a &bcell dock&r on the network. It exposes a single cell as live storage, so you can hot-swap megabyte cells like cartridges instead of burying them in a drive."]
	quest.4D4E011000000121.quest_subtitle: "Direct network cell access."
	quest.4D4E011000000121.title: "Cell Dock"
	quest.4D4E011000000122.quest_desc: ["Fabricate a &b1M cell component&r. One megabyte of storage in your palm, and the seed of every cell tier this wing builds."]
	quest.4D4E011000000122.quest_subtitle: "MEGA component ladder start."
	quest.4D4E011000000122.title: "1M Cell Component"
	quest.4D4E011000000123.quest_desc: ["Compress four 1M components worth of fabrication into a &b4M cell component&r. The ladder is honest: each rung costs about four of the last."]
	quest.4D4E011000000123.quest_subtitle: "Second MEGA component tier."
	quest.4D4E011000000123.title: "4M Cell Component"
	quest.4D4E011000000124.quest_desc: ["Push on to the &b16M component&r. At this density a single cell swallows mob farms whole, and your fabrication line is officially an industry."]
	quest.4D4E011000000124.quest_subtitle: "Denser MEGA component."
	quest.4D4E011000000124.title: "16M Cell Component"
	quest.4D4E011000000125.quest_desc: ["Finish at the &b64M cell component&r, the largest this age permits. The 256M tier exists, and the atomic age holds the keys to it."]
	quest.4D4E011000000125.quest_subtitle: "Gilded MEGA component cap."
	quest.4D4E011000000125.title: "64M Cell Component"
	quest.4D4E011000000126.quest_desc: ["Craft the &bMEGA cell housings&r for items, fluids, and chemicals. Slot a component into a housing and it becomes a finished cell; keep spares so a new component never waits on its shell."]
	quest.4D4E011000000126.quest_subtitle: "MEGA cell housings."
	quest.4D4E011000000126.title: "MEGA Cell Housings"
	quest.4D4E011000000127.quest_desc: ["Assemble the &bbulk item cell&r and its component. It stores exactly one item type in effectively unlimited depth. Partition it to cobble or skeleton drops and that resource stops having a meaningful count."]
	quest.4D4E011000000127.quest_subtitle: "Single-item bulk storage."
	quest.4D4E011000000127.title: "Bulk Item Cell"
	quest.4D4E011000000128.quest_desc: ["Slot a &bMEGA crafting accelerator&r into the MEGA CPU frame. It is the co-processor matched to this tier's crafting units, for the queues your megabyte cells make possible."]
	quest.4D4E011000000128.quest_subtitle: "MEGA crafting speed block."
	quest.4D4E011000000128.title: "MEGA Crafting Accelerator"
	quest.4D4E011000000129.quest_desc: ["Place a &bMEGA interface&r where you keep working stock. It holds far deeper reserves pinned in one block than the standard interface, which matters once your machines eat by the thousand."]
	quest.4D4E011000000129.quest_subtitle: "MEGA stock interface."
	quest.4D4E011000000129.title: "MEGA Interface"
	quest.4D4E01100000012A.quest_desc: ["Craft a &bMEGA energy cell&r. It buffers a colossal charge for the ME network, riding out generator hiccups that would brown-out a dense cell wall mid-craft."]
	quest.4D4E01100000012A.quest_subtitle: "ME network energy buffer."
	quest.4D4E01100000012A.title: "MEGA Energy Cell"
	quest.4D4E01100000012B.quest_desc: ["Hang a &bMEGA crafting monitor&r on the CPU wall. It displays the live job the multiblock is chewing through, which is half diagnostics and half the best screensaver you own."]
	quest.4D4E01100000012B.quest_subtitle: "MEGA crafting job display."
	quest.4D4E01100000012B.title: "MEGA Crafting Monitor"
	quest.4D4E01100000012C.quest_desc: ["Build &b1M crafting storage&r for the MEGA CPU. Crafting storage is the multiblock's scratch space, and at MEGA scale the scratch space starts in megabytes."]
	quest.4D4E01100000012C.quest_subtitle: "MEGA CPU storage."
	quest.4D4E01100000012C.title: "1M Crafting Storage"
	quest.4D4E01100000012D.quest_desc: ["Quadruple the CPU's working memory with &b4M crafting storage&r. Bigger scratch space means bigger single jobs without splitting the queue."]
	quest.4D4E01100000012D.quest_subtitle: "Larger MEGA CPU storage."
	quest.4D4E01100000012D.title: "4M Crafting Storage"
	quest.4D4E01100000012E.quest_desc: ["Step the CPU to &b16M crafting storage&r. At this point the limiting factor on a craft is your patience and your ingredient stock, not the machine."]
	quest.4D4E01100000012E.quest_subtitle: "Expanded MEGA job capacity."
	quest.4D4E01100000012E.title: "16M Crafting Storage"
	quest.4D4E01100000012F.quest_desc: ["Reach &b64M crafting storage&r. One block of CPU scratch space that would have held your entire first network several times over."]
	quest.4D4E01100000012F.quest_subtitle: "High-tier MEGA crafting storage."
	quest.4D4E01100000012F.title: "64M Crafting Storage"
	quest.4D4E011000000130.quest_desc: ["Cap the wing with &b256M crafting storage&r, the largest crafting buffer the grid knows. The matching 256M storage cells stay sealed until the atomic age."]
	quest.4D4E011000000130.quest_subtitle: "MEGA crafting storage cap."
	quest.4D4E011000000130.title: "256M Crafting Storage"
	quest.4D4E0120002400A1.quest_desc: [
		"Assemble the Supercharged Particle System, Mekanism's antimatter multiblock. This one node bundles the casing, ports, and supercharged coil you need to build it."
		"The SPS is a sphere of casing wrapped around an input and output core, with supercharged coils driving energy into it. It is one of the most demanding structures Mekanism offers, sitting at the top of the atomic-tier chain reaction cluster."
		"Follow Mekanism's guide for the exact shell dimensions and coil count. Once the structure is complete and powered, it can begin condensing antimatter."
	]
	quest.4D4E0120002400A1.quest_subtitle: "Build the SPS multiblock."
	quest.4D4E0120002400A1.title: "Supercharged Particle System"
	quest.4D4E0120002400A2.quest_desc: [
		"Run the Supercharged Particle System to produce Antimatter Pellets."
		"The SPS consumes polonium pellets and an enormous sustained energy draw to condense antimatter, the highest-value material in the Mekanism line. It takes real power infrastructure to keep the reaction fed, so expect to pair it with your best generators."
		"Antimatter feeds Mekanism's most advanced crafts. Producing your first pellet proves your atomic-tier power and processing can sustain the mod's endgame."
	]
	quest.4D4E0120002400A2.quest_subtitle: "Produce the antimatter material."
	quest.4D4E0120002400A2.title: "Antimatter"
	quest.4D4F011000000001.quest_desc: ["Erect &6Modern Industrialization&r's &bOil Drilling Rig&r. The multiblock pulls crude up from the deep strata on steel pipe and steam pressure, and every refining tower in this chapter drinks from it. Site it well; you will be back."]
	quest.4D4F011000000001.quest_subtitle: "The empire runs on crude."
	quest.4D4F011000000001.title: "Oil Drilling Rig"
	quest.4D4F011000000002.quest_desc: ["Press an &badvanced machine casing&r and finish it into a &bhull&r. This is the chassis tier that carries MV machinery, and the pattern repeats up the whole ladder: better metal, better casing, better machines."]
	quest.4D4F011000000002.quest_subtitle: "The MV chassis."
	quest.4D4F011000000002.title: "Advanced Casings"
	quest.4D4F011000000003.quest_desc: ["Bank your current in &bMV&r and &bHV storage units&r. Generators stall, quarries spike, and a charged buffer is the difference between a flicker and a factory-wide restart."]
	quest.4D4F011000000003.quest_subtitle: "Buffer the grid."
	quest.4D4F011000000003.title: "Storage Units"
	quest.4D4F011000000004.quest_desc: ["Form &6Immersive Engineering&r's &bArc Furnace&r multiblock with the engineer's hammer. The IE advancement confirms it is built: three electrodes, a molten alloy pool, and ore-to-ingot yields above a basic blast furnace."]
	quest.4D4F011000000004.quest_subtitle: "Steel by lightning."
	quest.4D4F011000000004.title: "Arc Furnace"
	quest.4D4F011000000005.quest_desc: ["Finish the heavy-industry lane. &6Actually Additions&r' &bAtomic Reconstructor&r converts by laser, the &bEmpowerer&r charges items on pedestals, and the blast compressor and pyrolyse oven push materials harder. Finishing this quest signs off the empire-of-iron proof lane for the astral threshold."]
	quest.4D4F011000000005.quest_subtitle: "Heavy lane capstone."
	quest.4D4F011000000005.title: "Empowerer"
	quest.4D4F011000000006.quest_desc: ["Craft an &badvanced coil&r for &6Actually Additions&r. Coils are the mod's component spine, and the empowered machines in this wing all want this tier or better wound into them."]
	quest.4D4F011000000006.quest_subtitle: "The reconstructor's next gear."
	quest.4D4F011000000006.title: "Advanced Coil"
	quest.4D4F011000000007.quest_desc: ["Fuel a &6EnderIO&r &bSoul Engine&r with bottled souls from your binder line. It burns the immaterial for very material FE, and it is the start of EnderIO's strange half of this chapter."]
	quest.4D4F011000000007.quest_subtitle: "Power with a pulse."
	quest.4D4F011000000007.title: "Soul Engine"
	quest.4D4F011000000100.quest_desc: ["Build a &bDistillery&r to take the first cut off your crude. Single-step separation covers the early fuel recipes while the full tower goes up next door."]
	quest.4D4F011000000100.quest_subtitle: "First cut of the barrel."
	quest.4D4F011000000100.title: "Distillery"
	quest.4D4F011000000101.quest_desc: ["Raise the &bDistillation Tower&r. The full multiblock splits crude into every fraction at once, and its output manifold feeds the diesel, polymer, and chemical lines in parallel."]
	quest.4D4F011000000101.quest_subtitle: "Full range upgrade."
	quest.4D4F011000000101.title: "Distillation Tower"
	quest.4D4F011000000102.quest_desc: ["Assemble the &bChemical Reactor&r. It combines the tower's fractions into plastics, refined fuels, and the synthetic intermediates the rest of MI quietly assumes you have. Most of this mod's late recipes route through here at least once."]
	quest.4D4F011000000102.quest_subtitle: "Where fractions become products."
	quest.4D4F011000000102.title: "Chemical Reactor"
	quest.4D4F011000000103.quest_desc: ["Power up an &bElectrolyzer&r. It splits compounds with raw current, water into its gases, salts into their metals, which makes it the supplier of half the reagents your chemical reactor asks for."]
	quest.4D4F011000000103.quest_subtitle: "Tear molecules apart."
	quest.4D4F011000000103.title: "Electrolyzer"
	quest.4D4F011000000104.quest_desc: ["Install a &bCentrifuge&r. Where the electrolyzer breaks bonds, this machine just spins mixtures until they give up their parts. Ores, fluids, and by-products all have a centrifuge recipe hiding somewhere."]
	quest.4D4F011000000104.quest_subtitle: "Separation by spin."
	quest.4D4F011000000104.title: "Centrifuge"
	quest.4D4F011000000105.quest_desc: ["Construct the &bVacuum Freezer&r. It chills gases to liquids and quenches hot ingots in seconds, and the cryo-fluids it produces are the coolant the high-tier machines ahead demand."]
	quest.4D4F011000000105.quest_subtitle: "Cold enough to matter."
	quest.4D4F011000000105.title: "Vacuum Freezer"
	quest.4D4F011000000106.quest_desc: ["Fit a &bHeat Exchanger&r between your hot and cold process lines. It moves heat from streams that have too much into streams that need it, which is efficiency the fuel bill notices immediately."]
	quest.4D4F011000000106.quest_subtitle: "Waste heat is free heat."
	quest.4D4F011000000106.title: "Heat Exchanger"
	quest.4D4F011000000107.quest_desc: ["Finish the process train with the &bPressurizer&r. It compresses working fluids to high-pressure states for the turbines and reactions that plain steam cannot drive. The boiler room has graduated."]
	quest.4D4F011000000107.quest_subtitle: "Steam, but angrier."
	quest.4D4F011000000107.title: "Pressurizer"
	quest.4D4F011000000108.quest_desc: ["Alloy up to the &bturbo casing&r and &bhull&r. These frames hold the HV hardware at the top of this chapter, and their material bill is why your stainless line exists."]
	quest.4D4F011000000108.quest_subtitle: "The HV chassis."
	quest.4D4F011000000108.title: "Turbo Casings"
	quest.4D4F011000000109.quest_desc: ["Roll &bclean stainless casings&r and the piped variant. Several multiblocks insist on stainless internals, and the clean finish is not vanity: the recipes that touch chemistry check for it."]
	quest.4D4F011000000109.quest_subtitle: "Food-grade, reactor-grade."
	quest.4D4F011000000109.title: "Stainless Casings"
	quest.4D4F01100000010A.quest_desc: ["Stock &bheatproof&r and &bfrostproof casings&r. The freezer wants one kind, the boilers want the other, and keeping both on the shelf is what separates a factory from a pile of crafting benches."]
	quest.4D4F01100000010A.quest_subtitle: "Built for both ends of the thermometer."
	quest.4D4F01100000010A.title: "Extreme Casings"
	quest.4D4F01100000010B.quest_desc: ["Wind a &bcupronickel coil&r for the electric blast furnace. Coil metallurgy sets the EBF's temperature ceiling, and cupronickel is the rung you can afford today."]
	quest.4D4F01100000010B.quest_subtitle: "The first EBF winding."
	quest.4D4F01100000010B.title: "Cupronickel Coil"
	quest.4D4F01100000010C.quest_desc: ["Upgrade the furnace with &bkanthal coils&r. The hotter winding unlocks the alloy heats cupronickel cannot reach, including metals the turbo tier is waiting on."]
	quest.4D4F01100000010C.quest_subtitle: "Hotter windings, harder alloys."
	quest.4D4F01100000010C.title: "Kanthal Coil"
	quest.4D4F01100000010D.quest_desc: ["Construct the &badvanced large steam boiler&r. It feeds banks of turbines from one firebox, and its appetite finally justifies the fuel lines you refined upstairs."]
	quest.4D4F01100000010D.quest_subtitle: "Steam at scale."
	quest.4D4F01100000010D.title: "Advanced Large Boiler"
	quest.4D4F01100000010E.quest_desc: ["Push to &bhigh pressure&r boilers, large and advanced. High-pressure steam quadruples what a turbine line can extract, at the price of plumbing that takes itself seriously."]
	quest.4D4F01100000010E.quest_subtitle: "High-pressure steam capacity."
	quest.4D4F01100000010E.title: "High Pressure Boilers"
	quest.4D4F01100000010F.quest_desc: ["Spin up an &bMV steam turbine&r. It converts your boiler output into the medium-voltage current the advanced machines draw. One boiler, several of these, and the factory hum changes pitch."]
	quest.4D4F01100000010F.quest_subtitle: "Steam becomes MV current."
	quest.4D4F01100000010F.title: "MV Steam Turbine"
	quest.4D4F011000000110.quest_desc: ["Build the &bHV steam turbine&r when the turbo tier starts asking for current the MV line cannot carry. Same steam, higher voltage, fewer excuses."]
	quest.4D4F011000000110.quest_subtitle: "The high-voltage step."
	quest.4D4F011000000110.title: "HV Steam Turbine"
	quest.4D4F011000000111.quest_desc: ["Cap the steam line with the &bLarge Steam Turbine&r multiblock. Fed high-pressure steam, it outproduces a shelf of block turbines."]
	quest.4D4F011000000111.quest_subtitle: "Multiblock steam generation."
	quest.4D4F011000000111.title: "Large Steam Turbine"
	quest.4D4F011000000112.quest_desc: ["Craft the &bMV Diesel Generator&r controller block unlocked at &6gilded_age&r. Assemble the multiblock hull and hatches at your fuel site when ready."]
	quest.4D4F011000000112.quest_subtitle: "Craft the MV hull controller."
	quest.4D4F011000000112.title: "MV Diesel Plant Controller"
	quest.4D4F011000000113.quest_desc: ["Craft the &bHV Diesel Generator&r controller block. Same &6gilded_age&r unlock as the MV rig; raise the larger hull when you need serious current without a boiler complex."]
	quest.4D4F011000000113.quest_subtitle: "High-voltage diesel control."
	quest.4D4F011000000113.title: "HV Diesel Plant Controller"
	quest.4D4F011000000114.quest_desc: ["Deploy the &bElectric Quarry&r. Given current and drill heads it strip-mines a chunk column on its own, and its output belt is the raw side of everything this chapter smelts. Aim it away from anything you love."]
	quest.4D4F011000000114.quest_subtitle: "The hole that feeds the empire."
	quest.4D4F011000000114.title: "Electric Quarry"
	quest.4D4F011000000115.quest_desc: ["Bolt together the &bHuge Diesel Engine&r from &6Create: Diesel Generators&r. It drinks the same unified diesel as your MI generators but pays out in raw rotation, stress enough to drive a whole Create wing off one crankshaft."]
	quest.4D4F011000000115.quest_subtitle: "Diesel-powered rotation."
	quest.4D4F011000000115.title: "Huge Diesel Engine"
	quest.4D4F011000000116.quest_desc: ["Place the &btransformer&r set: MV down to LV, MV up to HV, and HV back down. Your factory now spans three voltage tiers, and these blocks are what let old machines and new machines share one grid politely."]
	quest.4D4F011000000116.quest_subtitle: "Voltage, translated."
	quest.4D4F011000000116.title: "Transformers"
	quest.4D4F011000000117.quest_desc: ["Craft &bMV energy hatches&r, input and output. Multiblocks only touch the grid through hatches, so every machine hall you build keeps a drawer of these beside the casings."]
	quest.4D4F011000000117.quest_subtitle: "Plug the multiblocks in."
	quest.4D4F011000000117.title: "MV Energy Hatches"
	quest.4D4F011000000118.quest_desc: ["Step up to &bHV energy hatches&r for the multiblocks that gulp rather than sip. The turbo-tier machines will not even wake up on MV feeds."]
	quest.4D4F011000000118.quest_subtitle: "The heavier plug."
	quest.4D4F011000000118.title: "HV Energy Hatches"
	quest.4D4F011000000119.quest_desc: ["Fit &badvanced fluid hatches&r to your process multiblocks. Bigger internal tanks mean the distillation and reactor lines stop stalling on slow plumbing."]
	quest.4D4F011000000119.quest_subtitle: "Liquids in, liquids out."
	quest.4D4F011000000119.title: "Advanced Fluid Hatches"
	quest.4D4F01100000011A.quest_desc: ["Upgrade the wet lines with &bturbo fluid hatches&r when high-pressure steam and bulk chemistry start moving serious volume."]
	quest.4D4F01100000011A.quest_subtitle: "High-throughput fluid ports."
	quest.4D4F01100000011A.title: "Turbo Fluid Hatches"
	quest.4D4F01100000011B.quest_desc: ["Add &badvanced item hatches&r so the multiblocks can be stocked and emptied by your logistics instead of your hands. The quarry output finally has somewhere official to go."]
	quest.4D4F01100000011B.quest_subtitle: "Solids on schedule."
	quest.4D4F01100000011B.title: "Advanced Item Hatches"
	quest.4D4F01100000011C.quest_desc: ["Finish the hatch collection with the &bturbo item&r pair. They move stacks per cycle instead of items, sized for the EBF runs and quarry torrents of a mature factory."]
	quest.4D4F01100000011C.quest_subtitle: "High-throughput item ports."
	quest.4D4F01100000011C.title: "Turbo Item Hatches"
	quest.4D4F01100000011D.quest_desc: ["Craft the &bImproved Blast Furnace&r controller block unlocked at &6gilded_age&r. Build the preheated multiblock when you are ready to pour steel faster."]
	quest.4D4F01100000011D.quest_subtitle: "Craft the preheated hearth."
	quest.4D4F01100000011D.title: "Preheated Steel Hearth Controller"
	quest.4D4F01100000011E.quest_desc: ["Form the &bExcavator&r multiblock over a surveyed mineral deposit with the engineer's hammer. The IE advancement confirms it is built. The bucket wheel mines the vein on loop until the deposit runs out."]
	quest.4D4F01100000011E.quest_subtitle: "The wheel that eats hills."
	quest.4D4F01100000011E.title: "Excavator"
	quest.4D4F01100000011F.quest_desc: ["Forge a spare &bBucket Wheel&r. It is the excavator's working face, all steel buckets and bearings, and having a second one assembled means a worn site swap takes minutes instead of a day of pressing plates."]
	quest.4D4F01100000011F.quest_subtitle: "Spare teeth for the beast."
	quest.4D4F01100000011F.title: "Bucket Wheel"
	quest.4D4F011000000120.quest_desc: ["Set up the &bAssembler&r and load it with up to three recipes. Fed ingredients and power, it crafts in bulk, fluids included. It bridges IE's belts and the patterned autocrafting next door."]
	quest.4D4F011000000120.quest_subtitle: "Three recipes, no hands."
	quest.4D4F011000000120.title: "Assembler"
	quest.4D4F011000000121.quest_desc: ["Form the &bLightning Rod&r multiblock with a tall iron fence mast. The IE advancement confirms the capacitors are wired. Storms hit the mast and the rig stores the charge for free power."]
	quest.4D4F011000000121.quest_subtitle: "Storm power storage."
	quest.4D4F011000000121.title: "Lightning Rod"
	quest.4D4F011000000122.quest_desc: ["Mount a &bTesla Coil&r over the approaches to your factory. It arcs into anything that wanders close, intruders and owners alike. Carry the right tool to walk under your own defenses."]
	quest.4D4F011000000122.quest_subtitle: "Powered perimeter defense."
	quest.4D4F011000000122.title: "Tesla Coil"
	quest.4D4F011000000123.quest_desc: ["Install the &bgun turret&r and &bchemical turret&r. One speaks in cartridges, the other in sprayed flame or worse from its fluid tank. Between them and the tesla coil, the empire's walls patrol themselves."]
	quest.4D4F011000000123.quest_subtitle: "Automated factory defenses."
	quest.4D4F011000000123.title: "Turrets"
	quest.4D4F011000000124.quest_desc: ["Plant an &bAuto Lubricator&r beside the big rotating machines. Drip-fed lubricant keeps the excavator and pumpjacks running faster and longer. A quiet efficiency gain that compounds all day."]
	quest.4D4F011000000124.quest_subtitle: "Machine lubrication support."
	quest.4D4F011000000124.title: "Auto Lubricator"
	quest.4D4F011000000125.quest_desc: ["Add &6Immersive Petroleum&r's &bHydrotreater&r to the refinery train. It polishes diesel cuts with hydrogen for a cleaner, denser product, and the unified fuel line means every engine in the pack benefits."]
	quest.4D4F011000000125.quest_subtitle: "Refinery fuel polishing."
	quest.4D4F011000000125.title: "Hydrotreater"
	quest.4D4F011000000126.quest_desc: ["Finish the petroleum train with the &bCoker Unit&r. It cracks the heaviest residues into usable product plus petcoke, a fuel your solid-burners are happy to take. Nothing leaves this refinery unspent."]
	quest.4D4F011000000126.quest_subtitle: "Heavy residue cracking."
	quest.4D4F011000000126.title: "Coker Unit"
	quest.4D4F011000000127.quest_desc: ["Build the &bEnergizer&r and &bEnervator&r pair. One pours stored power into items, the other drains items back into the grid. Every battery-driven tool in your kit now has a charging bay."]
	quest.4D4F011000000127.quest_subtitle: "Charge in, charge out."
	quest.4D4F011000000127.title: "Energizer and Enervator"
	quest.4D4F011000000128.quest_desc: ["Craft the &bCrusher&r block unlocked at &6gilded_age&r. It is a single powered machine, not a multiblock. It doubles ore into dust once you place and feed it."]
	quest.4D4F011000000128.quest_subtitle: "Craft the crusher block."
	quest.4D4F011000000128.title: "AA Pulverizer"
	quest.4D4F011000000129.quest_desc: ["Craft the &bDouble Crusher&r block. Same single-machine form as the basic crusher, with two input lanes. Place it when your ore backlog needs parallel lanes."]
	quest.4D4F011000000129.quest_subtitle: "Dual-lane crushing."
	quest.4D4F011000000129.title: "AA Twin Pulverizer"
	quest.4D4F01100000012A.quest_desc: ["Add a &bPowered Furnace&r to pair with the crusher. Dust in, ingots out, all on CF, and it idles politely when the belt runs dry."]
	quest.4D4F01100000012A.quest_subtitle: "Grid-powered smelting."
	quest.4D4F01100000012A.title: "Powered Furnace"
	quest.4D4F01100000012B.quest_desc: ["Start the AA power room with a &bCoal Generator&r. It burns the boring stuff for steady CF and asks nothing of you. The exotic generators beside it are where the fun begins."]
	quest.4D4F01100000012B.quest_subtitle: "The honest baseline."
	quest.4D4F01100000012B.title: "Coal Generator"
	quest.4D4F01100000012C.quest_desc: ["Run an &bOil Generator&r on the canola line's output. Refined oils burn hotter than the raw press, so the fermenting barrel upstream is worth the patience."]
	quest.4D4F01100000012C.quest_subtitle: "Canola fuel generation."
	quest.4D4F01100000012C.title: "Oil Generator"
	quest.4D4F01100000012D.quest_desc: ["Feed a &bBio Reactor&r your farm surplus. The greener the mix, the better the burn. It pairs naturally with the leaf generator next door for a power room that smells like spring."]
	quest.4D4F01100000012D.quest_subtitle: "Farm surplus generation."
	quest.4D4F01100000012D.title: "Bio Reactor"
	quest.4D4F01100000012E.quest_desc: ["Plant a &bLeaf Generator&r inside a growing canopy. It eats the leaves around it for a steady trickle of CF while the trees regrow. Silly, green, and surprisingly dependable."]
	quest.4D4F01100000012E.quest_subtitle: "Canopy-fed CF."
	quest.4D4F01100000012E.title: "Leaf Generator"
	quest.4D4F01100000012F.quest_desc: ["Ring a &bHeat Collector&r with lava and let it sip the heat into current. No fuel, no moving parts, just geology paying rent."]
	quest.4D4F01100000012F.quest_subtitle: "Lava-side heat power."
	quest.4D4F01100000012F.title: "Heat Collector"
	quest.4D4F011000000130.quest_desc: ["Assemble the &bLava Factory&r with its casing ring. It spends CF to condense fresh lava, which your heat collectors and smelteries immediately spend again. The loop is absurd and you will build it anyway."]
	quest.4D4F011000000130.quest_subtitle: "Grid-powered lava supply."
	quest.4D4F011000000130.title: "Lava Factory"
	quest.4D4F011000000131.quest_desc: ["Press canola into oil with the &bCanola Press&r. The crop grows anywhere, the press never sleeps, and the oil line it starts ends in some of AA's best fuels."]
	quest.4D4F011000000131.quest_subtitle: "Canola oil processing."
	quest.4D4F011000000131.title: "Canola Press"
	quest.4D4F011000000132.quest_desc: ["Age the pressed oil in a &bFermenting Barrel&r. Time turns it into refined canola oil worth real CF in the oil generator. Set a row of barrels and forget them; they prefer it that way."]
	quest.4D4F011000000132.quest_subtitle: "Refined canola oil processing."
	quest.4D4F011000000132.title: "Fermenting Barrel"
	quest.4D4F011000000133.quest_desc: ["Place a &bBattery Box&r to bank your CF and charge batteries for field gear. The AA wing now generates, stores, and spends its own currency end to end."]
	quest.4D4F011000000133.quest_subtitle: "CF for the road."
	quest.4D4F011000000133.title: "Battery Box"
	quest.4D4F011000000134.quest_desc: ["Link two &bLaser Relays&r with a wrench and watch the beam carry CF across open air. Relays make AA's grid a constellation instead of a cable run, and the item variants share the same trick."]
	quest.4D4F011000000134.quest_subtitle: "Power without wires."
	quest.4D4F011000000134.title: "Laser Relay"
	quest.4D4F011000000135.quest_desc: ["Upgrade busy spans to &badvanced laser relays&r. They waste less power per hop, which your meter starts noticing once the constellation grows past a few stars."]
	quest.4D4F011000000135.quest_subtitle: "Lower-loss relay spans."
	quest.4D4F011000000135.title: "Advanced Laser Relay"
	quest.4D4F011000000136.quest_desc: ["Finish the network with &bextreme laser relays&r on the trunk lines. At this tier the beam barely taxes the throughput, and the wireless grid stops being a compromise."]
	quest.4D4F011000000136.quest_subtitle: "Extreme relay trunk lines."
	quest.4D4F011000000136.title: "Extreme Laser Relay"
	quest.4D4F011000000137.quest_desc: ["Craft AA's &bBreaker&r and &bPlacer&r. Simple block-eats-block automation that slots anywhere a farm or filler is missing one moving part."]
	quest.4D4F011000000137.quest_subtitle: "Simple block automation."
	quest.4D4F011000000137.title: "Breaker and Placer"
	quest.4D4F011000000138.quest_desc: ["Plant a &bFarmer&r at the center of your crops. It harvests and replants its plot on its own, the one-block answer to the gatherer-and-sower pair across the hall."]
	quest.4D4F011000000138.quest_subtitle: "Single-block crop upkeep."
	quest.4D4F011000000138.title: "Farmer"
	quest.4D4F011000000139.quest_desc: ["Deploy the &bVertical Digger&r to mine a clean column to bedrock. Smaller appetite than the big quarries, zero surface scar, and it hands you the hole as a free elevator shaft afterward."]
	quest.4D4F011000000139.quest_subtitle: "Vertical column mining."
	quest.4D4F011000000139.title: "Vertical Digger"
	quest.4D4F01100000013A.quest_desc: ["Mount a &bLong Range Breaker&r where a row of blocks needs clearing on a cycle. It breaks a line ahead of itself, which makes tree farms and cane walls one machine simpler."]
	quest.4D4F01100000013A.quest_subtitle: "Long-range block breaking."
	quest.4D4F01100000013A.title: "Long Range Breaker"
	quest.4D4F01100000013B.quest_desc: ["Place a &bRanged Collector&r to vacuum drops from the whole room and a &bFluid Collector&r for the puddles. Between them, the mob farm and the spill zone keep themselves tidy."]
	quest.4D4F01100000013B.quest_subtitle: "Ranged drop and fluid collection."
	quest.4D4F01100000013B.title: "Collectors"
	quest.4D4F01100000013C.quest_desc: ["Wire &bitem interfaces&r, plain and hopping, into your laser relay network. They let the beams carry items alongside power, so outbuildings ship cargo home with no belt in sight."]
	quest.4D4F01100000013C.quest_subtitle: "Laser-relay item transfer."
	quest.4D4F01100000013C.title: "Item Interfaces"
	quest.4D4F01100000013D.quest_desc: ["Bind a &bPhantom Breaker&r and &bPhantom Placer&r to remote spots with a phantom connector. They work their bound block from anywhere in range, no line of sight required. Spooky is a feature."]
	quest.4D4F01100000013D.quest_subtitle: "Remote block work."
	quest.4D4F01100000013D.title: "Phantom Workers"
	quest.4D4F01100000013E.quest_desc: ["Complete the phantom kit with the &bitemface&r, &bliquiface&r, and &benergyface&r. Each teleports its cargo type between bound blocks, which deletes entire pipe runs from your base's wiring diagram."]
	quest.4D4F01100000013E.quest_subtitle: "Remote cargo faces."
	quest.4D4F01100000013E.title: "Phantom Faces"
	quest.4D4F01100000013F.quest_desc: ["Build the &bSlice'N'Splice&r. It cuts and recombines heads and circuit parts into the components EnderIO's machines demand. Keep spare axes; the blades wear."]
	quest.4D4F01100000013F.quest_subtitle: "Surgery for circuits."
	quest.4D4F01100000013F.title: "Slice and Splice"
	quest.4D4F011000000140.quest_desc: ["Set a &bFarming Station&r over mixed crops with hoes and shears in its tool slots. It plants, harvests, and runs tree farms in one block. The closest thing this age has to hired help."]
	quest.4D4F011000000140.quest_subtitle: "Automated crops and trees."
	quest.4D4F011000000140.title: "Farming Station"
	quest.4D4F011000000141.quest_desc: ["Program EnderIO's &bCrafter&r with a single recipe and feed it parts. It is the dependable middle child of your autocrafting family: no patterns, no channels, just the same craft done right all day."]
	quest.4D4F011000000141.quest_subtitle: "Single-recipe automation."
	quest.4D4F011000000141.title: "Crafter"
	quest.4D4F011000000142.quest_desc: ["Repair a broken spawner into a &bPowered Spawner&r and bind it with a soul vial. Fed FE it spawns your chosen creature on command, which turns the mob crusher hall into a precision instrument."]
	quest.4D4F011000000142.quest_subtitle: "Powered mob spawning."
	quest.4D4F011000000142.title: "Powered Spawner"
	quest.4D4F011000000143.quest_desc: ["Raise an &bXP Obelisk&r beside the grinder. It banks experience as fluid, pays it back on demand, and never spills a level off the edge of a platform again."]
	quest.4D4F011000000143.quest_subtitle: "Experience storage."
	quest.4D4F011000000143.title: "XP Obelisk"
	quest.4D4F011000000144.quest_desc: ["Plant the &battractor&r, &baversion&r, and &binhibitor&r obelisks around your farms. One baits mobs in, one warns them off, one cancels their spawns outright. Monster traffic becomes a thing you direct."]
	quest.4D4F011000000144.quest_subtitle: "Mob control obelisks."
	quest.4D4F011000000144.title: "Crowd Obelisks"
	quest.4D4F011000000145.quest_desc: ["Finish the circle with the &brelocator&r and &bweather obelisks&r. One teleports spawns to where you want them dying, the other clears or summons storms for FE. The sky now has a control panel."]
	quest.4D4F011000000145.quest_subtitle: "Relocation and weather control."
	quest.4D4F011000000145.title: "World Obelisks"
	quest.4D4F011000000146.quest_desc: ["Install a &bWireless Charger&r with its antenna upgrades. Anything battery-powered on your person refills while you walk the halls. Your jetpack will never embarrass you mid-flight again."]
	quest.4D4F011000000146.quest_subtitle: "Wireless gear charging."
	quest.4D4F011000000146.title: "Wireless Charging"
	quest.4D4F011000000147.quest_desc: ["Build the &bCoral Generator&r from &6Create Propulsion&r. It converts coral fluid into FE through its top and bottom faces, a seaside power station for bases that went nautical. Niche, bright, and quietly competitive."]
	quest.4D4F011000000147.quest_subtitle: "Coral-fluid FE generation."
	quest.4D4F011000000147.title: "Coral Generator"
	quest.4D50011000000001.quest_desc: ["Start &6Mekanism&r's power line with a &bHeat Generator&r. Ring it with lava or feed it burnables and it converts the heat into steady current. Modest output, zero maintenance. The first brick of a renewable grid."]
	quest.4D50011000000001.quest_subtitle: "Lava pays the first bill."
	quest.4D50011000000001.title: "Heat Generator"
	quest.4D50011000000002.quest_desc: ["Wire in &6Electrodynamics&r' &bChemical Reactor&r. It runs the mod's wet chemistry on straight current, and its product list feeds the crusher line, the battery line, and the gas cards in the refinery wing."]
	quest.4D50011000000002.quest_subtitle: "Chemistry on a copper bus."
	quest.4D50011000000002.title: "Chemical Reactor"
	quest.4D50011000000003.quest_desc: ["Finish the oceanic lane. The &bAquatic Catalyst&r and chip are &6NauTec&r's core silicon, the deep sea drain feeds the lab its water, and the &bAugmentation Station&r starts upgrading you alongside your machines. Completing this quest signs off the ocean proof lane for the astral threshold."]
	quest.4D50011000000003.quest_subtitle: "Ocean lane capstone."
	quest.4D50011000000003.title: "Aquatic Catalyst"
	quest.4D50011000000004.quest_desc: ["Craft the &bMineral Crusher&r block unlocked at &6gilded_age&r. It is a single powered machine that pulverizes ore on current. Place and wire it when your crusher hall is ready."]
	quest.4D50011000000004.quest_subtitle: "Craft the first lane."
	quest.4D50011000000004.title: "ED Ore Pulverizer"
	quest.4D50011000000005.quest_desc: ["Construct the &bLarge Electric Furnace&r. Batch smelting on grid power, sized to keep pace with the macerator hall across the aisle. The dust it receives leaves as ingots by the stack."]
	quest.4D50011000000005.quest_subtitle: "Smelting by the hall."
	quest.4D50011000000005.title: "Large Electric Furnace"
	quest.4D50011000000006.quest_desc: ["Smelt &baquarine steel&r from its compound. &6NauTec&r's structural metal carries the lab's laser light without losing it, and every machine in this wing wants plates of it. Keep the furnace warm."]
	quest.4D50011000000006.quest_subtitle: "The ocean's alloy."
	quest.4D50011000000006.title: "Aquarine Steel"
	quest.4D50011000000100.quest_desc: ["Add a &bBio Generator&r and feed it bio fuel mashed from your crop surplus. It burns green and steady, and the farm that supplies it never runs out of clippings."]
	quest.4D50011000000100.quest_subtitle: "The compost burns clean."
	quest.4D50011000000100.title: "Bio Generator"
	quest.4D50011000000101.quest_desc: ["Raise a &bWind Generator&r as high as your build allows. Output scales with altitude, so the turbine on the peak quietly out-earns the one in the yard. A ridgeline of these is the cheapest baseload this age sells."]
	quest.4D50011000000101.quest_subtitle: "Height is voltage."
	quest.4D50011000000101.title: "Wind Generator"
	quest.4D50011000000102.quest_desc: ["Press &bsolar panels&r and frame them into a &bSolar Generator&r. It earns while the sun is up and sleeps when it is not, which makes it the perfect partner for the battery bank across the room."]
	quest.4D50011000000102.quest_subtitle: "Daylight on the meter."
	quest.4D50011000000102.title: "Solar Generator"
	quest.4D50011000000103.quest_desc: ["Cap the renewables with an &bAdvanced Solar Generator&r, a full tracking array on one post. The reward is &6Mekanism&r's &bAtomic Disassembler&r, the battery-hungry omni-tool that mines, chops, and digs as fast as you hold the button."]
	quest.4D50011000000103.quest_subtitle: "The rooftop array."
	quest.4D50011000000103.title: "Advanced Solar Generator"
	quest.4D50011000000104.quest_desc: ["Install the &badvanced thermoelectric manipulator&r. It pushes process streams to the exact temperatures the finicky recipes demand, hot or cold, which is why it sits in the middle of every serious Electrodynamics line."]
	quest.4D50011000000104.quest_subtitle: "Heat and cold, dialed in."
	quest.4D50011000000104.title: "Thermoelectric Manipulator"
	quest.4D50011000000105.quest_desc: ["Assemble &6Extended Industrialization&r's &bLarge Electric Macerator&r. The multiblock processes whole quarry loads into dust in batch runs, replacing a wall of single grinders with one central hall."]
	quest.4D50011000000105.quest_subtitle: "Grinding, industrialized."
	quest.4D50011000000105.title: "Large Electric Macerator"
	quest.4D50011000000106.quest_desc: ["Build the &bProcessing Array&r and rack standard machines inside it. The array runs them in parallel as one multiblock, so scaling a recipe no longer means another row of floor space."]
	quest.4D50011000000106.quest_subtitle: "Sixteen machines, one shell."
	quest.4D50011000000106.title: "Processing Array"
	quest.4D50011000000107.quest_desc: ["Raise the &bTesla Tower&r. It expands the Tesla power-transfer side of the Electrodynamics branch."]
	quest.4D50011000000107.quest_subtitle: "Build the Tesla Tower."
	quest.4D50011000000107.title: "Tesla Tower"
	quest.4D50011000000108.quest_desc: ["Craft the &bdouble mineral crusher&r block. Same single-machine form as the basic crusher, with two grinding lanes."]
	quest.4D50011000000108.quest_subtitle: "Optional: powered crop automation."
	quest.4D50011000000108.title: "Double Mineral Crusher"
	quest.4D50011000000109.quest_desc: ["Craft the &btriple mineral crusher&r block. Three lanes in one chassis."]
	quest.4D50011000000109.quest_subtitle: "Craft the three-lane crusher."
	quest.4D50011000000109.title: "Triple Mineral Crusher"
	quest.4D5001100000010A.quest_desc: ["Craft the &bChemical Mixer&r block unlocked at &6gilded_age&r. It blends solutions beside your reactor once placed."]
	quest.4D5001100000010A.quest_subtitle: "Craft the wet bench."
	quest.4D5001100000010A.title: "ED Solution Blender"
	quest.4D5001100000010B.quest_desc: ["Run brine and water through the &bElectrolytic Separator&r. It splits feed fluids into their gas components, stocking the tanks the chemical and battery lines draw on."]
	quest.4D5001100000010B.quest_subtitle: "Current splits the stream."
	quest.4D5001100000010B.title: "Electrolytic Separator"
	quest.4D5001100000010C.quest_desc: ["Pair the &badvanced compressor&r and &bdecompressor&r. One compresses gases and the other decompresses them for the gas-handling branch."]
	quest.4D5001100000010C.quest_subtitle: "Compress and decompress gases."
	quest.4D5001100000010C.title: "Compressor Pair"
	quest.4D5001100000010D.quest_desc: ["Fire up the &bOxidation Furnace&r. It roasts materials into oxide forms for later chemistry recipes."]
	quest.4D5001100000010D.quest_subtitle: "Craft the Oxidation Furnace."
	quest.4D5001100000010D.title: "Oxidation Furnace"
	quest.4D5001100000010E.quest_desc: ["Mount the &bLV&r and &bMV chargers&r on the workshop wall. They charge compatible Electrodynamics battery items."]
	quest.4D5001100000010E.quest_subtitle: "Charge LV and MV batteries."
	quest.4D5001100000010E.title: "LV/MV Chargers"
	quest.4D5001100000010F.quest_desc: ["Deploy the &bElectric Farmer&r multiblock over a field. It is the powered farming option for this branch."]
	quest.4D5001100000010F.quest_subtitle: "Automate powered farming."
	quest.4D5001100000010F.title: "Electric Farmer"
	quest.4D50011000000110.quest_desc: ["Place a &bMachine Chainer&r and its relays along a machine row. The chainer links every machine in the line to one power and logistics tap, which deletes a forest of individual cables from your factory floor."]
	quest.4D50011000000110.quest_subtitle: "One cable, whole row."
	quest.4D50011000000110.title: "Machine Chainer"
	quest.4D50011000000111.quest_desc: ["Print an &bMV solar panel&r. It feeds the MI-style grid directly at medium voltage, a clean daytime supplement to the boiler room next door."]
	quest.4D50011000000111.quest_subtitle: "Sunlight at medium voltage."
	quest.4D50011000000111.title: "MV Solar Panel"
	quest.4D50011000000112.quest_desc: ["Upgrade the roof to &bHV solar panels&r. They are the high-voltage solar tier for the Electrodynamics power branch."]
	quest.4D50011000000112.quest_subtitle: "Upgrade to HV solar."
	quest.4D50011000000112.title: "HV Solar Panel"
	quest.4D50011000000113.quest_desc: ["Energize an &6Extended Industrialization&r &bTesla Coil&r. It beams power through open air to receivers in range, which means outbuildings, vehicles, and remote rigs can finally drink from the main grid."]
	quest.4D50011000000113.quest_subtitle: "Power leaves the wire."
	quest.4D50011000000113.title: "Tesla Coil"
	quest.4D50011000000114.quest_desc: ["Swap perimeter coils for the &blethal&r variant. It adds a dangerous Tesla-coil option to the power network."]
	quest.4D50011000000114.quest_subtitle: "Add the lethal Tesla coil."
	quest.4D50011000000114.title: "Lethal Tesla Coil"
	quest.4D50011000000115.quest_desc: ["Add a &bTesla Particle Generator&r to the array. It gives the Tesla setup visible arc effects."]
	quest.4D50011000000115.quest_subtitle: "Visualize the Tesla field."
	quest.4D50011000000115.title: "Tesla Particle Generator"
	quest.4D50011000000116.quest_desc: ["Fit &btesla receivers&r and the MV and HV receiver hatches to your remote machines. Multiblocks can now take wireless power straight into their hatch row, no cable trench across the map."]
	quest.4D50011000000116.quest_subtitle: "Catch the broadcast."
	quest.4D50011000000116.title: "Tesla Receivers"
	quest.4D50011000000117.quest_desc: ["Wind the full ladder: &bcopper&r, &bannealed copper&r, &baluminum&r, and &belectrum&r tesla windings."]
	quest.4D50011000000117.quest_subtitle: "Craft the Tesla winding set."
	quest.4D50011000000117.title: "Tesla Windings"
	quest.4D50011000000118.quest_desc: ["Place a &bLarge Configurable Chest&r. It provides configurable bulk storage for the factory branch."]
	quest.4D50011000000118.quest_subtitle: "Add configurable bulk storage."
	quest.4D50011000000118.title: "Large Configurable Chest"
	quest.4D50011000000119.quest_desc: ["Place &bprismarine laser relays&r to carry NauTec's beam power between machines. The relays bend the lab's light around corners and down to the seabed floor where the work actually happens."]
	quest.4D50011000000119.quest_subtitle: "Light does the wiring."
	quest.4D50011000000119.title: "Prismarine Laser Relay"
	quest.4D5001100000011A.quest_desc: ["Add &blaser junctions&r where one beam must feed several machines. The junction splits and rejoins light cleanly, turning a single trunk beam into a whole distribution grid."]
	quest.4D5001100000011A.quest_subtitle: "Split the beam."
	quest.4D5001100000011A.title: "Laser Junction"
	quest.4D5001100000011B.quest_desc: ["Mount a &bLong Distance Laser&r and aim it at a far receiver. It throws the lab's power across open water in one shot, which is how an offshore outpost runs on the home reef's generators."]
	quest.4D5001100000011B.quest_subtitle: "Beam power past the horizon."
	quest.4D5001100000011B.title: "Long Distance Laser"
	quest.4D5001100000011C.quest_desc: ["Recover a &bdamaged aquatic chip&r from the ocean's ruins and machines. Corroded as it is, the chip still holds the patterns the analyzer needs to grow you clean replacements."]
	quest.4D5001100000011C.quest_subtitle: "Salvage with secrets."
	quest.4D5001100000011C.title: "Damaged Aquatic Chip"
	quest.4D5001100000011D.quest_desc: ["Build the &bBacterial Analyzer&r. It reads salvaged chips and living cultures alike, cataloging the strains your incubator will grow. The biological half of NauTec starts at this bench."]
	quest.4D5001100000011D.quest_subtitle: "Read the cultures."
	quest.4D5001100000011D.title: "Bacterial Analyzer"
	quest.4D5001100000011E.quest_desc: ["Forge &bbacterial containment shields&r. They wall the live cultures off from your lungs and your machines, and the mutator two benches down refuses to run without them."]
	quest.4D5001100000011E.quest_subtitle: "Keep the cultures in the glass."
	quest.4D5001100000011E.title: "Containment Shield"
	quest.4D5001100000011F.quest_desc: ["Warm an &bIncubator&r and seed it from the analyzer's catalog. It multiplies bacterial strains into working stock, the living feedstock for the mutator and bio reactor beside it."]
	quest.4D5001100000011F.quest_subtitle: "Grow the strain."
	quest.4D5001100000011F.title: "Incubator"
	quest.4D50011000000120.quest_desc: ["Assemble the &bMutator&r. In this pack its thermal manifold is regulated by a &6PneumaticCraft&r &bvortex tube&r, hot and cold cycling that stresses cultures into new strains. The pressure lab across the chapter is built into this machine."]
	quest.4D50011000000120.quest_subtitle: "Stress makes strange strains."
	quest.4D50011000000120.title: "Mutator"
	quest.4D50011000000121.quest_desc: ["Craft the &bNauTec Mixer&r block unlocked at &6gilded_age&r. It blends cultures and nutrient fluids once placed in the lab."]
	quest.4D50011000000121.quest_subtitle: "Craft the wet bench."
	quest.4D50011000000121.title: "NauTec Solution Bench"
	quest.4D50011000000122.quest_desc: ["Grow the &bBio Reactor&r around its cultures. Its living core is seeded with &6EnderIO&r &bpulsating crystals&r in this pack, two of them replacing the usual prismarine filler, so the soul-tech wing keeps this reactor's metabolism alive. Feed it and it pays the lab's power bill."]
	quest.4D50011000000122.quest_subtitle: "A living power core."
	quest.4D50011000000122.title: "Bio Reactor"
	quest.4D50011000000123.quest_desc: ["Extend the augmentation station with its &bextension&r block."]
	quest.4D50011000000123.quest_subtitle: "Extend the augmentation station."
	quest.4D50011000000123.title: "Augmentation Station Extension"
	quest.4D50011000000124.quest_desc: ["Refine &bbiosteel&r for the fleet's upgraded frames. The alloy enters Oritech's bill of materials at this tier and never leaves it; stock ingots now and the assembler wing stays fed."]
	quest.4D50011000000124.quest_subtitle: "Metal with a pulse."
	quest.4D50011000000124.title: "Biosteel"
	quest.4D50011000000125.quest_desc: ["Grind a &benderic lens&r. It focuses &6Oritech&r laser and enchanter optics. The overcharged crystal quest that follows is its high-energy sibling."]
	quest.4D50011000000125.quest_subtitle: "Glass that bends the rules."
	quest.4D50011000000125.title: "Enderic Lens"
	quest.4D50011000000126.quest_desc: ["Charge an &bovercharged crystal&r. It is a high-charge crystal component for the Oritech branch."]
	quest.4D50011000000126.quest_subtitle: "Charge an overcharged crystal."
	quest.4D50011000000126.title: "Overcharged Crystal"
	quest.4D50011000000127.quest_desc: ["Add Oritech's &bCentrifuge&r to the processing hall. It separates the fleet's slurries and mixed outputs into clean streams, and several ore chains do not finish without a pass through it."]
	quest.4D50011000000127.quest_subtitle: "Spin out the slurry."
	quest.4D50011000000127.title: "Centrifuge"
	quest.4D50011000000128.quest_desc: ["Install &blarge storage&r for the energy the fleet generates and spends in bursts. It smooths the reactor's output into something the assemblers can rely on between fuel loads."]
	quest.4D50011000000128.quest_subtitle: "A buffer worthy of the fleet."
	quest.4D50011000000128.title: "Large Storage"
	quest.4D50011000000129.quest_desc: ["Stand the &bFertilizer Block&r over your crops. It sprays growth across the work area on stored fluid and power, Oritech's contribution to the farm race the other mods started."]
	quest.4D50011000000129.quest_subtitle: "The fields join the fleet."
	quest.4D50011000000129.title: "Fertilizer Block"
	quest.4D5001100000012A.quest_desc: ["Slot a &bcrop filter addon&r into the farm machines. It filters which crops the automation handles."]
	quest.4D5001100000012A.quest_subtitle: "Filter automated crops."
	quest.4D5001100000012A.title: "Crop Filter Addon"
	quest.4D5001100000012B.quest_desc: ["Fit a &byield addon&r to a supported machine."]
	quest.4D5001100000012B.quest_subtitle: "Improve machine output."
	quest.4D5001100000012B.title: "Machine Yield Addon"
	quest.4D5001100000012C.quest_desc: ["Install an &binventory proxy addon&r so logistics can expose a machine inventory through the addon."]
	quest.4D5001100000012C.quest_subtitle: "Expose machine inventory."
	quest.4D5001100000012C.title: "Inventory Proxy Addon"
	quest.4D5001100000012D.quest_desc: ["Add &bcapacitor addon extenders&r to supported machines. They expand a machine's energy buffer."]
	quest.4D5001100000012D.quest_subtitle: "Expand machine energy buffers."
	quest.4D5001100000012D.title: "Capacitor Addon Extender"
	quest.4D5001100000012E.quest_desc: ["Back the reactor with a &bFuel Generator&r. It burns the oil spine's products for supplemental power, covering the gap while the reactor refuels or the lasers spike."]
	quest.4D5001100000012E.quest_subtitle: "Burn the refined cut, fleet edition."
	quest.4D5001100000012E.title: "Fuel Generator"
	quest.4D5001100000012F.quest_desc: ["Attach the &bquarry addon&r to supported mining automation."]
	quest.4D5001100000012F.quest_subtitle: "Automate quarry digging."
	quest.4D5001100000012F.title: "Quarry Addon"
	quest.4D50011000000130.quest_desc: ["Wire in a &bflux gate&r. It limits energy flow through a line."]
	quest.4D50011000000130.quest_subtitle: "Limit energy flow."
	quest.4D50011000000130.title: "Flux Gate"
	quest.4D50011000000131.quest_desc: ["Refine the raw lump into &bsilicon&r pure enough to slice. The refining loop rejects most of what you feed it; the part it keeps is the only part the wafer saw will touch."]
	quest.4D50011000000131.quest_subtitle: "Purity is the product."
	quest.4D50011000000131.title: "Refined Silicon"
	quest.4D50011000000132.quest_desc: ["Slice the boule into &bsilicon wafers&r. Each disc is a blank for printed circuits; the processing unit that ends this lane is made on these."]
	quest.4D50011000000132.quest_subtitle: "Wafers for the CPU line."
	quest.4D50011000000132.title: "Silicon Wafer"
	quest.4D50011000000133.quest_desc: ["Craft the Nautec Diving Helmet, Diving Chestplate, and Diving Boots. Keep the three pieces together for the deep-water work line."]
	quest.4D50011000000133.quest_subtitle: "Prepare the Nautec diving suit."
	quest.4D50011000000133.title: "Diving Suit"
	quest.4D50011000000134.quest_desc: ["Use the crowbar to open the etching setup; keep the acid bucket beside it."]
	quest.4D50011000000134.quest_subtitle: "Prepare tools for circuit etching."
	quest.4D50011000000134.title: "Etching Tools"
	quest.4D50011000000135.quest_desc: ["Craft the Nautec Prism Monocle. Keep it ready for inspection work in the aquatic systems branch."]
	quest.4D50011000000135.quest_subtitle: "Inspect the aquatic systems line."
	quest.4D50011000000135.title: "Prism Monocle"
	quest.4D50011000000136.quest_desc: ["Craft the Nautec Charger. Use it to support the charged equipment in this branch."]
	quest.4D50011000000136.quest_subtitle: "Charge the aquatic equipment."
	quest.4D50011000000136.title: "Nautec Charger"
	quest.4D50011000000137.quest_desc: ["Craft an Electrolyte Algae Serum Bucket and Vial. Keep both forms available for the Nautec chemistry line."]
	quest.4D50011000000137.quest_subtitle: "Prepare the EAS supplies."
	quest.4D50011000000137.title: "Electrolyte Algae Serum"
	quest.4D50011000000138.quest_desc: ["Use the valve and drain to route deep water into the Nautec line."]
	quest.4D50011000000138.quest_subtitle: "Route the deep-water flow."
	quest.4D50011000000138.title: "Deep Sea Drain"
	quest.4D50011000000139.quest_desc: ["Craft the Aquarine Steel Pickaxe and Aquarine Steel Sword. This completes the tool pair in the Nautec materials line."]
	quest.4D50011000000139.quest_subtitle: "Equip the aquarine steel tools."
	quest.4D50011000000139.title: "Aquarine Steel Tools"
	quest.4D5001100000013A.quest_desc: ["Craft the Aquarine Steel Chestplate and Aquarine Steel Helmet. Add them to the aquarine steel equipment line."]
	quest.4D5001100000013A.quest_subtitle: "Protect the aquarine steel kit."
	quest.4D5001100000013A.title: "Aquarine Steel Armor"
	quest.4D5001100000013B.quest_desc: ["Craft a Claw Robot Arm and an Augmentation Station Extension. These two items advance the Nautec robotic-work branch."]
	quest.4D5001100000013B.quest_subtitle: "Extend the Nautec work line."
	quest.4D5001100000013B.title: "Robotic Augmentation"
	quest.4D5001100000013C.quest_desc: ["Craft a Dolphin Fin and a Guardian Eye. This optional node records the final Nautec guardian components."]
	quest.4D5001100000013C.quest_subtitle: "Optional: finish the guardian components."
	quest.4D5001100000013C.title: "Aquatic Guardian Components"
	quest.4D50011000000200.quest_desc: [
		"Electrodynamics machines have upgrade slots, and this age unlocks the good ones. The &bAdvanced Capacity Upgrade&r, &bAdvanced Speed Upgrade&r, and &bUnbreaking Upgrade&r slot straight into a machine's upgrade slots the same way the basic capacity upgrade did back in the industrial era."
		"Advanced capacity deepens the machine's energy buffer, advanced speed pushes its work rate well past what the basic tiers allowed, and unbreaking protects against wear. Mix them to taste: a speed-stacked machine wants the deeper buffer to smooth its power draw."
		"This node is optional depth. Craft all three, drop them into the machines hanging off your LV and MV chargers, and watch the same old lineup run like new hardware."
	]
	quest.4D50011000000200.quest_subtitle: "Advanced capacity, speed, and unbreaking upgrades."
	quest.4D50011000000200.title: "Advanced Upgrades"
	quest.4D53010000010000.quest_desc: ["Forge &6Oritech&r's &bmachine cores&r five and seven, with the &bmachine extender&r and &bduratium&r that frame them. Core tier is the ceiling on every machine the fleet runs, and this chapter raises the ceiling twice."]
	quest.4D53010000010000.quest_subtitle: "The fleet outgrows itself."
	quest.4D53010000010000.title: "Machine Cores 5 and 7"
	quest.4D53010000010001.quest_desc: ["Set up the &bAtomic Forge&r with the &bfragment forge&r and &bparticle collector&r beside it. Together they work matter at the scale this age is named for; the fleet's endgame recipes route through all three."]
	quest.4D53010000010001.quest_subtitle: "The fleet's deep workshop."
	quest.4D53010000010001.title: "Atomic Forge"
	quest.4D53010000010002.quest_desc: ["Assemble the &bLarge Simulation Chamber&r from &6Hostile Neural Industrialization&r. The multiblock runs whole batches of mob simulations at once. It rebuilds the gilded sim loop at industrial width."]
	quest.4D53010000010002.quest_subtitle: "The fights scale up."
	quest.4D53010000010002.title: "Large Simulation Chamber"
	quest.4D53010000010003.quest_desc: ["Finish the neural wing with the &bLarge Loot Fabricator&r. Predictions go in at industrial volume and loot comes out the same way."]
	quest.4D53010000010003.quest_subtitle: "The machine soul signs off."
	quest.4D53010000010003.title: "Large Loot Fabricator"
	quest.4D53011000000100.quest_desc: ["Add a &bMono Loot Fabricator&r. Locked to a single prediction type it fabricates that one drop endlessly, the dedicated lane for whatever material your factories burn fastest."]
	quest.4D53011000000100.quest_subtitle: "One drop, on tap."
	quest.4D53011000000100.title: "Mono Loot Fabricator"
	quest.4D53011000000101.quest_desc: ["Install the &belectric simulation chamber&r for the side lab. It runs leaner than the multiblock and slots into a machine row, simulation for bases that ration their floor space."]
	quest.4D53011000000101.quest_subtitle: "Compact simulation processing."
	quest.4D53011000000101.title: "Electric Sim Chamber"
	quest.4D53011000000102.quest_desc: ["Build any &6More Machines&r factory or the evolved &balloyer&r line's entry. The addon mods teach machines that never had factory forms to run in parallel lanes, and this wing's ladder climbs through every tier they ship."]
	quest.4D53011000000102.quest_subtitle: "Every machine, factory-wide."
	quest.4D53011000000102.title: "New Factory Lines"
	quest.4D53011000000103.quest_desc: ["Upgrade any line to an &badvanced factory&r. Three process lanes share one power buffer and one footprint, and the &btier installer&r in the reward upgrades a placed machine without breaking it down."]
	quest.4D53011000000103.quest_subtitle: "Three lanes per machine."
	quest.4D53011000000103.title: "Advanced Factories"
	quest.4D53011000000104.quest_desc: ["Press on to an &belite factory&r. Five parallel lanes per machine turns the processing hall into a wall of synchronized industry, and the ore backlog finally starts losing."]
	quest.4D53011000000104.quest_subtitle: "Five lanes deep."
	quest.4D53011000000104.title: "Elite Factories"
	quest.4D53011000000105.quest_desc: ["Build an &bultimate factory&r, nine lanes in one chassis. Stock Mekanism stops at this rung, and the dense and overclocked tiers beyond it politely disagree."]
	quest.4D53011000000105.quest_subtitle: "Nine lanes. Stock tops out here."
	quest.4D53011000000105.title: "Ultimate Factories"
	quest.4D53011000000106.quest_desc: ["Cross into the &bdense tier&r: factories, cubes, bins, conduits, or circuits from the evolved line. Everything stock called ultimate, this tier treats as a starting point."]
	quest.4D53011000000106.quest_subtitle: "Evolved factory tier."
	quest.4D53011000000106.title: "Dense Tier"
	quest.4D53011000000107.quest_desc: ["Finish the ladder with an &boverclocked&r machine. The evolved line's final tier processes faster than your logistics can feed it. The first time that's been your problem rather than the machine's."]
	quest.4D53011000000107.quest_subtitle: "Top evolved machine tier."
	quest.4D53011000000107.title: "Overclocked Tier"
	quest.4D53011000000108.quest_desc: ["Install the &bPlanting Station&r. It sows and harvests on grid power at factory-line throughput. Mekanism finally weighing in on the farm question every other mod already answered."]
	quest.4D53011000000108.quest_subtitle: "Optional: agriculture, Mekanized."
	quest.4D53011000000108.title: "Planting Station"
	quest.4D53011000000109.quest_desc: ["Feed the &bRecycler&r your obsolete machines and failed experiments. It breaks them back into usable materials. A factory hall mid-upgrade produces a lot of both."]
	quest.4D53011000000109.quest_subtitle: "Optional: scrap back to stock."
	quest.4D53011000000109.title: "Recycler"
	quest.4D5301100000010A.quest_desc: ["Add the &bSolidification Chamber&r. It casts molten and liquid feedstocks into solid forms the rest of the line can handle, the missing step between your tank farm and your item pipes."]
	quest.4D5301100000010A.quest_subtitle: "Optional: liquids take shape."
	quest.4D5301100000010A.title: "Solidification Chamber"
	quest.4D5301100000010B.quest_desc: ["Raise the &blarge chemical infuser&r and &blarge rotary condensentrator&r with their casings. The bench chemistry of last chapter rebuilt at multiblock scale, for gas volumes a single machine would choke on."]
	quest.4D5301100000010B.quest_subtitle: "Optional: multiblock chemistry."
	quest.4D5301100000010B.title: "Large Chemistry"
	quest.4D5301100000010C.quest_desc: ["Pair the &bwireless charging&r and &btransmission stations&r. One tops up your gear as you walk the halls, the other beams grid power to receivers with no cable run at all."]
	quest.4D5301100000010C.quest_subtitle: "Optional: current, broadcast."
	quest.4D5301100000010C.title: "Wireless Power Stations"
	quest.4D5301100000010D.quest_desc: ["Craft any upgraded &bpersonal chest or barrel&r. The evolved tiers deepen the locked storage that travels with you, the one inventory no teammate and no machine can touch."]
	quest.4D5301100000010D.quest_subtitle: "Optional: yours and only yours."
	quest.4D5301100000010D.title: "Personal Vaults"
	quest.4D5301100000010E.quest_desc: ["Build an evolved-tier &bsolar generator&r, advanced through ultimate. Each tier multiplies the panel field's yield, and the ultimate array makes daylight a serious line item on the grid."]
	quest.4D5301100000010E.quest_subtitle: "Optional: the roof keeps climbing."
	quest.4D5301100000010E.title: "Solar Tiers"
	quest.4D5301100000010F.quest_desc: ["Press &6Modern Industrialization&r's &bhighly advanced casing&r and hull. This is the chassis the EV tier rides on, and the titanium and chromium plate in its bill of materials is why your metallurgy came first."]
	quest.4D5301100000010F.quest_subtitle: "The EV chassis."
	quest.4D5301100000010F.title: "Highly Advanced Casings"
	quest.4D53011000000110.quest_desc: ["Roll &bsolid titanium casings&r and the piped variant. Several of MI's late multiblocks specify titanium internals, and the metal's whole personality is refusing to fail."]
	quest.4D53011000000110.quest_subtitle: "Optional: the light-strong frame."
	quest.4D53011000000110.title: "Titanium Casings"
	quest.4D53011000000111.quest_desc: ["Craft &bEV energy hatches&r, in and out. Extreme voltage is what the atomic multiblocks drink, and these hatches are the only sockets rated for it."]
	quest.4D53011000000111.quest_subtitle: "The heaviest plugs yet."
	quest.4D53011000000111.title: "EV Energy Hatches"
	quest.4D53011000000112.quest_desc: ["Wire the &bEV grid&r: transformers both directions, the EV storage unit, EV cable, and the tesla receiver hatch for wireless feeds. The factory's spine now carries extreme voltage end to end."]
	quest.4D53011000000112.quest_subtitle: "Optional: the trunk line hardens."
	quest.4D53011000000112.title: "EV Grid"
	quest.4D53011000000113.quest_desc: ["Fit the &bhighly advanced&r item and fluid hatches. The EV multiblocks move material at rates the turbo tier never imagined, and these are the only doors wide enough."]
	quest.4D53011000000113.quest_subtitle: "Optional: the fire-hose fittings."
	quest.4D53011000000113.title: "Highly Advanced Hatches"
	quest.4D53011000000114.quest_desc: ["Commission the &bLarge Diesel Generator&r. The unified diesel line you built two ages ago feeds it, and the multiblock pays out EV current at a rate that justifies every refinery you ever expanded."]
	quest.4D53011000000114.quest_subtitle: "Optional: the oil spine's last word."
	quest.4D53011000000114.title: "Large Diesel Generator"
	quest.4D53011000000115.quest_desc: ["Build the &bMulti Processing Array&r from &6Industrialization Overdrive&r. It racks entire machines inside one multiblock and runs them as a single block of industry."]
	quest.4D53011000000115.quest_subtitle: "Optional: machines all the way in."
	quest.4D53011000000115.title: "Multi Processing Array"
	quest.4D53011000000116.quest_desc: ["Fabricate the &b256M cell component&r. The gilded grid stopped at 64M and called the rest an atomic secret; this is the secret. One component, a quarter-billion units of storage."]
	quest.4D53011000000116.quest_subtitle: "The promised megabytes."
	quest.4D53011000000116.title: "256M Cell Component"
	quest.4D53011000000117.quest_desc: ["Shell a &b256M cell&r for items, fluids, or chemicals. A single one swallows entire eras of your stockpile, and a drive bay of them is the last storage decision you will make this side of infinity."]
	quest.4D53011000000117.quest_subtitle: "Optional: the deep archive."
	quest.4D53011000000117.title: "256M Storage Cells"
	quest.4D53011000000118.quest_desc: ["Carry a &bportable cell workbench&r. It edits cell partitions from your inventory, so re-tasking a megabyte cell costs a click instead of a walk back to the lab."]
	quest.4D53011000000118.quest_subtitle: "Optional: partition on the go."
	quest.4D53011000000118.title: "Portable Cell Workbench"
	quest.4D53011000000119.quest_desc: ["Craft any &bportable MEGA cell&r: item, fluid, or chemical, one megabyte to two hundred fifty-six. It is a self-contained slice of your network that travels in a hotbar slot."]
	quest.4D53011000000119.quest_subtitle: "Optional: a warehouse in your pocket."
	quest.4D53011000000119.title: "Portable MEGA Cells"
	quest.4D5301100000011A.quest_desc: ["Fabricate &6ExtraDisks&r' &badvanced casing&r and the &bwithering processor&r. The processor's recipe asks your wither farm for its star material, and the infinite storage tier ahead asks for the processor."]
	quest.4D5301100000011A.quest_subtitle: "Optional: the grim component."
	quest.4D5301100000011A.title: "Withering Processor"
	quest.4D5301100000011B.quest_desc: ["Assemble the &binfinite item storage&r part, block, and disk. Refined Storage stops counting at this tier, and so can you."]
	quest.4D5301100000011B.quest_subtitle: "Optional: the count stops mattering."
	quest.4D5301100000011B.title: "Infinite Item Storage"
	quest.4D5301100000011C.quest_desc: ["Extend the infinite tier to &bfluids and chemicals&r. Every tank farm and gas cellar you built becomes a museum exhibit the day these disks spin up."]
	quest.4D5301100000011C.quest_subtitle: "Optional: lakes and atmospheres."
	quest.4D5301100000011C.title: "Infinite Fluids and Gases"
	quest.4D5301100000011D.quest_desc: ["Upgrade the cable parts to &bmega&r: importer, exporter, constructor, destructor. CableTiers' final tier moves inventories whole, the logistics to match your infinite disks."]
	quest.4D5301100000011D.quest_subtitle: "Optional: the ultra tier was a warmup."
	quest.4D5301100000011D.title: "Mega Cable Kit"
	quest.4D5301100000011E.quest_desc: ["Finish the tier with the &bmega autocrafter&r and both &bmega interfaces&r. Pattern queues and stock-keeping at the same scale as everything else in this wing: excessive, and exactly enough."]
	quest.4D5301100000011E.quest_subtitle: "Optional: the last RS hardware."
	quest.4D5301100000011E.title: "Mega Crafting and Interfaces"
	quest.4D5301100000011F.quest_desc: ["Forge the &bNetherite Crafter&r with the advanced importer and exporter beside it. The diamond tier you finished in the gilded age hands over to metal that has seen the Nether."]
	quest.4D5301100000011F.quest_subtitle: "Optional: ExtraStorage tops out."
	quest.4D5301100000011F.title: "Netherite Crafter"
	quest.4D53011000000120.quest_desc: ["Link a &bWireless Grid&r and stack &brange upgrades&r into the transmitter. Refined Storage's whole inventory rides along wherever you walk, and the reward crafting grid adds the bench."]
	quest.4D53011000000120.quest_subtitle: "Optional: the grid in your hand."
	quest.4D53011000000120.title: "RS Wireless Grid"
	quest.4D53011000000121.quest_desc: ["Place an &bautocrafting monitor&r, any color, or carry the wireless version. The crafting queue becomes a wall display, and canceling a misfired million-item job becomes a one-click mercy."]
	quest.4D53011000000121.quest_subtitle: "Optional: watch the queue from anywhere."
	quest.4D53011000000121.title: "Autocrafting Monitors"
	quest.4D53011000000122.quest_desc: ["Frame a region in &bspatial pylons&r and wire the &bspatial IO port&r. AE2 cuts the enclosed space into a cell, machines, walls, air, and all. The factory wing you built last month is now an item."]
	quest.4D53011000000122.quest_subtitle: "Optional: store the room itself."
	quest.4D53011000000122.title: "Spatial IO"
	quest.4D53011000000123.quest_desc: ["Place a &bSpatial Anchor&r on the network. It keeps every chunk your grid touches loaded, which your autocrafting queue will quietly thank you for at four in the morning."]
	quest.4D53011000000123.quest_subtitle: "Optional: the network stays awake."
	quest.4D53011000000123.title: "Spatial Anchor"
	quest.4D53011000000124.quest_desc: ["Install &6Advanced AE&r's &badvanced pattern providers&r, full and small. They hold deeper pattern libraries per face than anything the gilded grid shipped, and the upgrades beside them go deeper still."]
	quest.4D53011000000124.quest_subtitle: "Optional: dispatch, doubled."
	quest.4D53011000000124.title: "Advanced Pattern Providers"
	quest.4D53011000000125.quest_desc: ["Slot the &bprovider upgrades&r, speed and capacity. The dispatch desks of your autocrafting floor learn to hold more patterns and push them faster."]
	quest.4D53011000000125.quest_subtitle: "Advanced AE provider capacity."
	quest.4D53011000000125.title: "Provider Upgrades"
	quest.4D53011000000126.quest_desc: ["Frame the &bAssembler Matrix&r: frames, walls, and glass. The multiblock replaces whole walls of molecular assemblers with one structure; the function block quests ahead are its organs."]
	quest.4D53011000000126.quest_subtitle: "Optional: assemble the crafting matrix."
	quest.4D53011000000126.title: "Assembler Matrix Shell"
	quest.4D53011000000127.quest_desc: ["Each block controls throughput, pattern capacity, or cycle time."]
	quest.4D53011000000127.quest_subtitle: "Optional: crafters, patterns, speed."
	quest.4D53011000000127.title: "Matrix Internals"
	quest.4D53011000000128.quest_desc: ["Upgrade to the &bex inscriber&r and &bex charger&r. ExtendedAE's machine forms chew through circuit pressing and crystal charging at rates the originals never promised."]
	quest.4D53011000000128.quest_subtitle: "Optional: presses without patience."
	quest.4D53011000000128.title: "Ex Inscriber and Charger"
	quest.4D53011000000129.quest_desc: ["Swap busy single blocks for the &bex assembler&r, &bex pattern provider&r, and &bex interface&r. Everywhere the matrix is overkill, these carry the load instead."]
	quest.4D53011000000129.quest_subtitle: "Optional: the singles, upgraded."
	quest.4D53011000000129.title: "Ex Crafting Hardware"
	quest.4D5301100000012A.quest_desc: ["Mount the &bex drive&r and &bex IO port&r. More cells per block and faster rebalancing, sized for the 256M tier this wing fabricates."]
	quest.4D5301100000012A.quest_subtitle: "Optional: the bay grows teeth."
	quest.4D5301100000012A.title: "Ex Drive and IO"
	quest.4D5301100000012B.quest_desc: ["Add the &bingredient buffer&r, &boversize interface&r, and &bcaner&r. Between them they hold mid-craft ingredients, stock oversized stacks, and can fluids into cells, the three chores the stock grid never quite solved."]
	quest.4D5301100000012B.quest_subtitle: "Optional: the odd jobs covered."
	quest.4D5301100000012B.title: "Buffers and Caners"
	quest.4D5301100000012C.quest_desc: ["Install the &bcircuit cutter&r and &bcrystal fixer&r. One cuts printed circuits without press plates, the other repairs budding certus so a quartz farm never decays. Quiet little machines that retire two old chores."]
	quest.4D5301100000012C.quest_subtitle: "Optional: presses and patches."
	quest.4D5301100000012C.title: "Cutter and Fixer"
	quest.4D5301100000012D.quest_desc: ["Attach a &bPlayer Simulator&r to your Integrated Dynamics cabling. It performs right-clicks and attacks as if you stood there, the last missing verb in your automation vocabulary."]
	quest.4D5301100000012D.quest_subtitle: "Optional: automate player actions."
	quest.4D5301100000012D.title: "Player Simulator"
	quest.4D5301100000012E.quest_desc: ["Forge &6IFEU&r's &bultimate machine frame&r. Industrial Foregoing's chassis ladder gets one more rung in this pack, and the machines in this annex are what it carries."]
	quest.4D5301100000012E.quest_subtitle: "Optional: the frame beyond supreme."
	quest.4D5301100000012E.title: "Ultimate Machine Frame"
	quest.4D5301100000012F.quest_desc: ["Build the &bBig Dissolution Chamber&r. It runs the soaked-crafting recipes in batch, which matters now that your frames and cores consume fluids by the tank."]
	quest.4D5301100000012F.quest_subtitle: "Optional: the wet bench, scaled."
	quest.4D5301100000012F.title: "Big Dissolution Chamber"
	quest.4D53011000000130.quest_desc: ["Set the &bprecision&r and &bfluid crafting tables&r with a &bblueprint&r ready. The annex's recipes demand exact placement and wet steps a normal bench cannot express, and these two can."]
	quest.4D53011000000130.quest_subtitle: "Optional: benches with standards."
	quest.4D53011000000130.title: "Precision Crafting"
	quest.4D53011000000131.quest_desc: ["Install the &bInfuser&r with &bfluid transfer&r nodes feeding it. It steeps items in process fluids to transform them, the machine form of the dissolution trick."]
	quest.4D53011000000131.quest_subtitle: "Optional: soak it in."
	quest.4D53011000000131.title: "Infuser"
	quest.4D53011000000132.quest_desc: ["Deploy the &bPlatform Builder&r. It extends solid platforms out over voids and oceans on its own, the civil-engineering machine every megabase eventually wishes it had built first."]
	quest.4D53011000000132.quest_subtitle: "Optional: floors on demand."
	quest.4D53011000000132.title: "Platform Builder"
	quest.4D53011000000134.quest_desc: ["Fit the &bsculk laser lens&r and process &bliquid sculk matter&r into &bsculk gears&r. The laser drill learns to mine the deep dark's substance, and the annex turns it into machine parts."]
	quest.4D53011000000134.quest_subtitle: "Optional: the deep dark, industrialized."
	quest.4D53011000000134.title: "Sculk Processing"
	quest.4D53011000000135.quest_desc: ["Stock &bnetherite gears&r and &bmalic acid&r by the bucket. They are the annex's recurring ingredients, and having both on the shelf is the difference between crafting and waiting."]
	quest.4D53011000000135.quest_subtitle: "Malic acid and netherite parts."
	quest.4D53011000000135.title: "Acid and Alloy"
	quest.4D53011000000136.quest_desc: ["Craft any &bIFEU addon&r: apple, chance, energy, heal, thread, or silk, in their ranks. Each slots into the annex machines and bends a stat, and the full drawer is a tinkerer's afternoon well spent."]
	quest.4D53011000000136.quest_subtitle: "Optional: tune the annex."
	quest.4D53011000000136.title: "IFEU Addons"
	quest.4D53011000000138.quest_desc: ["Complete the mycelial family with the &bhalitosis&r, &bmeatallurgic&r, and &bnether star&r generators. The collection you started in the gilded refinery ends with a generator that burns nether stars."]
	quest.4D53011000000138.quest_subtitle: "Optional: the last three appetites."
	quest.4D53011000000138.title: "Mycelial Finale"
	quest.4D53011000000139.quest_desc: ["Build the &bMycelial Reactor&r. It only wakes when every mycelial generator type around it is running at once, and then it outpays the whole bank combined. The completed collection turns out to have been a power plant blueprint."]
	quest.4D53011000000139.quest_subtitle: "Optional: the collection pays out."
	quest.4D53011000000139.title: "Mycelial Reactor"
	quest.4D5301100000013A.quest_desc: ["Upgrade the furnace line to &bnetherite&r. The smelting ladder you have climbed since the dark ages has exactly one rung left after this, and it is not made of metal at all."]
	quest.4D5301100000013A.quest_subtitle: "Optional: the old ladder's last metal."
	quest.4D5301100000013A.title: "Netherite Furnace"
	quest.4D5301100000013B.quest_desc: ["Forge the &bRainbow Furnace&r, the top of the furnace ladder. It smelts at speeds that round to instant."]
	quest.4D5301100000013B.quest_subtitle: "Optional: the top of the furnace ladder."
	quest.4D5301100000013B.title: "Rainbow Furnace"
	quest.4D5301100000013C.quest_desc: [
		"Titanium is the atomic tier of MI's handheld ladder. The titanium drill digs faster than stainless and holds a bigger energy buffer."
		"Craft it from your titanium line and charge it like any MI electric tool. From here on your mining speed is a power question, not a material one."
	]
	quest.4D5301100000013C.quest_subtitle: "The atomic-age digger."
	quest.4D5301100000013C.title: "Titanium Drill"
	quest.4D5301100000013D.quest_desc: [
		"Quantum circuits and robot arms are the load-bearing components of MI's late tree. Nearly every high-tier machine consumes them silently."
		"Set up automated production now: the circuit line through your assembler, and robot arms from titanium and electronics."
		"Stockpile both. The fusion and quantum tiers ahead eat them in stacks."
	]
	quest.4D5301100000013D.quest_subtitle: "The parts your machines eat."
	quest.4D5301100000013D.title: "Circuits and Arms"
	quest.4D5301100000013E.quest_desc: [
		"Extended Industrialization's nano armor is a full powered set. Each piece drains energy instead of durability, so keep the set charged."
		"The nano saber is the matching weapon. It hits hard while powered and goes dull when the buffer empties."
		"Craft all four pieces and the saber. This set carries you until the quantum and gravi tiers in the next age."
	]
	quest.4D5301100000013E.quest_subtitle: "Powered armor and the saber."
	quest.4D5301100000013E.title: "Nano Suit"
	quest.4D61009737D94BDA.quest_desc: [
		"Grow to twenty-five citizens. At this size couriers, crafters, and guards all work in parallel and the town runs itself between your orders."
		"Housing and food are your limiting factors now, so plan ahead."
	]
	quest.4D61009737D94BDA.quest_subtitle: "The colony starts to hum."
	quest.4D61009737D94BDA.title: "Twenty-Five Citizens"
	quest.4D9DC4973FD340E5.quest_desc: [
		"Construct the &bCombat Academy&r. It trains melee guards, raising their skill so they survive longer in a real fight."
		"Pair it with the &bBarracks&r to turn a row of recruits into a proper garrison."
	]
	quest.4D9DC4973FD340E5.quest_subtitle: "Train your knights."
	quest.4D9DC4973FD340E5.title: "Combat Academy"
	quest.4DD7E2BD8508A117.quest_desc: [
		"Get all of your animal herders running at once. A colony raising its own cattle, pigs, chickens, sheep, and rabbits feeds and clothes itself without you hunting a thing."
		"This fires once the whole pen is staffed and working."
	]
	quest.4DD7E2BD8508A117.quest_subtitle: "Every herder at work."
	quest.4DD7E2BD8508A117.title: "Full Pasture"
	quest.4E44010000010000.quest_desc: ["Pull your first &braw uranium&r out of the deep stone. The Void Titan's fall opened this age, and the ore in your hand is what it was guarding."]
	quest.4E44010000010000.quest_subtitle: "The dawn has a glow to it."
	quest.4E44010000010000.title: "Raw Uranium"
	quest.4E44010000010001.quest_desc: ["Mix the dust into molten uranium at a mechanical mixer, then compact the fluid into &byellowcake&r. This dull brick is the standard currency of the main fission fuel lines, and three different mods will ask you for their own version of it before the chapter is out."]
	quest.4E44010000010001.quest_subtitle: "The first concentrate."
	quest.4E44010000010001.title: "Yellowcake"
	quest.4E44010000010002.quest_desc: ["Assemble &6Create: Nuclear&r's reactor: casing, core, frame, coolers, input and output, reinforced glass, and the blueprint that plans it. It pays out rotation rather than current, a reactor with a crankshaft. Graphite rods steady it while it runs."]
	quest.4E44010000010002.quest_subtitle: "The first pile."
	quest.4E44010000010002.title: "Create Reactor"
	quest.4E44010000010003.quest_desc: ["Raise the &bChemical Bench&r multiblock from &6Chemical Science&r. Its controller runs the wet processes the new age leans on, and the machines beside it in this chapter all feed from its outputs."]
	quest.4E44010000010003.quest_subtitle: "The lab goes atomic."
	quest.4E44010000010003.title: "Chemical Bench"
	quest.4E44010000010004.quest_desc: ["Keep the finished uranium rod. It proves the fuel chain; the reactor loop opens in the next chapter."]
	quest.4E44010000010004.quest_subtitle: "Nuclear dawn capstone."
	quest.4E44010000010004.title: "Uranium Rod"
	quest.4E44010000010005.quest_desc: ["Build the &bSpin Coater&r. It lays polymer films across plates and boards in even coats, the finishing step for the age's electronics. The polymer feedstock comes off your own chemical bench."]
	quest.4E44010000010005.quest_subtitle: "Thin films, fine machines."
	quest.4E44010000010005.title: "Spin Coater"
	quest.4E44011000000100.quest_desc: ["Crush the raw ore at your crushing wheels. In this pack the crush comes out as unified &buranium dust&r, which the mixing step drinks through the shared dust tag. The dust is exactly as unfriendly as it looks, so keep the hazmat rack nearby stocked."]
	quest.4E44011000000100.quest_subtitle: "Crush before you cook."
	quest.4E44011000000100.title: "Uranium Dust"
	quest.4E44011000000101.quest_desc: ["Enrich the yellowcake into &benriched yellowcake&r. The mechanical crafters fold it into fuel rods from here, and the reactor next door is already waiting on its first load."]
	quest.4E44011000000101.quest_subtitle: "Brighter and meaner."
	quest.4E44011000000101.title: "Enriched Yellowcake"
	quest.4E44011000000102.quest_desc: ["Craft the &breactor controller&r, the one Create reactor part with a nether star in the bill. It reads the blueprint, watches the rods, and decides when the pile runs. No controller, no startup."]
	quest.4E44011000000102.quest_subtitle: "A nether star at the helm."
	quest.4E44011000000102.title: "Reactor Controller"
	quest.4E44011000000103.quest_desc: ["Install the &bCircuitmaker&r. Atomic machinery wants denser boards than your gilded factories printed, and this bench builds them in place. Its appetite for polymers is what the spin coater line answers."]
	quest.4E44011000000103.quest_subtitle: "Boards for the new machines."
	quest.4E44011000000103.title: "Circuitmaker"
	quest.4E44011000000104.quest_desc: ["Set up the &6Nuclear Science&r &bGas Centrifuge&r. Fed processed uranium gas, it separates the useful isotope from the filler. It is the most important machine in the fuel pipeline you are about to build."]
	quest.4E44011000000104.quest_subtitle: "Spin the isotopes apart."
	quest.4E44011000000104.title: "Gas Centrifuge"
	quest.4E44011000000105.quest_desc: ["Add a &bFuel Reprocessor&r. Burned fuel still holds value, and this machine recovers it instead of letting it rot in a containment chest. The reward dust is a preview of the recovered material it will hand you."]
	quest.4E44011000000105.quest_subtitle: "Spent is not finished."
	quest.4E44011000000105.title: "Fuel Reprocessor"
	quest.4E44011000000106.quest_desc: ["Install the &bRadioactive Processor&r for the ores and dusts too hot for ordinary machines. It does the dirty intermediate work of the fuel chain so your regular processing line never has to touch it."]
	quest.4E44011000000106.quest_subtitle: "Hot material, careful hands."
	quest.4E44011000000106.title: "Radioactive Processor"
	quest.4E44011000000107.quest_desc: ["Produce both grades of &bpolymer stock&r at the chemical bench. The flexible grade lines pipes and cables; the rigid grade armors the machines that take a beating. The coater spends both by the stack."]
	quest.4E44011000000107.quest_subtitle: "Sheets the coater drinks."
	quest.4E44011000000107.title: "Polymer Stock"
	quest.4E44011000000108.quest_desc: ["Coat an &borganic solar panel&r. The films you just learned to lay become a generator with no moving parts, and a roof of them quietly pays for the lab below."]
	quest.4E44011000000108.quest_subtitle: "Film that earns."
	quest.4E44011000000108.title: "Organic Solar Panel"
	quest.4E44011000000109.quest_desc: ["Stitch &6Mekanism&r's full &bhazmat suit&r before anything else in this chapter touches your bare hands. Radiation in this age is a real mechanic with a real meter, and the suit is what keeps the meter boring."]
	quest.4E44011000000109.quest_subtitle: "Dress for the work."
	quest.4E44011000000109.title: "Hazmat Suit"
	quest.4E4401100000010A.quest_desc: ["Hang any piece of the &6Nuclear Science&r &bhazmat set&r by the lab door. Its shielding is tuned to that mod's own sources, and a spare suit means a torn glove never stops a shift."]
	quest.4E4401100000010A.quest_subtitle: "Optional: the second suit."
	quest.4E4401100000010A.title: "Lab Hazmat"
	quest.4E4401100000010B.quest_desc: ["Craft any &breinforced hazmat&r armor piece here; one piece satisfies this quest. Wear the full reinforced set before reactor-floor work. The plating shrugs off the field strengths that the standard suit only slows."]
	quest.4E4401100000010B.quest_subtitle: "Optional: for the reactor floor."
	quest.4E4401100000010B.title: "Reinforced Hazmat"
	quest.4E4401100000010C.quest_desc: ["Craft any &6Alex's Caves&r &bhazmat&r armor piece here; one piece satisfies this quest. Wear the full set before cave radiation work. The primordial depths have their own radiation rules."]
	quest.4E4401100000010C.quest_subtitle: "Optional: for the glowing caves."
	quest.4E4401100000010C.title: "Caver's Hazmat"
	quest.4E4401100000010D.quest_desc: ["Prospect a &buranium vein&r, any mod's will do: Mekanism, the unified ores, or Electrodynamics all seed the deep layers. The locks came off this rock the moment the age turned. Mine more than you think you need; the reward casks start your stockpile."]
	quest.4E4401100000010D.quest_subtitle: "Every mod has a vein."
	quest.4E4401100000010D.title: "Strike Uranium"
	quest.4E4401100000010E.quest_desc: ["Dig out &bthorium&r where the uranium runs thin. It burns slower and cleaner in the salt reactors ahead, and the chemists upstairs have a catalyst recipe with its name on it."]
	quest.4E4401100000010E.quest_subtitle: "Optional: the patient fuel."
	quest.4E4401100000010E.title: "Thorium Vein"
	quest.4E4401100000010F.quest_desc: ["Haul &bazure&r and &bscarlet neodymium&r out of the magnetic caves. The two ores repel and attract along the cave's own field lines, and the smelted ingots in the reward are the start of everything magnetic this age builds."]
	quest.4E4401100000010F.quest_subtitle: "Optional: the magnet metals."
	quest.4E4401100000010F.title: "Neodymium Lodes"
	quest.4E44011000000110.quest_desc: ["Recover a &buranium rod&r or a &bfissile core&r from the toxic depths of &6Alex's Caves&r. The caves ran their own nuclear age long before you arrived, and their leftovers slot straight into your stockpile."]
	quest.4E44011000000110.quest_subtitle: "Optional: the caves were here first."
	quest.4E44011000000110.title: "Toxic Salvage"
	quest.4E44011000000111.quest_desc: ["Mine &6Create: New Age&r's own &bthorium ore&r. Its reactor line runs on this vein specifically, and the refined sample in the reward shows where the fuel chain is headed."]
	quest.4E44011000000111.quest_subtitle: "Optional: a second opinion on thorium."
	quest.4E44011000000111.title: "New Age Thorium"
	quest.4E44011000000112.quest_desc: ["Refine the ore into &bnuclear fuel&r for the New Age reactor. The processing chain runs on your existing Create infrastructure, no new factory required, which is exactly this mod's charm."]
	quest.4E44011000000112.quest_subtitle: "Optional: rods for the rotary pile."
	quest.4E44011000000112.title: "Nuclear Fuel"
	quest.4E44011000000113.quest_desc: ["Assemble the &bNew Age thorium reactor&r: casing, rods, fuel acceptor, vents, glass, and the heat pump that moves its output. It produces heat your Create generators turn into work. The reactor belongs to the same family as your gearboxes."]
	quest.4E44011000000113.quest_subtitle: "Optional: heat for the magnet age."
	quest.4E44011000000113.title: "Thorium Reactor"
	quest.4E44011000000114.quest_desc: ["Build a &bgem generator&r from &6Generator Galore&r: diamond, emerald, or ender. Each burns its namesake for dense FE, a compact stopgap while the reactors warm up."]
	quest.4E44011000000114.quest_subtitle: "Optional: burn the jewelry box."
	quest.4E44011000000114.title: "Gem Generators"
	quest.4E44011000000115.quest_desc: ["Upgrade to an &b8x gem generator&r. Eight burn chambers in one block, for the bases that decided gem-burning was a lifestyle rather than a stopgap."]
	quest.4E44011000000115.quest_subtitle: "Optional: eight in one box."
	quest.4E44011000000115.title: "Octuple Generators"
	quest.4E44011000000116.quest_desc: ["Print a tier four, five, or six &bphotovoltaic cell&r from &6Solar Flux&r. The atomic-age cells embarrass everything your gilded roof carried, and the panels stack their output into one tidy block."]
	quest.4E44011000000116.quest_subtitle: "Optional: the roof pays better now."
	quest.4E44011000000116.title: "Photovoltaics IV-VI"
	quest.4E44011000000117.quest_desc: ["Stack &badvanced&r and &bvibrant capacitor banks&r from &6EnderIO&r. Reactor output comes in surges, and a wall of these smooths the surge into supply. They gang together into one shared battery the size of your patience."]
	quest.4E44011000000117.quest_subtitle: "Optional: deeper buffers for hotter grids."
	quest.4E44011000000117.title: "Capacitor Banks"
	quest.4E44011000000118.quest_desc: ["Fit a &bphotovoltaic module&r onto your EnderIO arrays, energetic, pulsating, or vibrant grade. They feed the capacitor wall directly, daylight straight into the buffer."]
	quest.4E44011000000118.quest_subtitle: "Optional: EnderIO catches rays."
	quest.4E44011000000118.title: "Photovoltaic Modules"
	quest.4E44011000000119.quest_desc: ["Install a &bGas-Burning Generator&r. Fed ethylene off a bio line it produces serious, steady current, the workhorse generator of every Mekanism base that has not gone fission yet."]
	quest.4E44011000000119.quest_subtitle: "Optional: ethylene pays rent."
	quest.4E44011000000119.title: "Gas-Burning Generator"
	quest.4E4401100000011A.quest_desc: ["Bolt down the &6Electrodynamics&r &bLathe&r. It turns rough stock into the precision parts the atomic machines specify, and nothing else in the shop cuts to its tolerances."]
	quest.4E4401100000011A.quest_subtitle: "Precision enters the shop."
	quest.4E4401100000011A.title: "Lathe"
	quest.4E4401100000011B.quest_desc: ["Assemble a &bMotor Complex&r. It is the drive block the mod's heavy machinery hangs off, and the quarry two quests over refuses to dig without one geared in."]
	quest.4E4401100000011B.quest_subtitle: "Torque by the rack."
	quest.4E4401100000011B.title: "Motor Complex"
	quest.4E4401100000011C.quest_desc: ["Deploy the &bElectrodynamics Quarry&r with its motor complex and frame. It strips terrain in clean slices on grid power, and its appetite finally gives your new generators something to do all day."]
	quest.4E4401100000011C.quest_subtitle: "Optional: the pit, electrified."
	quest.4E4401100000011C.title: "ED Quarry"
	quest.4E4401100000011D.quest_desc: ["Mount an &bHV charger&r on the workshop wall. The atomic age's battery tools drain fast and charge faster, and high voltage is the only plug that keeps up."]
	quest.4E4401100000011D.quest_subtitle: "Optional: the fast plug."
	quest.4E4401100000011D.title: "HV Charger"
	quest.4E4401100000011E.quest_desc: ["Build a &bcarbyne battery box&r. The exotic carbon lattice holds a staggering charge per block, the battery the HV side of your grid has been pretending it had."]
	quest.4E4401100000011E.quest_subtitle: "Optional: the dense bank."
	quest.4E4401100000011E.title: "Carbyne Battery Box"
	quest.4EEF0962CC249F30.quest_desc: [
		"Staff a Cook's Hut. The Cook serves prepared meals that keep citizens fed and content far better than raw food, which keeps everyone working."
		"Feed it from your farms, herders, and &bbakery&r."
	]
	quest.4EEF0962CC249F30.quest_subtitle: "Keep the citizens fed."
	quest.4EEF0962CC249F30.title: "Cook's Hut"
	quest.4F43010000010000.quest_desc: ["Slot a &bmachine processing addon&r into the fleet. Addons are how &6Oritech&r machines specialize past their cores, and this chapter's ladder runs from this first board to tier nine."]
	quest.4F43010000010000.quest_subtitle: "The fleet learns new verbs."
	quest.4F43010000010000.title: "Processing Addon"
	quest.4F43010000010001.quest_desc: ["Manufacture the &baccelerator motor&r, &bring&r, and &bsensor&r. They are the working organs of Oritech's particle accelerator, and the loop you lay with them decides how fast your particles fly."]
	quest.4F43010000010001.quest_subtitle: "Motor, ring, sensor."
	quest.4F43010000010001.title: "Accelerator Parts"
	quest.4F43010000010002.quest_desc: ["Install the &bcross-dimensional addon&r from &6Oritech Things&r. It lets fleet machines act across dimension lines, which the chaos gate two chapters over treats as the point of the whole exercise."]
	quest.4F43010000010002.quest_subtitle: "The fleet ignores borders."
	quest.4F43010000010002.title: "Cross-Dimensional Addon"
	quest.4F43010000010003.quest_desc: ["Generate a stable &baccelerator magnetic field&r. A tuned loop means this Oritech hangar is ready for the recipes ahead."]
	quest.4F43010000010003.quest_subtitle: "Electronics lane capstone."
	quest.4F43010000010003.title: "Magnetic Field"
	quest.4F43010000020001.quest_desc: [
		"Oritech runs its own fission reactor, and the pack now expects you to build it. Gather the reactor kit: single rods for fuel, walls to contain the core, heat vents and heat pipes to move thermal load, a neutron reflector to boost efficiency, and an energy port plus a fuel port for input and output."
		"Place the Nuclear Reactor Controller you unlocked in the Gilded Age, then assemble the parts into a sealed core around it. Feed it uranium fuel and watch the heat balance. Rods generate power and heat; vents and pipes carry that heat away. If output stalls, add reflectors or rebalance the rod layout."
		"Double and quad rods pack more fuel into one block but run hotter. Work up to them once the basic layout holds steady. This reactor is required progression. The plutonium for its pellets comes off your grinder and laser lines as a byproduct of uranium work."
	]
	quest.4F43010000020001.quest_subtitle: "Build the Oritech fission reactor."
	quest.4F43010000020001.title: "Critical Assembly"
	quest.4F43011000000100.quest_desc: ["Forge &bmachine core 6&r to fill the gap between the cores the machine-soul chapter pressed. The accelerator and the augment stations both list it in their frames."]
	quest.4F43011000000100.quest_subtitle: "The missing rung."
	quest.4F43011000000100.title: "Machine Core 6"
	quest.4F43011000000101.quest_desc: ["Seat the &baccelerator controller&r at the head of your ring. It drives particles around the loop you built and slams them to creation at the collision point. The fleet has officially entered physics."]
	quest.4F43011000000101.quest_subtitle: "The loop closes."
	quest.4F43011000000101.title: "Accelerator Controller"
	quest.4F43011000000102.quest_desc: ["Craft the &badvanced target designator&r. It aims the fleet's lasers and placers at exact coordinates, the difference between a tool and an incident."]
	quest.4F43011000000102.quest_subtitle: "Point precisely."
	quest.4F43011000000102.title: "Advanced Target Designator"
	quest.4F43011000000103.quest_desc: ["Mount the &bparticle accelerator speed sensor&r on the loop. It reports beam velocity to your comparators, so the collision experiments run on data instead of vibes."]
	quest.4F43011000000103.quest_subtitle: "Read the ring."
	quest.4F43011000000103.title: "Speed Sensor"
	quest.4F43011000000104.quest_desc: ["Install the &baugment application&r station. It implants Oritech's augments directly into you, the machine fleet's opinion that its operator is also hardware worth upgrading."]
	quest.4F43011000000104.quest_subtitle: "The fleet upgrades you."
	quest.4F43011000000104.title: "Augment Application"
	quest.4F43011000000105.quest_desc: ["Upgrade to the &badvanced augment station&r. The second-tier augments it installs need the atomic fleet's full toolchain behind them, which by now you have."]
	quest.4F43011000000105.quest_subtitle: "Deeper implants."
	quest.4F43011000000105.title: "Advanced Augment Station"
	quest.4F43011000000106.quest_desc: ["Add the &barcane augment station&r. It researches the top augment tier, enabling late-game upgrades like flight, ore vision, and gravity control."]
	quest.4F43011000000106.quest_subtitle: "Optional: the strange tier."
	quest.4F43011000000106.title: "Arcane Augment Station"
	quest.4F43011000000107.quest_desc: ["Wire a &bspawner controller&r into a mob-farm setup. It traps the first mob that walks onto it, then spends souls harvested from nearby deaths to spawn that mob type continuously."]
	quest.4F43011000000107.quest_subtitle: "Optional: the cage, automated."
	quest.4F43011000000107.title: "Spawner Controller"
	quest.4F43011000000108.quest_desc: ["Stand the &benchanter&r with its &bcatalyst&r block. You pick a specific enchantment from its menu, paid for with energy and souls drawn from nearby catalysts instead of rolling at random."]
	quest.4F43011000000108.quest_subtitle: "Machine enchanting."
	quest.4F43011000000108.title: "Enchanter and Catalyst"
	quest.4F43011000000109.quest_desc: ["Deploy the &bDestroyer&r. Set on a machine frame, it breaks the blocks in the area below it, and with the right addons it harvests crops or quarries straight down."]
	quest.4F43011000000109.quest_subtitle: "Optional: unmaking as a service."
	quest.4F43011000000109.title: "Destroyer"
	quest.4F4301100000010A.quest_desc: ["Raise the &bbig solar panel&r. This 3x3 multiblock makes 32 to 224 RF/t depending on core quality, runs in daylight under open sky, and pushes power from its north, south, and bottom faces."]
	quest.4F4301100000010A.quest_subtitle: "Optional: the fleet's own sun farm."
	quest.4F4301100000010A.title: "Big Solar Panel"
	quest.4F4301100000010B.quest_desc: ["Plant the &bDeep Drill&r over an ore resource node and it pulls from the node forever without using it up. It takes no power from cables; feed it with an enderic laser aimed straight at it."]
	quest.4F4301100000010B.quest_subtitle: "Optional: the ore vein that never ends."
	quest.4F4301100000010B.title: "Deep Drill"
	quest.4F4301100000010C.quest_desc: ["Mount a &blaser arm&r. It fires a directed beam up to 128 blocks to mine, to carry power wirelessly to machines like the Deep Drill, or to attack mobs with a hunter addon."]
	quest.4F4301100000010C.quest_subtitle: "Optional: the fleet's cutting torch."
	quest.4F4301100000010C.title: "Laser Arm"
	quest.4F4301100000010D.quest_desc: ["Install the fleet's &bbio generator&r. It makes 64 RF/t from biomass and organic farm waste, takes addon upgrades, and automates easily off an existing crop or tree farm."]
	quest.4F4301100000010D.quest_subtitle: "Optional: the hangar composts."
	quest.4F4301100000010D.title: "Oritech Bio Generator"
	quest.4F4301100000010E.quest_desc: ["Press a &bplutonium pellet&r for the fleet's reactor. Oritech's hottest fuel burns longer and harder than anything the gilded hangar ever loaded, and the prometheum line starts in its ashes."]
	quest.4F4301100000010E.quest_subtitle: "The fleet's hot fuel."
	quest.4F4301100000010E.title: "Plutonium Pellet"
	quest.4F4301100000010F.quest_desc: ["Refine a &bprometheum ingot&r. It is the alloy at the end of Oritech's metallurgy, and the addon ladder's ninth tier is forged from it. Past this ingot, the fleet has nothing left to teach."]
	quest.4F4301100000010F.quest_subtitle: "The fleet's last metal."
	quest.4F4301100000010F.title: "Prometheum"
	quest.4F43011000000110.quest_desc: ["Craft any one &bprocessing addon&r from ranks two through five."]
	quest.4F43011000000110.quest_subtitle: "Mid processing addon."
	quest.4F43011000000110.title: "Processing Ranks II-V"
	quest.4F43011000000111.quest_desc: ["Press any one high &bprocessing rank&r, seven through nine."]
	quest.4F43011000000111.quest_subtitle: "High processing addon."
	quest.4F43011000000111.title: "Processing Ranks VII-IX"
	quest.4F43011000000112.quest_desc: ["Craft any one &bspeed addon&r from ranks two through five."]
	quest.4F43011000000112.quest_subtitle: "Mid speed addon."
	quest.4F43011000000112.title: "Speed Ranks II-V"
	quest.4F43011000000113.quest_desc: ["Build any one &bspeed addon&r from ranks seven through nine."]
	quest.4F43011000000113.quest_subtitle: "High speed addon."
	quest.4F43011000000113.title: "Speed Ranks VII-IX"
	quest.4F43011000000114.quest_desc: ["Craft any one &befficiency addon&r from ranks two through five."]
	quest.4F43011000000114.quest_subtitle: "Mid efficiency addon."
	quest.4F43011000000114.title: "Efficiency Ranks II-V"
	quest.4F43011000000115.quest_desc: ["Press any one high &befficiency rank&r, seven through nine."]
	quest.4F43011000000115.quest_subtitle: "High efficiency addon."
	quest.4F43011000000115.title: "Efficiency Ranks VII-IX"
	quest.4F43011000000116.quest_desc: ["Craft any one &befficient speed addon&r from ranks two through six."]
	quest.4F43011000000116.quest_subtitle: "Efficient speed addon."
	quest.4F43011000000116.title: "Efficient Speed II-VI"
	quest.4F43011000000117.quest_desc: ["Build any one &befficient speed&r addon from ranks seven through nine."]
	quest.4F43011000000117.quest_subtitle: "High efficient speed addon."
	quest.4F43011000000117.title: "Efficient Speed VII-IX"
	quest.4F43011000000118.quest_desc: ["Craft any one &bcapacitor addon&r from ranks two through five."]
	quest.4F43011000000118.quest_subtitle: "Mid capacitor addon."
	quest.4F43011000000118.title: "Capacitor Ranks II-V"
	quest.4F43011000000119.quest_desc: ["Press any one high &bcapacitor rank&r, seven through nine."]
	quest.4F43011000000119.quest_subtitle: "Optional: high-rank capacitor addon."
	quest.4F43011000000119.title: "Capacitor Ranks VII-IX"
	quest.4F4301100000011A.quest_desc: ["Craft any one &bacceptor addon&r from ranks two through five."]
	quest.4F4301100000011A.quest_subtitle: "Mid acceptor addon."
	quest.4F4301100000011A.title: "Acceptor Ranks II-V"
	quest.4F4301100000011B.quest_desc: ["Build any one &bacceptor&r addon from ranks six through nine."]
	quest.4F4301100000011B.quest_subtitle: "Optional: the firehose intake."
	quest.4F4301100000011B.title: "Acceptor Ranks VI-IX"
	quest.4F43011000000120.quest_desc: ["Craft the Enderic Railgun, Prometheum Pickaxe, Prometheum Battleaxe, Electric Mace, Chainsaw, and Hand Drill. This optional Oritech node records the full field-gear set."]
	quest.4F43011000000120.quest_subtitle: "Optional: assemble the field-gear set."
	quest.4F43011000000120.title: "Oritech Field Gear"
	quest.4F43012000000201.quest_desc: [
		"Purify raw uranium in &6Mekanism&r's &bPurification Chamber&r to make &bUranium Clumps&r. This is the front of Mekanism's triple-ore line: one raw uranium becomes three clumps once the chamber has oxygen and power."
		"The clump is where the mods shake hands. Mekanism publishes its clumps to the &bc:clumps/uranium&r tag, and &6Create&r's crushed raw uranium sits in the same tag. &6Oritech&r's &bCentrifuge&r reads that tag directly: a dry spin returns two &buranium dust&r plus a &bsmall plutonium dust&r byproduct, and a water-fed spin returns three dust with no byproduct. Create splashing washes the same tag for dust as well."
		"No pack recipe was added here. The tag wiring ships in the jars. Hold one clump to log the route, then decide per batch whether you want the plutonium byproduct or the third dust."
	]
	quest.4F43012000000201.quest_subtitle: "Two mods, one clump tag."
	quest.4F43012000000201.title: "Clump Crossover"
	quest.4F43012000000202.quest_desc: [
		"Fuse a &bUranite Gem&r in &6Oritech&r's &bAtomic Forge&r. Two recipes exist and both read tags: one &bcopper dust&r plus two &braw uranium&r, or one &bcopper dust&r plus two &buranium dust&r. Any mod's raw or dust uranium qualifies, so your shared dust stockpile feeds straight in."
		"Need more raw uranium? Aim a &bDeep Drill&r at a rare uranium resource node, or push raw ore through the &bGrinder&r for dust plus a plutonium byproduct."
		"The gem is the compression step. It packs two units of fuel-grade uranium into one crystal, and the Assembler presses those crystals into pellets next. The reward Fluxite goes toward the accelerator work later in this wing."
	]
	quest.4F43012000000202.quest_subtitle: "Copper dust plus uranium, fused."
	quest.4F43012000000202.title: "Uranite Refinery"
	quest.4F43012000000203.quest_desc: [
		"Press &bUranium Pellets&r in the &bAssembler&r: two &bUranite Gems&r, one &bplastic plate&r, and a &bnickel ingot&r yield two pellets. Swap the nickel for adamant or duratium and the same press yields three or four."
		"Craft one pellet into nine &bsmall pellets&r when you want finer control. In the reactor a full pellet burns for 4000 ticks and a small one for 400, so small pellets are your throttle while you learn the heat curve."
		"This quest wants one of each form in hand. Keep the press running; the dense fuel grids ahead eat pellets by the stack."
	]
	quest.4F43012000000203.quest_subtitle: "Two gems in, two pellets out."
	quest.4F43012000000203.title: "Pellet Press"
	quest.4F43012000000204.quest_desc: [
		"Upgrade the core with &bDouble&r and &bQuad Reactor Rods&r. Each tier stacks more fuel positions into one block, and every rod still needs a &bfuel port&r on top of it through the shell."
		"Density pays and punishes. Neighboring rods raise output, and &breactor reflectors&r boost the efficiency of rods beside them, but all of that heat lands on the same few coolers. Route it away with &bheat pipes&r and shed it with &bvents&r; a vent pulls more heat the bigger the temperature gap."
		"Build the grid on paper first. A layout that outruns its cooling does not warn you politely. Add fuel gradually and watch the temperature trend before you commit the full load."
	]
	quest.4F43012000000204.quest_subtitle: "More rods, more heat, more plan."
	quest.4F43012000000204.title: "Dense Fuel Grid"
	quest.4F43012000000205.quest_desc: [
		"Instrument the reactor before you push it. This quest bundles the three control-side blocks: the &bAbsorber Port&r, the &bRedstone Port&r, and the &bReactor Condenser&r."
		"The condenser absorbs 16 heat per tick from every neighboring component, the strongest passive cooling in the set. The absorber port mounts on the shell above your heat absorbers and keeps them fed with coolant. The redstone port is the safety switch: a signal blocks new fuel insertion, and a comparator can read temperature, live rod count, or stored energy depending on the mode you pick with a right click."
		"Wire the comparator back into your fuel supply and the plant regulates itself. Fuel stops flowing at the threshold you chose, the pellets already inside burn out, and the core coasts down instead of cooking."
	]
	quest.4F43012000000205.quest_subtitle: "The plant that runs itself."
	quest.4F43012000000205.title: "Reactor Instrumentation"
	quest.4F43012000000206.quest_desc: [
		"Bank a dust from the &bc:dusts/plutonium&r tag. Every nuclear mod in the pack can reach it, and this filter accepts any of them."
		"The routes: collide any &buranium dust&r with a &bFluxite&r catalyst in the &bParticle Accelerator&r. Grind any raw uranium in the &bGrinder&r for two uranium dusts plus a &bsmall plutonium dust&r. Spin uranium clumps dry in the &bCentrifuge&r for the same byproduct. Nine small dusts craft into one full dust."
		"Two pack bridges join the other plants: a &6Mekanism&r &bPlutonium Pellet&r crushes into canonical plutonium dust, and &6Nuclear Science&r's &bPlutonium-239&r macerates into the same dust in the &6MI&r &bMacerator&r."
		"This stockpile is the Oritech-to-MI chain link. The MOX Program over in Chain Reaction draws on it: eight uranium-238 dust plus one plutonium dust mixes into MOX fuel."
	]
	quest.4F43012000000206.quest_subtitle: "Every plant pays into one tag."
	quest.4F43012000000206.title: "Plutonium Stockpile"
	quest.4F43012000000207.quest_desc: [
		"Stock up on &bFluxite&r, the collision catalyst. The &bEnderic Laser&r converts a placed &bamethyst cluster&r into Fluxite in one shot, so a budding amethyst farm keeps the laser fed."
		"The accelerator makes it too: collide &belectrum dust&r with &bredstone dust&r. And if your AE2 line is running, the &bCharger&r converts amethyst directly."
		"You will spend Fluxite on plutonium collisions and on Atomic Forge dust work. A passive farm now saves manual mining runs later."
	]
	quest.4F43012000000207.quest_subtitle: "Optional: farm the catalyst."
	quest.4F43012000000207.title: "Fluxite Feedstock"
	quest.4F44011000000001.quest_desc: ["Upgrade to &6Oritech&r's &bMachine Core 4&r. Core tier caps how hard every attached machine can run, and tier four is where the deep fleet stops idling and starts pulling its weight."]
	quest.4F44011000000001.quest_subtitle: "The fleet's next heart."
	quest.4F44011000000001.title: "Advanced Machine Core"
	quest.4F44011000000002.quest_desc: ["Place the &bAssembler&r and hand it component recipes. It manufactures Oritech's own parts on a loop, which is the moment the fleet starts reproducing instead of being hand-fed. Frame it with energy and watch the queue drain."]
	quest.4F44011000000002.quest_subtitle: "Self-replicating assembly."
	quest.4F44011000000002.title: "Assembler"
	quest.4F44011000000003.quest_desc: ["Deploy the &bPlacer&r. It sets blocks into the world from its inventory on the fleet's schedule, the outward-facing hand of an otherwise inward-looking machine row."]
	quest.4F44011000000003.quest_subtitle: "Places blocks on schedule."
	quest.4F44011000000003.title: "Placer"
	quest.4F44011000000004.quest_desc: ["Stand up Oritech's &bReactor Controller&r and case out its multiblock. The fleet's reactor turns its fuel into the dense power the assembler hall demands, and its control face is the most important screen in the wing."]
	quest.4F44011000000004.quest_subtitle: "The fleet's own furnace."
	quest.4F44011000000004.title: "Reactor Controller"
	quest.4F47011000000001.quest_desc: ["Extract &braw silicon&r from the fleet's processing line. It looks like gravel, but every wafer, board, and processing unit in the electronics lane starts as this dull lump."]
	quest.4F47011000000001.quest_subtitle: "Electronics feedstock."
	quest.4F47011000000001.title: "Raw Silicon"
	quest.4F47011000000002.quest_desc: ["Assemble a &bProcessing Unit&r. The Golden Workshop's advanced table seats one in place of its usual slate. This board is the silicon-chain proof the atomic capstone checks for."]
	quest.4F47011000000002.quest_subtitle: "Silicon lane capstone."
	quest.4F47011000000002.title: "Processing Unit"
	quest.4F53010000010000.quest_desc: ["Build a pair of &bdrone ports&r. Cargo drones ferry items between them over any terrain, the fleet's own air freight. The rest of the specialty hangar opens from here."]
	quest.4F53010000010000.quest_subtitle: "Cargo drone freight."
	quest.4F53010000010000.title: "Drone Port"
	quest.4F53010000010001.quest_desc: ["Press the &btier-six processing addon&r. The sixth rung is where the addon ladder turns serious, and the high ranks beyond it are built on prometheum."]
	quest.4F53010000010001.quest_subtitle: "The ladder's waist."
	quest.4F53010000010001.title: "Processing Tier 6"
	quest.4F53010000010002.quest_desc: ["Fabricate the &bmachine ultimate addon&r. It folds the whole addon family's bonuses into one slot, the fleet's final word on specialization."]
	quest.4F53010000010002.quest_subtitle: "One board, every bonus."
	quest.4F53010000010002.title: "Ultimate Addon"
	quest.4F53010000010003.quest_desc: ["Press the tier-six &bspeed&r, &befficiency&r, and &bcapacitor&r addons as a set."]
	quest.4F53010000010003.quest_subtitle: "Speed, efficiency, capacity addons."
	quest.4F53010000010003.title: "Tier 6 Addon Set"
	quest.4FB724CDDCB6E709.quest_desc: ["Smelt &bMolten Amethyst&r from raw amethyst. It is a liquid alchemy material the higher garden recipes call for, so render a batch before you reach them."]
	quest.4FB724CDDCB6E709.quest_subtitle: "Amethyst, rendered down."
	quest.4FB724CDDCB6E709.title: "Molten Amethyst"
	quest.503C5A0CE113962C.quest_desc: [
		"Craft the Golden Builder's &bAssistant Hammer&r. With it you can place blocks straight into a build site yourself, hurrying a construction along when you are impatient."
		"The gold version reaches further than the iron one, so it covers larger builds."
	]
	quest.503C5A0CE113962C.quest_subtitle: "Lend the builder a hand."
	quest.503C5A0CE113962C.title: "Golden Assistant Hammer"
	quest.5044010000010001.quest_desc: ["Place the &bNeutron Collector&r. It gathers neutrons for the compression line ahead."]
	quest.5044010000010001.quest_subtitle: "Gather neutrons here."
	quest.5044010000010001.title: "Neutron Collector"
	quest.5044010000010002.quest_desc: ["Place the &bNeutronium Compressor&r. Feed it bulk materials to form singularities for the Infinity Catalyst."]
	quest.5044010000010002.quest_subtitle: "Compress matter to its limit."
	quest.5044010000010002.title: "Neutronium Compressor"
	quest.5044010000010003.quest_desc: ["Craft a &bNeutronium Block&r. Keep the collector running until nine ingots are ready for compression."]
	quest.5044010000010003.quest_subtitle: "Stock before infinity crafts."
	quest.5044010000010003.title: "Neutronium Block"
	quest.5044010000010004.quest_desc: ["Craft a &bCrystal Matrix Block&r. It stores the matrix ingots used throughout extreme crafting."]
	quest.5044010000010004.quest_subtitle: "Condense the crystal matrix."
	quest.5044010000010004.title: "Crystal Matrix Block"
	quest.5044010000010005.quest_desc: ["Hold an &bInfinity Catalyst&r. Endgame crafts want this catalyst in hand."]
	quest.5044010000010005.quest_subtitle: "Endgame craft catalyst."
	quest.5044010000010005.title: "Infinity Catalyst"
	quest.5044010000010006.quest_desc: ["Keep an Infinity Singularity in your inventory. Completing this quest seals the ascension stage."]
	quest.5044010000010006.quest_subtitle: "Seal ascension stage."
	quest.5044010000010006.title: "Infinity Singularity"
	quest.5044010000020001.quest_desc: [
		"Craft nine crafting tables into a &bCompressed Crafting Table&r, then nine of those into a &bDouble Compressed Crafting Table&r."
		"Keep the compressed tiers after the craft. Avaritia treats them as ingredients, and the double table is the frame piece the Extreme Crafting Table is built around."
	]
	quest.5044010000020001.quest_subtitle: "Nine benches, then nine again."
	quest.5044010000020001.title: "Compressed Crafting Tables"
	quest.5044010000020002.quest_desc: [
		"Build the &bExtreme Crafting Table&r. The recipe wraps a Double Compressed Crafting Table, Crystal Matrix, and Diamond Lattice around a shelf of trophies: a beacon, a dragon egg, a heart of the sea, reinforced deepslate, and more."
		"Reinforced deepslate is craftable in this pack through the Oritech atomic forge, an Occultism ritual, or Avaritia's own recipe, so nothing on the list is a dead end."
		"Every Avaritia recipe from here forward runs in this nine-by-nine grid. Place it somewhere permanent next to bulk storage; the ingredient lists ahead are wide."
	]
	quest.5044010000020002.quest_subtitle: "The nine-by-nine crafting table."
	quest.5044010000020002.title: "Extreme Crafting Table"
	quest.5044010000020003.quest_desc: [
		"Press your neutron stock into &bNeutronium Ingots&r. Nine nuggets make an ingot, and ingots pack into blocks and back without loss."
		"Neutronium frames every craft ahead: dense collectors, Endest Pearls, the Enhancement Core, and the infinity gear itself. Set up a steady conversion line, because the recipes ahead consume ingots by the stack."
	]
	quest.5044010000020003.quest_subtitle: "The structural metal of the end."
	quest.5044010000020003.title: "Neutronium Ingot"
	quest.5044010000020004.quest_desc: [
		"Craft the &bEndest Pearl&r in the Extreme Crafting Table: rings of end stone and ender pearls close around Neutronium Ingots and a nether star."
		"Endest Pearls unlock the dense collector upgrades and the Enhancement Core. Craft several; nothing at this tier is single-use."
	]
	quest.5044010000020004.quest_subtitle: "The end, condensed."
	quest.5044010000020004.title: "Endest Pearl"
	quest.5044010000020005.quest_desc: ["Load iron into the &bNeutronium Compressor&r until it collapses into an Iron Singularity. This begins the material singularity ladder."]
	quest.5044010000020005.quest_subtitle: "Iron's final form."
	quest.5044010000020005.title: "Iron Singularity"
	quest.5044010000020006.quest_desc: ["Compress redstone into a &bRedstone Singularity&r. Keep bulk production feeding the compressor while the neutron collector runs."]
	quest.5044010000020006.quest_subtitle: "Condense a mountain of redstone."
	quest.5044010000020006.title: "Redstone Singularity"
	quest.5044010000020007.quest_desc: ["Compress gold into a &bGold Singularity&r. Singularities become the central ingredients of the Infinity Catalyst line."]
	quest.5044010000020007.quest_subtitle: "Collapse the gold reserve."
	quest.5044010000020007.title: "Gold Singularity"
	quest.5044010000020008.quest_desc: ["Compress diamonds into a &bDiamond Singularity&r. Automate the input supply before committing the full batch."]
	quest.5044010000020008.quest_subtitle: "Collapse the diamond reserve."
	quest.5044010000020008.title: "Diamond Singularity"
	quest.5044010000020009.quest_desc: ["Compress emeralds into an &bEmerald Singularity&r. This completes the primary singularity ladder used by AvaritiaNeo."]
	quest.5044010000020009.quest_subtitle: "Collapse the emerald reserve."
	quest.5044010000020009.title: "Emerald Singularity"
	quest.504401000002000A.quest_desc: ["Craft the &bSkullfire Sword&r in the Extreme Crafting Table. This is the first weapon milestone beyond the material compression line."]
	quest.504401000002000A.quest_subtitle: "Forge fire into a blade."
	quest.504401000002000A.title: "Skullfire Sword"
	quest.504401000002000B.quest_desc: ["Craft the &bInfinity Bow&r after the Infinity Catalyst and ingot lines are established. It is the ranged apex of AvaritiaNeo."]
	quest.504401000002000B.quest_subtitle: "Infinity at range."
	quest.504401000002000B.title: "Infinity Bow"
	quest.504401000002000C.quest_desc: [
		"Forge the full &bInfinity armor set&r in the Extreme Crafting Table: helmet, chestplate, pants, and boots. Each piece is drawn in Infinity Ingots around an Infinity Catalyst, framed in Neutronium."
		"The set shrugs off conventional damage entirely. Four pieces means four heavy crafts, so keep the neutron farm and your ingot line running while you work through them."
	]
	quest.504401000002000C.quest_subtitle: "Full Infinity armor."
	quest.504401000002000C.title: "Infinity Armor"
	quest.504401000002000D.quest_desc: [
		"Craft the &bInfinity Sword&r and &bInfinity Pickaxe&r in the Extreme Crafting Table, both built from Infinity Ingots, an Infinity Catalyst, Crystal Matrix, and Neutronium."
		"The sword deals absurd damage and carries a right-click ranged strike. The pickaxe clears wide areas at once and sweeps the drops up for you instead of littering the floor."
	]
	quest.504401000002000D.quest_subtitle: "The sword and the pick."
	quest.504401000002000D.title: "Infinity Tools"
	quest.504401000002000E.quest_desc: [
		"Mass mining with the Infinity Pickaxe packs the drops into &bMatter Clusters&r instead of spraying items. Hold a cluster and use it to unpack the contents; a full cluster carries 4,096 items."
		"The compressor closes the loop from the other side: 4,096 Neutronium Ingots press into a Full Matter Cluster. Clusters are the storage format of the age you just finished building."
	]
	quest.504401000002000E.quest_subtitle: "Compact storage for bulk drops."
	quest.504401000002000E.title: "Matter Clusters"
	quest.5054010000010000.quest_desc: ["Begin &6Mekanism&r's chemistry with the &bChemical Oxidizer&r. It turns solid feedstock into the gases the rest of this wing plumbs around, including the yellowcake step of your own fuel line."]
	quest.5054010000010000.quest_subtitle: "Solids become gases."
	quest.5054010000010000.title: "Chemical Oxidizer"
	quest.5054010000010001.quest_desc: ["It removes matching blocks without leaving an open quarry."]
	quest.5054010000010001.quest_subtitle: "Tell it what, not where."
	quest.5054010000010001.title: "Digital Miner"
	quest.5054010000010002.quest_desc: ["Print &belite control circuits&r and frame one into an &belite energy cube&r. Circuit tier is what gates every Mekanism machine upgrade, and elite boards are the standard this age's workshop runs on."]
	quest.5054010000010002.quest_subtitle: "The third tier of thought."
	quest.5054010000010002.title: "Elite Circuits"
	quest.5054010000010003.quest_desc: ["Print an &bultimate control circuit&r. Mekanism's top board. Needs chemistry, isotopes, and electronics running in the same base."]
	quest.5054010000010003.quest_subtitle: "Top Mek board printed."
	quest.5054010000010003.title: "Ultimate Circuit"
	quest.5054011000000100.quest_desc: ["Add the &bChemical Dissolution Chamber&r. Fed sulfuric acid it dissolves raw ore into slurry, the first step of the four-stage line that turns one ore into five ingots."]
	quest.5054011000000100.quest_subtitle: "Acid does the mining."
	quest.5054011000000100.title: "Dissolution Chamber"
	quest.5054011000000101.quest_desc: ["Pipe the dirty slurry through a &bChemical Washer&r. Clean slurry is what the crystallizer downstream accepts, and the water bill is why your condensers exist."]
	quest.5054011000000101.quest_subtitle: "Rinse the slurry clean."
	quest.5054011000000101.title: "Chemical Washer"
	quest.5054011000000102.quest_desc: ["Finish the ore line with the &bChemical Crystallizer&r. It precipitates washed slurry into crystals worth five times the original ore, the payoff block of the whole acid line."]
	quest.5054011000000102.quest_subtitle: "Slurry back to stone."
	quest.5054011000000102.title: "Chemical Crystallizer"
	quest.5054011000000103.quest_desc: ["Spin up the &bIsotopic Centrifuge&r. It divides a gas into its heavier and lighter fractions, the machine that turns your uranium gases into reactor-grade feed."]
	quest.5054011000000103.quest_subtitle: "Sort atoms by weight."
	quest.5054011000000103.title: "Isotopic Centrifuge"
	quest.5054011000000104.quest_desc: ["Mount a &bSolar Neutron Activator&r under open sky. It bathes gases in solar neutrons to transmute them, turning lithium into tritium for Mekanism's own fuel lines."]
	quest.5054011000000104.quest_subtitle: "Sunlight finishes the job."
	quest.5054011000000104.title: "Solar Neutron Activator"
	quest.5054011000000105.quest_desc: ["Assemble an &bultimate energy cube&r. It buffers enough current to ride out a reactor scram, and its guts preview the ultimate circuit the capstone will demand."]
	quest.5054011000000105.quest_subtitle: "The last battery tier."
	quest.5054011000000105.title: "Ultimate Energy Cube"
	quest.5054011000000106.quest_desc: ["Print a top-tier board from a second line: &6Electrodynamics&r elite or ultimate circuits, or the dense circuit from the evolved Mekanism press. Cross-checking your circuit supply across mods is what keeps the factory wings from fighting over boards."]
	quest.5054011000000106.quest_subtitle: "Optional: every mod prints now."
	quest.5054011000000106.title: "Circuit Foundry"
	quest.5054011000000107.quest_desc: ["Print an &borganic circuit&r at the circuit assembler. It lays the DPP-DTT polymer film from your spin coater over glass and plastic, a board no furnace was involved in, and a few late recipes specifically want this grown grade."]
	quest.5054011000000107.quest_subtitle: "Optional: a board that grew."
	quest.5054011000000107.title: "Organic Circuit"
	quest.5054011000000108.quest_desc: ["Install &6Electrodynamics&r' &bChemical Crystallizer&r. It precipitates that mod's own solution chains into solids, and several atomic alloys take their first form in this drum."]
	quest.5054011000000108.quest_subtitle: "The other crystal line."
	quest.5054011000000108.title: "ED Crystallizer"
	quest.5054011000000109.quest_desc: ["Add the &bElectrolysis Chamber&r. It splits brines and solutions with raw current at industrial scale, the heavy sibling of the separator you wired two ages ago."]
	quest.5054011000000109.quest_subtitle: "Current cracks compounds."
	quest.5054011000000109.title: "Electrolysis Chamber"
	quest.505401100000010A.quest_desc: ["Plumb in the &bMineral Washer&r. Crushed ore takes a sulfuric bath here before smelting, and the extra yield is the difference that funds this whole wing."]
	quest.505401100000010A.quest_subtitle: "Acid-washed yields."
	quest.505401100000010A.title: "Mineral Washer"
	quest.505401100000010B.quest_desc: ["Build the &benergized alloyer&r. It fuses the mod's mid alloys on heavy current, and the war chapter will requisition its output by the stack."]
	quest.505401100000010B.quest_subtitle: "Optional: fusion by the furnace-load."
	quest.505401100000010B.title: "Energized Alloyer"
	quest.505401100000010C.quest_desc: ["Upgrade to the &breinforced alloyer&r for the alloys the energized model cannot hold together. The hardened chamber is the last word in this mod's metallurgy."]
	quest.505401100000010C.quest_subtitle: "Optional: the hardened forge."
	quest.505401100000010C.title: "Reinforced Alloyer"
	quest.505401100000010D.quest_desc: ["Cast &belement blocks&r of uranium, plutonium, and thorium. Storage, bragging rights, and a vault wall that hums faintly when you stand near it. Label the room."]
	quest.505401100000010D.quest_subtitle: "Optional: the table, in blocks."
	quest.505401100000010D.title: "Element Vault"
	quest.505401100000010E.quest_desc: ["Press the &bplatinum-thorium catalyst&r. It accelerates the bench's hardest conversions without being consumed, which makes it the most valuable small object in the lab."]
	quest.505401100000010E.quest_subtitle: "Optional: the reusable miracle."
	quest.505401100000010E.title: "Platinum-Thorium Catalyst"
	quest.505401100000010F.quest_desc: ["Somewhere overhead, &buranium and thorium veins&r run through the Moon, Mars, Mercury, and Venus. This ledger entry waits for the rockets of the next age to bring a sample home. Nothing in this chapter requires it."]
	quest.505401100000010F.quest_subtitle: "Optional: veins on other worlds."
	quest.505401100000010F.title: "Off-World Isotopes"
	quest.5054011000000110.quest_desc: ["Upgrade any line to &badvanced&r tier: cable, pipe, tube, transporter, or conductor. The chemistry wing moves real volume now, and basic conduits are officially the bottleneck."]
	quest.5054011000000110.quest_subtitle: "Wider pipes for hotter work."
	quest.5054011000000110.title: "Advanced Conduits"
	quest.5054011000000111.quest_desc: ["Step the trunk lines to &belite&r conduits. This is the tier the factory wing assumes, and re-piping now is cheaper than re-piping mid-meltdown."]
	quest.5054011000000111.quest_subtitle: "The factory-grade run."
	quest.5054011000000111.title: "Elite Conduits"
	quest.5054011000000112.quest_desc: ["Lay &bultimate&r conduit where the reactor loops will run. Whatever the machines can produce, these can carry, and the question retires permanently."]
	quest.5054011000000112.quest_subtitle: "Optional: no more bottlenecks, ever."
	quest.5054011000000112.title: "Ultimate Conduits"
	quest.5054011000000113.quest_desc: ["Craft the &badvanced&r storage set: bin, chemical tank, fluid tank, and energy cube. The chemistry wing produces faster than you can spend, and the surplus needs somewhere rated to hold it."]
	quest.5054011000000113.quest_subtitle: "Bins, tanks, and cubes."
	quest.5054011000000113.title: "Advanced Storage"
	quest.5054011000000114.quest_desc: ["Upgrade the stockroom to &belite&r bins and tanks. Each tier multiplies capacity several-fold, and the fuel campaign ahead is exactly the kind of thing you stockpile for."]
	quest.5054011000000114.quest_subtitle: "Optional: the deep shelves."
	quest.5054011000000114.title: "Elite Storage"
	quest.5054011000000115.quest_desc: ["Finish at &bultimate&r tier. One bin holds a mountain, one tank holds a lake, and inventory anxiety becomes a previous age's problem."]
	quest.5054011000000115.quest_subtitle: "Optional: the bottomless stockroom."
	quest.5054011000000115.title: "Ultimate Storage"
	quest.5054011000000116.quest_desc: ["Build any &bmid or max chemical tank&r from &6Mekanism: More Machines&r. They slot between the standard tiers, so the tank farm can match capacity to chemical instead of rounding up."]
	quest.5054011000000116.quest_subtitle: "Optional: the in-between sizes."
	quest.5054011000000116.title: "Mid and Max Tanks"
	quest.5054011000000117.quest_desc: ["Assemble an &bInduction Matrix&r: casing, ports, and your first cell and provider. The multiblock stores energy at a scale loose cubes cannot pretend to, and the reactors ahead will fill it anyway."]
	quest.5054011000000117.quest_subtitle: "The battery becomes a building."
	quest.5054011000000117.title: "Induction Matrix"
	quest.5054011000000118.quest_desc: ["Upgrade the matrix internals with any higher-tier &bcell or provider&r, through ultimate and the dense and overclocked grades beyond. Cells set how much the building holds; providers set how fast it pours."]
	quest.5054011000000118.quest_subtitle: "Optional: deeper cells, faster providers."
	quest.5054011000000118.title: "Matrix Tiers"
	quest.5054011000000119.quest_desc: ["Craft a pair of &bQuantum Entangloporters&r. Items, fluids, gases, heat, and power all cross between them instantly with no line in between. The far side of the base just became adjacent."]
	quest.5054011000000119.quest_subtitle: "Optional: pipes through nowhere."
	quest.5054011000000119.title: "Quantum Entangloporter"
	quest.505401100000011A.quest_desc: ["Install a &bDimensional Stabilizer&r over your reactor complex. It keeps the surrounding chunks loaded while you are away, because a fission plant that pauses mid-burn is everyone's least favorite surprise."]
	quest.505401100000011A.quest_subtitle: "Optional: the chunk stays awake."
	quest.505401100000011A.title: "Dimensional Stabilizer"
	quest.505401100000011B.quest_desc: ["Build any tier of &6Mekanism Lasers&r' emitter, fixed or toggleable. The tiered beams outclass the stock laser for digging and feeding amplifiers, and the toggleable bodies answer redstone."]
	quest.505401100000011B.quest_subtitle: "Optional: brighter, hotter, tiered."
	quest.505401100000011B.title: "Laser Tiers"
	quest.505401100000011C.quest_desc: ["Add a &blaser splitter&r and &bstopper&r to the array. One divides a beam across several targets, the other parks it safely, and together they turn a laser into a laser NETWORK."]
	quest.505401100000011C.quest_subtitle: "Optional: route the light."
	quest.505401100000011C.title: "Beam Control"
	quest.505401100000011D.quest_desc: ["Assemble the &benergy storage casing&r and &bcell&r. They bank power for the laser array's heavy pulses, so the big shots come off the buffer instead of browning out the base."]
	quest.505401100000011D.quest_subtitle: "Optional: charge the shot."
	quest.505401100000011D.title: "Beam Capacitors"
	quest.505401100000011E.quest_desc: ["Cap the array with the &bOre Generator&r. Sustained beam energy condenses fresh ore inside it, mining in reverse. Feed it the array's spare capacity and the stockpile grows on light alone."]
	quest.505401100000011E.quest_subtitle: "Optional: the beam gives back."
	quest.505401100000011E.title: "Ore Generator"
	quest.5057011000000001.quest_desc: ["Open the &bAstral Dimension&r. Build its altars and the astranite cauldron, then step through. This gate opens with the Gilded Age; the five factory proof lanes are not required here, but the atomic capstone later requires every lane capstone plus the Void Titan."]
	quest.5057011000000001.quest_subtitle: "The threshold past the wires."
	quest.5057011000000001.title: "Astral Dimension"
	quest.5057011000000002.quest_desc: ["Smelt raw haul into &bastranite ingots&r. The metal outclasses every factory alloy below it, and you need stock before you call the &c&lVoid Titan&r."]
	quest.5057011000000002.quest_subtitle: "Smelt the starlight metal."
	quest.5057011000000002.title: "Astranite Ingot"
	quest.5057011000000003.quest_desc: ["Hunt the &c&lVoid Titan&r. It runs the astral dimension. The kill and the &bTitan Helmet&r drop are both required dependencies of the atomic capstone; the disassembler quest that follows does not substitute for either."]
	quest.5057011000000003.quest_subtitle: "Kill for the helmet drop."
	quest.5057011000000003.title: "Void Titan"
	quest.5057011000000004.quest_desc: ["Hold &6Mekanism&r's &bAtomic Disassembler&r for the ledger. This capstone fans in the five Gilded lane proofs (refinery, grid, heavy industry, ocean, silicon), the Chartered Arcana capstone, and the Void Titan. Turn in every dependency and the atomic age opens."]
	quest.5057011000000004.quest_subtitle: "Atomic age capstone."
	quest.5057011000000004.title: "Atomic Disassembler"
	quest.5057011000000005.quest_desc: ["Duel the &c&lAngel Boss&r out in the astral wastes. It guards nothing you strictly need, which is exactly why the trophy is worth having."]
	quest.5057011000000005.quest_subtitle: "Defeat the Angel Boss."
	quest.5057011000000005.title: "Angel Boss"
	quest.5057011000000006.quest_desc: ["Topple the &c&lTower of Malice&r. The structure itself is the boss, and bringing it down is one of the dimension's stranger fights."]
	quest.5057011000000006.quest_subtitle: "Defeat the Tower of Malice."
	quest.5057011000000006.title: "Tower of Malice"
	quest.5057011000000007.quest_desc: ["Bring down &c&lHelioos&r. One more of the dimension's optional terrors, worth the fight for the trophy alone."]
	quest.5057011000000007.quest_subtitle: "Defeat Helioos."
	quest.5057011000000007.title: "Helioos"
	quest.5057011000000008.quest_desc: ["Cross blades with the &c&lAmethyst Knight&r. A fast, clean duel by astral standards, and a fine warm-up before you call on the Titan."]
	quest.5057011000000008.quest_subtitle: "Defeat the Amethyst Knight."
	quest.5057011000000008.title: "Amethyst Knight"
	quest.505701100000000A.quest_desc: [
		"Malkuth is Kingdom, a fallen king who once ruled with kindness. Reaching him needs its own tracking eye. Craft the &bEye of Malkuth&r from &bIce&r, a &bMagma Block&r, and one &bEye of Ender&r in the shown pattern."
		"The recipe unlocks at the Gilded Age tier, so this trial sits above the Chesed exam, not beside it. Like an Eye of Ender, the finished eye points toward the Malkuth Arena that generates in the Overworld."
		"Build one eye and carry it into the next step. You will throw it to find the arena."
	]
	quest.505701100000000A.quest_subtitle: "Craft the locator eye."
	quest.505701100000000A.title: "Eye of Malkuth"
	quest.505701100000000B.quest_desc: [
		"Throw the &bEye of Malkuth&r and chase the direction it gives until you reach the &bMalkuth Arena&r. Walking inside the structure completes this step. Come at night, since that is when the fight is meant to be fought."
		"Malkuth wears armor nothing can pierce, so direct attacks do nothing. Instead the fight makes you weak to either Fire or Ice, and your current weakness shows next to your crosshair. During his Cannonade you must fire the arena cannons that match the element you are weak to. Those shots are what actually hurt him."
		"Do not leave the arena while the fight is live. Stepping out turns the Knight into a Coward, and that carries a death penalty. Stay in, read your weakness, and work the correct cannons."
	]
	quest.505701100000000B.quest_subtitle: "Find and enter Malkuth's arena."
	quest.505701100000000B.title: "The Fallen King's Arena"
	quest.505701100000000C.quest_desc: [
		"Bring Malkuth down and keep the &bFire and Ice Core&r in your inventory. The kill and item proof record the victory without consuming the core."
		"This is the Gilded Age exam. It grants the Malkuth proof and joins the Gilded capstone alongside the Void Titan, so both fights are required before the Atomic age."
		"The Fire and Ice Core is also a usable tool. Attach it to an item that deals damage; use it to throw a fireball, or crouch and use it to throw an iceball."
	]
	quest.505701100000000C.quest_subtitle: "Defeat Malkuth, claim the Fire and Ice Core."
	quest.505701100000000C.title: "Malkuth, the Tsar's Wrath"
	quest.5057011000000100.quest_desc: ["Quarry &bastral stone&r from the dimension crust. Stock a few stacks. Every altar recipe and build out here starts with it."]
	quest.5057011000000100.quest_subtitle: "Base stone for astral builds."
	quest.5057011000000100.title: "Astral Stone"
	quest.5057011000000101.quest_desc: ["Mine &braw astranite&r deep in the astral strata and compress a storage block. This metal feeds every forged tool and armor line in the chapter."]
	quest.5057011000000101.quest_subtitle: "Core ore of the age."
	quest.5057011000000101.title: "Raw Astranite"
	quest.5057011000000102.quest_desc: ["Compress nine ingots into an &bastranite block&r. Handy storage and a building block for astral bases."]
	quest.5057011000000102.quest_subtitle: "Obtain an Astranite Block."
	quest.5057011000000102.title: "Astranite Block"
	quest.5057011000000103.quest_desc: ["Refine &blucid ingots&r from lucid ore. Lucid does not craft from scratch: apply it over netherite gear at a smithing table with templates from astral dungeons."]
	quest.5057011000000103.quest_subtitle: "Smithing upgrade metal."
	quest.5057011000000103.title: "Lucid Ingot"
	quest.5057011000000104.quest_desc: ["Bank a &bblock of lucid&r and the &blucid rock&r it weathers from. Keeps upgrade crafts from stalling on ore runs."]
	quest.5057011000000104.quest_subtitle: "Stockpile lucid block and rock."
	quest.5057011000000104.title: "Lucid Stockpile"
	quest.5057011000000105.quest_desc: ["Gather &bvoid shards&r from the dark reaches. Every gem, charge, and void weapon downstream starts here."]
	quest.5057011000000105.quest_subtitle: "Start of the void chain."
	quest.5057011000000105.title: "Void Shards"
	quest.5057011000000106.quest_desc: ["Fuse shards into a &bvoid gem&r. Intermediate form before pure void and the charge recipes."]
	quest.5057011000000106.quest_subtitle: "Stable void workpiece."
	quest.5057011000000106.title: "Void Gem"
	quest.5057011000000107.quest_desc: ["Condense gems into &bpure void&r. Charges, Void Eater, and several late recipes draw from this."]
	quest.5057011000000107.quest_subtitle: "Feedstock for void crafts."
	quest.5057011000000107.title: "Pure Void"
	quest.5057011000000108.quest_desc: ["Pack pure void into a &bvoid charge&r and its larger variant. Stock both before the supreme altar fight."]
	quest.5057011000000108.quest_subtitle: "Ammo for supreme altar."
	quest.5057011000000108.title: "Void Charges"
	quest.5057011000000109.quest_desc: ["Forge the full &bastranite toolset&r, sword included. It is the working tool line for deeper astral expeditions."]
	quest.5057011000000109.quest_subtitle: "Collect the full astranite toolset."
	quest.5057011000000109.title: "Astranite Toolset"
	quest.505701100000010A.quest_desc: ["Plate yourself in &bastranite armor&r. Forge the full set for dungeon loot runs in the astral dimension."]
	quest.505701100000010A.quest_subtitle: "Collect the full astranite armor set."
	quest.505701100000010A.title: "Astranite Armor"
	quest.505701100000010B.quest_desc: ["Recover an astral &bsmithing template&r: lucid, sword, void eater, or titan helmet. Use the matching template for the related astral upgrade recipes."]
	quest.505701100000010B.quest_subtitle: "Recover any astral smithing template."
	quest.505701100000010B.title: "Astral Smithing Templates"
	quest.505701100000010C.quest_desc: ["Smith netherite tools over with &blucid&r at a smithing table, using the lucid template."]
	quest.505701100000010C.quest_subtitle: "Collect the full lucid toolset."
	quest.505701100000010C.title: "Lucid Tools"
	quest.505701100000010D.quest_desc: ["Upgrade a full netherite suit into &blucid armor&r."]
	quest.505701100000010D.quest_subtitle: "Collect the full lucid armor set."
	quest.505701100000010D.title: "Lucid Armor"
	quest.505701100000010E.quest_desc: ["Smith a &blucid sword&r over netherite with the lucid template."]
	quest.505701100000010E.quest_subtitle: "Obtain a Lucid Sword."
	quest.505701100000010E.title: "Lucid Sword"
	quest.505701100000010F.quest_desc: ["Upgrade the lucid blade into the &bAstral Sword&r with the sword template."]
	quest.505701100000010F.quest_subtitle: "Obtain an Astral Sword."
	quest.505701100000010F.title: "Astral Sword"
	quest.5057011000000110.quest_desc: ["Forge the &bVoid Eater&r from pure void. Strong melee option for late astral mobs."]
	quest.5057011000000110.quest_subtitle: "Obtain a Void Eater."
	quest.5057011000000110.title: "Void Eater"
	quest.5057011000000111.quest_desc: ["Smith the &bUpgraded Void Eater&r with the void eater template."]
	quest.5057011000000111.quest_subtitle: "Obtain an Upgraded Void Eater."
	quest.5057011000000111.title: "Upgraded Void Eater"
	quest.5057011000000112.quest_desc: ["Tan and stitch a full &bharsh leather&r suit from dimension fauna."]
	quest.5057011000000112.quest_subtitle: "Collect the full harsh leather armor set."
	quest.5057011000000112.title: "Harsh Leather Armor"
	quest.5057011000000113.quest_desc: ["Sew the full &bpajama&r set. A collection set for players who want the astral wardrobe complete."]
	quest.5057011000000113.quest_subtitle: "Collect the full pajama armor set."
	quest.5057011000000113.title: "Pajama Armor"
	quest.5057011000000114.quest_desc: ["Collect any piece of &btormented armor&r."]
	quest.5057011000000114.quest_subtitle: "Collect any tormented armor piece."
	quest.5057011000000114.title: "Tormented Armor"
	quest.5057011000000115.quest_desc: ["Craft the &bamethyst&r and &bvoid necklaces&r."]
	quest.5057011000000115.quest_subtitle: "Collect both astral necklaces."
	quest.5057011000000115.title: "Astral Necklaces"
	quest.5057011000000116.quest_desc: ["Obtain the &bamethyst key&r."]
	quest.5057011000000116.quest_subtitle: "Obtain an Amethyst Key."
	quest.5057011000000116.title: "Amethyst Key"
	quest.5057011000000117.quest_desc: ["Obtain &bmagma wings&r or &bbouncy boots&r."]
	quest.5057011000000117.quest_subtitle: "Obtain Magma Wings or Bouncy Boots."
	quest.5057011000000117.title: "Magma Wings or Bouncy Boots"
	quest.5057011000000118.quest_desc: ["Collect &bburning shards&r and fuse a &bburning orb&r. Several astral recipes ask for one."]
	quest.5057011000000118.quest_subtitle: "Collect Burning Shards and a Burning Orb."
	quest.5057011000000118.title: "Burning Shards and Orb"
	quest.5057011000000119.quest_desc: ["Obtain a &bfrost charge&r or &bdecay charge&r."]
	quest.5057011000000119.quest_subtitle: "Obtain a Frost or Decay Charge."
	quest.5057011000000119.title: "Elemental Charges"
	quest.505701100000011A.quest_desc: ["Obtain a &bvoid fang&r."]
	quest.505701100000011A.quest_subtitle: "Obtain a Void Fang."
	quest.505701100000011A.title: "Void Fang"
	quest.505701100000011B.quest_desc: ["Smith the &bTitan Helmet&r into the &bSupreme Helmet&r with the titan helmet template."]
	quest.505701100000011B.quest_subtitle: "Obtain a Supreme Helmet."
	quest.505701100000011B.title: "Supreme Helmet"
	quest.505701100000011C.quest_desc: ["Obtain an &bastral transmitter&r."]
	quest.505701100000011C.quest_subtitle: "Obtain an Astral Transmitter."
	quest.505701100000011C.title: "Astral Transmitter"
	quest.505701100000011D.quest_desc: ["Claim the &bfinal crystal&r from the deepest holdings. Required to activate the supreme altar fight."]
	quest.505701100000011D.quest_subtitle: "Key for supreme altar."
	quest.505701100000011D.title: "Final Crystal"
	quest.505701100000011E.quest_desc: ["Collect any astral &bpresent&r: Anomal, Tower of Malice, Void Titan, or plain astral reward."]
	quest.505701100000011E.quest_subtitle: "Collect any astral present."
	quest.505701100000011E.title: "Astral Presents"
	quest.52453550206EC770.quest_desc: [
		"Build the &bDyer's Hut&r. The Dyer produces dyes from flowers and plants, coloring the wool, banners, and blocks your builds use."
		"Feed it the Florist's flowers and it runs itself."
	]
	quest.52453550206EC770.quest_subtitle: "Color for wool and concrete."
	quest.52453550206EC770.title: "Dyer's Hut"
	quest.5246011000000001.quest_desc: ["Craft a &bpity machine frame&r and upgrade it into a &bsimple frame&r. Every &6Industrial Foregoing&r machine is built around one of these chassis, so the frame tier you can make decides the machine tier you can own."]
	quest.5246011000000001.quest_subtitle: "The chassis everything bolts to."
	quest.5246011000000001.title: "Machine Frames"
	quest.5246011000000002.quest_desc: ["Place a &bPlant Gatherer&r facing your field. It mows crops in its work area and drops the produce into its inventory, no replanting hands required. This is the intake side of a farm that runs while you are underground."]
	quest.5246011000000002.quest_subtitle: "The harvest, mechanized."
	quest.5246011000000002.title: "Plant Gatherer"
	quest.5246011000000003.quest_desc: ["Craft the &bFluid Collector&r and &bFluid Placer&r pair. One drinks source blocks out of the world, the other pours them back wherever you aim it. Between them, lava moats, oil pools, and flooded shafts all become cargo."]
	quest.5246011000000003.quest_subtitle: "Pick liquids up, put liquids down."
	quest.5246011000000003.title: "Fluid Handlers"
	quest.5246011000000004.quest_desc: ["Digest your crop surplus in a &bBioreactor&r and burn the result in a &bBiofuel Generator&r. The more ingredient variety the reactor eats, the richer the fuel, so a mixed farm out-powers a monoculture. This pair is the refinery's bread-and-butter generator."]
	quest.5246011000000004.quest_subtitle: "Burn the harvest."
	quest.5246011000000004.title: "Biofuel Power"
	quest.5246011000000005.quest_desc: ["Craft a &bMob Imprisonment Tool&r and click it on a mob. The creature folds into the tool, ready to be released or duplicated elsewhere. The mob industry in this wing starts with whatever you bring back in one of these."]
	quest.5246011000000005.quest_subtitle: "A creature in a can."
	quest.5246011000000005.title: "Mob Imprisonment Tool"
	quest.5246011000000007.quest_desc: ["Ring a &bLaser Drill&r with &blaser bases&r and it pulls ore out of nothing, with colored lenses biasing which ores surface. In this pack the ore base is petroleum-built and the soul base leans on EnderIO, so the refinery and soul lines both feed the beam. Completing this quest signs off the refinery proof lane for the astral threshold."]
	quest.5246011000000007.quest_subtitle: "Ore from a beam of light."
	quest.5246011000000007.title: "Laser Drill"
	quest.5246011000000008.quest_desc: ["Erect the &bFractionating Column&r from &6Chemical Science&r. Fed crude from the oil spine, it splits the barrel into light and heavy cuts that the rest of this wing refines further."]
	quest.5246011000000008.quest_subtitle: "The crude splitter."
	quest.5246011000000008.title: "Fractionating Column"
	quest.5246011000000009.quest_desc: ["Carry a &bDeep Learner&r from &6Hostile Neural Networks&r with a data model inside. Every kill of the matching mob teaches the model, tier by tier, until the simulator can fight the creature for you."]
	quest.5246011000000009.quest_subtitle: "It studies your kills."
	quest.5246011000000009.title: "Deep Learner"
	quest.5246011000000010.quest_desc: ["Build the &bEnchantment Factory&r and plumb in the essence your crusher banks. It pushes items through the enchanting table's roulette on liquid experience, no lapis-stained fingers involved."]
	quest.5246011000000010.quest_subtitle: "Levels by the tankful."
	quest.5246011000000010.title: "Enchantment Factory"
	quest.5246011000000011.quest_desc: ["Feed mob predictions into the &bLoot Fabricator&r and select a fabricator output."]
	quest.5246011000000011.quest_subtitle: "Optional: predictions made real."
	quest.5246011000000011.title: "Loot Fabricator"
	quest.5246011000000100.quest_desc: ["Set a &bFluid Extractor&r against a log and let it chew. It slowly eats the wood and weeps &blatex&r into its tank. Point it at dark oak for the best yield per log."]
	quest.5246011000000100.quest_subtitle: "Tap the trees."
	quest.5246011000000100.title: "Fluid Extractor"
	quest.5246011000000101.quest_desc: ["Feed latex and water into the &bLatex Processing Unit&r. It cures the mix into &btiny dry rubber&r, which presses into the plastic this whole mod runs on. Keep the extractor and this unit running as a pair and you will never buy plastic again."]
	quest.5246011000000101.quest_subtitle: "Latex in, rubber out."
	quest.5246011000000101.title: "Latex Processing Unit"
	quest.5246011000000102.quest_desc: ["Build the &bDissolution Chamber&r. It crafts recipes that need an item soaked in fluid, including the advanced machine frames further up this chapter. Whenever a recipe in this mod looks impossible at a bench, it probably belongs in here."]
	quest.5246011000000102.quest_subtitle: "Crafting with a wet step."
	quest.5246011000000102.title: "Dissolution Chamber"
	quest.5246011000000103.quest_desc: ["Soak the parts for an &badvanced machine frame&r in the dissolution chamber. This chassis unlocks the heavier machines in the back half of the chapter, and it is the last frame this age strictly needs."]
	quest.5246011000000103.quest_subtitle: "The second chassis tier."
	quest.5246011000000103.title: "Advanced Frame"
	quest.5246011000000104.quest_desc: ["Push one tier further to the &bsupreme machine frame&r. It is a later frame tier you can prepare while the refinery lines are already running."]
	quest.5246011000000104.quest_subtitle: "Optional: a chassis with headroom."
	quest.5246011000000104.title: "Supreme Frame"
	quest.5246011000000105.quest_desc: ["Add a &bResourceful Furnace&r to the line. It is the refinery's FE-powered smelting option."]
	quest.5246011000000105.quest_subtitle: "Craft one Resourceful Furnace."
	quest.5246011000000105.title: "Resourceful Furnace"
	quest.5246011000000106.quest_desc: ["Pair the gatherer with a &bPlant Sower&r. Feed it the seeds the harvest throws off and it replants the same field on its own. The two machines together close the loop on every row crop you grow."]
	quest.5246011000000106.quest_subtitle: "Seeds go back in the ground."
	quest.5246011000000106.title: "Plant Sower"
	quest.5246011000000107.quest_desc: ["Install a &bPlant Fertilizer&r and stock it with fertilizer from your sewage line. It bone-meals the work area continuously, which turns a patient farm into a fast one."]
	quest.5246011000000107.quest_subtitle: "Hurry the field along."
	quest.5246011000000107.title: "Plant Fertilizer"
	quest.5246011000000108.quest_desc: ["Craft a &bBlock Breaker&r. It mines whatever block sits in front of it, over and over, which makes it the engine of cobble lines, cane farms, and any build where a block needs removing on a schedule."]
	quest.5246011000000108.quest_subtitle: "A piston with a pickaxe."
	quest.5246011000000108.title: "Block Breaker"
	quest.5246011000000109.quest_desc: ["Set a &bBlock Placer&r opposite the breaker. It sets blocks from its inventory into the world, so the pair can rebuild and re-mine the same spot forever. Most compact farms in this mod are just these two facing each other."]
	quest.5246011000000109.quest_subtitle: "The other half of the loop."
	quest.5246011000000109.title: "Block Placer"
	quest.524601100000010A.quest_desc: ["Lay down a &bHydroponic Bed&r and its simulated sibling. Each bed grows a single crop at speed when fed fluid and power, packing a whole field's output into one block. The simulated bed skips the plant entirely and grows the harvest in silicon."]
	quest.524601100000010A.quest_subtitle: "Farmland without the farm."
	quest.524601100000010A.title: "Hydroponic Beds"
	quest.524601100000010B.quest_desc: ["Crown the hydroponic line with a &bHydroponic Simulation Processor&r. It drives the simulated beds, trading power and ether for crops that never touched dirt. One processor can carry a bank of beds."]
	quest.524601100000010B.quest_subtitle: "The farm brain."
	quest.524601100000010B.title: "Simulation Processor"
	quest.524601100000010C.quest_desc: ["Place a &bWater Condensator&r and give it power. It condenses water out of nothing, filling tanks faster than any bucket brigade. Every wet machine in this chapter drinks from one of these eventually."]
	quest.524601100000010C.quest_subtitle: "An infinite spring in a box."
	quest.524601100000010C.title: "Water Condensator"
	quest.524601100000010D.quest_desc: ["Run your dirty fluids through the &bFluid Sieving Machine&r. It strains solids out of liquid streams, and it is the step that turns ender slurry and friends into something a tank is glad to hold."]
	quest.524601100000010D.quest_subtitle: "Pan the slurry."
	quest.524601100000010D.title: "Fluid Sieving Machine"
	quest.524601100000010E.quest_desc: ["Your farms throw off &bsludge&r as a by-product. The &bSludge Refiner&r boils it down into dirt, clay, sand, and the occasional surprise, so even the waste stream of your base pays rent."]
	quest.524601100000010E.quest_subtitle: "Waste back into worth."
	quest.524601100000010E.title: "Sludge Refiner"
	quest.524601100000010F.quest_desc: ["Build the &bWashing Factory&r and plumb in liquid meat from your mob line. It scrubs raw ore into a fermented state that the station beside it can mature into extra metal. This is the front half of the mod's ore multiplication."]
	quest.524601100000010F.quest_subtitle: "Scrub the raw ore."
	quest.524601100000010F.title: "Washing Factory"
	quest.5246011000000110.quest_desc: ["Assemble a &bFluid Laser Base&r beneath your laser drill. Aimed at the right depth it pulls whole tanks of lava, oil, and stranger fluids out of the bedrock. The item drill ahead shares its lenses, so nothing you build here is wasted."]
	quest.5246011000000110.quest_subtitle: "Drill for liquids."
	quest.5246011000000110.title: "Fluid Laser Base"
	quest.5246011000000111.quest_desc: ["Stand a &bFermentation Station&r next to the washing factory. It matures fermented raw ore into a richer state that smelts into more metal than the rock ever held. The maturing step is slow, so set it running and work elsewhere."]
	quest.5246011000000111.quest_subtitle: "Finish the ore wash."
	quest.5246011000000111.title: "Fermentation Station"
	quest.5246011000000112.quest_desc: ["Run a &bSewer&r under your animal pens and pipe the output to a &bSewage Composter&r. Sewage composts into fertilizer, fertilizer feeds the plant fertilizer, and the farm speeds up on its own manure."]
	quest.5246011000000112.quest_subtitle: "The herd pays twice."
	quest.5246011000000112.title: "Sewage Works"
	quest.5246011000000113.quest_desc: ["Feed the &bSpores Recreator&r a mushroom and it multiplies the culture for you."]
	quest.5246011000000113.quest_subtitle: "Craft one Spores Recreator."
	quest.5246011000000113.title: "Spores Recreator"
	quest.5246011000000114.quest_desc: ["Craft the &bPitiful Generator&r if you need a small FE source before the biofuel line stands."]
	quest.5246011000000114.quest_subtitle: "Craft one Pitiful Generator."
	quest.5246011000000114.title: "Pitiful Generator"
	quest.5246011000000115.quest_desc: ["Start a &bmycelial generator&r bank: the furnace, culinary, frosty, and slimey units each burn their own themed fuel, from cooked food to snow to slime. Alone they are modest. As a matched set they out-produce anything else in the room."]
	quest.5246011000000115.quest_subtitle: "Generators with a diet."
	quest.5246011000000115.title: "Mycelial Array I"
	quest.5246011000000116.quest_desc: ["Extend the bank with the &bender&r, &bdeath&r, &bdisenchantment&r, and &bpotion&r mycelial generators."]
	quest.5246011000000116.quest_subtitle: "Craft the second mycelial generator set."
	quest.5246011000000116.title: "Mycelial Array II"
	quest.5246011000000117.quest_desc: ["Round out the set with the &bexplosive&r, &bmagma&r, &brocket&r, &bpink&r, and &bcrimed&r generators."]
	quest.5246011000000117.quest_subtitle: "Craft the third mycelial generator set."
	quest.5246011000000117.title: "Mycelial Array III"
	quest.5246011000000118.quest_desc: ["Craft the &bMob Crusher&r block. It is a single &6Industrial Foregoing&r machine, not a multiblock. Place it over a mob floor when you are ready to farm essence."]
	quest.5246011000000118.quest_subtitle: "Craft the grinder."
	quest.5246011000000118.title: "Mob Essence Grinder"
	quest.5246011000000119.quest_desc: ["Load a captured mob into the &bMob Duplicator&r and feed it essence. It prints copies of the creature into the room, which the crusher next door is more than happy to receive. Choose the captive carefully and the loot writes itself."]
	quest.5246011000000119.quest_subtitle: "Print the captive."
	quest.5246011000000119.title: "Mob Duplicator"
	quest.524601100000011A.quest_desc: ["Point an &bAnimal Rancher&r at your pens. It shears the sheep and milks the cows on a timer, stocking your larder without a single click. The pens become a production line instead of a chore."]
	quest.524601100000011A.quest_subtitle: "Wool, milk, and no labor."
	quest.524601100000011A.title: "Animal Rancher"
	quest.524601100000011B.quest_desc: ["Add an &bAnimal Feeder&r to breed the pens automatically and an &bAnimal Baby Separator&r to push the young into their own paddock."]
	quest.524601100000011B.quest_subtitle: "Craft the feeder and separator."
	quest.524601100000011B.title: "Feeder and Separator"
	quest.524601100000011C.quest_desc: ["Mount a &bMob Detector&r where it can watch the floor. It emits a redstone signal based on nearby creatures."]
	quest.524601100000011C.quest_subtitle: "Craft one Mob Detector."
	quest.524601100000011C.title: "Mob Detector"
	quest.524601100000011D.quest_desc: ["Sink a &bMarine Fisher&r over open water. It automates fishing output for the refinery side systems."]
	quest.524601100000011D.quest_subtitle: "Craft one Marine Fisher."
	quest.524601100000011D.title: "Marine Fisher"
	quest.524601100000011E.quest_desc: ["The &bWither Builder&r stacks soul sand and skulls for automated wither summoning. Build containment before using it."]
	quest.524601100000011E.quest_subtitle: "Craft one Wither Builder."
	quest.524601100000011E.title: "Wither Builder"
	quest.524601100000011F.quest_desc: ["Build a &bStasis Chamber&r beneath the builder's work area. It holds entities inside its working area for controlled mob handling."]
	quest.524601100000011F.quest_subtitle: "Craft one Stasis Chamber."
	quest.524601100000011F.title: "Stasis Chamber"
	quest.5246011000000120.quest_desc: ["Lay a run of &bconveyor belts&r between machines. They move items and entities across a visible route."]
	quest.5246011000000120.quest_subtitle: "Craft conveyor belts."
	quest.5246011000000120.title: "Conveyor Belts"
	quest.5246011000000124.quest_desc: ["Add a &bSteam Cracker&r behind the column. It runs the heavy fractions back through heat and steam until they break into the lighter feedstocks your reactors actually want. Nothing from the barrel goes to waste."]
	quest.5246011000000124.quest_subtitle: "Heavy cuts made light."
	quest.5246011000000124.title: "Steam Cracker"
	quest.5246011000000125.quest_desc: ["Install the &bCatalytic Reformer&r. It reworks the column's middle fraction into the high-grade feed the polymer and fuel recipes call for. In this pack its coking stack is lined with Immersive Petroleum &basphalt&r and framed in Electrodynamics tank steel."]
	quest.5246011000000125.quest_subtitle: "Upgrade the middle cut."
	quest.5246011000000125.title: "Catalytic Reformer"
	quest.5246011000000126.quest_desc: ["Fit an &bHDS Unit&r into the train. It strips the sulfur compounds out of your fuel cuts so the engines and reactors downstream burn clean. Skipping it works until the day a recipe refuses your dirty diesel."]
	quest.5246011000000126.quest_subtitle: "Scrub the fuel line."
	quest.5246011000000126.title: "HDS Unit"
	quest.5246011000000127.quest_desc: ["Raise the &bRedox Furnace&r multiblock around its controller. It runs the high-heat conversions the bench machines cannot touch, and building one says your chemistry has outgrown the tabletop."]
	quest.5246011000000127.quest_subtitle: "The chemical hearth."
	quest.5246011000000127.title: "Redox Furnace"
	quest.5246011000000128.quest_desc: ["Print a &bchromatography card&r for any single gas. Slotted into the gas apparatus, a card tunes the machine toward that gas."]
	quest.5246011000000128.quest_subtitle: "Craft any chromatography card."
	quest.5246011000000128.title: "Chromatography Cards"
	quest.5246011000000129.quest_desc: ["Build the &bSimulation Chamber&r and load a trained model. It replays the fight in silicon, consuming polymer clay and power, and pays out the mob's loot in prediction form. In this pack its core is a NauTec &baquatic chip&r, so the oceanic lab next door supplies the brain this machine thinks with."]
	quest.5246011000000129.quest_subtitle: "The fight, virtualized."
	quest.5246011000000129.title: "Simulation Chamber"
	quest.524601100000012A.quest_desc: ["Keep &bblank data models&r and &bprediction matrices&r in supply. Blanks become new mob studies, and matrices hold simulator output."]
	quest.524601100000012A.quest_subtitle: "Stock blank models and matrices."
	quest.524601100000012A.title: "Models and Matrices"
	quest.524601100000012B.quest_desc: ["Add an &bEnchantment Extractor&r. It lifts an enchantment off any tool and writes it to a fresh book, leaving the gear plain. Bad rolls and mob-drop junk become a book library instead of furnace fodder."]
	quest.524601100000012B.quest_subtitle: "Peel the magic off."
	quest.524601100000012B.title: "Enchantment Extractor"
	quest.524601100000012C.quest_desc: ["Set up the &bEnchantment Applicator&r to merge books onto gear with essence instead of anvil levels. Combined with the extractor you can strip, sort, and restack enchantments assembly-line style."]
	quest.524601100000012C.quest_subtitle: "The anvil, automated."
	quest.524601100000012C.title: "Enchantment Applicator"
	quest.524601100000012D.quest_desc: ["Pass your book backlog through the &bEnchantment Sorter&r. It sorts enchanted items from plain ones for the refinery's enchantment line."]
	quest.524601100000012D.quest_subtitle: "Craft one Enchantment Sorter."
	quest.524601100000012D.title: "Enchantment Sorter"
	quest.524601100000012E.quest_desc: ["Automate brewing with the &bPotion Brewer&r."]
	quest.524601100000012E.quest_subtitle: "Craft one Potion Brewer."
	quest.524601100000012E.title: "Potion Brewer"
	quest.524601100000012F.quest_desc: ["Craft the &bDye Mixer&r block, unlocked in the Gilded Age. It blends pigments into &6Artificial Dye&r once placed and fed."]
	quest.524601100000012F.quest_subtitle: "Craft the Artificial Dye Station."
	quest.524601100000012F.title: "Artificial Dye Station"
	quest.5246011000000130.quest_desc: ["Mount an &bInfinity Charger&r. It charges supported infinity-tier tools once you have them."]
	quest.5246011000000130.quest_subtitle: "Craft one Infinity Charger."
	quest.5246011000000130.title: "Infinity Charger"
	quest.5246011000000131.quest_desc: ["Lay &bsoul network pipe&r from your soul laser base and keep a &bsoul surge&r charged. These parts support the refinery's soul-network branch."]
	quest.5246011000000131.quest_subtitle: "Craft soul network parts."
	quest.5246011000000131.title: "Soul Network"
	quest.5246011000000140.quest_desc: [
		"The diesel mining drill and diesel chainsaw drink the diesel your refinery line already produces. Fill them from a tank or fluid slot and they outpace every steam tool."
		"The drill has a 3x3 mode and the chainsaw fells whole trees. Check each tool's mode toggle before you dig or cut."
		"Keep a filled spare in your pack. A dry diesel tool is just a heavy stick."
	]
	quest.5246011000000140.quest_subtitle: "Fuel-burning drill and chainsaw."
	quest.5246011000000140.title: "Diesel Field Tools"
	quest.5246011000000141.quest_desc: [
		"The diesel jetpack burns fuel for real flight. Hold the ascend key to climb and feather it to hover. Watch the tank; an empty jetpack is a long fall."
		"The stainless steel drill is the tier above diesel digging speed and pairs well with the jetpack for quarry walls and ceilings."
		"Both fill from the same diesel stock as your field tools. One refinery feeds your whole kit."
	]
	quest.5246011000000141.quest_subtitle: "Jetpack up, stainless down."
	quest.5246011000000141.title: "Diesel Mobility"
	quest.5347010000010001.quest_desc: ["Hold a &bSchrödinger's Safe&r. Right click a dangerous block with it in hand to capture that block as the core of a large multiblock power bank. Stabilize the result with enderic lasers to multiply how much energy it stores."]
	quest.5347010000010001.quest_subtitle: "A power bank with teeth."
	quest.5347010000010001.title: "Schrödinger's Safe"
	quest.5347010000010002.quest_desc: ["Right click the &bBlack Hole&r to log it. Oritech itself warns against placing one casually, so study it where it sits."]
	quest.5347010000010002.quest_subtitle: "Handle with extreme care."
	quest.5347010000010002.title: "Black Hole"
	quest.5350010000010000.quest_desc: ["Milestones complete automatically when their linked capstone is complete. The welcome tile only records your starting age; it grants no items, power, or later age."]
	quest.5350010000010000.quest_subtitle: "Granted at world entry."
	quest.5350010000010000.title: "&8Dark Ages&r"
	quest.5350010000020000.quest_subtitle: "Medieval age gate."
	quest.5350010000020000.title: "&8Medieval Times&r"
	quest.5350010000020001.quest_desc: [
		"&2What Waits in the Grove&r closes Medieval Times. Its reveal gate requires &6Marks of the Craft&r, the &bSand Filter&r in &bRotational Power&r, and the &7Black Foundry Controller&r."
		"Complete &2Master of the Grove&r to open the &5Renaissance&r."
		"[ \"Open the \", { \"text\": \"Grove capstone\", \"underlined\": true, \"clickEvent\": { \"action\": \"change_page\", \"value\": \"6D7E8F901A2B1054\" } }, \" to view the gate.\" ]"
	]
	quest.5350010000020001.quest_subtitle: "Complete the Grove capstone to open the Renaissance."
	quest.5350010000020001.title: "&2What Waits in the Grove&r"
