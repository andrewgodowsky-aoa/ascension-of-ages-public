	quest.537A8F99CC3F525D.quest_desc: [
		"Grow your standing guard to eight. A handful of trained, posted guards turns a colony from easy prey into a hard target."
		"Build the towers and &bbarracks&r space to house them all."
	]
	quest.537A8F99CC3F525D.quest_subtitle: "A patrol becomes a garrison."
	quest.537A8F99CC3F525D.title: "Army of Eight"
	quest.53967D6D1E7151E0.quest_desc: ["Collect the Gnome Hat and Gnome Boots from the gnomes. The little set is light protection, but it wears well around the garden and finishes the gnome drops."]
	quest.53967D6D1E7151E0.quest_subtitle: "Hat and boots, more charm than armor."
	quest.53967D6D1E7151E0.title: "Gnome Gear"
	quest.53F8923B85A8A9CC.quest_desc: [
		"Command eighty guards. A garrison this large shrugs off all but the worst raids, the mark of a fortress town."
		"Sustaining it takes serious food and gear production behind the walls."
	]
	quest.53F8923B85A8A9CC.quest_subtitle: "A fortress colony."
	quest.53F8923B85A8A9CC.title: "Army of Eighty"
	quest.5449010000010001.quest_desc: ["Place the &bCrafting Core&r. Ringed with pedestals, it forms Extended Crafting's combination altar."]
	quest.5449010000010001.quest_subtitle: "The combination altar's heart."
	quest.5449010000010001.title: "Crafting Core"
	quest.5449010000010002.quest_desc: ["Hold an &bElite Table&r. It carries a seven-by-seven grid for elite table recipes."]
	quest.5449010000010002.quest_subtitle: "A seven-by-seven bench."
	quest.5449010000010002.title: "Elite Table"
	quest.5449010000010003.quest_desc: ["Hold an &bUltimate Table&r. Its nine-by-nine grid sits at the top of the table ladder."]
	quest.5449010000010003.quest_subtitle: "The nine-by-nine bench."
	quest.5449010000010003.title: "Ultimate Table"
	quest.5449010000010004.quest_desc: ["Place the &bCompressor&r. It crushes a huge count of one ingredient into a single dense output when a compression recipe calls for it."]
	quest.5449010000010004.quest_subtitle: "Mass compression in one block."
	quest.5449010000010004.title: "Compressor"
	quest.5449010000010005.quest_desc: ["Hold an &bUltimate Component&r. The fusion table wants this part before endgame crafts open."]
	quest.5449010000010005.quest_subtitle: "Part before endgame crafts."
	quest.5449010000010005.title: "Ultimate Component"
	quest.5449010000010006.quest_desc: ["Keep an Ultimate Catalyst in your inventory. Completing this quest seals the ascension stage."]
	quest.5449010000010006.quest_subtitle: "Seal ascension stage."
	quest.5449010000010006.title: "Ultimate Catalyst"
	quest.5449010000020001.quest_desc: [
		"Craft &bCrystaltine Ingots&r in the &bElite Table&r. The seven-wide recipe presses diamonds, lapis, iron, and gold around a nether star and returns four ingots per craft."
		"Crystaltine is the material tier the endgame recipes lean on. Stock nether stars before you start; every batch consumes one."
	]
	quest.5449010000020001.quest_subtitle: "Lapis and starlight, alloyed."
	quest.5449010000020001.title: "Crystaltine Ingot"
	quest.5449010000020002.quest_desc: [
		"Combine a &bBlack Iron Slate&r, &bLuminessence&r, and two Crystaltine Ingots for the &bCrystaltine Component&r. Then set four components around a black iron ingot for the &bCrystaltine Catalyst&r."
		"Keep a stack of components on hand. The catalyst is a per-craft key for recipes that ask for it, so one or two is plenty."
	]
	quest.5449010000020002.quest_subtitle: "Components for the top tier."
	quest.5449010000020002.title: "Crystaltine Parts"
	quest.5449010000020003.quest_desc: [
		"Return to the &bEnder Crafter&r and &bFlux Crafter&r you built in the Gilded Age. Ring a nether star with eyes of ender in the Ender Crafter for the &bEnder Star&r. Ring one with gold in the Flux Crafter for the &bFlux Star&r; that craft drinks 400,000 FE."
		"The Ender Crafter works on its own schedule while its end crafting alters channel the recipe. The Flux Crafter stalls without power, so check its buffer before you blame the recipe."
	]
	quest.5449010000020003.quest_subtitle: "Stars from the Gilded crafters."
	quest.5449010000020003.title: "Ender and Flux Stars"
	quest.5449010000020004.quest_desc: [
		"Slot an &bUltimate Catalyst&r into Extended Crafting's &bCompressor&r, then feed the input a massive count of a single material. Iron, gold, diamond, and sixteen more each collapse into their own &bSingularity&r. Any one of them completes this quest."
		"Counts run into the thousands per craft, so point a bulk production line at the compressor rather than feeding it by hand."
	]
	quest.5449010000020004.quest_subtitle: "Thousands pressed into one."
	quest.5449010000020004.title: "Singularity Compression"
	quest.5449010000020005.quest_desc: [
		"Collect one of every enabled &bSingularity&r, all nineteen types, and fuse them in the &bUltimate Table&r into the &bUltimate Singularity&r."
		"This is the longest bulk grind in Extended Crafting. Automate the compressor feed for each material and let your storage system meter the inputs."
	]
	quest.5449010000020005.quest_subtitle: "Every singularity, fused."
	quest.5449010000020005.title: "Ultimate Singularity"
	quest.5457010000010000.quest_desc: ["Stand up &6Modular Forcefields&r: the fortron capacitor, biometric identifier, and interdiction matrix. Together they project a barrier, decide who belongs inside it, and evict who does not. Build the defense before you build anything worth defending."]
	quest.5457010000010000.quest_subtitle: "The shield goes up first."
	quest.5457010000010000.title: "Modular Forcefields"
	quest.5457010000010001.quest_desc: ["Construct the tier-one &blauncher platform&r with its control panel and support frame, then ring the site with &bradar&r, the fire-control set, the ESM tower, proximity detectors, and the air raid siren."]
	quest.5457010000010001.quest_subtitle: "The silo takes shape."
	quest.5457010000010001.title: "Launcher Platform"
	quest.5457010000010002.quest_desc: ["Assemble the &bnuclear warhead&r. It draws on every enrichment and engineering chain this age built. The capstone asks you to hold it, not to use it."]
	quest.5457010000010002.quest_subtitle: "The nuclear warhead."
	quest.5457010000010002.title: "Nuclear Warhead"
	quest.5457010000010003.quest_desc: ["Stand the complete deterrent: forcefields live, silo certified, warhead racked. This closes the atomic war lane and hands off to the silenced prophets chapter."]
	quest.5457010000010003.quest_subtitle: "Deterrent complete."
	quest.5457010000010003.title: "Threshold Crossed"
	quest.5457010000010004.quest_desc: ["Load the original payload rack: &bobsidian&r, &bbreaching&r, &bfragmentation&r, &bEMP&r, and &bender&r shells. They are the safe half of the catalog; the warhead galleries later in this lane hold the rest."]
	quest.5457010000010004.quest_subtitle: "Optional: the starter rack."
	quest.5457010000010004.title: "First Payloads"
	quest.5457011000000100.quest_desc: ["Complete the field array: the &bfortron field projector&r throws the barrier, the &bcoercion deriver&r feeds it fortron, and &bfocus matrices&r shape where the wall stands. Together with the capacitor they are the whole shield, end to end."]
	quest.5457011000000100.quest_subtitle: "The barrier takes shape."
	quest.5457011000000100.title: "Field Projection"
	quest.5457011000000101.quest_desc: ["Upgrade the silo to &btier two&r: platform, panel, and frame. Range and payload class both climb, and the range officer in you starts thinking in map regions instead of chunks."]
	quest.5457011000000101.quest_subtitle: "Optional: longer reach."
	quest.5457011000000101.title: "Launcher Tier 2"
	quest.5457011000000102.quest_desc: ["Finish the silo at &btier three&r. The heaviest payloads in the catalog need this platform under them, including the one the chapter's capstone keeps under glass."]
	quest.5457011000000102.quest_subtitle: "Optional: the full silo."
	quest.5457011000000102.title: "Launcher Tier 3"
	quest.5457011000000103.quest_desc: ["Assemble a &btier-one missile&r body. It is the airframe every payload in the gallery rides, and watching your first test shot arc over the valley is a rite of this age."]
	quest.5457011000000103.quest_subtitle: "Optional: the range opens."
	quest.5457011000000103.title: "First Missile"
	quest.5457011000000104.quest_desc: ["Craft the handheld &brocket launcher&r for fire missions that cannot wait for a silo. The &btracker&r in the reward locks a payload onto a moving target, which changes several arguments permanently."]
	quest.5457011000000104.quest_subtitle: "Optional: artillery, shoulder edition."
	quest.5457011000000104.title: "Rocket Launcher"
	quest.5457011000000105.quest_desc: ["Load a payload from the kinetic rack: &bincendiary&r, &bexothermic&r, &bendothermic&r, &bshrapnel&r, or the &banvil&r. Each reshapes the impact site in its own dialect. Test far from anything you have opinions about."]
	quest.5457011000000105.quest_subtitle: "Kinetic payload rack."
	quest.5457011000000105.title: "Kinetic Payloads"
	quest.5457011000000106.quest_desc: ["Arm an exotic payload: &bantigravity&r, &battractive&r, &brepulsive&r, &bsonic&r, or &bhypersonic&r. These warheads argue with gravity and pressure instead of just heat, and the test range footage is worth the materials alone."]
	quest.5457011000000106.quest_subtitle: "Exotic payload rack."
	quest.5457011000000106.title: "Exotic Payloads"
	quest.5457011000000107.quest_desc: ["Stock the hazard rack with any one payload: &bchemical&r, &bcontagious&r, &binfestive&r, &bdebilitation&r, or &bcondensive&r. They linger over the impact zone and make it nobody's favorite biome for a while. The siren exists for your own tests as much as anyone's."]
	quest.5457011000000107.quest_subtitle: "Optional: area denial."
	quest.5457011000000107.title: "Hazard Payloads"
	quest.5457011000000108.quest_desc: ["Craft either extreme for the gallery: the &brejuvination&r shell that heals and regrows the land it lands on, or the &bthermobaric&r shell that very much does not."]
	quest.5457011000000108.quest_subtitle: "Extreme payload options."
	quest.5457011000000108.title: "Extremes of the Catalog"
	quest.5457011000000109.quest_desc: ["Mount a &bbasic laser turret&r on the wall. It draws from the grid and tracks anything hostile in range, and unlike the gilded gun turrets it never asks for ammunition."]
	quest.5457011000000109.quest_subtitle: "Optional: the perimeter aims itself."
	quest.5457011000000109.title: "Laser Turret"
	quest.545701100000010A.quest_desc: ["Upgrade the post to the &badvanced laser turret&r. Faster tracking and a heavier beam mean fewer things ever reach the wall at all."]
	quest.545701100000010A.quest_subtitle: "Optional: sharper eyes, hotter beam."
	quest.545701100000010A.title: "Advanced Laser Turret"
	quest.545701100000010B.quest_desc: ["Install the &belite laser turret&r. At this tier a single post covers what a squad used to, and night watches become something you remember fondly."]
	quest.545701100000010B.quest_subtitle: "Optional: the wall takes over."
	quest.545701100000010B.title: "Elite Laser Turret"
	quest.545701100000010C.quest_desc: ["Cap the perimeter with the &bultimate laser turret&r. It handles anything the prophets' world sends at it, and the watchtower job quietly retires."]
	quest.545701100000010C.quest_subtitle: "Optional: ultimate perimeter turret."
	quest.545701100000010C.title: "Ultimate Laser Turret"
	quest.545701100000010D.quest_desc: ["Build the original &6Mekanism&r &blaser&r. It digs through blocks, burns what it hits, and can feed the laser amplifier next door."]
	quest.545701100000010D.quest_subtitle: "Optional: Mekanism laser."
	quest.545701100000010D.title: "Mekanism Laser"
	quest.545701100000010E.quest_desc: ["Add the &blaser amplifier&r. It banks beam energy from several lasers into one colossal pulse, and the redstone trigger makes the discharge a decision instead of a drizzle."]
	quest.545701100000010E.quest_subtitle: "Optional: charge the shot."
	quest.545701100000010E.title: "Laser Amplifier"
	quest.545701100000010F.quest_desc: ["Finish the optical line with the &btractor beam&r. It catches everything the amplified pulse dislodges, so mining by laser stops meaning a crater full of lost drops."]
	quest.545701100000010F.quest_subtitle: "Optional: catch the spoils."
	quest.545701100000010F.title: "Laser Tractor Beam"
	quest.5457011000000110.quest_desc: ["Press &bindustrial TNT&r. MI's demolition charge clears quarry benches in clean, predictable lifts, mining explosives with a safety briefing attached."]
	quest.5457011000000110.quest_subtitle: "Optional: industrial demolition charge."
	quest.5457011000000110.title: "Industrial TNT"
	quest.5457011000000111.quest_desc: ["Roll &bblastproof casings&r. They wall in your test range and line the implosion compressor, plating that lets detonation become a manufacturing step instead of an accident report."]
	quest.5457011000000111.quest_subtitle: "Optional: contain the argument."
	quest.5457011000000111.title: "Blastproof Casing"
	quest.5457011000000112.quest_desc: ["Cast &6Modern Industrialization&r's &bnuke&r block. It is the factory empire's own final argument, kept in the same locked room as the Ballistix warhead."]
	quest.5457011000000112.quest_subtitle: "MI deterrent block."
	quest.5457011000000112.title: "MI Nuke"
	quest.5457011000000113.quest_desc: ["Fabricate the full &bquantum armor&r suit. It is MI's endgame plate, and the materials bill reads like the index of this whole questbook."]
	quest.5457011000000113.quest_subtitle: "Optional: probability as plating."
	quest.5457011000000113.title: "Quantum Armor"
	quest.5457011000000114.quest_desc: ["Forge the &bquantum sword&r to match the suit. It swings with the same disregard for conventional physics the armor stands on, and it is the last blade the tech tree will ever hand you."]
	quest.5457011000000114.quest_subtitle: "MI quantum weapon."
	quest.5457011000000114.title: "Quantum Sword"
	quest.5457011000000115.quest_desc: ["Tank up &6Mekanism&r's hydrogen &bflamethrower&r. For clearing dense hostile rooms there is still nothing more persuasive at ten blocks, and your electrolyzer makes the fuel from water."]
	quest.5457011000000115.quest_subtitle: "Optional: close-range policy."
	quest.5457011000000115.title: "Flamethrower"
	quest.5457011000000116.quest_desc: ["Build &6Chemical Science&r's &bflamethrower&r as well. It drinks the lab's own fuel blends, and owning both models makes you the district's least subtle collector."]
	quest.5457011000000116.quest_subtitle: "Optional: the lab keeps its own torch."
	quest.5457011000000116.title: "ChemSci Flamethrower"
	quest.5457011000000117.quest_desc: ["Build the &bModification Station&r. It installs and tunes the modules that make the MekaSuit more wardrobe than armor, and every upgrade this wing earns passes across its table."]
	quest.5457011000000117.quest_subtitle: "The suit bench."
	quest.5457011000000117.title: "Modification Station"
	quest.5457011000000118.quest_desc: ["Assemble the full &bMekaSuit&r. Powered, modular, and hungry for antimatter fuel. The module rack quests that follow are where it grows."]
	quest.5457011000000118.quest_subtitle: "The atomic age, worn."
	quest.5457011000000118.title: "MekaSuit"
	quest.5457011000000119.quest_desc: ["Forge the &bMeka-Tool&r. Modules teach it to mine, fell, dig, shear, and strike. One handle replaces the whole rack by the door. Pair it with the suit and your hotbar gets four slots back."]
	quest.5457011000000119.quest_subtitle: "Optional: modular powered tool."
	quest.5457011000000119.title: "Meka-Tool"
	quest.545701100000011A.quest_desc: ["Install any &bwork module&r: energy banks, attack amplification, blasting, excavation, vein mining, farming, shearing, silk-touch, ore-luck, or the evolved luck unit. Each one adds another role to the suit."]
	quest.545701100000011A.quest_subtitle: "Optional: the suit earns a wage."
	quest.545701100000011A.title: "Work Modules"
	quest.545701100000011B.quest_desc: ["Fit any &bmobility module&r: jetpack, locomotive boosting, hydraulic jumps, hydrostatic glide, gyroscopic stabilization, frost walking, soul surfing, elytra flight, magnetism, or servo assistance. The map gets smaller with every install."]
	quest.545701100000011B.quest_subtitle: "Optional: the suit learns to move."
	quest.545701100000011B.title: "Mobility Modules"
	quest.545701100000011C.quest_desc: ["Slot any &blife support module&r: radiation shielding, air purification, electrolytic breathing, nutritional injection, dosimetry, vision enhancement, laser dissipation, charge distribution, or the generator units that refuel the suit from heat and sun. The hazmat rack becomes a museum piece."]
	quest.545701100000011C.quest_subtitle: "Optional: the suit keeps you alive."
	quest.545701100000011C.title: "Life Support Modules"
	quest.545701100000011D.quest_desc: ["Forge any late-tier &bpaxel&r: steel, lapis, osmium, netherite, refined glowstone, or refined obsidian. The three-in-one tool from the gilded workshop graduates into the atomic metallurgy."]
	quest.545701100000011D.quest_subtitle: "Late-tier paxel option."
	quest.545701100000011D.title: "Paxel Arsenal"
	quest.545701100000011E.quest_desc: ["Smith a full set of &brefined glowstone armor&r. Light, bright, and tougher than it looks, it is the armor for anyone who wants the lab lit wherever they stand."]
	quest.545701100000011E.quest_subtitle: "Optional: armor with a halo."
	quest.545701100000011E.title: "Refined Glowstone Armor"
	quest.545701100000011F.quest_desc: ["Forge &brefined obsidian armor&r, the heaviest conventional plate Mekanism pours. Until the MekaSuit comes off the bench, nothing you own takes a hit better."]
	quest.545701100000011F.quest_subtitle: "Optional: the immovable suit."
	quest.545701100000011F.title: "Refined Obsidian Armor"
	quest.5468102A19D28104.quest_desc: [
		"Hunt the &c&lCorrupted Ancient Hero&r. It spawns naturally in the &boverworld&r, at y=12 or lower. "
		"Weight is low, so keep moving. Its broken sword is the drop you came for."
	]
	quest.5468102A19D28104.quest_subtitle: "Defeat the Corrupted Ancient Hero."
	quest.5468102A19D28104.title: "Corrupted Ancient Hero"
	quest.5570BA2E7BCC50C2.quest_desc: [
		"Cast a &bMushroomite Chunk&r. The garden's mushrooms render into a metal-like material, and the foundry's &bingot cast&r is what shapes it into a usable chunk."
		"It is the feedstock the mushroom-tier tools are forged from."
	]
	quest.5570BA2E7BCC50C2.quest_subtitle: "Metal grown from mushrooms."
	quest.5570BA2E7BCC50C2.title: "Mushroomite Chunk"
	quest.55851524FDDB6959.quest_desc: [
		"Build the &bChef's Kitchen&r. The Chef cooks raw ingredients into full meals that feed citizens better than loose food, raising their saturation and mood."
		"Keep it stocked from the farms and herders and the whole town eats well."
	]
	quest.55851524FDDB6959.quest_subtitle: "Proper meals, not scraps."
	quest.55851524FDDB6959.title: "Chef's Kitchen"
	quest.55E3541DEC3D3BE4.quest_desc: ["Gather more &bDark Essence&r. It is the scarce reagent the strongest &6Monster Plus&r recipes demand, so stock a few before you start crafting."]
	quest.55E3541DEC3D3BE4.quest_subtitle: "The rare one they all want."
	quest.55E3541DEC3D3BE4.title: "Dark Essence"
	quest.5607E15F448C5DC8.quest_desc: ["Craft a &bMortar and Pestle&r. It grinds herbs and oddments into the powders and pastes the &6Alchemist's Garden&r recipes are built on. Set it on the workbench you will be brewing at."]
	quest.5607E15F448C5DC8.quest_subtitle: "Grind herbs into reagents."
	quest.5607E15F448C5DC8.title: "Mortar and Pestle"
	quest.560CECEDB7CEC742.quest_desc: ["Craft a &bClay Tool Cast&r and keep it with your forging kit. A cast is the reusable mold side of Overgeared smithing, shaping parts without hammering each one out by hand."]
	quest.560CECEDB7CEC742.quest_subtitle: "Put the hammer down."
	quest.560CECEDB7CEC742.title: "Quick Casting"
	quest.5786EDCFEBE0F04B.quest_desc: ["Make a &bBezoar Stone&r. It is the garden's cure-all against poison, which you will want on hand the moment you start handling the more toxic plants."]
	quest.5786EDCFEBE0F04B.quest_subtitle: "The garden's antidote."
	quest.5786EDCFEBE0F04B.title: "Bezoar Stone"
	quest.57C889EC980D33D9.quest_desc: [
		"Build the &bFarmer's Hut&r and mark out fields beside it. The Farmer plants, tends, and harvests crops across them, feeding most of the colony."
		"Pair it with a &bComposter&r for the enriched dirt the fields need."
	]
	quest.57C889EC980D33D9.quest_subtitle: "The colony's main food engine."
	quest.57C889EC980D33D9.title: "Farmer's Hut"
	quest.57E439CDF7D76BB1.quest_desc: ["Brew a &bBlood Bottle&r from blood roses. The garden uses it as both a reagent in stronger recipes and a drink in its own right."]
	quest.57E439CDF7D76BB1.quest_subtitle: "Bottled from blood roses."
	quest.57E439CDF7D76BB1.title: "Blood Bottle"
	quest.5827E9110E4B19F9.quest_desc: [
		"Upgrade the &bMystical Site&r to level five. A higher-level site lifts colony happiness further, and the happiest colonies are the most productive."
		"Worth the materials once you are running a large town."
	]
	quest.5827E9110E4B19F9.quest_subtitle: "Push happiness further."
	quest.5827E9110E4B19F9.title: "Mystical Site, Level 5"
	quest.583A7AA84FEC027F.quest_desc: [
		"Build the &bBuilder's Hut&r and assign a worker. The Builder constructs and upgrades every other building from your requests, so the colony grows only as fast as they can work."
		"Keep them supplied with materials or the whole town stalls waiting on one person."
	]
	quest.583A7AA84FEC027F.quest_subtitle: "Who builds everything else."
	quest.583A7AA84FEC027F.title: "Builder's Hut"
	quest.5A11A2FC20E5CE2A.quest_desc: [
		"Construct the &bBarracks&r. It houses and posts guards in real numbers, the core of a defense that holds once raids turn serious."
		"Each tower built onto it stations another guard, so plan room to grow."
	]
	quest.5A11A2FC20E5CE2A.quest_subtitle: "Defense in numbers."
	quest.5A11A2FC20E5CE2A.title: "Barracks"
	quest.5B311BE4300DA13C.quest_desc: ["Craft the Conduit Cage from Create: Aquatic Ambitions. Keep it with the aquatic machinery line."]
	quest.5B311BE4300DA13C.quest_subtitle: "Optional: route power through the conduit cage."
	quest.5B311BE4300DA13C.title: "Conduit Cage"
	quest.5EB4C3D826C19D59.quest_desc: [
		"Craft a &bSand Filter&r from sand, a &bCreate nozzle&r, and a &bfluid tank&r. Connect a pump and send &bDirty Water&r into the top."
		"The filter produces &bPurified Water&r at the bottom. Route the output into a tank to form a repeatable bulk purification system for drinking water."
	]
	quest.5EB4C3D826C19D59.quest_subtitle: "Create-powered bulk purification."
	quest.5EB4C3D826C19D59.title: "&6Sand Filter&r"
	quest.5F5DB67F6A470C73.quest_desc: [
		"Field thirty guards. At this size a raid meets a genuine wall of defenders rather than a token patrol."
		"Keep the &bbarracks&r and training buildings feeding the ranks."
	]
	quest.5F5DB67F6A470C73.quest_subtitle: "A real wall of defenders."
	quest.5F5DB67F6A470C73.title: "Army of Thirty"
	quest.60D53613768CA1F3.quest_desc: [
		"Build a &bCampfire&r and light it. It cooks raw food slowly without any fuel and throws off enough warmth to take the edge off a cold night."
		"The chapter opens here. &6Cold Sweat&r will punish an unprepared night, so get a fire going before you do anything else."
		""
	]
	quest.60D53613768CA1F3.quest_subtitle: "Warmth, light, and cooked food in one block."
	quest.60D53613768CA1F3.title: "A Fire to Live By"
	quest.62CA9D0E97DAD5A0.quest_desc: [
		"Craft the portable loom, grindstone, cartography table, stonecutter, smithing table, and anvil. Each one opens its station from the hotbar, so banners, repairs, maps, and cut stone all happen on the move."
		"Carry the ones a trip actually needs rather than the whole set, and your inventory stays usable."
	]
	quest.62CA9D0E97DAD5A0.quest_subtitle: "Loom, anvil, and the rest in your bag."
	quest.62CA9D0E97DAD5A0.title: "Pocket Workstations"
	quest.62FF13481B0696BA.quest_desc: [
		"Place a &bCalendar&r to track the date and current season from &6Ecliptic Seasons&r. Crops grow on the season they belong to, so knowing whether spring or winter is coming decides what is worth sowing."
		"Check it before a big planting. A field sown out of season is wasted seed."
	]
	quest.62FF13481B0696BA.quest_subtitle: "Read the season before you plant."
	quest.62FF13481B0696BA.title: "Calendar"
	quest.65D23E7683812E26.quest_desc: [
		"Watch a colonist eat something grim, like rotten flesh. Hungry citizens eat whatever is on hand, which is a clear sign your food supply is running short."
		"Take it as a cue to get a farmer and a cook running before morale drops."
	]
	quest.65D23E7683812E26.quest_subtitle: "A sign the larder is thin."
	quest.65D23E7683812E26.title: "Lean Times"
	quest.6689B369ECBF5D7C.quest_desc: ["Forge the complete &bMushroomite&r set: sword, pickaxe, axe, shovel, and hoe. They are the garden's own tier of gear, the payoff for working the mushroom line end to end."]
	quest.6689B369ECBF5D7C.quest_subtitle: "Complete Mushroomite tools."
	quest.6689B369ECBF5D7C.title: "Mushroomite Tools"
	quest.67E8B8DCFC93F832.quest_desc: [
		"Raise a &bWarehouse&r. It is the central store every building delivers to and draws from, which is what lets a colony share resources instead of each hut hoarding its own."
		"Add racks inside to expand how much it can hold."
	]
	quest.67E8B8DCFC93F832.quest_subtitle: "The store everything pulls from."
	quest.67E8B8DCFC93F832.title: "Warehouse"
	quest.68500900087F92BC.quest_desc: [
		"Teach a crafter to make doors. Adding the recipe lets the colony produce its own, one more chore off your hands."
		"Keep adding recipes like this and your crafters cover most of what you need."
	]
	quest.68500900087F92BC.quest_subtitle: "One more thing you stop crafting."
	quest.68500900087F92BC.title: "Carpenter's Doors"
	quest.68FC81E133443E76.quest_desc: [
		"Build the &bLibrary&r. Citizens study there to raise their Intelligence and Knowledge, which speeds &bUniversity&r research across the whole colony."
		"A well-read colony advances noticeably faster, so staff it early."
	]
	quest.68FC81E133443E76.quest_subtitle: "Smarter citizens, faster research."
	quest.68FC81E133443E76.title: "Library"
	quest.696BDC29ACCBBE29.quest_desc: [
		"Have the Undertaker raise a fallen citizen. With a staffed &bGraveyard&r and the right totem, a lost colonist can be brought back rather than gone for good."
		"It is the colony's insurance against losing a trained worker to a bad raid."
	]
	quest.696BDC29ACCBBE29.quest_subtitle: "Death need not be final."
	quest.696BDC29ACCBBE29.title: "Raise the Dead"
	quest.69EAF1072D492F1A.quest_desc: [
		"Get hold of an &bAncient Tome&r. Used at the &bTown Hall&r it summons mercenaries to help fight off a raid your own guards cannot handle alone."
		"Keep one in reserve for the night a raid comes in heavier than expected."
	]
	quest.69EAF1072D492F1A.quest_subtitle: "Call in hired help."
	quest.69EAF1072D492F1A.title: "Ancient Tome"
	quest.6A1E8D4C0F2B7A11.quest_desc: [
		"Break gravel until you have &bflint&r in hand. Before any metal exists, flint is what &6Overgeared&r uses to chip loose stone into workable &bRock&r."
		"Gravel sits under most rivers and in patches underground, so a short dig is usually enough to start."
	]
	quest.6A1E8D4C0F2B7A11.quest_subtitle: "The first cutting edge."
	quest.6A1E8D4C0F2B7A11.title: "Flint"
	quest.6A1E8D4C0F2B7A12.quest_desc: [
		"Hold &bflint&r and right-click a stone block to chip off a &bRock&r, and repeat until you have a few. The flint can break, so carve more than you need. This is how &6Overgeared&r gathers raw stone, no crafting grid required."
		"Rocks are the raw stock for every knapped part, so keep a small pile on hand."
	]
	quest.6A1E8D4C0F2B7A12.quest_subtitle: "Loose stone, shaped by hand."
	quest.6A1E8D4C0F2B7A12.title: "Knapping Rocks"
	quest.6A1E8D4C0F2B7A13.quest_desc: [
		"Hold a &bRock&r in each hand and right-click to open the knapping screen, then click cells to chip the rock down to the &bStone Pickaxe Head&r shape. It is the business end of a pickaxe and nothing more, since &6Overgeared&r builds tools from separate parts."
		"Knap a spare while you are at it. Heads wear out and a backup saves a trip."
	]
	quest.6A1E8D4C0F2B7A13.quest_subtitle: "The working end of your first tool."
	quest.6A1E8D4C0F2B7A13.title: "Stone Pickaxe Head"
	quest.6A1E8D4C0F2B7A14.quest_desc: [
		"Fit the knapped head to a handle to finish a working &bStone Pickaxe&r. Because the tool is assembled from parts, a worn one can be rebuilt instead of thrown away."
		"This is the pick that gets you to &bcopper&r and the first real ores."
	]
	quest.6A1E8D4C0F2B7A14.quest_subtitle: "Head plus handle makes a tool."
	quest.6A1E8D4C0F2B7A14.title: "Basic Mining"
	quest.6A1E8D4C0F2B7A15.quest_desc: [
		"Mine &bcopper&r ore and smelt a few ingots. Copper is the first metal the forge can work, a clear step up from knapped stone for tools and parts."
		"Smelt more than you think you need. The smithing tools coming up all want &bcopper&r."
	]
	quest.6A1E8D4C0F2B7A15.quest_subtitle: "Your first metal."
	quest.6A1E8D4C0F2B7A15.title: "Enter Metals"
	quest.6A1E8D4C0F2B7A16.quest_desc: [
		"Forge a &bCopper Smithing Hammer&r. It is the heart of metalworking in &6Overgeared&r, used to beat heated ingots into blades, heads, and the other parts your gear is built from."
		"Keep it close to the forge. Almost every metal part from here is shaped with it."
	]
	quest.6A1E8D4C0F2B7A16.quest_subtitle: "The tool that shapes metal."
	quest.6A1E8D4C0F2B7A16.title: "Copper Smithing Hammer"
	quest.6A1E8D4C0F2B7A18.quest_desc: [
		"Craft &bWooden Tongs&r. Heated ingots and parts will burn you bare-handed, and tongs are what let you move them around the forge while they are still hot."
		"A small thing, but the smithing steps ahead expect you to have a pair."
	]
	quest.6A1E8D4C0F2B7A18.quest_subtitle: "Handle hot metal without burning."
	quest.6A1E8D4C0F2B7A18.title: "Wooden Tongs"
	quest.6A1E8D4C0F2B7A19.quest_desc: [
		"Set up a &bGrindstone&r. A ground edge performs better than a rough one, and the stone also strips usable material back out of worn gear instead of wasting it."
		"Polishing parts raises forging quality later, but polishing is optional for the blueprint quests ahead."
	]
	quest.6A1E8D4C0F2B7A19.quest_subtitle: "Toss a fresh tool head in the water, grab it and then sharpen it."
	quest.6A1E8D4C0F2B7A19.title: "Grindstone"
	quest.6A1E8D4C0F2B7A1A.quest_desc: [
		"Build a &bDrafting Table&r. Commit an &bEmpty Blueprint&r here to draft a finished smithing blueprint."
		"Blueprint tiers are Poor, Well, Expert, Perfect, and Master. Higher tiers raise forging ceilings later. Poor is enough to progress."
	]
	quest.6A1E8D4C0F2B7A1A.quest_subtitle: "Where designs get drawn up."
	quest.6A1E8D4C0F2B7A1A.title: "The Drawing Board"
	quest.6A1E8D4C0F2B7B03.quest_desc: [
		"Craft an &bEmpty Blueprint&r. It is the blank sheet you commit a design to at the &bDrafting Table&r, used up each time you lock in a new pattern."
		"Keep a few spare. Drafting is cheap and you will redraw as better recipes open."
	]
	quest.6A1E8D4C0F2B7B03.quest_subtitle: "A blank to draw on."
	quest.6A1E8D4C0F2B7B03.title: "First Draft"
	quest.6A1E8D4C0F2B7C01.quest_desc: ["Craft a &bStone Smithing Anvil&r. This is where hammer meets heated metal: place a glowing ingot on the anvil and strike it into tool parts. Higher anvil tiers come later, stone is enough for copper work. Make one by right clicking stone with your hammer."]
	quest.6A1E8D4C0F2B7C01.quest_subtitle: "Every forge needs a face."
	quest.6A1E8D4C0F2B7C01.title: "The Smithing Anvil"
	quest.6A60B76053393288.quest_desc: [
		"Keep the &bSmeltery&r running on a steady stream of ore. As it levels up the Smelter starts returning bonus output. That is the colony's own form of ore doubling."
		"The more ore you push through, the more the upgrades pay back."
	]
	quest.6A60B76053393288.quest_subtitle: "Bonus metal at higher levels."
	quest.6A60B76053393288.title: "Feed the Smeltery"
	quest.6B0CE8AD86991E28.quest_desc: [
		"Raise a &bComposter's Hut&r. The Composter turns spare food and plants into compost, which the Farmer needs to enrich fields."
		"What you grow becomes compost, and compost makes the next crop grow faster."
	]
	quest.6B0CE8AD86991E28.quest_subtitle: "Surplus into rich dirt."
	quest.6B0CE8AD86991E28.title: "Composter's Hut"
	quest.6B26495A9E7D77FC.quest_desc: [
		"Reach five citizens. Five colonists is enough to cover the essential jobs and get real production moving."
		"Build a few more homes and the colony climbs from here."
	]
	quest.6B26495A9E7D77FC.quest_subtitle: "Enough to get rolling."
	quest.6B26495A9E7D77FC.title: "Five Citizens"
	quest.6B80B2314CC47FD6.quest_desc: [
		"Upgrade the &bSmeltery&r to level three. A higher-level Smeltery smelts faster and begins returning bonus metal from ore."
		"Push ore through it and the upgrade quickly pays you back."
	]
	quest.6B80B2314CC47FD6.quest_subtitle: "Faster, with bonus output."
	quest.6B80B2314CC47FD6.title: "Smeltery, Level 3"
	quest.6BB0C51EE8CA5966.quest_desc: [
		"Sink a &bMiner's Hut&r. The Miner digs a &bshaft&r and brings up stone and ore without you lifting a pick."
		"Level the hut to send them deeper, where the richer ores sit."
	]
	quest.6BB0C51EE8CA5966.quest_subtitle: "Stone and ore from a shaft."
	quest.6BB0C51EE8CA5966.title: "Miner's Hut"
	quest.6D061DBB350F5529.quest_desc: ["Hunt the gnome that claims the burrow. It is more nuisance than threat, but its drops are the start of the gnome gear and brew."]
	quest.6D061DBB350F5529.quest_subtitle: "Small, quick, and full of tricks."
	quest.6D061DBB350F5529.title: "Gnome"
	quest.6D08A993695D141E.quest_desc: [
		"Collect &bChameleon Molt&r from chameleons. &6Cold Sweat&r treats it as adaptive insulation, so armor lined with it resists both heat and cold instead of just one."
		"Save it for the &bChameleon Scale&r set rather than spending it on a single piece."
	]
	quest.6D08A993695D141E.quest_subtitle: "Insulation that works both ways."
	quest.6D08A993695D141E.title: "Chameleon Molt"
	quest.6D56AD1BEC644A10.quest_desc: [
		"Build the &bArchery&r. It trains ranged guards who thin a raid before it ever reaches your walls."
		"Keep it stocked with bows and the chicken herder laying for feathers."
	]
	quest.6D56AD1BEC644A10.quest_subtitle: "Train your archers."
	quest.6D56AD1BEC644A10.title: "Archery"
	quest.6D7E8F901A2B050A.quest_desc: ["Complete Marks of the Craft, the Sand Filter in Rotational Power, and the Black Foundry Controller. Then complete Master of the Grove to open the Renaissance."]
	quest.6D7E8F901A2B050A.quest_subtitle: "Complete the Grove reveal requirements. Only the Dark Metal and Corrupted Hero Questlines are required, and will get you to the next age."
	quest.6D7E8F901A2B050A.title: "Grove Access"
	quest.6D7E8F901A2B1010.quest_desc: [
		"Track down the &c&lSculptor&r, a &6Mowzie's Mobs&r boss who hurls stone from a distance. Break line of sight to dodge the volleys, then close the gap between casts."
		"Its drops feed the &bgeomancer&r gear."
	]
	quest.6D7E8F901A2B1010.quest_subtitle: "An earth-mage that fights from range."
	quest.6D7E8F901A2B1010.title: "Tongbi, the Sculptor"
	quest.6D7E8F901A2B1011.quest_desc: ["Take the &bGeomancer Staff&r from the &c&lSculptor&r. It flings chunks of stone as a ranged attack, a strong opener before a melee fight closes in."]
	quest.6D7E8F901A2B1011.quest_subtitle: "Throw the earth back at them."
	quest.6D7E8F901A2B1011.title: "Geomancer Staff"
	quest.6D7E8F901A2B1013.quest_desc: [
		"Hunt the &c&lNaga&r, a flying serpent boss that strafes overhead and dives to bite. Wait for the dive and strike as it passes, then back off before the next pass."
		"Its fang is the prize worth keeping."
	]
	quest.6D7E8F901A2B1013.quest_subtitle: "A serpent that strikes from the air."
	quest.6D7E8F901A2B1013.title: "Naga"
	quest.6D7E8F901A2B1014.quest_desc: ["Collect a &bNaga Fang&r from a slain serpent. It is the crafting material behind the Naga's gear."]
	quest.6D7E8F901A2B1014.quest_subtitle: "The serpent's crafting drop."
	quest.6D7E8F901A2B1014.title: "Naga Fang"
	quest.6D7E8F901A2B1016.quest_desc: ["Craft the Spear. It strikes from a step further than most weapons, which keeps the grove's faster hunters at arm's length while you fight."]
	quest.6D7E8F901A2B1016.quest_subtitle: "Reach the enemy first."
	quest.6D7E8F901A2B1016.title: "Spear"
	quest.6D7E8F901A2B1018.quest_desc: ["Craft the &bBluff Rod&r. It is more of a trick than a mainstay, worth carrying for the moment its effect gets you out of a corner."]
	quest.6D7E8F901A2B1018.quest_subtitle: "A Mowzie's Mobs curio."
	quest.6D7E8F901A2B1018.title: "Bluff Rod"
	quest.6D7E8F901A2B1019.quest_desc: [
		"Hunt the Elokosa Howler, the night form of the Elokosa and a quick, wolf-like predator. Fight it with room to dodge rather than against a wall."
		"Its paw is the drop you want."
	]
	quest.6D7E8F901A2B1019.quest_subtitle: "The night runs faster here. Optional."
	quest.6D7E8F901A2B1019.title: "Elokosa Howler"
	quest.6D7E8F901A2B101A.quest_desc: ["Claim the &bPaw of the Full Moon&r. Swung, it weakens the mobs around you, softening a pack before you wade into it."]
	quest.6D7E8F901A2B101A.quest_subtitle: "Sap the strength of a crowd."
	quest.6D7E8F901A2B101A.title: "Paw of the Full Moon"
	quest.6D7E8F901A2B101D.quest_desc: ["Get a &bPaw of the Crescent Moon&r. It marks the mobs it strikes with fragility, so your follow-up blows land that much harder."]
	quest.6D7E8F901A2B101D.quest_subtitle: "Make them easier to kill."
	quest.6D7E8F901A2B101D.title: "Paw of the Crescent Moon"
	quest.6D7E8F901A2B101F.quest_desc: ["Smelt &bDark Metal&r from the scrap the &6Born in Chaos&r undead drop, then block some up for storage. It is the base metal for that mod's darker tools and armor."]
	quest.6D7E8F901A2B101F.quest_subtitle: "The metal of the chaos host."
	quest.6D7E8F901A2B101F.title: "Dark Metal"
	quest.6D7E8F901A2B1020.quest_desc: ["Recover the &bOrb of the Summoner&r. It is an uncommon drop that feeds the higher-tier &6Born in Chaos&r crafts, so hold onto it until you need it."]
	quest.6D7E8F901A2B1020.quest_subtitle: "A rare crafting drop."
	quest.6D7E8F901A2B1020.title: "Orb of the Summoner"
	quest.6D7E8F901A2B1021.quest_desc: ["Craft a &bDeath Totem&r and keep it on you. Held, it offers a measure of protection when a fight turns against you."]
	quest.6D7E8F901A2B1021.quest_subtitle: "A second chance in a bad fight."
	quest.6D7E8F901A2B1021.title: "Death Totem"
	quest.6D7E8F901A2B1022.quest_desc: ["Gather &bMonster Skin&r and a &bNightmare Claw&r from the chaos mobs. Both are crafting materials for the mod's dark armor and weapons."]
	quest.6D7E8F901A2B1022.quest_subtitle: "Skin and claw for crafting."
	quest.6D7E8F901A2B1022.title: "Monster Parts"
	quest.6D7E8F901A2B1023.quest_desc: ["Collect a &bSeed of Chaos&r and a &bShattered Skull&r. The seed brings on chaos spawns when you want them, and the skull feeds rituals and crafts."]
	quest.6D7E8F901A2B1023.quest_subtitle: "Stir up more to hunt."
	quest.6D7E8F901A2B1023.title: "Seed of Chaos"
	quest.6D7E8F901A2B1024.quest_desc: ["Make the &bStaff of Magic Arrows&r. It fires magical bolts at range, a steady answer to fliers and skirmishers that close too fast for a bow."]
	quest.6D7E8F901A2B1024.quest_subtitle: "Ranged answer to fliers."
	quest.6D7E8F901A2B1024.title: "Staff of Magic Arrows"
	quest.6D7E8F901A2B1025.quest_desc: ["Grind &bSpiritual Dust&r from the spirit mobs. It is a crafting reagent several &6Born in Chaos&r recipes lean on, so gather a small stock."]
	quest.6D7E8F901A2B1025.quest_subtitle: "Reagent from the spirits."
	quest.6D7E8F901A2B1025.title: "Spiritual Dust"
	quest.6D7E8F901A2B1026.quest_desc: ["Hunt down a Nightmare Stalker. Its claw is the drop you are after. This pairs with the crafting steps that need one."]
	quest.6D7E8F901A2B1026.quest_subtitle: "Hunt it for the claw."
	quest.6D7E8F901A2B1026.title: "Nightmare Stalker"
	quest.6D7E8F901A2B1027.quest_desc: ["Brew the &bElixir of Wither Resistance&r. Drink it before facing anything that withers; the effect does not stick."]
	quest.6D7E8F901A2B1027.quest_subtitle: "Shrug off the wither."
	quest.6D7E8F901A2B1027.title: "Elixir of Wither Resistance"
	quest.6D7E8F901A2B1028.quest_desc: ["Place the Gentleman Frog tombstone. It is a memorial more than a tool, a small dark flourish for the base."]
	quest.6D7E8F901A2B1028.quest_subtitle: "A bit of grim decor."
	quest.6D7E8F901A2B1028.title: "The Gentleman Frog"
	quest.6D7E8F901A2B1029.quest_desc: ["Brew a &bTransmuting Elixir&r. It converts one material into another, a handy shortcut when a recipe wants something you are short on."]
	quest.6D7E8F901A2B1029.quest_subtitle: "Turn one thing into another."
	quest.6D7E8F901A2B1029.title: "Transmuting Elixir"
	quest.6D7E8F901A2B102A.quest_desc: ["Brew the &bElixir of Vampirism&r. While it lasts your strikes return health to you, which keeps a drawn-out fight survivable."]
	quest.6D7E8F901A2B102A.quest_subtitle: "Heal off your own hits."
	quest.6D7E8F901A2B102A.title: "Elixir of Vampirism"
	quest.6D7E8F901A2B102C.quest_desc: ["Get a &bPaw of the Gibbous Moon&r. It slows the mobs it hits, which is exactly what you want when peeling away from a crowd."]
	quest.6D7E8F901A2B102C.quest_subtitle: "Slow the swarm down."
	quest.6D7E8F901A2B102C.title: "Paw of the Gibbous Moon"
	quest.6D7E8F901A2B1050.quest_desc: [
		"Fell the &c&lFerrous Wroughtnaut&r, one of the four grove beasts. It waits underground in a &bWrought Chamber&r, a stone hall generated between roughly Y 20 and Y 50; dig and listen for the hollow room, then step close to wake it. Any three of the four beasts count toward Grove mastery."
		"Its wind-up is slow but its recovery is brief; dodge the swing and strike then."
	]
	quest.6D7E8F901A2B1050.quest_subtitle: "First of the four great beasts."
	quest.6D7E8F901A2B1050.title: "The Great Hunt: Wroughtnaut"
	quest.6D7E8F901A2B1051.quest_desc: ["Kill a &c&lFoliaath&r. It spawns naturally in &bjungle&r biomes, disguised as a harmless little plant until you step within reach, so watch the jungle floor for suspicious sprouts. Stay at its range edge or strike from the side, and do not stand in its mouth."]
	quest.6D7E8F901A2B1051.quest_subtitle: "A carnivorous plant that lunges."
	quest.6D7E8F901A2B1051.title: "The Great Hunt: Foliaath"
	quest.6D7E8F901A2B1052.quest_desc: [
		"Bring down the &c&lFrostmaw&r, a giant frost beast that freezes the ground and you with it. One sleeps in an ice den on open snowy ground such as &bSnowy Plains&r; it avoids snowy taigas and forests, so search treeless snowfields. Keep moving to shake the chill and strike between its slams."
		"Warm gear and steady footing matter as much as your weapon here."
	]
	quest.6D7E8F901A2B1052.quest_subtitle: "Keep moving or freeze."
	quest.6D7E8F901A2B1052.title: "The Great Hunt: Frostmaw"
	quest.6D7E8F901A2B1053.quest_desc: ["Track down a &c&lGrottol&r, the shy cave creature that drops a diamond and bolts the moment it is threatened. It spawns rarely in dark caves at &bY 16 and below&r, down into the deepslate layers, and never under open sky. Explore deep tunnels and listen for skittering. Corner it before it burrows away and the kill is yours."]
	quest.6D7E8F901A2B1053.quest_subtitle: "Spawns below y=16 in caves. "
	quest.6D7E8F901A2B1053.title: "The Great Hunt: Grottol"
	quest.6D7E8F901A2B1054.quest_desc: [
		"With at least three of the four great beasts felled, the grove's hardest hunts are behind you. Complete this repeatable grant quest to open the &dRenaissance&r stage."
		"If your stage ever desyncs, rerun this quest after the great hunts are done."
	]
	quest.6D7E8F901A2B1054.quest_subtitle: "Three great beasts open Renaissance."
	quest.6D7E8F901A2B1054.title: "Master of the Grove"
	quest.6D7E8F901A2B2102.quest_desc: ["Assemble the &bGeomancer&r beads, robe, belt, and sandals from the &c&lSculptor&r's drops. Worn together the set leans into earth magic."]
	quest.6D7E8F901A2B2102.quest_subtitle: "The Sculptor's full set."
	quest.6D7E8F901A2B2102.title: "Geomancer Regalia"
	quest.6D7E8F901A2B2103.quest_desc: ["Collect &bLuminous Jelly&r. It glows to light your way and feeds a few recipes, including the wither-resistance brew."]
	quest.6D7E8F901A2B2103.quest_subtitle: "Light and a brewing ingredient."
	quest.6D7E8F901A2B2103.title: "Luminous Jelly"
	quest.6D7E8F901A2B3002.quest_desc: ["Take down the &c&lSupreme Bonescaller&r, a stronger caster that throws far more bone than its lesser kin. Burn it down fast or you will drown in skeletons."]
	quest.6D7E8F901A2B3002.quest_subtitle: "The elite that fields an army."
	quest.6D7E8F901A2B3002.title: "Supreme Bonescaller"
	quest.6D7E8F901A2B3004.quest_desc: ["Kill the Dire Hound Leader, the alpha that drives the pack. Drop it and the rest of the hounds lose their bite."]
	quest.6D7E8F901A2B3004.quest_subtitle: "Break the pack's alpha."
	quest.6D7E8F901A2B3004.title: "Dire Hound Leader"
	quest.6D7E8F901A2B3005.quest_desc: ["Face &c&lSir Pumpkinhead&r, an armored boss of the chaos host that fights in heavy swings. Time your dodges to its rhythm and answer between blows."]
	quest.6D7E8F901A2B3005.quest_subtitle: "A knight with a gourd for a head."
	quest.6D7E8F901A2B3005.title: "Sir Pumpkinhead"
	quest.6D7E8F901A2B3006.quest_desc: ["Cut down a Door Knight and a Fallen Chaos Knight. Both are armored and deliberate, so wear them down rather than trade blow for blow."]
	quest.6D7E8F901A2B3006.quest_subtitle: "Patient, armored, and slow."
	quest.6D7E8F901A2B3006.title: "Chaos Knights"
	quest.6D7E8F901A2B3007.quest_desc: ["Hunt a Lifestealer. It drains your health on contact, so keep it at weapon range and never let it latch on."]
	quest.6D7E8F901A2B3007.quest_subtitle: "Do not let it cling."
	quest.6D7E8F901A2B3007.title: "Lifestealer"
	quest.6D7E8F901A2B3008.quest_desc: ["Clear out a Zombie Bruiser and a Bone Imp. The bruiser hits hard up close while the imp harasses from the edges, so separate them and deal with each in turn."]
	quest.6D7E8F901A2B3008.quest_subtitle: "Split them up."
	quest.6D7E8F901A2B3008.title: "Bruiser and Imp"
	quest.6D7E8F901A2B3009.quest_desc: ["These two kills complete the small-host entry in the bestiary."]
	quest.6D7E8F901A2B3009.quest_subtitle: "The small fry."
	quest.6D7E8F901A2B3009.title: "Pests of the Host"
	quest.6D7E8F901A2B300A.quest_desc: ["Hunt a Crystalian and a Spectral Skull from &6Monster Plus&r. The crystal zombie is tough up close while the floating skull spits projectiles, so silence the skull before you commit."]
	quest.6D7E8F901A2B300A.quest_subtitle: "Drop the skull first."
	quest.6D7E8F901A2B300A.title: "Crystalian and Skull"
	quest.6D7E8F901A2B300E.quest_desc: ["Collect an &bAncient Crystal Fragment&r and some &bDark Essence&r. Both are crafting materials behind the higher-tier &6Monster Plus&r equipment."]
	quest.6D7E8F901A2B300E.quest_subtitle: "Drops for the better gear."
	quest.6D7E8F901A2B300E.title: "Crystal and Essence"
	quest.6D7E8F901A2B300F.quest_desc: ["Forge the &bDark Chestplate&r and Helmet. Built from the mobs you have been clearing, it is a solid mid-game set worth the materials."]
	quest.6D7E8F901A2B300F.quest_subtitle: "Forged from the hunt."
	quest.6D7E8F901A2B300F.title: "Dark Armor"
	quest.6DDBA2A0973F5F0C.quest_desc: [
		"Fire a &bTerracotta Bowl&r and use it to scoop water. &6Thirst&r drains its own bar alongside hunger, and a bowl is the simplest way to drink before you have anything better."
		"Untreated water carries a risk. This is a stopgap until you can purify it."
	]
	quest.6DDBA2A0973F5F0C.quest_subtitle: "Something to drink from."
	quest.6DDBA2A0973F5F0C.title: "Terracotta Bowl"
	quest.6F697569C417FCCE.quest_desc: [
		"Craft a &bStone Fillet Knife&r and use it on your catch. Filleting a fish gives two cookable portions instead of one, so the same trip to the water feeds more mouths."
		"Keep it on your hotbar next to the rod and processing fish becomes one quick step."
	]
	quest.6F697569C417FCCE.quest_subtitle: "More meals from the same catch."
	quest.6F697569C417FCCE.title: "Stone Fillet Knife"
	quest.7001A54F9729CC12.quest_desc: ["Assemble a &bLarge Water Wheel&r. It trades a bigger frame for steadier torque, carrying more machines on the same current than the small wheel ever could."]
	quest.7001A54F9729CC12.quest_subtitle: "More wheel for your water."
	quest.7001A54F9729CC12.title: "&6The Large Water Wheel&r"
	quest.70D99BC8FE5F6FC7.quest_desc: [
		"Hang a &6Comforts&r &bHammock&r between two posts and rest in it to pass the day. Unlike a bed it leaves your spawn point alone, which is ideal for a camp far from home."
		"It needs rope and nails to mount, so make those first."
	]
	quest.70D99BC8FE5F6FC7.quest_subtitle: "Rest without resetting your spawn."
	quest.70D99BC8FE5F6FC7.title: "Hammock"
	quest.71FCF06A98CC66D7.quest_desc: [
		"Craft a &bClipboard&r. It lists every open request across the colony, so you can see at a glance what each builder still needs."
		"Keep it on you while you manage supplies and nothing slips through."
	]
	quest.71FCF06A98CC66D7.quest_subtitle: "See every open work order."
	quest.71FCF06A98CC66D7.title: "Clipboard"
	quest.7218362698C1805A.quest_desc: ["Gather &bMushroom Spores&r and a &bGlittering Spore&r. Plain spores grow the magical mushrooms, and the glittering kind feeds the higher-tier mushroom work that follows."]
	quest.7218362698C1805A.quest_subtitle: "Seed the fungal line."
	quest.7218362698C1805A.title: "Mushroom Spores"
	quest.72A736B300C6F055.quest_desc: ["Craft a &bGolden Ring Base&r. On its own it does nothing, but it is the blank that each of the garden's enchanted rings is built on."]
	quest.72A736B300C6F055.quest_subtitle: "The blank every ring starts as."
	quest.72A736B300C6F055.title: "Golden Ring Base"
	quest.72C749AD9F1C634E.quest_desc: [
		"Build a &bResidence&r and welcome a new citizen. Homes raise your population cap, and more colonists means more hands for every job."
		"Keep raising houses as the town grows or you cap out on workers."
	]
	quest.72C749AD9F1C634E.quest_subtitle: "More homes, more citizens."
	quest.72C749AD9F1C634E.title: "Residence"
	quest.743D7D9204915A13.quest_desc: [
		"Bury a fallen citizen in a &bgraveyard&r. Colonists who die can be laid to rest, which keeps morale up and, with an Undertaker, opens the door to bringing them back."
		"Grim work, but a colony that loses people needs somewhere to put them."
	]
	quest.743D7D9204915A13.quest_subtitle: "Death is bookkeeping too."
	quest.743D7D9204915A13.title: "Lay Them to Rest"
	quest.74C114D0C0D4D374.quest_desc: [
		"Construct the &bHospital&r. Its healer treats sick and injured citizens who would otherwise stay down, keeping your workforce intact."
		"Stock it with the remedies the healer asks for and recoveries speed up."
	]
	quest.74C114D0C0D4D374.quest_subtitle: "Keep your workers on their feet."
	quest.74C114D0C0D4D374.title: "Hospital"
	quest.75599A9909C7A8C8.quest_desc: [
		"Get a citizen fed for the first time. Colonists need food, and a hungry worker slows down or stops entirely. A stocked rack near their hut keeps them productive."
		"Drop some spare food in the &bwarehouse&r and watch them help themselves."
	]
	quest.75599A9909C7A8C8.quest_subtitle: "Citizens have to eat."
	quest.75599A9909C7A8C8.title: "First Meal"
	quest.75CBFD0F90772359.quest_desc: [
		"Build the &bTavern&r. It recruits new citizens and draws visitors you can hire, the main way to grow your population beyond births."
		"A lively &btavern&r keeps the town filling up with workers."
	]
	quest.75CBFD0F90772359.quest_subtitle: "Where new citizens arrive."
	quest.75CBFD0F90772359.title: "Tavern"
	quest.76902E25E4B4C8E7.quest_desc: ["Alloy copper and zinc into &bBrass&r. Any brass ingot counts. Brass parts open the precise side of Create, and this pack unlocks the route in the Medieval age."]
	quest.76902E25E4B4C8E7.quest_subtitle: "Alloy copper and zinc into brass."
	quest.76902E25E4B4C8E7.title: "&6Enter Brass&r"
	quest.771A0BD657D158BA.quest_desc: ["Craft both items, then use them in the Marks of the Craft line."]
	quest.771A0BD657D158BA.quest_subtitle: "Prepare the cooking and brewing supplies."
	quest.771A0BD657D158BA.title: "Marks of the Craft"
	quest.7733FF946E05AB9C.quest_desc: ["Brew a Gnome's Brew from gnome ingredients. It is a garden potion with a distinctly gnomish bite to it."]
	quest.7733FF946E05AB9C.quest_subtitle: "A potion with a kick."
	quest.7733FF946E05AB9C.title: "Gnome's Brew"
	quest.7813F9EAC9075122.quest_desc: [
		"Boil or filter water until it reads as purified, then keep a stock on hand. &6Thirst&r tracks how clean your water is, and dirty water both hydrates less and can make you sick."
		"A few purified drinks in storage means a &6thirst&r emergency never turns into a death."
	]
	quest.7813F9EAC9075122.quest_subtitle: "Drink clean or pay the thirst penalty."
	quest.7813F9EAC9075122.title: "Purified Water"
	quest.7870800C28A7E199.quest_desc: [
		"Build the &bChicken Herder's Hut&r. It keeps chickens for eggs, meat, and feathers, and those feathers arm your archers later on."
		"A small flock supplies a lot, so it earns its space quickly."
	]
	quest.7870800C28A7E199.quest_subtitle: "Eggs, meat, and feathers."
	quest.7870800C28A7E199.title: "Chicken Herder's Hut"
	quest.79933C964312F721.quest_desc: [
		"Build the &bSifter's Hut&r. The Sifter runs dirt, sand, gravel, and soul sand through meshes to pull out seeds, ores, and oddments, a slow trickle of free material."
		"Keep it fed with bulk filler and let it work in the background."
	]
	quest.79933C964312F721.quest_subtitle: "Free resources from cheap dirt."
	quest.79933C964312F721.title: "Sifter's Hut"
	quest.7A1F010000000002.quest_desc: [
		"Combine andesite and iron to make &bAndesite Alloy&r. It is the base material for nearly every early &6Create&r component, so build up a small stock before you build anything else."
		"Most quests in this chapter use it. Make a stack and keep it handy."
	]
	quest.7A1F010000000002.quest_subtitle: "The material everything starts from."
	quest.7A1F010000000002.title: "&6Andesite Alloy&r"
	quest.7A1F010000000003.quest_desc: ["Craft a &bShaft&r. Shafts carry rotational force from a power source to a machine. Everything that spins begins with one."]
	quest.7A1F010000000003.quest_subtitle: "Rotation in a straight line."
	quest.7A1F010000000003.title: "&6Shaft&r"
	quest.7A1F010000000004.quest_desc: [
		"Build a &bWater Wheel&r over flowing water. It is your first real power source, turning a current into steady rotation with no fuel to feed."
		"Line a few in a row along a river and the output climbs. This is the cheapest way to get a network spinning."
	]
	quest.7A1F010000000004.quest_subtitle: "Free power from a stream."
	quest.7A1F010000000004.title: "&6Water Power&r"
	quest.7A1F010000000006.quest_desc: ["Craft a &bCogwheel&r. Cogwheels mesh to hand rotation from one &bshaft&r to another, and paired with a &blarge cogwheel&r they change its speed. Gearing starts here."]
	quest.7A1F010000000006.quest_subtitle: "Pass rotation between shafts."
	quest.7A1F010000000006.title: "&6Rotational Force&r"
	quest.7A1F010000000007.quest_desc: ["Make a &bLarge Cogwheel&r. Meshed with a small one it steps speed up or down depending on which drives which. Use it to get the slower, stronger rotation that some machines want."]
	quest.7A1F010000000007.quest_subtitle: "Trade speed for strength."
	quest.7A1F010000000007.title: "&6Rolling Ratios&r"
	quest.7A1F020000000001.quest_desc: ["Craft a &bHand Crank&r. Right-click it for a short burst of rotation, enough to run a single machine before you have a real power network. It is handy for testing a build."]
	quest.7A1F020000000001.quest_subtitle: "A burst of power by hand."
	quest.7A1F020000000001.title: "&6Hand Crank&r"
	quest.7A1F020000000002.quest_desc: ["Place a &bWindmill Bearing&r and build sails onto it. Spun by wind it makes rotation without water, which suits a base away from a river. Glue the sails on first, then engage the bearing."]
	quest.7A1F020000000002.quest_subtitle: "Power from open sky."
	quest.7A1F020000000002.title: "&6The Power of Wind&r"
	quest.7A1F020000000003.quest_desc: ["Craft Sail Frames. They are the bare frame a &bwindmill&r is built from, cheaper than full sails and fine for a first rotor. Ring at least eight around the bearing to get it turning."]
	quest.7A1F020000000003.quest_subtitle: "The skeleton of a windmill."
	quest.7A1F020000000003.title: "&6Sail Frame&r"
	quest.7A1F020000000004.quest_desc: ["Make &bWindmill&r Sails. They catch more wind than bare frames, so a rotor of sails spins faster and carries more machines. Swap frames for sails once you can spare the wool."]
	quest.7A1F020000000004.quest_subtitle: "More wind, more speed."
	quest.7A1F020000000004.title: "&6Windmill Sail&r"
	quest.7A1F020000000005.quest_desc: ["Make a &bWrench&r. It rotates blocks, adjusts their settings, and picks them up without breaking them. Keep it on your hotbar, because you will reach for it constantly."]
	quest.7A1F020000000005.quest_subtitle: "Rotate, configure, pick up."
	quest.7A1F020000000005.title: "&6Fine Tuning&r"
	quest.7A1F030000000001.quest_desc: ["Build a &bGearbox&r. It carries rotation around corners and splits it down several shafts, which keeps a power layout tidy instead of a snarl of loose cogs. Encase it once the line is set."]
	quest.7A1F030000000001.quest_subtitle: "Turn power around corners."
	quest.7A1F030000000001.title: "&6Gearbox&r"
	quest.7A1F030000000002.quest_desc: ["Craft a &bGearshift&r. A redstone signal flips rotation direction through it, which matters for anything that has to run both ways, like a piston bridge. Wire it where you need to switch."]
	quest.7A1F030000000002.quest_subtitle: "Reverse direction on a signal."
	quest.7A1F030000000002.title: "&6Inverted Mechanics&r"
	quest.7A1F030000000003.quest_desc: ["Make a &bClutch&r. A redstone signal stops rotation past it while the source keeps turning, so you can pause one machine and leave the rest running. It pairs naturally with the &bgearshift&r."]
	quest.7A1F030000000003.quest_subtitle: "Cut power without stopping the source."
	quest.7A1F030000000003.title: "&6Clutch&r"
	quest.7A1F030000000004.quest_desc: ["Craft Encased Chain Drives. Chained in a line they pass rotation across a row of blocks at one speed, a clean alternative to long &bshaft&r-and-cog runs. Good for feeding a wall of machines."]
	quest.7A1F030000000004.quest_subtitle: "Carry power across a row."
	quest.7A1F030000000004.title: "&6Rotation Transfer&r"
	quest.7A1F030000000005.quest_desc: ["Make an &bAdjustable Chain Gearshift&r. Set it in a chain drive and a redstone signal scales the speed of everything downstream. Use it where one line needs to change pace on the fly."]
	quest.7A1F030000000005.quest_subtitle: "Vary the speed on demand."
	quest.7A1F030000000005.title: "&6Better Ratios&r"
	quest.7A1F040000000001.quest_desc: [
		"Craft the &bGoggles&r and wear them. They show the stress and speed of any kinetic block you look at, which is how you find the stall or overload in a network."
		"Do not run a serious build without them. Half of &6Create&r is reading what the &bgoggles&r tell you."
	]
	quest.7A1F040000000001.quest_subtitle: "See stress and speed at a glance."
	quest.7A1F040000000001.title: "&6A Real Technician&r"
	quest.7A1F040000000002.quest_desc: ["Build a &bSpeedometer&r onto a &bshaft&r. It reports the precise speed at that point, which matters because many machines have a minimum and maximum they will run at. Check it wherever a machine misbehaves."]
	quest.7A1F040000000002.quest_subtitle: "Read the exact rotation speed."
	quest.7A1F040000000002.title: "&6Speedometer&r"
	quest.7A1F040000000003.quest_desc: ["Make a &bRotation Speed Controller&r and set it under a &blarge cogwheel&r. It outputs an exact speed from a scroll value, with no gearing math to work out. This is the precise way to tune a line."]
	quest.7A1F040000000003.quest_subtitle: "Dial in an exact speed."
	quest.7A1F040000000003.title: "&6Rotation Speed Controller&r"
	quest.7A1F050000000001.quest_desc: [
		"Build a &bMillstone&r and give it rotation. It grinds ore, crops, and blocks into useful outputs from a single spinning block."
		"This is the mill the chapter is named for. Feed it from a belt and it runs itself."
	]
	quest.7A1F050000000001.quest_subtitle: "Single-block grinding."
	quest.7A1F050000000001.title: "&6Millwork&r"
	quest.7A1F050000000002.quest_desc: ["Set up a &bMechanical Press&r over a &bdepot&r or belt. It presses ingots into sheets and compacts blocks, a step in dozens of recipes ahead. Run it off a steady source so it does not stall mid-press."]
	quest.7A1F050000000002.quest_subtitle: "Sheets, plates, and compacting."
	quest.7A1F050000000002.title: "&6Mechanical Press&r"
	quest.7A1F050000000003.quest_desc: ["Place a &bBasin&r. It holds the items and fluids a press or &bmixer&r works on and catches the result underneath. Most multi-step &6Create&r recipes sit on one."]
	quest.7A1F050000000003.quest_subtitle: "Where mixing and pressing happen."
	quest.7A1F050000000003.title: "&6Basin&r"
	quest.7A1F050000000004.quest_desc: ["Build an &bEncased Fan&r. Blow its air through fire, water, or lava and it smelts, washes, or smokes whatever passes in front, a stack at a time. Aim it at the right block for the job you want."]
	quest.7A1F050000000004.quest_subtitle: "Smelt, wash, and smoke in bulk."
	quest.7A1F050000000004.title: "&6Blowing Power&r"
	quest.7A1F050000000005.quest_desc: ["Craft a &bRolling Mill&r. It uses rotation to roll ingots into rods and shaped stock, a natural companion to the press once your first mill floor is running."]
	quest.7A1F050000000005.quest_subtitle: "Roll ingots into rods."
	quest.7A1F050000000005.title: "&6Rolling Mill&r"
	quest.7A1F060000000001.quest_desc: ["Craft a &bMechanical Belt&r and stretch it between two shafts. Belts carry items across distance and feed machines, the backbone of any &6Create&r layout. Lay your first line out from the &bmillstone&r."]
	quest.7A1F060000000001.quest_subtitle: "Move items across the floor."
	quest.7A1F060000000001.title: "&6Mechanical Belt&r"
	quest.7A1F060000000002.quest_desc: ["Make a &bChute&r. It moves items vertically between belts and inventories, covering the gaps a flat belt cannot. Stack them to climb a wall."]
	quest.7A1F060000000002.quest_subtitle: "Items, straight up and down."
	quest.7A1F060000000002.title: "&6Chute&r"
	quest.7A1F060000000003.quest_desc: ["Place a &bDepot&r. It holds a single item where a press, fan, or &bdeployer&r can work on it, the still counterpart to a moving belt. Good for one-off processing without a full line."]
	quest.7A1F060000000003.quest_subtitle: "Hold one item out in the open."
	quest.7A1F060000000003.title: "&6Depot&r"
	quest.7A1F060000000004.quest_desc: ["Craft an &bAndesite Funnel&r. It pulls items onto a belt or pushes them into storage, the basic link between &6Create&r logistics and a normal chest. Point the arrow the way you want items to move."]
	quest.7A1F060000000004.quest_subtitle: "Bridge belts and chests."
	quest.7A1F060000000004.title: "&6Andesite Funnel&r"
	quest.7A1F060000000005.quest_desc: ["Make a &bFilter&r. Slot it into a funnel or tunnel and only the items you list pass, which keeps a sorting line from jamming on the wrong thing. Set one wherever a stream needs to split."]
	quest.7A1F060000000005.quest_subtitle: "Let only the right items through."
	quest.7A1F060000000005.title: "&6Filter&r"
	quest.7A1F060000000006.quest_desc: ["Build a &bPortable Storage Interface&r. It empties or fills a moving contraption's inventory at a fixed point, which is how a mobile harvester or drill hands off its haul. Face two at each other for a clean transfer."]
	quest.7A1F060000000006.quest_subtitle: "Load and unload moving builds."
	quest.7A1F060000000006.title: "&6Portable Storage Interface&r"
	quest.7A1F070000000001.quest_desc: ["Craft Fluid Pipes. They move water, lava, and other fluids between tanks, pumps, and machines, but they need a pump to actually push anything. Plan the route before you place it."]
	quest.7A1F070000000001.quest_subtitle: "Carry fluids between machines."
	quest.7A1F070000000001.title: "&6Fluid Logistics&r"
	quest.7A1F070000000002.quest_desc: ["Build a &bFluid Tank&r. It stores whatever your pipes carry, and a buffer keeps a pump and a consumer from stalling each other. Stack it taller for more capacity."]
	quest.7A1F070000000002.quest_subtitle: "Buffer your fluids."
	quest.7A1F070000000002.title: "&6Fluid Storage&r"
	quest.7A1F070000000003.quest_desc: ["Make a &bMechanical Pump&r and power it. It drives fluid through pipes in the direction it faces, and without one a pipe network just sits full. Set it inline and give it rotation."]
	quest.7A1F070000000003.quest_subtitle: "Make fluids actually flow."
	quest.7A1F070000000003.title: "&6Mechanical Pump&r"
	quest.7A1F080000000001.quest_desc: ["Craft &bSuper Glue&r. It binds blocks together so they move as a single contraption when pushed or rotated. This is what stops a moving build from flying apart."]
	quest.7A1F080000000001.quest_subtitle: "Bind blocks into one contraption."
	quest.7A1F080000000001.title: "&6Super Glue&r"
	quest.7A1F080000000002.quest_desc: ["Make a &bLinear Chassis&r. It holds neighboring blocks along one axis so a piston or pulley can move a whole structure, not a single block. Set its range with the &bwrench&r."]
	quest.7A1F080000000002.quest_subtitle: "Grip a structure together."
	quest.7A1F080000000002.title: "&6Structural Integrity&r"
	quest.7A1F080000000003.quest_desc: ["Build a &bMechanical Piston&r. Driven by rotation it pushes and pulls an entire glued or chassis-held contraption, the foundation of doors, bridges, and elevators. Watch the stress, since long pushes cost more."]
	quest.7A1F080000000003.quest_subtitle: "Push and pull a whole build."
	quest.7A1F080000000003.title: "&6Mechanical Piston&r"
	quest.7A1F080000000004.quest_desc: ["Craft a &bRope Pulley&r. It lifts and drops a contraption straight up and down, ideal for elevators and retracting drills. Anchor it above whatever you want to move."]
	quest.7A1F080000000004.quest_subtitle: "Raise and lower a contraption."
	quest.7A1F080000000004.title: "&6Rope Pulley&r"
	quest.7A1F080000000005.quest_desc: ["Make a &bMechanical Bearing&r. It rotates an attached structure, which is how windmills turn and how spinning builds work. Engage it by redstone or by hand."]
	quest.7A1F080000000005.quest_subtitle: "Spin a contraption."
	quest.7A1F080000000005.title: "&6Mechanical Bearing&r"
	quest.7A1F080000000006.quest_desc: ["Place a &bCart Assembler&r on a track. It mounts a contraption onto a minecart so it can drive itself along the rail, a simple mobile platform. Drop a cart under it and power the assembler."]
	quest.7A1F080000000006.quest_subtitle: "Put a build on rails."
	quest.7A1F080000000006.title: "&6Cart Assembler&r"
	quest.7A1F080000000008.quest_desc: [
		"Craft the &bMechanical Harvester&r, &bMechanical Saw&r, and &bMechanical Plough&r. Mounted on a moving contraption they reap crops, fell trees, and till soil as they pass, turning a cart or piston into a field crew."
		"Build all three and a single moving rig can run a whole farm."
	]
	quest.7A1F080000000008.quest_subtitle: "Harvest, cut, and till on the move."
	quest.7A1F080000000008.title: "&6Contraption Tools&r"
	quest.7A1F090000000001.quest_desc: ["Make a &bSchematic and Quill&r. Box in any build and it saves the layout as a reusable schematic, which a Schematicannon can then print elsewhere. Record your best designs before you tear them down."]
	quest.7A1F090000000001.quest_subtitle: "Capture a build to reprint."
	quest.7A1F090000000001.title: "&6A New Machinist&r"
	quest.7A1F0A0000000001.quest_desc: [
		"Forge a &bBrass Casing&r. Brass unlocks &6Create&r's smarter machines, and the casing is the shared shell most of them are built around. You need brass from the foundry chapter first."
		"Once casings are flowing, the &bdeployer&r, tunnels, and crafters all come within reach."
	]
	quest.7A1F0A0000000001.quest_subtitle: "The second tier opens here."
	quest.7A1F0A0000000001.title: "&6Basic Brass&r"
	quest.7A1F0A0000000002.quest_desc: ["Build a &bDeployer&r. It uses an item or tool exactly as a player would, placing blocks, tilling soil, or crafting in the world. Give it a &bfilter&r so it only acts on the right input."]
	quest.7A1F0A0000000002.quest_subtitle: "A mechanical hand."
	quest.7A1F0A0000000002.title: "&6Deployer&r"
	quest.7A1F0A0000000004.quest_desc: ["Craft a &bBrass Funnel&r. Like the andesite version but smarter, it filters by item and reads stack counts, which makes precise routing possible. Use it where a line needs exact control."]
	quest.7A1F0A0000000004.quest_subtitle: "Funnels that read and filter."
	quest.7A1F0A0000000004.title: "&6Brass Funnel&r"
	quest.7A1F0A0000000005.quest_desc: ["Make a &bBrass Tunnel&r. Set across belts it splits and balances items between several outputs, the clean way to fan one input out to many machines. Pick the distribution mode you need."]
	quest.7A1F0A0000000005.quest_subtitle: "Split and balance a belt."
	quest.7A1F0A0000000005.title: "&6Brass Tunnel&r"
	quest.7A1F0A0000000006.quest_desc: ["Assemble a group of Mechanical Crafters. Arranged in the recipe's shape they craft multi-step components and contraption parts on their own, including items you cannot make by hand. Wire the paths so inputs meet at the output."]
	quest.7A1F0A0000000006.quest_subtitle: "Automate the crafting grid."
	quest.7A1F0A0000000006.title: "&6Automatic Assembly&r"
	quest.7A1F0A0000000007.quest_desc: ["Craft a &bSequenced Gearshift&r. It runs a timed list of rotation moves. A piston can extend, wait, and retract on its own. This is how precise contraption timing is set up."]
	quest.7A1F0A0000000007.quest_subtitle: "Choreograph a contraption."
	quest.7A1F0A0000000007.title: "&6Sequenced Gearshift&r"
	quest.7A1F0A0000000008.quest_desc: ["Build a pair of Crushing Wheels. Spun toward each other they crush ore for roughly double output and chew through a stream of material fast, a clear step up from the &bmillstone&r. Space them exactly one block apart."]
	quest.7A1F0A0000000008.quest_subtitle: "Double your ore at scale."
	quest.7A1F0A0000000008.title: "&6Crushing Wheels&r"
	quest.7A1F0B0000000001.quest_desc: ["Make a &bFlywheel&r. It steadies and stores rotation, and hooked to a &bfurnace&r engine it becomes a strong, reliable source for a growing base. Keep it fed and it carries a large network."]
	quest.7A1F0B0000000001.quest_subtitle: "Smooth, stored power."
	quest.7A1F0B0000000001.title: "&6Flywheel&r"
	quest.7A1F0B0000000002.quest_desc: ["Craft an &bElectron Tube&r from &brose quartz&r. It is the smart component behind the &bRotation Speed Controller&r and display links. Keep a few in stock for logistics builds."]
	quest.7A1F0B0000000002.quest_subtitle: "The brass-era smart component."
	quest.7A1F0B0000000002.title: "&6Electron Tube&r"
	quest.7A1F0B0000000003.quest_desc: ["Make &bRose Quartz&r. It is the pink crystal behind Electron Tubes and a few decorative blocks. A minor brass-era material. A few go a long way."]
	quest.7A1F0B0000000003.quest_subtitle: "A small but required crystal."
	quest.7A1F0B0000000003.title: "&6Rose Quartz&r"
	quest.7A1F0B0000000004.quest_desc: ["Build a &bMechanical Arm&r. It moves items between several points you assign, sorting inputs to outputs with no belt between them. Program its targets with the &bwrench&r, in the order it should run."]
	quest.7A1F0B0000000004.quest_subtitle: "Sort items between set points."
	quest.7A1F0B0000000004.title: "&6Mechanical Arm&r"
	quest.7A1F0B0000000005.quest_desc: ["Make a &bClockwork Bearing&r. It rotates a contraption to match the time of day, which is what drives working clock hands and timed displays. Build it onto a clock face for the effect."]
	quest.7A1F0B0000000005.quest_subtitle: "A contraption that tracks time."
	quest.7A1F0B0000000005.title: "&6The Timekeeper&r"
	quest.7A1F0D0000000001.quest_desc: [
		"Build an &bAlloy Forge&r from &6Alloyed&r: five iron ingots, a furnace, and three deepslate. It is a fuel-burning station with its own input, fuel, and output slots. It is not a Create machine and needs no rotation, and it is not a plain furnace either."
		"Feed it a furnace fuel such as coal or charcoal and it works through its input over a cook time, the same way a furnace burns fuel. This is your early upgrade bench for turning iron into steel and copper into bronze."
	]
	quest.7A1F0D0000000001.quest_subtitle: "Optional. A fuel-burning alloy bench."
	quest.7A1F0D0000000001.title: "&dAlloy Forge&r"
	quest.7A1F0D0000000002.quest_desc: [
		"Smelt &bSteel&r in the Alloy Forge, then forge a steel gear set. Steel is three iron ingots plus one coal and one fire charge in the Forge. Turn the steel into a &bSteel Pickaxe&r, a &bSteel Chestplate&r, and a &bSteel Sheet&r."
		"Steel tools and armor sit a tier above iron and hold up longer. The Steel Sheet is the plate you press for later decorative and structural steel blocks. These are the real Alloyed items, so hand them in directly."
	]
	quest.7A1F0D0000000002.quest_subtitle: "Optional. Iron to steel gear."
	quest.7A1F0D0000000002.title: "&dSteel Gear&r"
	quest.7A1F0D0000000003.quest_desc: [
		"Cast a &bBronze Bell&r. Bronze is copper plus zinc plus fire in the Forge. With Create installed the recipe uses one copper ingot, three zinc nuggets, and one Cinder Flour, so gather those rather than iron nuggets."
		"The bell itself is not made from bare ingots. Press a bronze ingot into a Bronze Sheet on a Mechanical Press, and compact nine bronze ingots into a Bronze Block. Then stack the block over the sheet in a crafting grid to get the bell."
		"The Bronze Bell rings when you hit it or feed it a redstone pulse. A wrench tunes its pitch, and a Create Deployer can ring it on a timer. Hang it from chains, fences, or iron bars for a working redstone instrument."
	]
	quest.7A1F0D0000000003.quest_subtitle: "Optional. A tunable redstone bell."
	quest.7A1F0D0000000003.title: "&dBronze Bell&r"
	quest.7A55C10000000001.quest_desc: [
		"You run the drain, so now work the reef itself. Craft a &bPrismarine Rod&r and a &bFishing Net&r from Hybrid Aquatic."
		"The rod is the base for the specialized hooks that come next. The net lets you scoop small fish and drops straight out of the water instead of hooking them one at a time."
		"This whole branch is optional. Nothing here gates your progression. It is here so the deep pays you back in food, materials, and gear."
	]
	quest.7A55C10000000001.quest_subtitle: "Optional depth. Build the biological harvest arm off the deep-sea drain."
	quest.7A55C10000000001.title: "The Living Harvest"
	quest.7A55C10000000002.quest_desc: [
		"Fit the Prismarine Rod with the right hook for the job. Craft the &bBarbed Hook&r, the &bGlowing Hook&r, and the &bMagnetic Hook&r."
		"The Barbed Hook raises your catch rate in daylight. The Glowing Hook lights the line and fishes better at night. The Magnetic Hook pulls up more treasure and junk instead of fish."
		"Swap the hook on your rod to match the time of day and what you are after."
	]
	quest.7A55C10000000002.quest_subtitle: "Optional depth. One hook for day, one for night, one for treasure."
	quest.7A55C10000000002.title: "Specialized Hooks"
	quest.7A55C10000000003.quest_desc: [
		"Craft a &bCrab Pot&r and place it on the sea floor. It catches crabs and small shellfish on its own over time."
		"Check it and empty it like a trap. It is a slow, hands-off supply of seafood that keeps producing while you run the rest of your operation."
	]
	quest.7A55C10000000003.quest_subtitle: "Optional depth. Passive seafood while you work."
	quest.7A55C10000000003.title: "Set the Crab Pot"
	quest.7A55C10000000004.quest_desc: [
		"Pearls drop from oysters and clams out in the reef. Collect a &bPearl&r and the rarer &bBlack Pearl&r."
		"Nine of each compress into a &bPearl Block&r and a &bBlack Pearl Block&r for compact storage and decoration. Craft both blocks to prove the loop."
		"Pearls feed several Hybrid Aquatic recipes, so a stock of them is worth keeping."
	]
	quest.7A55C10000000004.quest_subtitle: "Optional depth. Pearls, black pearls, and storage blocks."
	quest.7A55C10000000004.title: "Pearls of the Deep"
	quest.7A55C10000000005.quest_desc: [
		"Turn reef materials into tools. Craft the &bCoral Blade&r and a &bCoral Pickaxe&r."
		"The Coral Blade is a light underwater weapon for the stinging and biting things that share the reef with you. The Coral Pickaxe handles the softer stone and coral down here."
		"This is light gear, not a deep-op kit. It keeps your hands full while you gather rather than replacing your main tools."
	]
	quest.7A55C10000000005.quest_subtitle: "Optional depth. Coral gear for close reef work."
	quest.7A55C10000000005.title: "Reef Tooling"
	quest.7A55C10000000006.quest_desc: [
		"Cook what you pull from the water. Prepare &bCooked Fish Steak&r, &bCooked Lobster&r, &bCooked Crab&r, and &bCooked Shrimp&r."
		"Each cooks in a furnace or smoker from the raw catch your rod, net, and crab pot bring in. Together they turn the reef into a steady food supply for long dives."
	]
	quest.7A55C10000000006.quest_subtitle: "Optional depth. Cooked seafood, no hunting required."
	quest.7A55C10000000006.title: "Cook the Catch"
	quest.7A55C10000000007.quest_desc: [
		"Take the catch further with Ocean's Delight dishes. Prepare &bStuffed Cod&r, &bStuffed Squid&r, &bSeagrass Salad&r, &bKelp Encrusted Cod&r, &bHoney Fried Kelp&r, and &bSquid Rings&r."
		"These use a cooking pot or crafting from fish, squid, kelp, and seagrass you gather in the shallows and reef. They restore more hunger and saturation than plain cooked fish, so they carry you through longer operations under the water."
	]
	quest.7A55C10000000007.quest_subtitle: "Optional depth. Ocean's Delight cooking."
	quest.7A55C10000000007.title: "Dishes of the Deep"
	quest.7A55C10000000008.quest_desc: [
		"Bring up two signs of a living sea floor. Collect a &bGiant Clam&r and a &bHydrothermal Vent Shaft&r."
		"The clam is a large filter feeder that anchors the reef. The vent shaft is a piece of the hot mineral chimney that feeds life where no sunlight reaches. Set both in your base as proof the deep is its own world."
	]
	quest.7A55C10000000008.quest_subtitle: "Optional flavor. Trophies from a living sea floor."
	quest.7A55C10000000008.title: "A Life Down Here"
	quest.7A55C10000000009.quest_desc: [
		"Neptunium is Aquaculture's deep-sea metal. You get its raw form as a rare catch while fishing, then refine it into a &bNeptunium Ingot&r."
		"This is the keystone for the best dive kit in the pack. Everything past this node is built from it, so bank several ingots before you move on."
		"This branch stays hidden until you complete the harvest rig above, then reveals itself as the payoff for working the deep."
	]
	quest.7A55C10000000009.quest_subtitle: "Optional depth. The mastery metal of the deep."
	quest.7A55C10000000009.title: "Neptunium Ingot"
	quest.7A55C1000000000A.quest_desc: [
		"Forge the full armor set: &bNeptunium Helmet&r, &bChestplate&r, &bLeggings&r, and &bBoots&r."
		"Each piece grants a deep-op ability while worn. The chestplate lets you breathe underwater. The helmet gives you clear underwater vision. The leggings remove the weight of the water so you move freely. The boots raise your swim speed."
		"Worn together this is the mastery dive kit, a full tier above the early diving suit. It turns the deep from a place you visit into a place you can work."
	]
	quest.7A55C1000000000A.quest_subtitle: "Optional depth. Breathe, see, and move underwater."
	quest.7A55C1000000000A.title: "Neptunium Dive Suit"
	quest.7A55C1000000000B.quest_desc: [
		"Craft the &bNeptunium Fishing Rod&r and the &bNeptunium Fillet Knife&r."
		"The rod makes fish bite more often, so your catch rate climbs even without swapping hooks. The fillet knife cleans fish into more fillets than a lesser blade."
		"Neptunium tools also work at full speed underwater, with none of the mining or attack penalty normal tools take down there."
	]
	quest.7A55C1000000000B.quest_subtitle: "Optional depth. Tools that ignore the water."
	quest.7A55C1000000000B.title: "Neptunium Field Kit"
	quest.7A55C1000000000C.quest_desc: [
		"Finish the set with a &bNeptunium Pickaxe&r and a &bNeptunium Sword&r."
		"Like the rest of the Neptunium line, both ignore the underwater penalty and swing at full speed beneath the surface. This is the last of the mastery gear, so it is here only if you want the complete kit."
	]
	quest.7A55C1000000000C.quest_subtitle: "Optional depth. Round out the deep-op tools."
	quest.7A55C1000000000C.title: "Neptunium Toolset"
	quest.7A55C1000000000D.quest_desc: [
		"Create Aquatic Ambitions adds a fan process called Channeling. Instead of fire, water, or lava, the catalyst is conduit power passing through water. Prove the material line by obtaining a &bSuspicious Rock&r and &bCalcium Rich Powder&r."
		"Both come from milling Create Limestone. The powder is the common output and the rock is a rare byproduct. Point an Encased Fan so its air blows through the water charged by an active conduit, then convey items into that stream. The Suspicious Rock channeled this way yields nautilus shells and spiky shells."
		"Watch the water depth. Extra layers of water above the conduit dilute its power and downgrade the stream to plain Washing instead of Channeling, so keep the charged water shallow over the fan path."
		"The payoff is renewable prismarine, coral, and weathered copper, plus a way to farm the pieces of a whole conduit. Note that the useful results such as Heart of the Sea, nautilus shells, and prismarine are vanilla items, so this quest tasks the addon's own intermediates instead."
	]
	quest.7A55C1000000000D.quest_subtitle: "Optional depth. A new Create fan process powered by a conduit."
	quest.7A55C1000000000D.title: "Conduit Channeling"
	quest.7A55C1000000000E.quest_desc: [
		"The Conduit Cage is the compact machine that replaces the large vanilla conduit frame. Craft a &bPrismarine Alloy Block&r to prove your alloy stock is deep enough to run a full Cage station."
		"Awaken a Cage by pumping a fluid into its bottom face with a Create pump or fluid pipe. Awakened with water it emits the vanilla Conduit Power effect to nearby entities. Other fluids give other effects, driven by the addon's fluid effect tags, and a mode slot filters who is affected: everyone, players, friendly mobs, or monsters."
		"This turns the Cage into an area buff or hazard station on top of its channeling job. It is utility flavor, so build it only if you want an automated effect emitter down at the deep op."
	]
	quest.7A55C1000000000E.quest_subtitle: "Optional depth. Awaken the Cage for area effects."
	quest.7A55C1000000000E.title: "Conduit Cage Station"
	quest.7A55C1000000000F.quest_desc: [
		"Some ruins and burrows flood, and holding your breath only gets you so far. Craft the full Hybrid Aquatic diving set: &bDiving Helmet&r, &bDiving Suit&r, &bDiving Leggings&r, and &bDiving Boots&r."
		"The set is cheap early gear, built from copper, leather, and glass you already have. Worn together it lets you stay under long enough to search a flooded room instead of surfacing every few seconds."
		"This is the on-ramp, not the deep-op kit. It gets you into the water. Better dive gear waits much later once you are working the sea for real."
	]
	quest.7A55C1000000000F.quest_subtitle: "Optional depth. Cheap gear for diving flooded ruins."
	quest.7A55C1000000000F.title: "Diving Suit"
	quest.7B26069EC5CF71D4.quest_desc: ["Hunt the Desert Sorceress and her Acolyte. The sorceress casts from range while the acolyte shields and supports her, so cut through the minion first."]
	quest.7B26069EC5CF71D4.quest_subtitle: "Defeat the acolyte, then the sorceress. Optional."
	quest.7B26069EC5CF71D4.title: "Desert Casters"
	quest.7B598669D634519A.quest_desc: ["Place an Empty &bGnome Burrow&r. It is the home a gnome moves into, so setting one down is how you get a gnome to show up and fight at all."]
	quest.7B598669D634519A.quest_subtitle: "Bait a gnome out of hiding."
	quest.7B598669D634519A.title: "Gnome Burrow"
	quest.7B5E2CD676A1A1C4.quest_desc: [
		"Build the &bBakery&r. The Baker turns wheat into bread and other baked food, a dependable staple for feeding a rising population."
		"Keep the farmer's wheat flowing to it and nobody goes hungry."
	]
	quest.7B5E2CD676A1A1C4.quest_subtitle: "Bread for a growing town."
	quest.7B5E2CD676A1A1C4.title: "Bakery"
	quest.7C0AC10000000001.quest_desc: [
		"Press a &bPrismarine Alloy Rod&r. The rod is the shaft for the heavier reef gear and a common ingredient in the deeper Create Aquatic Ambitions recipes."
		"Roll or press the alloy into rod form the same way you make any Create rod stock. Craft a few. Nothing downstream in this branch works without them."
	]
	quest.7C0AC10000000001.quest_subtitle: "Optional depth. A prismarine alloy rod for deeper work."
	quest.7C0AC10000000001.title: "Forge the Rod"
	quest.7C0AC10000000002.quest_desc: [
		"Awaken the &bConduit Cage&r, then use it to channel the reef. Pump a fluid into the cage through its bottom face and it comes alive."
		"Keep a Spiky Shell produced by the awakened cage to close out this branch."
	]
	quest.7C0AC10000000002.quest_subtitle: "Optional depth. Pump fluid into the Conduit Cage, then channel the reef."
	quest.7C0AC10000000002.title: "Awaken and Channel"
	quest.7D3489901AA47547.quest_desc: [
		"Place your &bTown Hall&r and claim the surrounding land. The moment it goes down the colony exists, with borders, a citizen cap, and a management interface."
		"Everything you build from here grows outward from this point."
	]
	quest.7D3489901AA47547.quest_subtitle: "The colony is official."
	quest.7D3489901AA47547.title: "Claim the Land"
	quest.7D36D95D74E1588E.quest_desc: ["Craft the &bAlchemist's Glove&r. It lets you harvest the prickly plants, brambleroot above all, without taking damage for the trouble. Keep it on before you reach into the garden's nastier beds."]
	quest.7D36D95D74E1588E.quest_subtitle: "Pick the thorny plants safely."
	quest.7D36D95D74E1588E.title: "Alchemist's Glove"
